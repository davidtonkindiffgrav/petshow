---
import PawLogo from './PawLogo.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<header class="sticky top-0 z-50 bg-white/[0.92] backdrop-blur-[10px] border-b border-[#efebf5]">
  <div class="max-w-container mx-auto px-7 py-[14px] flex items-center justify-between gap-6">

    <!-- Logo -->
    <PawLogo />

    <!-- Desktop nav -->
    <nav class="hidden min-[900px]:flex items-center gap-[30px]" aria-label="Main navigation">
      <a href="#" class="why-trigger text-[15px] font-semibold text-[#4a4357] hover:text-brand transition-colors">Why Us</a>
      <a href={`${base}#how`}    class="text-[15px] font-semibold text-[#4a4357] hover:text-brand transition-colors">How It Works</a>
      <a href="#" class="events-trigger text-[15px] font-semibold text-[#4a4357] hover:text-brand transition-colors">Events</a>
      <a href={`${base}pricing`} class="text-[15px] font-semibold text-[#4a4357] hover:text-brand transition-colors">Pricing</a>
      <a href={`${base}faq`}     class="text-[15px] font-semibold text-[#4a4357] hover:text-brand transition-colors">FAQ</a>
      {/* <a href={`${base}#hof`}     class="text-[15px] font-semibold text-[#4a4357] hover:text-brand transition-colors">Hall of Fame</a> */}
    </nav>

    <!-- Desktop actions -->
    <div class="hidden min-[900px]:flex items-center gap-3">
      <div id="header-actions-logged-out" class="flex items-center gap-3">
        <a href={`${base}login`}
          class="text-[15px] font-bold text-brand border-[1.5px] border-[#b8e4e0] rounded-btn-sm px-[18px] py-[9px] hover:bg-brand-tint transition-colors">
          Log In
        </a>
        <a href={`${base}signup`}
          class="text-[15px] font-bold text-white bg-brand rounded-btn-sm px-5 py-[10px] shadow-hero-btn hover:bg-brand-dark transition-colors">
          Sign Up
        </a>
      </div>

      <!-- Logged-in: avatar + dropdown -->
      <div id="header-user-menu" style="display:none;position:relative;">
        <button id="header-avatar-btn" type="button" aria-haspopup="true" aria-expanded="false"
          style="display:flex;align-items:center;gap:8px;background:none;border:none;cursor:pointer;padding:2px;">
          <div id="header-avatar-bubble" style="width:36px;height:36px;border-radius:50%;background:#002d6b;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;overflow:hidden;flex-shrink:0;">?</div>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2.5 4.5L6 8l3.5-3.5" stroke="#6b7c89" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="header-avatar-menu" style="display:none;position:absolute;right:0;top:calc(100% + 10px);background:#fff;border:1px solid #efebf5;border-radius:13px;box-shadow:0 8px 24px rgba(10,31,68,0.10);padding:6px;min-width:190px;z-index:60;">
          <div id="header-menu-name" style="padding:9px 12px 7px;font-size:13.5px;font-weight:700;color:#1c1626;border-bottom:1px solid #f0f4f5;margin-bottom:4px;"></div>
          <div id="header-menu-links"></div>
          <button id="header-signout" type="button" class="hover:bg-[#f5f8f9] transition-colors" style="width:100%;text-align:left;background:none;border:none;margin-top:4px;padding:9px 12px;border-top:1px solid #f0f4f5;font-size:13.5px;font-weight:600;color:#6f6880;cursor:pointer;border-radius:9px;font-family:inherit;">Sign out</button>
        </div>
      </div>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="hamburger-btn"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
      class="flex min-[900px]:hidden p-2 rounded-lg text-[#4a4357] hover:bg-brand-tint transition-colors"
    >
      <svg id="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" class="hidden">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile nav overlay -->
<div id="nav-overlay" class="fixed inset-0 bg-black/30 z-40 hidden" aria-hidden="true"></div>

<!-- Mobile nav panel -->
<div
  id="mobile-nav"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="fixed inset-y-0 right-0 z-50 w-72 bg-white shadow-2xl flex flex-col"
>
  <div class="flex items-center justify-between px-6 py-4 border-b border-[#efebf5]">
    <PawLogo height={34} />
    <button id="nav-close" aria-label="Close navigation menu" class="p-2 rounded-lg text-[#4a4357] hover:bg-brand-tint transition-colors">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <nav class="flex flex-col px-4 py-4 gap-1 flex-1 overflow-y-auto" aria-label="Mobile navigation">
    <a href="#" class="why-trigger py-4 px-3 text-base font-semibold text-[#4a4357] rounded-lg hover:bg-brand-tint hover:text-brand transition-colors">Why Us</a>
    <a href={`${base}#how`}     class="py-4 px-3 text-base font-semibold text-[#4a4357] rounded-lg hover:bg-brand-tint hover:text-brand transition-colors">How It Works</a>
    <a href="#" class="events-trigger py-4 px-3 text-base font-semibold text-[#4a4357] rounded-lg hover:bg-brand-tint hover:text-brand transition-colors">Events</a>
    <a href={`${base}pricing`} class="py-4 px-3 text-base font-semibold text-[#4a4357] rounded-lg hover:bg-brand-tint hover:text-brand transition-colors">Pricing</a>
    <a href={`${base}faq`}     class="py-4 px-3 text-base font-semibold text-[#4a4357] rounded-lg hover:bg-brand-tint hover:text-brand transition-colors">FAQ</a>
    {/* <a href={`${base}#hof`}     class="py-4 px-3 text-base font-semibold text-[#4a4357] rounded-lg hover:bg-brand-tint hover:text-brand transition-colors">Hall of Fame</a> */}
  </nav>

  <div id="mobile-actions-logged-out" class="flex flex-col gap-3 px-4 pb-8 pt-2 border-t border-[#efebf5]">
    <a href={`${base}login`} class="w-full text-center font-bold text-brand border-[1.5px] border-[#b8e4e0] rounded-btn py-3 hover:bg-brand-tint transition-colors">Log In</a>
    <a href={`${base}signup`} class="w-full text-center font-bold text-white bg-brand rounded-btn py-3 shadow-hero-btn hover:bg-brand-dark transition-colors">Sign Up</a>
  </div>
  <div id="mobile-user-menu" class="px-4 pb-8 pt-2 border-t border-[#efebf5]" style="display:none;">
    <div class="flex items-center gap-3 px-1 py-2 mb-2">
      <div id="mobile-avatar-bubble" style="width:40px;height:40px;border-radius:50%;background:#002d6b;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;overflow:hidden;flex-shrink:0;">?</div>
      <span id="mobile-menu-name" class="text-[15px] font-bold text-[#1c1626] truncate"></span>
    </div>
    <div id="mobile-menu-links" class="flex flex-col gap-1 mb-3"></div>
    <button id="mobile-signout" type="button" class="w-full text-center font-bold text-[#6f6880] border-[1.5px] border-[#efebf5] rounded-btn py-3 hover:bg-brand-tint transition-colors">Sign out</button>
  </div>
</div>

<script>
  const raw  = import.meta.env.BASE_URL;
  const base = raw.endsWith('/') ? raw : raw + '/';

  const btn     = document.getElementById('hamburger-btn');
  const nav     = document.getElementById('mobile-nav');
  const overlay = document.getElementById('nav-overlay');
  const closeBtn = document.getElementById('nav-close');
  const iconMenu  = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  function openNav() {
    nav?.classList.add('open');
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    btn?.setAttribute('aria-expanded', 'true');
    iconMenu?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
  }

  function closeNav() {
    nav?.classList.remove('open');
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
    btn?.setAttribute('aria-expanded', 'false');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
  }

  btn?.addEventListener('click', openNav);
  closeBtn?.addEventListener('click', closeNav);
  overlay?.addEventListener('click', closeNav);

  // ── Logged-in state: swap Log In/Sign Up for the user menu ──────────────
  // A user's `profiles.roles` is a tag array (e.g. ['participant','organiser']),
  // so the menu lists one destination link per role the user actually holds.
  const ROLE_META: Record<string, { label: string; href: string }> = {
    organiser:   { label: 'Organiser Hub', href: 'organiser' },
    judge:       { label: 'Judge Hub',     href: 'judge' },
    participant: { label: 'My Show Hub',   href: 'participant' },
    admin:       { label: 'Admin',         href: 'admin' },
  };

  (async () => {
    const { getAuth } = await import('../lib/auth.js');
    const { session, profile } = await getAuth();
    if (!session) return;

    const loggedOutDesktop = document.getElementById('header-actions-logged-out');
    const userMenuDesktop  = document.getElementById('header-user-menu');
    const loggedOutMobile  = document.getElementById('mobile-actions-logged-out');
    const userMenuMobile   = document.getElementById('mobile-user-menu');
    if (loggedOutDesktop) loggedOutDesktop.style.display = 'none';
    if (userMenuDesktop)  userMenuDesktop.style.display  = 'flex';
    if (loggedOutMobile)  loggedOutMobile.style.display  = 'none';
    if (userMenuMobile)   userMenuMobile.style.display   = 'block';

    const displayName = profile?.display_name || session.user.email?.split('@')[0] || 'there';
    const initial      = displayName.charAt(0).toUpperCase();
    const roles: string[] = profile?.roles || ['participant'];

    // Avatar bubble: profile photo if set, else initials
    [document.getElementById('header-avatar-bubble'), document.getElementById('mobile-avatar-bubble')].forEach(el => {
      if (!el) return;
      if (profile?.avatar_url) {
        el.innerHTML = `<img src="${profile.avatar_url}" alt="" style="width:100%;height:100%;object-fit:cover;">`;
      } else {
        el.textContent = initial;
      }
    });

    const nameDesktop = document.getElementById('header-menu-name');
    if (nameDesktop) nameDesktop.textContent = displayName;
    const nameMobile = document.getElementById('mobile-menu-name');
    if (nameMobile) nameMobile.textContent = displayName;

    // One destination link per role tag the user holds
    const linksDesktop = document.getElementById('header-menu-links');
    const linksMobile  = document.getElementById('mobile-menu-links');
    Object.entries(ROLE_META).forEach(([role, meta]) => {
      if (!roles.includes(role)) return;
      if (linksDesktop) {
        const a = document.createElement('a');
        a.href = base + meta.href;
        a.textContent = meta.label;
        a.className = 'hover:bg-brand-tint transition-colors';
        a.style.cssText = 'display:block;padding:9px 12px;font-size:13.5px;font-weight:600;color:#1c1626;border-radius:9px;text-decoration:none;';
        linksDesktop.appendChild(a);
      }
      if (linksMobile) {
        const a2 = document.createElement('a');
        a2.href = base + meta.href;
        a2.textContent = meta.label;
        a2.className = 'py-3 px-3 text-[15px] font-semibold text-[#4a4357] rounded-lg hover:bg-brand-tint hover:text-brand transition-colors';
        linksMobile.appendChild(a2);
      }
    });

    // Desktop dropdown open/close
    const avatarBtn  = document.getElementById('header-avatar-btn');
    const avatarMenu = document.getElementById('header-avatar-menu');
    avatarBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const opening = avatarMenu!.style.display === 'none';
      avatarMenu!.style.display = opening ? 'block' : 'none';
      avatarBtn.setAttribute('aria-expanded', String(opening));
    });
    document.addEventListener('click', () => {
      if (avatarMenu) avatarMenu.style.display = 'none';
      avatarBtn?.setAttribute('aria-expanded', 'false');
    });

    // Sign out (desktop menu + mobile panel)
    const doSignOut = async () => {
      const { supabase } = await import('../lib/supabase.js');
      await supabase.auth.signOut();
      window.location.href = base + 'login';
    };
    document.getElementById('header-signout')?.addEventListener('click', doSignOut);
    document.getElementById('mobile-signout')?.addEventListener('click', doSignOut);
  })();

  // Close nav when a link inside it is clicked (except events-trigger/why-trigger — those open their own panel)
  nav?.querySelectorAll('a:not(.events-trigger):not(.why-trigger)').forEach(link => link.addEventListener('click', closeNav));

  // ── Events browse panel ──────────────────────────────────────────────
  const eventsOverlay = document.getElementById('events-overlay');
  const eventsPanel   = document.getElementById('events-panel');
  const eventsList    = document.getElementById('events-list');
  const eventsClose   = document.getElementById('events-close');
  let showsCache: any[] | null = null;

  function openEvents() {
    closeNav();
    eventsOverlay!.style.opacity = '1';
    eventsOverlay!.style.pointerEvents = 'auto';
    eventsPanel!.style.transform = 'translateY(0)';
    document.body.style.overflow = 'hidden';
    if (!showsCache) loadShows();
  }

  function closeEvents() {
    eventsOverlay!.style.opacity = '0';
    eventsOverlay!.style.pointerEvents = 'none';
    eventsPanel!.style.transform = 'translateY(100%)';
    document.body.style.overflow = '';
  }

  async function loadShows() {
    const { supabase } = await import('../lib/supabase.js');
    const { isVotingOpen, zonedDateTime } = await import('../lib/voteWindow.js');
    const { data, error } = await supabase
      .from('shows')
      .select('id, title, host_org, logo_url, banner_url, show_date, show_time, timezone, entry_open_date, entry_open_time, entry_close_date, entry_close_time, entry_fee, currency, status, description, is_judged, vote_open_mode, results_published_at')
      .order('show_date', { ascending: true });
    if (error) { console.error('[Events panel]', error); eventsList!.innerHTML = `<p style="padding:20px;color:red;">Error: ${error.message}</p>`; return; }
    const now2 = Date.now();
    showsCache = (data || []).filter(s => {
      if (s.status === 'draft') return false;
      const openAt  = zonedDateTime(s.entry_open_date,  s.entry_open_time,  s.timezone);
      const closeAt = zonedDateTime(s.entry_close_date, s.entry_close_time, s.timezone);
      const openOk  = !openAt  || openAt.getTime()  <= now2;
      const closeOk = !closeAt || closeAt.getTime() >= now2;
      // Public vote shows stay listed while their voting window is open,
      // even after entries close — that's when people come to vote.
      s._votingOpen = isVotingOpen(s);
      return (openOk && closeOk) || s._votingOpen;
    });
    renderShows(showsCache);
  }

  const SYMS: Record<string,string> = { AUD:'A$', NZD:'NZ$', USD:'$', GBP:'£', EUR:'€', CAD:'C$', ZAR:'R', SGD:'S$' };
  function esc(s: any) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function fmtDate(d: string) { return new Date(d).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }); }
  function daysLeft(d: string) {
    const n = Math.ceil((new Date(d).getTime() - Date.now()) / 86400000);
    return n <= 0 ? '' : n === 1 ? '1 day left' : `${n} days left`;
  }

  function renderShows(shows: any[]) {
    const raw = import.meta.env.BASE_URL;
    const base = raw.endsWith('/') ? raw : raw + '/';

    if (!shows.length) {
      eventsList!.innerHTML = `
        <div style="text-align:center;padding:52px 20px;">
          <p style="font-size:16px;font-weight:800;color:#1c1626;margin:0 0 6px;">No open shows right now</p>
          <p style="font-size:14px;color:#6f6880;margin:0;">Check back soon — new shows are added regularly.</p>
        </div>`;
      return;
    }

    eventsList!.innerHTML = shows.map(show => {
      const thumb = show.logo_url
        ? `<img src="${esc(show.logo_url)}" style="width:56px;height:56px;border-radius:12px;object-fit:contain;background:#f5f3fa;border:1px solid #efebf5;flex-shrink:0;" alt="" />`
        : `<div style="width:56px;height:56px;border-radius:12px;background:linear-gradient(135deg,#1ba89a,#002d6b);display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:800;color:#fff;flex-shrink:0;">${esc((show.title||'?')[0].toUpperCase())}</div>`;
      const org   = show.host_org || '';
      const fee   = show.entry_fee > 0 ? `${SYMS[show.currency]||'$'}${show.entry_fee}` : '—';
      const close = show.entry_close_date ? daysLeft(show.entry_close_date) : '';
      const desc  = show.description ? show.description.slice(0, 100) + (show.description.length > 100 ? '…' : '') : '';
      const banner = show.banner_url
        ? `<div style="width:112px;height:48px;border-radius:10px;overflow:hidden;flex-shrink:0;">
             <img src="${esc(show.banner_url)}" style="width:100%;height:100%;object-fit:cover;object-position:right center;display:block;" alt="" />
           </div>`
        : '';
      return `
        <button onclick="window.location.href='${base}show?id=${esc(show.id)}'"
          style="width:100%;text-align:left;background:#fff;border:1px solid #efebf5;border-radius:16px;padding:14px 16px;display:flex;align-items:center;gap:14px;cursor:pointer;font-family:inherit;margin-bottom:10px;transition:border-color 0.15s,box-shadow 0.15s;"
          onmouseover="this.style.borderColor='#b8e4e0';this.style.boxShadow='0 4px 14px rgba(10,31,68,0.07)'"
          onmouseout="this.style.borderColor='#efebf5';this.style.boxShadow='none'">
          ${thumb}
          <div style="flex:1;min-width:0;">
            <div style="font-size:15px;font-weight:800;color:#1c1626;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(show.title||'Untitled Show')}</div>
            ${org ? `<div style="font-size:13px;color:#6f6880;margin-top:2px;">${esc(org)}</div>` : ''}
            ${desc ? `<div style="font-size:12px;color:#9b94a8;margin-top:3px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">${esc(desc)}</div>` : ''}
            <div style="display:flex;align-items:center;gap:8px;margin-top:7px;flex-wrap:wrap;">
              ${show.show_date ? `<span style="font-size:12px;font-weight:600;color:#6f6880;">📅 ${fmtDate(show.show_date)}</span>` : ''}
              <span style="font-size:11.5px;font-weight:700;color:#1ba89a;background:#e3f5f2;padding:2px 9px;border-radius:99px;">${fee}</span>
              ${show._votingOpen ? `<span style="font-size:11.5px;font-weight:700;color:#5B43C4;background:#efeafd;padding:2px 9px;border-radius:99px;">🗳️ Voting open</span>` : ''}
              ${close ? `<span style="font-size:12px;font-weight:600;color:#b67d12;">${close}</span>` : ''}
            </div>
          </div>
          ${banner}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="flex-shrink:0;"><path d="M5 3l5 5-5 5" stroke="#c4bed0" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>`;
    }).join('');
  }

  document.querySelectorAll('.events-trigger').forEach(el =>
    el.addEventListener('click', (e) => { e.preventDefault(); openEvents(); })
  );
  eventsClose?.addEventListener('click', closeEvents);
  eventsOverlay?.addEventListener('click', closeEvents);

  // ── "Why Us" modal ───────────────────────────────────────────────────
  const whyOverlay = document.getElementById('why-overlay');
  const whyModal   = document.getElementById('why-modal');
  const whyClose   = document.getElementById('why-close');
  const whyImg     = document.getElementById('why-modal-img') as HTMLImageElement | null;

  function openWhy() {
    closeNav();
    // Mirror whatever the homepage hero is currently showing, if present on
    // this page; otherwise pick from the same hero-1/hero-2 pool it uses.
    if (whyImg) {
      const heroImg = document.getElementById('hero-img') as HTMLImageElement | null;
      whyImg.src = (heroImg && heroImg.getAttribute('src')) || (Math.random() < 0.5 ? `${base}hero-1.jpg` : `${base}hero-2.jpg`);
    }
    whyOverlay!.style.opacity = '1';
    whyOverlay!.style.pointerEvents = 'auto';
    document.body.style.overflow = 'hidden';
  }

  function closeWhy() {
    whyOverlay!.style.opacity = '0';
    whyOverlay!.style.pointerEvents = 'none';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.why-trigger').forEach(el =>
    el.addEventListener('click', (e) => { e.preventDefault(); openWhy(); })
  );
  whyClose?.addEventListener('click', closeWhy);
  whyOverlay?.addEventListener('click', closeWhy);
  whyModal?.addEventListener('click', e => e.stopPropagation());
  document.querySelectorAll('.why-cta').forEach(el => el.addEventListener('click', closeWhy));

  document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeEvents(); closeWhy(); } });
</script>

<!-- Events browse panel -->
<div id="events-overlay" aria-hidden="true"
  style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:60;opacity:0;pointer-events:none;transition:opacity 0.3s;"></div>

<div id="events-panel" role="dialog" aria-modal="true" aria-label="Browse open shows"
  style="position:fixed;bottom:0;left:0;right:0;z-index:61;background:#fff;border-radius:24px 24px 0 0;box-shadow:0 -8px 40px rgba(10,31,68,0.18);display:flex;flex-direction:column;max-height:82vh;transform:translateY(100%);transition:transform 0.3s ease-out;">

  <!-- Drag handle -->
  <div style="display:flex;justify-content:center;padding:12px 0 6px;flex-shrink:0;">
    <div style="width:40px;height:4px;background:#dde3e8;border-radius:99px;"></div>
  </div>

  <!-- Panel header -->
  <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 20px 14px;border-bottom:1px solid #efebf5;flex-shrink:0;">
    <div>
      <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0;line-height:1.25;">Open Shows</h2>
      <p style="font-size:13px;color:#6f6880;margin:4px 0 0;">Currently accepting entries · prices set by each organiser, in their own currency</p>
    </div>
    <button id="events-close" aria-label="Close"
      style="width:36px;height:36px;border-radius:50%;background:#f5f3fa;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4a4357" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
