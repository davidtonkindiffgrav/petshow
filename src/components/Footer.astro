---
import PawLogo from './PawLogo.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<footer class="max-w-container mx-auto px-7 pt-[60px] pb-10">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[1.6fr_1fr_1fr_1fr_1fr] gap-[30px]">

    <!-- Brand cell -->
    <div>
      <PawLogo size={34} wordmarkSize={21} subtitleSize={8} />
      <p class="mt-4 text-[14px] text-[#6f6880] leading-relaxed max-w-[220px]">
        The online platform for pet shows, competitions and fundraising events.
      </p>
    </div>

    <!-- Explore -->
    <div>
      <h3 class="text-[14px] font-extrabold text-[#1c1626] mb-4">Explore</h3>
      <ul class="flex flex-col gap-[10px]">
        <li><a href={`${base}#events`}     class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Events</a></li>
        <li><a href={`${base}#categories`} class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Categories</a></li>
        {/* <li><a href={`${base}#hof`}        class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Hall of Fame</a></li> */}
        <li><a href={`${base}#how`}        class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">How It Works</a></li>
      </ul>
    </div>

    <!-- Support -->
    <div>
      <h3 class="text-[14px] font-extrabold text-[#1c1626] mb-4">Support</h3>
      <ul class="flex flex-col gap-[10px]">
        <li><a href="#" class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Help Center</a></li>
        <li><a href="#" class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Contact Us</a></li>
        <li><a href="#" class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Terms of Service</a></li>
        <li><a href="#" class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Privacy Policy</a></li>
      </ul>
    </div>

    <!-- For Organisers -->
    <div>
      <h3 class="text-[14px] font-extrabold text-[#1c1626] mb-4">For Organisers</h3>
      <ul class="flex flex-col gap-[10px]">
        <li><a href={`${base}login`} class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Create a Show</a></li>
        <li><a href="#"              class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Fundraising Tools</a></li>
        <li><a href={`${base}#pricing`} class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Pricing</a></li>
        <li><a href="#"              class="text-[14px] font-medium text-[#6f6880] hover:text-brand transition-colors">Resources</a></li>
      </ul>
    </div>

    <!-- Stay Connected -->
    <div>
      <h3 class="text-[14px] font-extrabold text-[#1c1626] mb-4">Stay Connected</h3>
      <div class="flex flex-wrap gap-3">
        <!-- Facebook -->
        <a href="#" aria-label="Facebook" class="w-[38px] h-[38px] rounded-full bg-brand-tint flex items-center justify-center text-brand hover:bg-brand-tint2 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <!-- Instagram -->
        <a href="#" aria-label="Instagram" class="w-[38px] h-[38px] rounded-full bg-brand-tint flex items-center justify-center text-brand hover:bg-brand-tint2 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>

        <!-- Email -->
        <a href="mailto:hello@petshowonline.com" aria-label="Email us" class="w-[38px] h-[38px] rounded-full bg-brand-tint flex items-center justify-center text-brand hover:bg-brand-tint2 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-[#efebf5] mt-[34px] pt-[22px]">
    <p class="text-[13px] text-[#9b94a8]">© 2025 Fur to Feathers. All rights reserved.</p>
  </div>
</footer>
