---
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
interface Props {
  height?: number;
}
const { height = 44 } = Astro.props;
---

<a href={base} class="inline-flex items-center no-underline">
  <img
    src={`${base}images/ftf_logo_2048x648.png`}
    alt="Fur to Feathers — Online Pet Shows"
    style={`height:${height}px;width:auto`}
    class="block"
  />
</a>
