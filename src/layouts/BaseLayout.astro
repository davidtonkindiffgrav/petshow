---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Fur to Feathers — Online Pet Shows',
  description = 'Run online pet shows and competitions that bring communities together and raise money for causes you care about.',
} = Astro.props;

const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href={`${base}images/favicon.ico`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}images/favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}images/favicon-16x16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}images/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}images/site.webmanifest`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,500;1,600&family=Caveat:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline define:vars={{ base }}>
      // Password recovery links without an explicit redirect (e.g. sent from the
      // Supabase dashboard) land on the Site URL with the token in the hash.
      // Forward to the reset page before any Supabase client consumes the token.
      if (window.location.hash.includes('type=recovery')
          && !window.location.pathname.startsWith(base + 'reset-password')) {
        window.location.replace(base + 'reset-password' + window.location.search + window.location.hash);
      }
    </script>
  </head>
  <body class="font-sans text-[#1c1626] bg-white antialiased overflow-x-hidden">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
