---
import '../styles/global.css';

interface Props {
  title: string;
  activePage?: string;
  description?: string;
}

const { title, activePage = '', description } = Astro.props;

const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';

function navClass(page: string) {
  return activePage === page
    ? 'flex items-center gap-3 px-3 py-2.5 rounded-[10px] text-[13.5px] font-semibold bg-brand/20 text-white transition-colors'
    : 'flex items-center gap-3 px-3 py-2.5 rounded-[10px] text-[13.5px] font-semibold text-white/55 hover:text-white hover:bg-white/[0.06] transition-colors';
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Fur to Feathers</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/x-icon" href={`${base}images/favicon.ico`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}images/favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}images/favicon-16x16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}images/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}images/site.webmanifest`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,500;1,600&family=Caveat:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex h-screen overflow-hidden bg-[#f0fafa] font-sans antialiased text-[#1c1626]">

    <!-- Mobile backdrop -->
    <div id="sidebar-backdrop"
      class="fixed inset-0 bg-black/40 z-40 opacity-0 pointer-events-none transition-opacity duration-300 min-[900px]:hidden"
      aria-hidden="true"></div>

    <!-- Sidebar — fixed overlay on mobile, in-flow on desktop -->
    <aside id="dashboard-sidebar"
      class="fixed inset-y-0 left-0 z-50 w-[220px] bg-[#002d6b] flex flex-col h-full overflow-y-auto -translate-x-full transition-transform duration-300 ease-in-out min-[900px]:relative min-[900px]:translate-x-0 min-[900px]:z-auto min-[900px]:shrink-0">

      <!-- White logo header -->
      <div class="bg-white px-4 h-[72px] flex items-center justify-between gap-2 shrink-0">
        <a href={base} class="flex-1 min-w-0 flex items-center no-underline">
          <img src={`${base}images/ftf_logo_2048x648.png`} alt="Fur to Feathers" style="width:100%;height:auto" class="block" />
        </a>
        <button id="sidebar-close"
          class="min-[900px]:hidden w-7 h-7 rounded-full bg-brand-tint flex items-center justify-center text-[#002d6b] hover:bg-brand/20 transition-colors shrink-0"
          aria-label="Close navigation">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <!-- Nav -->
      <nav class="flex-1 px-3 py-5 space-y-0.5" aria-label="Dashboard navigation">

        <a href={`${base}organiser`} class={navClass('dashboard')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
          Dashboard
        </a>

        <a href={`${base}organiser/shows`} class={navClass('shows')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Shows
        </a>

        <a href={`${base}organiser/entries`} class={navClass('entries')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
            <line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/>
            <line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
          </svg>
          Entries
        </a>

        <a href={`${base}organiser/judging`} class={navClass('judging')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
          Judging &amp; Results
        </a>

<a href={`${base}organiser/settings`} class={navClass('settings')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
          Settings
        </a>

      </nav>

      <!-- User popover -->
      <div class="relative px-4 py-4 border-t border-white/10">
        <button id="user-popover-trigger"
          class="flex items-center gap-3 w-full text-left hover:opacity-80 transition-opacity"
          aria-haspopup="true" aria-expanded="false">
          <div id="sidebar-avatar" class="w-8 h-8 rounded-full bg-brand flex items-center justify-center text-white text-[12px] font-extrabold shrink-0 overflow-hidden">?</div>
          <div class="min-w-0 flex-1">
            <p id="sidebar-username" class="text-[13px] font-semibold text-white truncate">Loading…</p>
            <p id="sidebar-role-badge" class="text-[11px] text-white/40">Organiser</p>
          </div>
          <svg id="user-popover-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/40 shrink-0 transition-transform" aria-hidden="true">
            <polyline points="18 15 12 9 6 15"/>
          </svg>
        </button>

        <!-- Menu (flies upward) -->
        <div id="user-popover"
          style="display:none"
          class="absolute bottom-full left-0 right-0 mb-2 bg-white rounded-[14px] shadow-[0_-6px_28px_rgba(28,22,38,0.13)] py-1.5 z-50">
          <a href={`${base}organiser/settings`}
            class="flex items-center gap-3 px-4 py-2.5 text-[13.5px] font-semibold text-[#1c1626] hover:bg-[#f0fafa] transition-colors">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
            Settings
          </a>
          <button id="sidebar-switch-participant"
            class="flex items-center gap-3 px-4 py-2.5 text-[13.5px] font-semibold text-[#1c1626] hover:bg-[#f0fafa] transition-colors w-full text-left">
            <img src={`${base}images/ftf_logo_256x212.png`} width="15" style="height:auto;display:block;" alt="" aria-hidden="true" />
            My Show Hub
          </button>
          <button id="sidebar-switch-judge" style="display:none"
            class="flex items-center gap-3 px-4 py-2.5 text-[13.5px] font-semibold text-[#1c1626] hover:bg-[#f0fafa] transition-colors w-full text-left">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="8" r="6"/>
              <path d="M15.5 13.5 17 22l-5-3-5 3 1.5-8.5"/>
            </svg>
            Judge Mode
          </button>
          <div class="my-1 mx-3 border-t border-[#efebf5]"></div>
          <button id="sidebar-signout"
            class="flex items-center gap-3 px-4 py-2.5 text-[13.5px] font-semibold text-red-500 hover:bg-red-50 transition-colors w-full text-left">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Sign out
          </button>
        </div>
      </div>

    </aside>

    <!-- Main area -->
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">

      <!-- Top bar -->
      <header class="h-[72px] bg-white border-b border-[#efebf5] flex items-center px-4 min-[900px]:px-8 justify-between shrink-0 gap-3">
        <!-- Hamburger — mobile only -->
        <button id="sidebar-toggle"
          class="min-[900px]:hidden w-9 h-9 rounded-lg flex items-center justify-center text-[#4a4357] hover:bg-[#f0fafa] transition-colors shrink-0"
          aria-label="Open navigation" aria-expanded="false" aria-controls="dashboard-sidebar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <h1 class="text-[17px] min-[900px]:text-[19px] font-extrabold text-[#1c1626] tracking-[-0.01em] flex-1 min-[900px]:flex-none truncate">{title}</h1>
        <div class="flex items-center gap-3 shrink-0">
          <slot name="actions" />
        </div>
      </header>

      <!-- Scrollable content -->
      <main class="flex-1 overflow-y-auto p-4 min-[900px]:p-8">
        <slot />
      </main>

    </div>

  </body>
</html>

<script>
  const sidebar  = document.getElementById('dashboard-sidebar');
  const backdrop = document.getElementById('sidebar-backdrop');
  const toggle   = document.getElementById('sidebar-toggle');
  const closeBtn = document.getElementById('sidebar-close');

  function openSidebar() {
    sidebar.style.transform = 'translateX(0)';
    backdrop.style.opacity = '1';
    backdrop.style.pointerEvents = 'auto';
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeSidebar() {
    sidebar.style.transform = '';
    backdrop.style.opacity = '0';
    backdrop.style.pointerEvents = 'none';
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', openSidebar);
  closeBtn?.addEventListener('click', closeSidebar);
  backdrop?.addEventListener('click', closeSidebar);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeSidebar(); closePopover(); } });

  // Auto-close when a nav link is tapped on mobile
  sidebar?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => { if (window.innerWidth < 900) closeSidebar(); })
  );

  // User popover (bottom-left)
  const userTrigger  = document.getElementById('user-popover-trigger');
  const userPopover  = document.getElementById('user-popover');
  const userChevron  = document.getElementById('user-popover-chevron');

  function openPopover() {
    userPopover.style.display = 'block';
    userTrigger?.setAttribute('aria-expanded', 'true');
    userChevron?.style.setProperty('transform', 'rotate(180deg)');
  }
  function closePopover() {
    userPopover.style.display = 'none';
    userTrigger?.setAttribute('aria-expanded', 'false');
    userChevron?.style.setProperty('transform', '');
  }

  userTrigger?.addEventListener('click', e => {
    e.stopPropagation();
    userPopover.style.display === 'none' ? openPopover() : closePopover();
  });
  document.addEventListener('click', closePopover);
  userPopover?.addEventListener('click', e => e.stopPropagation());

  // Switch to participant view — adds role if missing, then redirects
  document.getElementById('sidebar-switch-participant')?.addEventListener('click', async () => {
    const { supabase } = await import('../lib/supabase.js');
    const { getAuth }  = await import('../lib/auth.js');
    const { session, profile, base } = await getAuth();
    if (!session) return;
    const roles = profile?.roles || [];
    if (!roles.includes('participant')) {
      await supabase.from('profiles').update({ roles: [...roles, 'participant'] }).eq('id', session.user.id);
    }
    window.location.href = base + 'participant';
  });

  // Reveal "Judge Mode" only for accounts that already hold the judge role
  // (judge access is granted via show invite, not self-service like participant/organiser).
  (async () => {
    const { getAuth } = await import('../lib/auth.js');
    const { profile, base } = await getAuth();
    if (profile?.roles?.includes('judge')) {
      const judgeBtn = document.getElementById('sidebar-switch-judge');
      if (judgeBtn) {
        judgeBtn.style.display = 'flex';
        judgeBtn.addEventListener('click', () => { window.location.href = base + 'judge'; });
      }
    }
  })();
</script>
