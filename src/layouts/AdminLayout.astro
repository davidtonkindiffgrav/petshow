---
import '../styles/global.css';

interface Props {
  title: string;
  activePage?: string;
  description?: string;
}

const { title, activePage = '', description } = Astro.props;

const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';

function navClass(page: string) {
  return activePage === page
    ? 'flex items-center gap-3 px-3 py-2.5 rounded-[10px] text-[13.5px] font-semibold bg-coral/[0.16] text-white transition-colors'
    : 'flex items-center gap-3 px-3 py-2.5 rounded-[10px] text-[13.5px] font-semibold text-[#b7c8de] hover:text-white hover:bg-white/[0.06] transition-colors';
}

function groupLabel(text: string) {
  return `px-3 pt-4 pb-1.5 text-[10.5px] font-bold uppercase tracking-wider text-[#5c86bd]`;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Admin — Fur to Feathers</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/x-icon" href={`${base}images/favicon.ico`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,500;1,600&family=Caveat:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex h-screen overflow-hidden bg-[#f4f6f8] font-sans antialiased text-[#1c1626]">

    <!-- Mobile backdrop -->
    <div id="sidebar-backdrop"
      class="fixed inset-0 bg-black/40 z-40 opacity-0 pointer-events-none transition-opacity duration-300 min-[900px]:hidden"
      aria-hidden="true"></div>

    <!-- Sidebar — fixed overlay on mobile, in-flow on desktop -->
    <aside id="dashboard-sidebar"
      class="fixed inset-y-0 left-0 z-50 w-[220px] bg-gradient-to-b from-[#00193b] to-[#00265c] flex flex-col h-full overflow-y-auto -translate-x-full transition-transform duration-300 ease-in-out min-[900px]:relative min-[900px]:translate-x-0 min-[900px]:z-auto min-[900px]:shrink-0">

      <!-- White logo header with ADMIN badge -->
      <div class="bg-white px-4 h-[72px] flex items-center justify-between gap-2 shrink-0">
        <a href={`${base}admin`} class="flex-1 min-w-0 flex items-center gap-2 no-underline">
          <img src={`${base}images/ftf_logo_2048x648.png`} alt="Fur to Feathers" style="width:80%;height:auto" class="block" />
          <span class="shrink-0 bg-coral text-white text-[10px] font-bold px-2 py-0.5 rounded-full tracking-wide">ADMIN</span>
        </a>
        <button id="sidebar-close"
          class="min-[900px]:hidden w-7 h-7 rounded-full bg-brand-tint flex items-center justify-center text-[#002d6b] hover:bg-brand/20 transition-colors shrink-0"
          aria-label="Close navigation">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

      <!-- Nav -->
      <nav class="flex-1 px-3 py-5 space-y-0.5" aria-label="Admin navigation">

        <a href={`${base}admin`} class={navClass('dashboard')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
          Dashboard
        </a>

        <p class={groupLabel('Financial')}>Financial</p>

        <a href={`${base}admin/financial`} class={navClass('financial')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
          Financial Centre
        </a>

        <a href={`${base}admin/settlements`} class={navClass('settlements')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
            <line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="15" y2="17"/>
          </svg>
          Settlements
          <span id="nav-settlements-badge" style="display:none" class="ml-auto bg-coral text-white text-[10.5px] font-extrabold px-2 py-0.5 rounded-full"></span>
        </a>

        <a href={`${base}admin/documents`} class={navClass('documents')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
          </svg>
          Documents
        </a>

        <p class={groupLabel('People & Shows')}>People &amp; Shows</p>

        <a href={`${base}admin/users`} class={navClass('users')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          Users
        </a>

        <a href={`${base}admin/shows`} class={navClass('shows')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          Shows
        </a>
        <!-- Organisations: add once a dedicated organisations-list page exists -->

        <p class={groupLabel('Insights')}>Insights</p>

        <a href={`${base}admin/analytics`} class={navClass('analytics')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
          </svg>
          Analytics
        </a>

        <p class={groupLabel('Platform')}>Platform</p>

        <a href={`${base}admin/settings`} class={navClass('settings')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
          Platform Config
        </a>

        <a href={`${base}admin/health`} class={navClass('health')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
          System Health
        </a>

        <a href={`${base}admin/storage`} class={navClass('storage')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="22" y1="12" x2="2" y2="12"/>
            <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>
            <line x1="6" y1="16" x2="6.01" y2="16"/><line x1="10" y1="16" x2="10.01" y2="16"/>
          </svg>
          Storage
        </a>

        <a href={`${base}admin/email`} class={navClass('email')}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22 6 12 13 2 6"/>
          </svg>
          Email
        </a>

      </nav>

      <!-- User popover -->
      <div class="relative px-4 py-4 border-t border-white/10">
        <button id="user-popover-trigger"
          class="flex items-center gap-3 w-full text-left hover:opacity-80 transition-opacity"
          aria-haspopup="true" aria-expanded="false">
          <div id="sidebar-avatar" class="w-8 h-8 rounded-full bg-coral flex items-center justify-center text-white text-[12px] font-extrabold shrink-0 overflow-hidden">?</div>
          <div class="min-w-0 flex-1">
            <p id="sidebar-username" class="text-[13px] font-semibold text-white truncate">Loading…</p>
            <p id="sidebar-role-badge" class="text-[11px] text-[#93a9c7]">Admin</p>
          </div>
          <svg id="user-popover-chevron" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#93a9c7] shrink-0 transition-transform" aria-hidden="true">
            <polyline points="18 15 12 9 6 15"/>
          </svg>
        </button>

        <!-- Menu (flies upward) -->
        <div id="user-popover"
          style="display:none"
          class="absolute bottom-full left-0 right-0 mb-2 bg-white rounded-[14px] shadow-[0_-6px_28px_rgba(28,22,38,0.13)] py-1.5 z-50">
          <button id="sidebar-signout"
            class="flex items-center gap-3 px-4 py-2.5 text-[13.5px] font-semibold text-red-500 hover:bg-red-50 transition-colors w-full text-left">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Sign out
          </button>
        </div>
      </div>

    </aside>

    <!-- Main area -->
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">

      <!-- Top bar -->
      <header class="h-[72px] bg-white border-b border-[#e6eaee] flex items-center px-4 min-[900px]:px-8 justify-between shrink-0 gap-3">
        <!-- Hamburger — mobile only -->
        <button id="sidebar-toggle"
          class="min-[900px]:hidden w-9 h-9 rounded-lg flex items-center justify-center text-[#4a4357] hover:bg-[#f4f6f8] transition-colors shrink-0"
          aria-label="Open navigation" aria-expanded="false" aria-controls="dashboard-sidebar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <h1 class="text-[17px] min-[900px]:text-[19px] font-extrabold text-[#1c1626] tracking-[-0.01em] flex-1 min-[900px]:flex-none truncate">{title}</h1>
        <form id="admin-search-form" class="hidden min-[900px]:flex items-center gap-2" role="search">
          <input id="admin-search-input" type="search" placeholder="Search users, shows, organisations, payments…"
            class="text-[13px] border border-[#e6eaee] rounded-btn-sm px-3 py-2 bg-[#f7f9fa] w-[280px] focus:w-[340px] transition-all focus:outline-none focus:ring-2 focus:ring-coral/30" />
        </form>
        <div class="flex items-center gap-3 shrink-0 min-[900px]:flex-none flex-1 justify-end">
          <slot name="actions" />
        </div>
      </header>

      <!-- Scrollable content -->
      <main class="flex-1 overflow-y-auto p-4 min-[900px]:p-8">
        <slot />
      </main>

    </div>

  </body>
</html>

<script>
  const sidebar  = document.getElementById('dashboard-sidebar');
  const backdrop = document.getElementById('sidebar-backdrop');
  const toggle   = document.getElementById('sidebar-toggle');
  const closeBtn = document.getElementById('sidebar-close');

  function openSidebar() {
    sidebar.style.transform = 'translateX(0)';
    backdrop.style.opacity = '1';
    backdrop.style.pointerEvents = 'auto';
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeSidebar() {
    sidebar.style.transform = '';
    backdrop.style.opacity = '0';
    backdrop.style.pointerEvents = 'none';
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', openSidebar);
  closeBtn?.addEventListener('click', closeSidebar);
  backdrop?.addEventListener('click', closeSidebar);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeSidebar(); closePopover(); } });

  // Auto-close when a nav link is tapped on mobile
  sidebar?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => { if (window.innerWidth < 900) closeSidebar(); })
  );

  // User popover (bottom-left)
  const userTrigger  = document.getElementById('user-popover-trigger');
  const userPopover  = document.getElementById('user-popover');
  const userChevron  = document.getElementById('user-popover-chevron');

  function openPopover() {
    userPopover.style.display = 'block';
    userTrigger?.setAttribute('aria-expanded', 'true');
    userChevron?.style.setProperty('transform', 'rotate(180deg)');
  }
  function closePopover() {
    userPopover.style.display = 'none';
    userTrigger?.setAttribute('aria-expanded', 'false');
    userChevron?.style.setProperty('transform', '');
  }

  userTrigger?.addEventListener('click', e => {
    e.stopPropagation();
    userPopover.style.display === 'none' ? openPopover() : closePopover();
  });
  document.addEventListener('click', closePopover);
  userPopover?.addEventListener('click', e => e.stopPropagation());

  // Topbar global search
  const rawBase = import.meta.env.BASE_URL;
  const searchBase = rawBase.endsWith('/') ? rawBase : rawBase + '/';
  document.getElementById('admin-search-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const q = document.getElementById('admin-search-input').value.trim();
    if (q) window.location.href = `${searchBase}admin/search?q=${encodeURIComponent(q)}`;
  });

  // Settlements pending-approval badge — runs on every admin page since the
  // sidebar (and thus this badge) is shared. settlements has an admin
  // RLS-bypass read policy, so this is safe to query directly without
  // admin-api — the same exception settlements.astro already relies on.
  // Never blocks render; hidden on any failure.
  (async () => {
    try {
      const { supabase } = await import('../lib/supabase.js');
      const { count } = await supabase.from('settlements').select('id', { count: 'exact', head: true }).eq('status', 'pending_approval');
      const badge = document.getElementById('nav-settlements-badge');
      if (badge && count) { badge.textContent = String(count); badge.style.display = 'inline-flex'; }
    } catch { /* decorative — never break the sidebar over it */ }
  })();
</script>
