---
import '../styles/global.css';
import PawLogo from '../components/PawLogo.astro';

interface Props {
  title: string;
  displayName?: string;
  userInitial?: string;
  dualRole?: boolean;
}

const { title, displayName = '', userInitial = '?', dualRole = false } = Astro.props;

const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Fur to Feathers</title>
    <link rel="icon" type="image/x-icon" href={`${base}images/favicon.ico`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}images/favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}images/favicon-16x16.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}images/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}images/site.webmanifest`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,500;1,600&display=swap"
      rel="stylesheet"
    />
  <style>
    /* Desktop: show center nav, hide mobile hub link */
    @media (min-width: 700px) {
      #hub-nav-desktop  { display: flex !important; }
      #hub-home-mobile  { display: none !important; }
    }
    /* Mobile: hide center nav, show mobile hub link */
    @media (max-width: 699px) {
      #hub-nav-desktop  { display: none !important; }
      #hub-home-mobile  { display: block !important; }
      /* Tighten header padding so everything fits on 320px screens */
      #hub-header-inner { padding: 12px 14px !important; }
    }
  </style>
  </head>
  <body class="font-sans antialiased" style="background:#eef3f4;color:#0a1f44;min-height:100vh;">

    <!-- Top bar -->
    <header style="background:#fff;border-bottom:1px solid #e7eef0;position:sticky;top:0;z-index:40;">
      <div id="hub-header-inner" style="max-width:1080px;margin:0 auto;padding:14px 22px;display:flex;align-items:center;justify-content:space-between;gap:18px;">

        <!-- Logo -->
        <PawLogo height={38} />

        <!-- Center nav (desktop only) -->
        <nav id="hub-nav-desktop" style="display:flex;align-items:center;gap:22px;font-size:14.5px;font-weight:600;">
          <a href={`${base}participant`} style="color:#002d6b;font-weight:800;text-decoration:none;">My Show Hub</a>
          <button class="events-trigger" style="color:#48586a;text-decoration:none;background:none;border:none;font-size:14.5px;font-weight:600;cursor:pointer;font-family:inherit;padding:0;">Browse Shows</button>
          <a href={`${base}#how-it-works`} style="color:#48586a;text-decoration:none;">How It Works</a>
        </nav>

        <!-- Right: role switcher slot + mobile hub link + avatar -->
        <div style="display:flex;align-items:center;gap:12px;flex:none;">
          <div id="hub-nav-actions"></div>
          <!-- Mobile-only direct link to hub (always tappable) -->
          <a id="hub-home-mobile" href={`${base}participant`} style="font-size:13px;font-weight:800;color:#002d6b;text-decoration:none;white-space:nowrap;">My Show Hub</a>
          <!-- Avatar + chevron (dropdown anchor) -->
          <div style="position:relative;">
            <div id="hub-avatar-btn" style="display:flex;align-items:center;gap:7px;cursor:pointer;">
              <div style="width:38px;height:38px;border-radius:50%;background:#002d6b;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;" id="hub-avatar-initial">
                {userInitial}
              </div>
              <svg width="13" height="13" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2.5 4.5L6 8l3.5-3.5" stroke="#6b7c89" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <!-- Dropdown -->
            <div id="hub-avatar-menu" style="display:none;position:absolute;right:0;top:calc(100% + 8px);background:#fff;border:1px solid #e7eef0;border-radius:13px;box-shadow:0 8px 24px rgba(10,31,68,0.10);padding:6px;min-width:160px;z-index:50;">
              {displayName && <div style="padding:8px 12px 6px;font-size:13px;font-weight:700;color:#0a1f44;border-bottom:1px solid #f0f4f5;margin-bottom:4px;">{displayName}</div>}
              <button id="hub-signout" style="width:100%;text-align:left;background:none;border:none;padding:9px 12px;font-size:13.5px;font-weight:600;color:#6b7c89;cursor:pointer;border-radius:9px;font-family:inherit;" class="hover:bg-[#f5f8f9]">Sign out</button>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Page content -->
    <main>
      <slot />
    </main>

    <!-- Events browse panel -->
    <div id="events-overlay" aria-hidden="true"
      style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:60;opacity:0;pointer-events:none;transition:opacity 0.3s;"></div>

    <div id="events-panel" role="dialog" aria-modal="true" aria-label="Browse open shows"
      style="position:fixed;bottom:0;left:0;right:0;z-index:61;background:#fff;border-radius:24px 24px 0 0;box-shadow:0 -8px 40px rgba(10,31,68,0.18);display:flex;flex-direction:column;max-height:82vh;transform:translateY(100%);transition:transform 0.3s ease-out;">
      <div style="display:flex;justify-content:center;padding:12px 0 6px;flex-shrink:0;">
        <div style="width:40px;height:4px;background:#dde3e8;border-radius:99px;"></div>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 20px 14px;border-bottom:1px solid #efebf5;flex-shrink:0;">
        <div>
          <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0;line-height:1.25;">Open Shows</h2>
          <p style="font-size:13px;color:#6f6880;margin:4px 0 0;">Currently accepting entries</p>
        </div>
        <button id="events-close" aria-label="Close"
          style="width:36px;height:36px;border-radius:50%;background:#f5f3fa;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4a4357" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div id="events-list" style="overflow-y:auto;flex:1;padding:14px 16px 24px;">
        <div style="display:flex;justify-content:center;align-items:center;padding:52px 0;">
          <div style="width:32px;height:32px;border:3px solid rgba(27,168,154,0.2);border-top-color:#1ba89a;border-radius:50%;animation:spin 0.8s linear infinite;"></div>
        </div>
      </div>
    </div>

  </body>
</html>

<script>
  import { supabase } from '../lib/supabase.js';
  import { isVotingOpen } from '../lib/voteWindow.js';

  const avatarBtn  = document.getElementById('hub-avatar-btn');
  const avatarMenu = document.getElementById('hub-avatar-menu');

  avatarBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const hidden = avatarMenu.style.display === 'none';
    avatarMenu.style.display = hidden ? 'block' : 'none';
  });
  document.addEventListener('click', () => { if (avatarMenu) avatarMenu.style.display = 'none'; });

  document.getElementById('hub-signout')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    const raw = import.meta.env.BASE_URL;
    const base = raw.endsWith('/') ? raw : raw + '/';
    window.location.href = base + 'login';
  });

  // ── Events browse panel ──────────────────────────────────────────────
  const eventsOverlay = document.getElementById('events-overlay');
  const eventsPanel   = document.getElementById('events-panel');
  const eventsList    = document.getElementById('events-list');
  const eventsClose   = document.getElementById('events-close');
  let showsCache: any[] | null = null;

  function openEvents() {
    eventsOverlay!.style.opacity = '1';
    eventsOverlay!.style.pointerEvents = 'auto';
    eventsPanel!.style.transform = 'translateY(0)';
    document.body.style.overflow = 'hidden';
    if (!showsCache) loadShows();
  }

  function closeEvents() {
    eventsOverlay!.style.opacity = '0';
    eventsOverlay!.style.pointerEvents = 'none';
    eventsPanel!.style.transform = 'translateY(100%)';
    document.body.style.overflow = '';
  }

  async function loadShows() {
    const { data, error } = await supabase
      .from('shows')
      .select('id, title, host_org, logo_url, banner_url, show_date, show_time, timezone, entry_open_date, entry_open_time, entry_close_date, entry_close_time, entry_fee, currency, status, description, is_judged, vote_open_mode, results_published_at')
      .order('show_date', { ascending: true });
    if (error) { console.error('[Events panel]', error); eventsList!.innerHTML = `<p style="padding:20px;color:red;">Error: ${error.message}</p>`; return; }
    const now2 = Date.now();
    showsCache = (data || []).filter((s: any) => {
      if (s.status === 'draft') return false;
      const openOk  = !s.entry_open_date  || new Date(s.entry_open_date).getTime()  <= now2;
      const closeOk = !s.entry_close_date || new Date(s.entry_close_date).getTime() >= now2;
      // Public vote shows stay listed while their voting window is open,
      // even after entries close — that's when people come to vote.
      s._votingOpen = isVotingOpen(s);
      return (openOk && closeOk) || s._votingOpen;
    });
    renderShows(showsCache);
  }

  const SYMS: Record<string,string> = { AUD:'A$', NZD:'NZ$', USD:'$', GBP:'£', EUR:'€', CAD:'C$', ZAR:'R', SGD:'S$' };
  function esc(s: any) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function fmtDate(d: string) { return new Date(d).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }); }
  function daysLeft(d: string) {
    const n = Math.ceil((new Date(d).getTime() - Date.now()) / 86400000);
    return n <= 0 ? '' : n === 1 ? '1 day left' : `${n} days left`;
  }

  function renderShows(shows: any[]) {
    const rawBase = import.meta.env.BASE_URL;
    const base2 = rawBase.endsWith('/') ? rawBase : rawBase + '/';
    if (!shows.length) {
      eventsList!.innerHTML = `
        <div style="text-align:center;padding:52px 20px;">
          <p style="font-size:16px;font-weight:800;color:#1c1626;margin:0 0 6px;">No open shows right now</p>
          <p style="font-size:14px;color:#6f6880;margin:0;">Check back soon — new shows are added regularly.</p>
        </div>`;
      return;
    }
    eventsList!.innerHTML = shows.map((show: any) => {
      const thumb = show.logo_url
        ? `<img src="${esc(show.logo_url)}" style="width:56px;height:56px;border-radius:12px;object-fit:contain;background:#f5f3fa;border:1px solid #efebf5;flex-shrink:0;" alt="" />`
        : `<div style="width:56px;height:56px;border-radius:12px;background:linear-gradient(135deg,#1ba89a,#002d6b);display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:800;color:#fff;flex-shrink:0;">${esc((show.title||'?')[0].toUpperCase())}</div>`;
      const org   = show.host_org || '';
      const fee   = show.entry_fee > 0 ? `${SYMS[show.currency]||'$'}${show.entry_fee}` : '—';
      const close = show.entry_close_date ? daysLeft(show.entry_close_date) : '';
      const desc  = show.description ? show.description.slice(0, 100) + (show.description.length > 100 ? '…' : '') : '';
      const banner = show.banner_url
        ? `<div style="width:96px;height:60px;border-radius:10px;overflow:hidden;flex-shrink:0;"><img src="${esc(show.banner_url)}" style="width:100%;height:100%;object-fit:cover;display:block;" alt="" /></div>`
        : '';
      return `
        <button onclick="window.location.href='${base2}show?id=${esc(show.id)}'"
          style="width:100%;text-align:left;background:#fff;border:1px solid #efebf5;border-radius:16px;padding:14px 16px;display:flex;align-items:center;gap:14px;cursor:pointer;font-family:inherit;margin-bottom:10px;transition:border-color 0.15s,box-shadow 0.15s;"
          onmouseover="this.style.borderColor='#b8e4e0';this.style.boxShadow='0 4px 14px rgba(10,31,68,0.07)'"
          onmouseout="this.style.borderColor='#efebf5';this.style.boxShadow='none'">
          ${thumb}
          <div style="flex:1;min-width:0;">
            <div style="font-size:15px;font-weight:800;color:#1c1626;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(show.title||'Untitled Show')}</div>
            ${org ? `<div style="font-size:13px;color:#6f6880;margin-top:2px;">${esc(org)}</div>` : ''}
            ${desc ? `<div style="font-size:12px;color:#9b94a8;margin-top:3px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">${esc(desc)}</div>` : ''}
            <div style="display:flex;align-items:center;gap:8px;margin-top:7px;flex-wrap:wrap;">
              ${show.show_date ? `<span style="font-size:12px;font-weight:600;color:#6f6880;">📅 ${fmtDate(show.show_date)}</span>` : ''}
              <span style="font-size:11.5px;font-weight:700;color:#1ba89a;background:#e3f5f2;padding:2px 9px;border-radius:99px;">${fee}</span>
              ${show._votingOpen ? `<span style="font-size:11.5px;font-weight:700;color:#5B43C4;background:#efeafd;padding:2px 9px;border-radius:99px;">🗳️ Voting open</span>` : ''}
              ${close ? `<span style="font-size:12px;font-weight:600;color:#b67d12;">${close}</span>` : ''}
            </div>
          </div>
          ${banner}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="flex-shrink:0;"><path d="M5 3l5 5-5 5" stroke="#c4bed0" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>`;
    }).join('');
  }

  document.querySelectorAll('.events-trigger').forEach(el =>
    el.addEventListener('click', (e) => { e.preventDefault(); openEvents(); })
  );
  eventsClose?.addEventListener('click', closeEvents);
  eventsOverlay?.addEventListener('click', closeEvents);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeEvents(); });
</script>

<style>
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
