---
import BaseLayout from '../layouts/BaseLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<BaseLayout title="Page Not Found — Fur to Feathers" description="The page you're looking for doesn't exist.">

  <div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="text-center max-w-[420px]">
      <div class="w-20 h-20 rounded-full bg-brand-tint flex items-center justify-center mx-auto mb-6">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/>
        </svg>
      </div>
      <p class="text-[13px] font-bold text-brand uppercase tracking-[0.08em] mb-2">404</p>
      <h1 class="text-[26px] font-extrabold text-[#1c1626] mb-3">We couldn't find that page</h1>
      <p class="text-[15px] text-[#6f6880] leading-relaxed mb-8">
        The page you're looking for may have moved or no longer exists.
      </p>
      <a href={base}
        class="inline-flex items-center gap-2 bg-brand text-white text-[16px] font-bold px-[26px] py-[15px] rounded-btn shadow-btn-primary hover:bg-brand-dark hover:-translate-y-px transition-all">
        Back to Home
      </a>
    </div>
  </div>

</BaseLayout>
