---
import BaseLayout from '../layouts/BaseLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<BaseLayout title="Participant — PetShow Online">
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-16" style="background:#ffe4ee20">
    <div class="w-full max-w-lg bg-white rounded-card-lg shadow-card-float overflow-hidden">
      <!-- Colour accent bar (coral) -->
      <div class="h-2 w-full" style="background:#f0518a"></div>

      <div class="px-10 pt-10 pb-12 text-center">
        <!-- Icon -->
        <div class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6" style="background:#ffe4ee">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="#f0518a" aria-hidden="true">
            <path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/>
          </svg>
        </div>

        <h1 class="text-[36px] font-extrabold tracking-[-0.02em] leading-tight mb-2" style="color:#f0518a">Welcome, Participant!</h1>
        <p class="text-[18px] font-semibold text-[#1c1626] mb-3">Your entry portal is coming soon.</p>
        <p class="text-[15px] text-[#6f6880] leading-relaxed mb-10 max-w-sm mx-auto">
          We're hard at work building the full platform. In the meantime, explore the landing page or try a different role.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href={base}
            class="inline-flex items-center justify-center gap-2 text-white font-bold rounded-btn px-6 py-3 transition-colors hover:opacity-90"
            style="background:#f0518a;box-shadow:0 10px 24px rgba(240,81,138,0.3)">
            Back to Home
          </a>
          <a href={`${base}login`}
            class="inline-flex items-center justify-center gap-2 font-bold rounded-btn px-6 py-3 border-[1.5px] transition-colors"
            style="color:#f0518a;border-color:#f0a4d0">
            Log Out
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
