---
import ParticipantLayout from '../layouts/ParticipantLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<ParticipantLayout title="My Show Hub" userInitial="?" dualRole={false}>
  <div id="hub-root" style="max-width:1080px;margin:0 auto;padding:30px 22px 70px;">
    <p style="color:#6b7c89;font-size:15px;">Loading…</p>
  </div>
</ParticipantLayout>

<script>
  import { getAuth } from '../lib/auth.js';
  import { supabase } from '../lib/supabase.js';
  import { isVotingOpen } from '../lib/voteWindow.js';

  const { session, profile, base } = await getAuth();
  if (!session) { window.location.replace(base + 'login'); throw 0; }

  const dualRole = profile?.roles?.includes('organiser') ?? false;
  const displayName = profile?.display_name || session.user.email || '';
  const userInitial = (displayName[0] || '?').toUpperCase();

  // Update layout avatar
  const avatarEl = document.getElementById('hub-avatar-initial');
  if (avatarEl) avatarEl.textContent = userInitial;

  // Inject role switcher or nothing into nav-actions slot
  if (dualRole) {
    const slot = document.getElementById('hub-nav-actions');
    if (slot) {
      slot.innerHTML = `<a href="${base}organiser" style="display:inline-flex;align-items:center;gap:7px;font-size:13.5px;font-weight:700;color:#1ba89a;border:1.5px solid #cfeae6;border-radius:10px;padding:8px 13px;text-decoration:none;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h10" stroke="#1ba89a" stroke-width="2" stroke-linecap="round"/></svg>
        Organiser View
      </a>`;
    }
  }

  // Fetch entries, then related shows and categories separately
  const { data: rawEntries } = await supabase
    .from('show_entries')
    .select('id, show_id, category_id, animal_name, breed, photo_url, status, result_place, created_at')
    .eq('user_id', session.user.id)
    .eq('status', 'confirmed')
    .order('created_at', { ascending: false });

  const showIds    = [...new Set((rawEntries ?? []).map(e => e.show_id).filter(Boolean))];
  const catIds     = [...new Set((rawEntries ?? []).map(e => e.category_id).filter(Boolean))];

  const [showsRes, catsRes] = await Promise.all([
    showIds.length ? supabase.from('shows').select('id, title, host_org, show_date, show_time, timezone, vote_open_mode, entry_open_date, entry_open_time, entry_close_date, entry_close_time, currency, results_published_at, is_judged').in('id', showIds) : { data: [] },
    catIds.length  ? supabase.from('show_categories').select('id, name').in('id', catIds) : { data: [] },
  ]);

  const showsMap = Object.fromEntries((showsRes.data || []).map(s => [s.id, s]));
  const catsMap  = Object.fromEntries((catsRes.data  || []).map(c => [c.id, c]));

  const entries = (rawEntries ?? []).map(e => ({
    ...e,
    shows:           showsMap[e.show_id]    || null,
    show_categories: catsMap[e.category_id] || null,
  }));

  // ── Helpers ──────────────────────────────────────────────────────────────────
  function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  const thumbGrads = [
    'linear-gradient(135deg,#1ba89a,#0f6f8f)',
    'linear-gradient(135deg,#5b6cf0,#8a5bf0)',
    'linear-gradient(135deg,#f0a92b,#f0603e)',
    'linear-gradient(135deg,#f06ba0,#9a5bf0)',
  ];

  function entryKind(entry) {
    if (entry.shows?.results_published_at) return entry.result_place ? 'won' : 'noplace';
    const now = new Date();
    if (entry.shows?.entry_close_date && new Date(entry.shows.entry_close_date) > now) return 'open';
    return 'judging';
  }

  function isVotingNow(entry) {
    return !!entry.shows && isVotingOpen(entry.shows);
  }

  function copyEntryLink(entryId) {
    const base2 = (typeof base === 'string' ? base : '/');
    const url = window.location.origin + base2 + 'entry?id=' + encodeURIComponent(entryId);
    navigator.clipboard.writeText(url).catch(() => {});
    let toast = document.getElementById('part-link-toast');
    if (!toast) {
      toast = document.createElement('div');
      toast.id = 'part-link-toast';
      Object.assign(toast.style, {
        position: 'fixed', bottom: '24px', left: '50%', transform: 'translateX(-50%)',
        background: '#1c1626', color: 'white', padding: '8px 16px', borderRadius: '10px',
        fontSize: '13px', fontWeight: '600', zIndex: '200', transition: 'opacity 0.25s',
        whiteSpace: 'nowrap', opacity: '0', pointerEvents: 'none',
      });
      document.body.appendChild(toast);
    }
    toast.textContent = 'Entry link copied!';
    toast.style.opacity = '1';
    clearTimeout((toast as any)._t);
    (toast as any)._t = setTimeout(() => { toast.style.opacity = '0'; }, 2500);
  }

  const kindMap = {
    open:    { badgeText: 'Entries Open',     badgeBg: '#e3f5f2', badgeColor: '#117e72', stripBg: '#e3f5f2',                                    stripColor: '#117e72', stripText: '✓ Entry submitted. Good luck!' },
    judging: { badgeText: 'Awaiting Judging', badgeBg: '#fef3d6', badgeColor: '#b67d12', stripBg: '#fdf6e3',                                    stripColor: '#9a6b0e', stripText: '⏳ Judging in progress' },
    won:     { badgeText: 'Results In',       badgeBg: '#e6f7ec', badgeColor: '#1d8a4e', stripBg: 'linear-gradient(90deg,#fff6df,#fdeecb)',     stripColor: '#8a5a00', stripText: null },
    noplace: { badgeText: 'Results In',       badgeBg: '#eef1f4', badgeColor: '#6b7c89', stripBg: '#f1f4f6',                                    stripColor: '#6b7c89', stripText: 'Results published. Thanks for entering 💛' },
  };

  function placeLabel(n) {
    if (!n) return '';
    const s = ['th','st','nd','rd'];
    const v = n % 100;
    return n + (s[(v-20)%10] || s[v] || s[0]) + ' Place';
  }

  function formatDate(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  // ── Render ────────────────────────────────────────────────────────────────────
  let filter = 'all';

  // Which show groups are expanded (Set of show_id strings)
  const expandedShows = new Set();

  function groupByShow(list) {
    const map = new Map();
    for (const e of list) {
      const sid = e.show_id || '__unknown__';
      if (!map.has(sid)) map.set(sid, []);
      map.get(sid).push(e);
    }
    return [...map.entries()].map(([showId, grpEntries]) => ({ showId, entries: grpEntries, show: grpEntries[0]?.shows || {} }));
  }

  function visibleGroups() {
    const all = entries || [];
    const filtered = filter === 'all' ? all : all.filter(e => {
      const k = entryKind(e);
      if (filter === 'active')  return k === 'open' || k === 'judging';
      if (filter === 'results') return k === 'won'  || k === 'noplace';
      return true;
    });
    return groupByShow(filtered);
  }

  function groupStatus(grpEntries) {
    const kinds = grpEntries.map(entryKind);
    if (kinds.includes('won'))     return 'won';
    if (kinds.includes('noplace')) return 'noplace';
    if (kinds.includes('judging')) return 'judging';
    return 'open';
  }

  function placeBadge(place, isNZ) {
    if (!place || place > 10) return '';
    if (place <= 3) {
      const colors = isNZ
        ? ['#dc2626', '#2563eb', '#d97706']  // NZ: 1st=red, 2nd=blue, 3rd=amber
        : ['#2563eb', '#dc2626', '#d97706']; // default: 1st=blue, 2nd=red, 3rd=amber
      const bg = colors[place - 1];
      return `<div style="width:26px;height:26px;border-radius:50%;background:${bg};display:flex;align-items:center;justify-content:center;flex:none;font-size:13px;font-weight:800;color:#fff;">${place}</div>`;
    }
    // 4th–10th: outline only
    return `<div style="width:26px;height:26px;border-radius:50%;border:2px solid #d1d5db;display:flex;align-items:center;justify-content:center;flex:none;font-size:11px;font-weight:700;color:#9aa8b4;">${place}</div>`;
  }

  function renderEntryRow(entry, idx) {
    const kind   = entryKind(entry);
    const km     = kindMap[kind];
    const cat    = entry.show_categories?.name || '';
    const grad   = thumbGrads[idx % 4];
    const init   = (entry.animal_name || '?')[0].toUpperCase();
    const detailParts = [entry.breed, cat].filter(Boolean).join(' · ');
    const isNZ   = entry.shows?.currency === 'NZD';
    const badge  = placeBadge(entry.result_place, isNZ);

    return `
    <div class="entry-row" data-entry-id="${esc(entry.id)}"
      style="display:flex;align-items:center;gap:12px;padding:10px 16px;cursor:pointer;transition:background .12s;">
      ${entry.photo_url
        ? `<img src="${esc(entry.photo_url)}" style="width:42px;height:42px;border-radius:10px;flex:none;object-fit:cover;" alt="${esc(entry.animal_name)}" />`
        : `<div style="width:42px;height:42px;border-radius:10px;flex:none;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:17px;background:${grad};">${esc(init)}</div>`}
      <div style="flex:1;min-width:0;">
        <div style="font-size:14px;font-weight:700;color:#0a1f44;">${esc(entry.animal_name || '—')}</div>
        ${detailParts ? `<div style="font-size:12px;color:#6b7c89;margin-top:1px;">${esc(detailParts)}</div>` : ''}
      </div>
      ${badge}
      <span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:99px;background:${km.badgeBg};color:${km.badgeColor};white-space:nowrap;flex:none;">${km.badgeText}</span>
      ${isVotingNow(entry)
        ? `<button class="share-entry-btn" data-entry-id="${esc(entry.id)}"
             style="flex:none;background:none;border:1.5px solid #cfeae6;border-radius:8px;padding:5px 10px;cursor:pointer;display:flex;align-items:center;gap:5px;font-size:12px;font-weight:700;color:#1ba89a"
             title="Copy shareable link to boost votes">
             <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
               <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
               <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
             </svg>
             Share
           </button>`
        : ''}
      <span style="flex:none;font-size:13px;font-weight:700;color:#1ba89a;display:flex;align-items:center;gap:3px;">View
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M5 3l5 5-5 5" stroke="#1ba89a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </div>`;
  }

  function renderShowGroup({ showId, entries: grpEntries, show }) {
    const expanded  = expandedShows.has(showId);
    const count     = grpEntries.length;
    const kind      = groupStatus(grpEntries);
    const km        = kindMap[kind];
    const dateLabel = show.results_published_at
      ? 'Held · ' + formatDate(show.show_date)
      : show.entry_close_date && new Date(show.entry_close_date) > new Date()
        ? 'Closes · ' + formatDate(show.entry_close_date)
        : show.show_date ? 'Show Day · ' + formatDate(show.show_date) : '';

    const rowsHtml = grpEntries.map((e, i) =>
      (i > 0 ? `<div style="height:1px;background:#f0f4f5;margin:0 16px;"></div>` : '') + renderEntryRow(e, i)
    ).join('');

    return `
    <div class="show-group" style="background:#fff;border:1px solid #e7eef0;border-radius:16px;overflow:hidden;box-shadow:0 6px 18px rgba(10,31,68,0.04);">
      <div class="show-group-header" data-show-id="${esc(showId)}"
        style="display:flex;align-items:center;gap:13px;padding:15px 16px;cursor:pointer;transition:background .12s;">
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:3px;">
            <div style="font-size:16px;font-weight:800;color:#0a1f44;line-height:1.25;">${esc(show.title || 'Untitled Show')}</div>
            <span style="font-size:11px;font-weight:700;padding:3px 9px;border-radius:99px;background:${km.badgeBg};color:${km.badgeColor};white-space:nowrap;">${km.badgeText}</span>
          </div>
          <div style="font-size:12.5px;color:#9aa8b4;display:flex;align-items:center;gap:10px;">
            ${dateLabel ? `<span style="display:flex;align-items:center;gap:4px;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4.5" width="18" height="16" rx="3" stroke="#9aa8b4" stroke-width="1.8"/><path d="M3 9h18M8 2.5v4M16 2.5v4" stroke="#9aa8b4" stroke-width="1.8" stroke-linecap="round"/></svg>
              ${esc(dateLabel)}</span><span style="opacity:.5;">·</span>` : ''}
            <span>${count} ${count === 1 ? 'entry' : 'entries'}</span>
          </div>
        </div>
        <svg class="group-chevron" style="flex:none;transition:transform .2s;transform:${expanded ? 'rotate(180deg)' : 'rotate(0deg)'};"
          width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 9l6 6 6-6" stroke="#9aa8b4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="show-group-entries" style="display:${expanded ? 'block' : 'none'};border-top:1px solid #f0f4f5;">
        <div style="padding:6px 0;">${rowsHtml}</div>
      </div>
    </div>`;
  }

  function renderEmptyState() {
    return `
    <div style="background:#fff;border:1px solid #e7eef0;border-radius:20px;padding:56px 30px;text-align:center;box-shadow:0 6px 18px rgba(10,31,68,0.04);">
      <div style="margin:0 auto 22px;width:fit-content;">
        <img src="${base}images/ftf_logo_256x212.png" width="80" style="height:auto;display:block;" alt="" aria-hidden="true" />
      </div>
      <h2 style="font-size:23px;font-weight:800;margin:0 0 8px;color:#0a1f44;">No shows yet. Let's find your first!</h2>
      <p style="font-size:15px;color:#5b6b78;margin:0 auto 24px;max-width:420px;line-height:1.55;">When you enter a pet show, it'll show up here so you can track your entry, payment and results all in one place.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <button id="btn-browse-shows" style="background:#1ba89a;color:#fff;font-weight:700;font-size:15px;padding:13px 24px;border-radius:12px;border:none;cursor:pointer;font-family:inherit;">Browse Shows</button>
        <a href="${base}#how-it-works" style="background:#fff;color:#002d6b;font-weight:700;font-size:15px;padding:13px 24px;border-radius:12px;border:1.5px solid #d8e2e6;text-decoration:none;">How It Works</a>
      </div>
    </div>`;
  }

  function tabStyle(active) {
    return active
      ? 'padding:7px 15px;border-radius:9px;font-weight:700;font-size:13.5px;cursor:pointer;border:none;background:#002d6b;color:#fff;font-family:inherit;'
      : 'padding:7px 15px;border-radius:9px;font-weight:700;font-size:13.5px;cursor:pointer;border:none;background:transparent;color:#6b7c89;font-family:inherit;';
  }

  function renderDashboard() {
    const all      = entries || [];
    const total    = all.length;
    const active   = all.filter(e => { const k = entryKind(e); return k === 'open' || k === 'judging'; }).length;
    const results  = all.filter(e => { const k = entryKind(e); return k === 'won'  || k === 'noplace'; }).length;
    const groups   = visibleGroups();
    const name     = displayName.split(' ')[0] || 'there';

    const upgradeBanner = dualRole ? '' : `
    <div style="position:relative;overflow:hidden;background:linear-gradient(110deg,#002d6b,#013a85);border-radius:18px;padding:20px 24px;display:flex;align-items:center;gap:18px;flex-wrap:wrap;margin-bottom:26px;">
      <img src="${base}images/ftf_logo_256x212.png" style="position:absolute;right:18px;bottom:-26px;width:150px;height:auto;opacity:0.12;filter:brightness(0) invert(1);pointer-events:none;" alt="" aria-hidden="true" />
      <div style="width:46px;height:46px;border-radius:13px;background:rgba(27,168,154,0.22);display:flex;align-items:center;justify-content:center;flex:none;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l2.5 5.2 5.5.8-4 3.9 1 5.6L12 16.9 7 18.5l1-5.6-4-3.9 5.5-.8L12 3z" fill="#3ad6c4"/></svg>
      </div>
      <div style="flex:1;min-width:220px;">
        <div style="color:#fff;font-weight:700;font-size:17px;margin-bottom:3px;">Want to run your own show?</div>
        <div style="color:#bcd2f0;font-size:14px;">Hosting on Fur to Feathers is <strong style="color:#fff;">free</strong>. Raise money and bring your community together.</div>
      </div>
      <button id="upgrade-btn" style="flex:none;background:#1ba89a;color:#fff;font-weight:700;font-size:14.5px;padding:12px 20px;border-radius:11px;border:none;cursor:pointer;font-family:inherit;">Start a Show. Free!</button>
    </div>`;

    const showsSection = total === 0 ? renderEmptyState() : `
    <div>
      <div style="display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:16px;">
        <h2 style="font-size:19px;font-weight:800;margin:0;color:#0a1f44;">Your Shows</h2>
        <div style="display:flex;gap:5px;background:#fff;border:1px solid #e7eef0;padding:4px;border-radius:12px;">
          <button class="filter-btn" data-filter="all"     style="${tabStyle(filter === 'all')}">All</button>
          <button class="filter-btn" data-filter="active"  style="${tabStyle(filter === 'active')}">Active</button>
          <button class="filter-btn" data-filter="results" style="${tabStyle(filter === 'results')}">Results</button>
        </div>
      </div>
      <div id="cards-grid" style="display:flex;flex-direction:column;gap:10px;">
        ${groups.map(g => renderShowGroup(g)).join('')}
      </div>
      ${groups.length === 0 ? `<p style="text-align:center;color:#6b7c89;padding:32px 0;font-size:15px;">No entries match this filter.</p>` : ''}
    </div>`;

    return `
    <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-bottom:22px;">
      <div>
        <h1 style="font-size:30px;font-weight:800;letter-spacing:-0.02em;margin:0 0 6px;color:#0a1f44;">Hi, ${esc(name)}</h1>
        <p style="font-size:15px;color:#5b6b78;margin:0;">Here's everything you've entered. Good luck out there!</p>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;">
        <div style="background:#fff;border:1px solid #e7eef0;border-radius:13px;padding:10px 16px;text-align:center;min-width:84px;"><div style="font-size:21px;font-weight:800;color:#002d6b;">${total}</div><div style="font-size:11.5px;font-weight:600;color:#6b7c89;">Entered</div></div>
        <div style="background:#fff;border:1px solid #e7eef0;border-radius:13px;padding:10px 16px;text-align:center;min-width:84px;"><div style="font-size:21px;font-weight:800;color:#1ba89a;">${active}</div><div style="font-size:11.5px;font-weight:600;color:#6b7c89;">Active</div></div>
        <div style="background:#fff;border:1px solid #e7eef0;border-radius:13px;padding:10px 16px;text-align:center;min-width:84px;"><div style="font-size:21px;font-weight:800;color:#f0a92b;">${results}</div><div style="font-size:11.5px;font-weight:600;color:#6b7c89;">Results</div></div>
      </div>
    </div>
    ${upgradeBanner}
    ${showsSection}`;
  }

  // Initial render
  const root = document.getElementById('hub-root');
  root.innerHTML = renderDashboard();

  root.addEventListener('click', async (e) => {
    // Browse shows — delegate to header's events-trigger
    if (e.target.closest('#btn-browse-shows')) {
      document.querySelector('.events-trigger')?.dispatchEvent(new MouseEvent('click', { bubbles: true }));
      return;
    }

    // Upgrade to organiser
    if (e.target.closest('#upgrade-btn')) {
      const btn = e.target.closest('#upgrade-btn');
      btn.textContent = 'Setting up…';
      btn.disabled = true;
      const newRoles = [...(profile?.roles || ['participant']), 'organiser'];
      await supabase.from('profiles').update({ roles: newRoles }).eq('id', session.user.id);
      window.location.href = base + 'organiser';
      return;
    }

    // Filter tabs
    const filterBtn = e.target.closest('.filter-btn');
    if (filterBtn) {
      filter = filterBtn.dataset.filter;
      root.innerHTML = renderDashboard();
      return;
    }

    // Show group header — toggle expand/collapse
    const groupHeader = e.target.closest('.show-group-header');
    if (groupHeader) {
      const showId  = groupHeader.dataset.showId;
      const panel   = groupHeader.closest('.show-group');
      const body    = panel?.querySelector('.show-group-entries');
      const chevron = panel?.querySelector('.group-chevron');
      if (expandedShows.has(showId)) {
        expandedShows.delete(showId);
        if (body)    body.style.display    = 'none';
        if (chevron) chevron.style.transform = 'rotate(0deg)';
      } else {
        expandedShows.add(showId);
        if (body)    body.style.display    = 'block';
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }
      return;
    }

    // Share entry link (for public vote shows in voting phase)
    const shareBtn = e.target.closest('.share-entry-btn');
    if (shareBtn) {
      e.stopPropagation();
      copyEntryLink(shareBtn.dataset.entryId);
      return;
    }

    // Entry row click — navigate to entry detail
    const entryRow = e.target.closest('.entry-row');
    if (entryRow?.dataset.entryId) {
      window.location.href = base + 'participant/entry?id=' + encodeURIComponent(entryRow.dataset.entryId);
    }
  });

  // Hover highlight on entry rows
  root.addEventListener('mouseover', e => {
    const row = e.target.closest('.entry-row');
    if (row) row.style.background = '#f6f9f9';
  });
  root.addEventListener('mouseout', e => {
    const row = e.target.closest('.entry-row');
    if (row) row.style.background = 'transparent';
  });

  // Hover lift on show-group header
  root.addEventListener('mouseover', e => {
    const hdr = e.target.closest('.show-group-header');
    if (hdr) hdr.style.background = '#f9fbfb';
  });
  root.addEventListener('mouseout', e => {
    const hdr = e.target.closest('.show-group-header');
    if (hdr) hdr.style.background = 'transparent';
  });
</script>
