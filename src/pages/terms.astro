---
import BaseLayout from '../layouts/BaseLayout.astro';

const raw  = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';

const updated = '3 July 2026';
---

<BaseLayout title="Terms & Conditions — Fur to Feathers" description="Terms of use, refund policy, and platform rules for Fur to Feathers.">

  <div style="max-width:720px;margin:0 auto;padding:60px 24px 100px;">

    <p style="font-size:13px;font-weight:700;color:#1ba89a;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 10px;">Legal</p>
    <h1 style="font-size:32px;font-weight:900;color:#1c1626;margin:0 0 8px;line-height:1.2;">Terms & Conditions</h1>
    <p style="font-size:13px;color:#9b94a8;margin:0 0 48px;">Last updated {updated}</p>

    <!-- 1 -->
    <section style="margin-bottom:40px;">
      <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 12px;">1. About Fur to Feathers</h2>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0 0 10px;">
        Fur to Feathers is an online platform that allows clubs and individuals ("Organisers") to create and manage pet shows, and allows pet owners ("Exhibitors") to enter those shows. We provide the technology; the shows themselves are run by independent Organisers.
      </p>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0;">
        By creating an account, running a show, or entering a show on this platform, you agree to these terms in full.
      </p>
    </section>

    <!-- 2 -->
    <section style="margin-bottom:40px;">
      <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 12px;">2. Fees and Payments</h2>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0 0 10px;">
        Organisers set their own entry fee per show. At checkout, Exhibitors also pay a platform service fee charged by Fur to Feathers. This service fee is displayed clearly before payment is taken.
      </p>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0 0 10px;">
        All payments are processed securely by Stripe. By completing a payment you also agree to <a href="https://stripe.com/legal/consumer" target="_blank" rel="noopener" style="color:#1ba89a;font-weight:600;">Stripe's Terms of Service</a>.
      </p>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0 0 10px;">
        Fur to Feathers does not store card details. All card data is handled directly by Stripe.
      </p>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0;">
        For information on how we handle your personal data, including how Stripe processes payment information, please read our <a href={`${base}privacy`} style="color:#1ba89a;font-weight:600;">Privacy Policy</a>.
      </p>
    </section>

    <!-- 3 -->
    <section style="margin-bottom:40px;background:#fff5f5;border:1.5px solid #fecaca;border-radius:14px;padding:24px 24px 20px;">
      <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 12px;">3. Refund Policy</h2>

      <p style="font-size:13px;font-weight:700;color:#dc2626;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 8px;">Service fees are non-refundable</p>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0 0 16px;">
        The platform service fee charged by Fur to Feathers is non-refundable under any circumstances. This fee covers payment processing costs that are incurred the moment a transaction is completed and cannot be recovered by us regardless of what happens to the entry or show afterwards.
      </p>

      <p style="font-size:13px;font-weight:700;color:#4a4357;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 8px;">Entry fees</p>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0 0 16px;">
        Fur to Feathers is a platform provider; we are not a party to the agreement between an Exhibitor and an Organiser. We do not issue refunds of entry fees on behalf of Organisers, and we have no visibility into or control over any refund arrangements an Organiser may choose to offer their exhibitors. If you believe you are entitled to a refund of an entry fee, you must contact the organising club directly.
      </p>

      <p style="font-size:13px;font-weight:700;color:#4a4357;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 8px;">Chargebacks</p>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0;">
        Filing a chargeback or payment dispute for a legitimate transaction on this platform is a breach of these Terms. We reserve the right to permanently suspend accounts associated with fraudulent chargebacks and to recover any costs incurred as a result of an unjustified dispute.
      </p>
    </section>

    <!-- 4 -->
    <section style="margin-bottom:40px;">
      <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 12px;">4. Organiser Responsibilities</h2>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0 0 10px;">
        By creating a show on Fur to Feathers, Organisers agree to:
      </p>
      <ul style="margin:0 0 10px;padding-left:20px;display:flex;flex-direction:column;gap:8px;">
        {[
          'Provide accurate and complete show information, including entry fees, closing dates, and judging categories.',
          'Run the show substantially as advertised. If a show is cancelled, Organisers must make reasonable efforts to communicate with all registered exhibitors promptly.',
          'Handle any exhibitor communications, disputes, or refund requests relating to entry fees directly.',
          'Not use the platform to collect fees for shows they have no genuine intention of running.',
          'Comply with all applicable local laws, including consumer protection laws in their jurisdiction.',
        ].map(item => (
          <li style="font-size:14px;color:#4a4357;line-height:1.7;">{item}</li>
        ))}
      </ul>
    </section>

    <!-- 5 -->
    <section style="margin-bottom:40px;">
      <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 12px;">5. Exhibitor Responsibilities</h2>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0 0 10px;">By entering a show, Exhibitors agree to:</p>
      <ul style="margin:0;padding-left:20px;display:flex;flex-direction:column;gap:8px;">
        {[
          'Provide accurate information about themselves and their pet(s).',
          'Only enter animals they own or have the legal right to enter on behalf of the owner.',
          'Submit only photos they own or have the right to use. Photos are made publicly accessible on the internet so that judges can view entries — by uploading a photo you confirm this, grant Fur to Feathers a non-exclusive licence to display it in connection with the relevant show, and take full responsibility for obtaining consent from any identifiable person in the photo (including acting as parent or legal guardian for any child who appears).',
          'Accept that entry fees and service fees are committed at the point of payment.',
        ].map(item => (
          <li style="font-size:14px;color:#4a4357;line-height:1.7;">{item}</li>
        ))}
      </ul>
    </section>

    <!-- 6 -->
    <section style="margin-bottom:40px;">
      <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 12px;">6. Platform Availability</h2>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0;">
        We aim to keep Fur to Feathers available at all times but cannot guarantee uninterrupted access. We reserve the right to carry out maintenance, updates, or suspend the platform where necessary. We are not liable for losses arising from platform downtime.
      </p>
    </section>

    <!-- 7 -->
    <section style="margin-bottom:40px;">
      <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 12px;">7. Limitation of Liability</h2>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0 0 10px;">
        Fur to Feathers provides a platform; we are not responsible for the conduct of Organisers or Exhibitors, the quality or outcome of any show, or any disputes arising between them.
      </p>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0;">
        To the maximum extent permitted by law, our total liability to any user for any claim arising out of or relating to these Terms or the platform shall not exceed the amount paid by that user to Fur to Feathers in the 12 months preceding the claim.
      </p>
    </section>

    <!-- 8 -->
    <section style="margin-bottom:40px;">
      <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 12px;">8. Changes to These Terms</h2>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0;">
        We may update these Terms from time to time. Where changes are material, we will notify users via email or a notice on the platform. Continued use of the platform after changes take effect constitutes acceptance of the updated Terms.
      </p>
    </section>

    <!-- 9 -->
    <section style="margin-bottom:48px;">
      <h2 style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 12px;">9. Governing Law</h2>
      <p style="font-size:14px;color:#4a4357;line-height:1.8;margin:0;">
        These Terms are governed by the laws of Victoria, Australia. Any disputes will be subject to the exclusive jurisdiction of the courts of Victoria, except where mandatory local consumer protection laws in your jurisdiction provide otherwise.
      </p>
    </section>

    <!-- Contact -->
    <div style="background:#f5f8f9;border-radius:14px;padding:24px;">
      <h2 style="font-size:16px;font-weight:800;color:#1c1626;margin:0 0 8px;">Questions?</h2>
      <p style="font-size:14px;color:#4a4357;line-height:1.7;margin:0;">
        If you have questions about these Terms or our refund policy, contact us at <a href="mailto:hello@furtofeathers.com" style="color:#1ba89a;font-weight:600;">hello@furtofeathers.com</a>.
      </p>
    </div>

  </div>

</BaseLayout>
