---
import BaseLayout from '../layouts/BaseLayout.astro';
import HallOfFameCarousel from '../components/HallOfFameCarousel.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<BaseLayout>

  <!-- ═══════════════════════════════════════════════════
       1. HERO
  ════════════════════════════════════════════════════ -->
  <section id="why" class="max-w-container mx-auto px-4 min-[600px]:px-7 pt-10 min-[900px]:pt-[54px] pb-6 min-[900px]:pb-7">
    <div class="grid grid-cols-1 min-[900px]:grid-cols-[0.9fr_1.18fr] items-center gap-6 min-[900px]:gap-10">

      <!-- LEFT: copy -->
      <div>
        <!-- Eyebrow pill -->
        <div class="inline-flex items-center gap-2 bg-brand-tint rounded-full px-[15px] py-2 mb-6">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="#f0518a" aria-hidden="true">
            <path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/>
          </svg>
          <span class="text-[13.5px] font-bold text-brand">More Fun. More Paws. More Purpose.</span>
        </div>

        <!-- H1 -->
        <h1 class="text-[32px] min-[500px]:text-[42px] min-[900px]:text-[55px] font-extrabold leading-[1.04] tracking-[-0.03em] mb-5">
          <span class="text-[#1c1626]">Virtual Pet Shows.</span><br />
          <span class="text-brand">Real Impact.</span>
        </h1>

        <!-- Lead paragraph -->
        <p class="text-[16px] min-[600px]:text-[18px] leading-[1.62] text-[#5d566b] max-w-[430px] mb-8">
          Fur to Feathers makes it easy to run online pet shows and competitions that bring
          communities together and raise money for the causes you care about.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-4 mb-10">
          <a href={`${base}login`}
            class="inline-flex items-center gap-2 bg-brand text-white text-[16px] font-bold px-[26px] py-[15px] rounded-btn shadow-btn-primary hover:bg-brand-dark hover:-translate-y-px transition-all">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Create a Show
          </a>
          <a href={`${base}#events`}
            class="inline-flex items-center gap-2 text-brand bg-white text-[16px] font-bold px-[22px] py-[13px] rounded-btn border-[1.5px] border-[#e6dcfb] hover:bg-brand-tint hover:-translate-y-px transition-all">
            <svg width="15" height="15" viewBox="0 0 48 48" fill="none" aria-hidden="true">
              <ellipse cx="24" cy="31" rx="11" ry="9" fill="#7c3aed"/>
              <ellipse cx="11" cy="23" rx="5.5" ry="6" fill="#7c3aed"/>
              <ellipse cx="37" cy="23" rx="5.5" ry="6" fill="#7c3aed"/>
              <ellipse cx="17" cy="14" rx="5" ry="5.5" fill="#a855f7"/>
              <ellipse cx="31" cy="14" rx="5" ry="5.5" fill="#a855f7"/>
            </svg>
            Browse Events
          </a>
        </div>

        <!-- Mini features -->
        <div class="flex flex-wrap gap-[26px]">
          <!-- Great for Fundraisers -->
          <div class="flex items-start gap-3">
            <div class="w-[38px] h-[38px] rounded-[11px] bg-[#ffe4ee] flex-shrink-0 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#f0518a" aria-hidden="true">
                <path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/>
              </svg>
            </div>
            <div>
              <p class="text-[14.5px] font-bold text-[#1c1626]">Great for Fundraisers</p>
              <p class="text-[12.5px] text-[#7d7689] leading-snug">Raise more with our easy fundraising tools</p>
            </div>
          </div>
          <!-- Easy to Run -->
          <div class="flex items-start gap-3">
            <div class="w-[38px] h-[38px] rounded-[11px] bg-[#d6f5f0] flex-shrink-0 flex items-center justify-center">
              <svg width="15" height="15" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <ellipse cx="24" cy="31" rx="11" ry="9" fill="#0d9488"/>
                <ellipse cx="11" cy="23" rx="5.5" ry="6" fill="#0d9488"/>
                <ellipse cx="37" cy="23" rx="5.5" ry="6" fill="#0d9488"/>
                <ellipse cx="17" cy="14" rx="5" ry="5.5" fill="#2dd4bf"/>
                <ellipse cx="31" cy="14" rx="5" ry="5.5" fill="#2dd4bf"/>
              </svg>
            </div>
            <div>
              <p class="text-[14.5px] font-bold text-[#1c1626]">Easy to Run</p>
              <p class="text-[12.5px] text-[#7d7689] leading-snug">Simple setup. We handle the rest.</p>
            </div>
          </div>
          <!-- Fair & Fun -->
          <div class="flex items-start gap-3">
            <div class="w-[38px] h-[38px] rounded-[11px] bg-[#dcf6e3] flex-shrink-0 flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>
              </svg>
            </div>
            <div>
              <p class="text-[14.5px] font-bold text-[#1c1626]">Fair &amp; Fun</p>
              <p class="text-[12.5px] text-[#7d7689] leading-snug">Anonymous judging for fair, unbiased results</p>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: outer wrapper — overflow visible so the "Perfect for" card can hang left -->
      <div class="relative">

        <!-- Image frame — overflow hidden only here, for border-radius crop -->
        <div
          class="relative w-full rounded-3xl min-[900px]:rounded-[0_24px_24px_0] shadow-hero-frame max-[900px]:shadow-none"
          style="aspect-ratio:3/2;overflow:hidden"
        >
          <img
            src={`${base}hero-dog.jpg`}
            alt="A happy dog ready for the show"
            class="w-full h-full object-cover object-center"
            loading="eager"
          />

          <!-- Left-edge fade overlay (desktop only) -->
          <div
            class="hidden min-[900px]:block absolute inset-0 pointer-events-none"
            style="background:linear-gradient(90deg,#ffffff 0%,#ffffff 24%,rgba(255,255,255,0.88) 40%,rgba(255,255,255,0.35) 57%,rgba(255,255,255,0) 72%)"
            aria-hidden="true"
          ></div>

          <!-- Floating decorations (clipped by image frame — intentional) -->
          <div class="ps-float animate-floaty absolute top-[8%] right-[-8px]" style="--deco-r:-8deg" aria-hidden="true">
            <svg width="42" height="42" viewBox="0 0 24 24" fill="#f0518a" style="filter:drop-shadow(0 6px 10px rgba(240,81,138,0.35))" aria-hidden="true">
              <path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/>
            </svg>
          </div>
          <div class="ps-float animate-floaty2 absolute bottom-[12%] right-[16px]" style="--deco-r:6deg" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="#a855f7" style="filter:drop-shadow(0 4px 8px rgba(168,85,247,0.3))" aria-hidden="true">
              <path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/>
            </svg>
          </div>
          <div class="ps-float animate-floaty3 absolute top-[28%] right-[-4px] w-[12px] h-[12px] rounded-[3px] bg-[#fbbf24]" style="--deco-r:15deg;filter:drop-shadow(0 2px 6px rgba(251,191,36,0.4))" aria-hidden="true"></div>
          <div class="ps-float animate-floaty4 absolute bottom-[32%] right-[10px] w-[11px] h-[11px] rounded-[3px] bg-[#2dd4bf]" style="--deco-r:-10deg;filter:drop-shadow(0 2px 6px rgba(45,212,191,0.4))" aria-hidden="true"></div>
        </div>

        <!-- Outer left-fade: extends past the image frame's left edge to cover box-shadow bleed (desktop only) -->
        <div
          class="hidden min-[900px]:block absolute inset-y-0 pointer-events-none"
          style="left:-56px;right:50%;background:linear-gradient(90deg,#ffffff 0%,#ffffff 32%,rgba(255,255,255,0) 100%)"
          aria-hidden="true"
        ></div>

        <!-- "Perfect for:" card — outside overflow:hidden, hangs over left edge freely -->
        <div
          class="hidden min-[900px]:block absolute top-1/2 -translate-y-1/2 w-[234px] bg-[#fffdf7] rounded-card-sm border border-[#f3eee2] shadow-card-float"
          style="left:-22px;padding:18px 20px"
          aria-label="Perfect for these use cases"
        >
          <div class="flex items-center gap-2 mb-3">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="#f0518a" aria-hidden="true">
              <path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/>
            </svg>
            <span class="text-[15px] font-extrabold text-[#1c1626]">Perfect for:</span>
          </div>
          {['Charity Fundraisers','Community Events','Shelter Support','Special Occasions','Fun Competitions'].map(item => (
            <div class="flex items-center gap-2.5 mb-2">
              <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="10" fill="#7c3aed"/>
                <polyline points="8 12 11 15 16 9" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="text-[13.5px] font-semibold text-[#403a4d]">{item}</span>
            </div>
          ))}
          <p class="font-hand text-[21px] font-bold text-brand mt-3 leading-tight">
            Big hearts. Happy pets.<br />Stronger communities.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       2. FUNDRAISING BAND
  ════════════════════════════════════════════════════ -->
  <section id="fundraising" class="max-w-container mx-auto px-4 min-[600px]:px-7 mt-9">
    <div class="relative overflow-hidden rounded-card flex flex-wrap items-center gap-[26px] px-6 min-[600px]:px-9 py-[26px] min-[600px]:py-[30px]"
      style="background:linear-gradient(120deg,#6d28d9,#5b21b6)">

      <!-- Faint paw watermark -->
      <svg class="absolute top-[-20px] right-[-20px] opacity-[0.12] pointer-events-none" width="160" height="160" viewBox="0 0 48 48" fill="white" aria-hidden="true">
        <ellipse cx="24" cy="31" rx="11" ry="9"/>
        <ellipse cx="11" cy="23" rx="5.5" ry="6"/>
        <ellipse cx="37" cy="23" rx="5.5" ry="6"/>
        <ellipse cx="17" cy="14" rx="5" ry="5.5"/>
        <ellipse cx="31" cy="14" rx="5" ry="5.5"/>
      </svg>

      <!-- Icon tile -->
      <div class="w-[62px] h-[62px] rounded-panel flex-shrink-0 flex items-center justify-center" style="background:rgba(255,255,255,0.16)">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" fill="#f0a4d0" stroke="white" stroke-width="1.5"/>
          <!-- Hands suggestion: two small arcs below heart -->
          <path d="M7 16c0 0 2-1 5-1s5 1 5 1" stroke="white" stroke-width="1.5" stroke-linecap="round" fill="none"/>
        </svg>
      </div>

      <!-- Text -->
      <div class="flex-1 min-w-0 min-[480px]:min-w-[200px]">
        <h2 class="text-[22px] font-extrabold text-white leading-tight mb-1">Fundraise while having fun!</h2>
        <p class="text-[15px] text-[#e3d8fb] leading-relaxed">
          Keep more of what you raise. We charge a small platform fee so you can focus on making a big difference.
        </p>
      </div>

      <!-- CTA -->
      <a href="#" class="flex-shrink-0 inline-flex items-center gap-2 bg-white text-[#6d28d9] text-[15px] font-bold rounded-[12px] px-[22px] py-[14px] hover:bg-brand-tint transition-colors">
        Learn More About Fundraising
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       3. HOW IT WORKS
  ════════════════════════════════════════════════════ -->
  <section id="how" class="max-w-how mx-auto px-4 min-[600px]:px-7 pt-12 min-[900px]:pt-[74px] pb-10 min-[900px]:pb-16">
    <!-- Heading -->
    <div class="text-center mb-10 min-[600px]:mb-12">
      <h2 class="text-[26px] min-[600px]:text-[34px] font-extrabold tracking-[-0.02em] text-[#1c1626]">How Fur to Feathers Works</h2>
      <div class="w-16 h-1 bg-brand rounded-full mx-auto mt-3"></div>
    </div>

    <!-- Steps grid -->
    <div class="relative grid grid-cols-1 min-[480px]:grid-cols-2 min-[900px]:grid-cols-4 gap-[18px]">
      <!-- Dashed connector (desktop only) -->
      <div
        class="hidden min-[900px]:block absolute top-[38px] border-t-2 border-dashed border-[#d9d2e8] pointer-events-none"
        style="left:12.5%;right:12.5%"
        aria-hidden="true"
      ></div>

      <!-- Step 1: Create Your Show -->
      <div class="flex flex-col items-center text-center">
        <div class="w-[76px] h-[76px] rounded-full bg-[#efe7fd] flex items-center justify-center mb-4 relative z-10">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <div class="flex items-center gap-2 mb-1.5">
          <span class="w-[22px] h-[22px] rounded-full bg-[#2e1065] text-white text-[11px] font-bold flex items-center justify-center flex-shrink-0">1</span>
          <h3 class="text-[16px] font-extrabold text-[#1c1626]">Create Your Show</h3>
        </div>
        <p class="text-[14px] text-[#6f6880] leading-[1.55] max-w-[200px]">Set up your event in minutes. Add categories, dates and your cause.</p>
      </div>

      <!-- Step 2: Participants Enter -->
      <div class="flex flex-col items-center text-center">
        <div class="w-[76px] h-[76px] rounded-full bg-[#ffe4ee] flex items-center justify-center mb-4 relative z-10">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#f0518a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
          </svg>
        </div>
        <div class="flex items-center gap-2 mb-1.5">
          <span class="w-[22px] h-[22px] rounded-full bg-[#2e1065] text-white text-[11px] font-bold flex items-center justify-center flex-shrink-0">2</span>
          <h3 class="text-[16px] font-extrabold text-[#1c1626]">Participants Enter</h3>
        </div>
        <p class="text-[14px] text-[#6f6880] leading-[1.55] max-w-[200px]">Your community enters, pays securely and submits photos or videos.</p>
      </div>

      <!-- Step 3: Judging Happens -->
      <div class="flex flex-col items-center text-center">
        <div class="w-[76px] h-[76px] rounded-full bg-[#fef1d6] flex items-center justify-center mb-4 relative z-10">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#e89b1c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="8 6 2 12 8 18"/><polyline points="16 6 22 12 16 18"/><line x1="12" y1="2" x2="12" y2="22"/>
          </svg>
        </div>
        <div class="flex items-center gap-2 mb-1.5">
          <span class="w-[22px] h-[22px] rounded-full bg-[#2e1065] text-white text-[11px] font-bold flex items-center justify-center flex-shrink-0">3</span>
          <h3 class="text-[16px] font-extrabold text-[#1c1626]">Judging Happens</h3>
        </div>
        <p class="text-[14px] text-[#6f6880] leading-[1.55] max-w-[200px]">Judges score entries anonymously for a fair and unbiased competition.</p>
      </div>

      <!-- Step 4: Celebrate & Raise -->
      <div class="flex flex-col items-center text-center">
        <div class="w-[76px] h-[76px] rounded-full bg-[#dcf6e3] flex items-center justify-center mb-4 relative z-10">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
          </svg>
        </div>
        <div class="flex items-center gap-2 mb-1.5">
          <span class="w-[22px] h-[22px] rounded-full bg-[#2e1065] text-white text-[11px] font-bold flex items-center justify-center flex-shrink-0">4</span>
          <h3 class="text-[16px] font-extrabold text-[#1c1626]">Celebrate &amp; Raise</h3>
        </div>
        <p class="text-[14px] text-[#6f6880] leading-[1.55] max-w-[200px]">Winners are announced and funds raised go to your cause!</p>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       4. HALL OF FAME (component)
  ════════════════════════════════════════════════════ -->
  <HallOfFameCarousel />


  <!-- ═══════════════════════════════════════════════════
       5. STATS BAND
  ════════════════════════════════════════════════════ -->
  <section class="max-w-container mx-auto px-4 min-[600px]:px-7 mt-7">
    <div class="bg-cream rounded-card-lg px-5 min-[600px]:px-10 py-8 min-[600px]:py-[34px]">
      <div class="grid grid-cols-1 min-[700px]:grid-cols-[auto_1fr_auto] items-center gap-8 min-[700px]:gap-[34px]">

        <!-- Heart-paw icon -->
        <div class="max-[700px]:mx-auto" aria-hidden="true">
          <svg width="84" height="84" viewBox="0 0 84 84" fill="none">
            <path d="M42 72S14 55 14 33a16 16 0 0 1 28-10.5A16 16 0 0 1 70 33C70 55 42 72 42 72z" fill="#7c3aed"/>
            <ellipse cx="42" cy="50" rx="7" ry="5.5" fill="white"/>
            <ellipse cx="34" cy="43" rx="3.5" ry="4" fill="white"/>
            <ellipse cx="50" cy="43" rx="3.5" ry="4" fill="white"/>
            <ellipse cx="37" cy="37" rx="3" ry="3.5" fill="white"/>
            <ellipse cx="47" cy="37" rx="3" ry="3.5" fill="white"/>
          </svg>
        </div>

        <!-- Text -->
        <div class="max-[700px]:text-center">
          <h2 class="text-[21px] font-extrabold text-brand leading-snug mb-2">Built for pet lovers and causes that matter.</h2>
          <p class="text-[14px] text-[#6f6880] leading-relaxed max-w-[380px] max-[700px]:mx-auto">
            From local fundraisers to special events, Fur to Feathers helps you create memorable experiences and make a real impact.
          </p>
        </div>

        <!-- Feature highlights -->
        <div class="grid grid-cols-2 gap-x-6 gap-y-3 max-[700px]:mx-auto">
          {[
            'Free to get started',
            'Live in minutes',
            'No tech skills needed',
            'Built for fundraising',
          ].map(label => (
            <div class="flex items-center gap-2">
              <span class="w-5 h-5 rounded-full bg-brand/10 flex items-center justify-center shrink-0">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="text-[13px] font-semibold text-[#4a4357] whitespace-nowrap">{label}</span>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       6. FINAL CTA BAND
  ════════════════════════════════════════════════════ -->
  <section id="pricing" class="max-w-container mx-auto px-4 min-[600px]:px-7 mt-7 mb-12 min-[600px]:mb-16">
    <div class="relative overflow-hidden rounded-card flex flex-wrap items-center justify-between gap-5 px-6 min-[600px]:px-[38px] py-7 min-[600px]:py-[30px]"
      style="background:linear-gradient(120deg,#7c3aed,#6d28d9)">

      <!-- Faint paw watermark -->
      <svg class="absolute bottom-[-30px] left-[-20px] opacity-10 pointer-events-none" width="180" height="180" viewBox="0 0 48 48" fill="white" aria-hidden="true">
        <ellipse cx="24" cy="31" rx="11" ry="9"/>
        <ellipse cx="11" cy="23" rx="5.5" ry="6"/>
        <ellipse cx="37" cy="23" rx="5.5" ry="6"/>
        <ellipse cx="17" cy="14" rx="5" ry="5.5"/>
        <ellipse cx="31" cy="14" rx="5" ry="5.5"/>
      </svg>

      <!-- Text -->
      <div>
        <h2 class="text-[20px] min-[600px]:text-[24px] font-extrabold text-white leading-tight">Ready to create something amazing?</h2>
        <p class="text-[15px] text-[#e3d8fb] mt-1">Start your virtual pet show today and turn fun into impact.</p>
      </div>

      <!-- Buttons -->
      <div class="flex flex-wrap gap-3">
        <a href={`${base}login`}
          class="inline-flex items-center gap-2 bg-white text-[#6d28d9] text-[15px] font-bold rounded-[12px] px-[22px] py-[13px] hover:bg-brand-tint transition-colors">
          Get Started Free
        </a>
        <a href={`${base}#how`}
          class="inline-flex items-center gap-2 text-white text-[15px] font-bold rounded-[12px] px-[22px] py-[13px] border-[1.5px] border-white/50 hover:bg-white/10 transition-colors">
