---
import BaseLayout from '../layouts/BaseLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<BaseLayout title="Create Account — Fur to Feathers" description="Create your free Fur to Feathers account.">

  <div class="min-h-[80vh] flex items-center justify-center bg-brand-tint/50 px-4 py-12">

    <!-- Sign-up card -->
    <div id="signup-card" class="w-full max-w-md bg-white rounded-card-lg shadow-card-float p-10">

      <!-- Logo -->
      <div class="flex justify-center mb-6">
        <a href={base} class="inline-flex items-center gap-2.5 no-underline">
          <svg width="42" height="42" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <ellipse cx="24" cy="31" rx="11" ry="9" fill="#7c3aed"/>
            <ellipse cx="11" cy="23" rx="5.5" ry="6" fill="#7c3aed"/>
            <ellipse cx="37" cy="23" rx="5.5" ry="6" fill="#7c3aed"/>
            <ellipse cx="17" cy="14" rx="5" ry="5.5" fill="#a855f7"/>
            <ellipse cx="31" cy="14" rx="5" ry="5.5" fill="#a855f7"/>
          </svg>
          <div class="flex flex-col leading-none">
            <span class="text-[20px] font-extrabold tracking-[-0.02em] text-[#1c1626]">Fur to Feathers</span>
            <span class="text-[9px] font-bold text-[#9b94a8] tracking-[0.32em] uppercase">PET SHOWS</span>
          </div>
        </a>
      </div>

      <h1 class="text-[26px] font-extrabold text-[#1c1626] text-center mb-1">Create your account</h1>
      <p class="text-[15px] text-[#6f6880] text-center mb-7">What do you want to do?</p>

      <!-- Role picker -->
      <div class="grid grid-cols-2 gap-3 mb-7" role="group" aria-label="Choose your role">

        <button type="button" id="role-participant" class="role-btn flex flex-col items-center gap-2.5 rounded-[14px] border-2 px-3 py-5 transition-all cursor-pointer" data-role="participant">
          <div class="w-11 h-11 rounded-full flex items-center justify-center" style="background:#ffe4ee">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#f0518a" aria-hidden="true">
              <path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/>
            </svg>
          </div>
          <span class="text-[12.5px] font-bold text-[#1c1626] text-center leading-snug">Enter my pet<br>in a show</span>
        </button>

        <button type="button" id="role-organiser" class="role-btn flex flex-col items-center gap-2.5 rounded-[14px] border-2 px-3 py-5 transition-all cursor-pointer" data-role="organiser">
          <div class="w-11 h-11 rounded-full flex items-center justify-center" style="background:#f1eafe">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <span class="text-[12.5px] font-bold text-[#1c1626] text-center leading-snug">Organise<br>a show</span>
        </button>

      </div>

      <!-- Organiser sub-type (revealed when Organiser role is selected) -->
      <div id="organiser-subtype" style="display:none" class="mb-7 p-4 rounded-[14px] border border-brand/10 bg-brand-tint/40">
        <p class="text-[12.5px] font-semibold text-[#4a4357] mb-2.5">Are you signing up as…</p>
        <div class="grid grid-cols-2 gap-2 mb-3">
          <button type="button" id="subtype-individual" class="subtype-btn flex flex-col items-center gap-1.5 rounded-[11px] border-2 border-brand bg-white px-3 py-3 text-[12px] font-bold text-[#1c1626] transition-all" data-subtype="individual" style="box-shadow:0 0 0 3px rgba(124,58,237,0.18)">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            Individual
          </button>
          <button type="button" id="subtype-club" class="subtype-btn flex flex-col items-center gap-1.5 rounded-[11px] border-2 border-[#e6dcfb] bg-white px-3 py-3 text-[12px] font-bold text-[#1c1626] transition-all" data-subtype="club">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            Club / Org
          </button>
        </div>
        <div id="club-name-field" style="display:none">
          <label for="club-name" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Club / Organisation name</label>
          <input
            type="text"
            id="club-name"
            placeholder="e.g. Sunny Paws Dog Club"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>
      </div>

      <!-- Form -->
      <form id="signup-form" novalidate>

        <div class="mb-4">
          <label for="display-name" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Your name</label>
          <input
            type="text"
            id="display-name"
            autocomplete="name"
            placeholder="e.g. Sarah Jones"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>

        <div class="mb-4">
          <label for="email" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Email address</label>
          <input
            type="email"
            id="email"
            autocomplete="email"
            placeholder="you@example.com"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>

        <div class="mb-4">
          <label for="password" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Password</label>
          <input
            type="password"
            id="password"
            autocomplete="new-password"
            placeholder="At least 6 characters"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>

        <div class="mb-6">
          <label for="confirm-password" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Confirm password</label>
          <input
            type="password"
            id="confirm-password"
            autocomplete="new-password"
            placeholder="••••••••"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>

        <p id="signup-error" class="hidden text-[13px] text-red-500 text-center mb-4 bg-red-50 border border-red-100 rounded-lg px-3 py-2" role="alert"></p>

        <button
          type="submit"
          id="signup-btn"
          class="w-full bg-brand text-white text-[16px] font-bold py-[14px] rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors disabled:opacity-60"
        >
          Create Account
        </button>

      </form>

      <p class="text-center text-[13px] text-[#9b94a8] mt-6">
        Already have an account?
        <a href={`${base}login`} class="text-brand font-semibold hover:underline">Log in</a>
      </p>

    </div>

    <!-- Success state -->
    <div id="signup-success" class="hidden w-full max-w-md bg-white rounded-card-lg shadow-card-float p-10 text-center">
      <div class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6" style="background:#f0fdf4">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </div>
      <h2 class="text-[24px] font-extrabold text-[#1c1626] mb-3">Check your inbox!</h2>
      <p class="text-[15px] text-[#6f6880] leading-relaxed mb-1">
        We've sent a confirmation link to
      </p>
      <p id="success-email" class="text-[15px] font-bold text-[#1c1626] mb-4"></p>
      <p class="text-[14px] text-[#9b94a8] leading-relaxed mb-8">
        Click the link in the email to activate your account, then come back here to log in.
      </p>
      <a href={`${base}login`}
        class="inline-flex items-center justify-center bg-brand text-white text-[15px] font-bold px-8 py-[13px] rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
        Go to Login
      </a>
    </div>

  </div>

</BaseLayout>

<script>
  import { supabase } from '../lib/supabase.js';

  const raw = import.meta.env.BASE_URL;
  const base = raw.endsWith('/') ? raw : raw + '/';

  // Already logged in? Go to choose (which handles single-role redirect)
  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session) window.location.replace(base + 'choose');
  });

  // Role selection
  let selectedRole = 'participant';
  let selectedSubtype = 'individual';

  const STYLES = {
    participant: { border: '#f0518a', bg: '#fff8fb', ring: 'rgba(240,81,138,0.18)' },
    organiser:   { border: '#7c3aed', bg: '#faf7ff', ring: 'rgba(124,58,237,0.18)' },
  };

  function setRole(role) {
    selectedRole = role;
    document.querySelectorAll('.role-btn').forEach(btn => {
      const r = btn.dataset.role;
      if (r === role) {
        btn.style.borderColor = STYLES[r].border;
        btn.style.background  = STYLES[r].bg;
        btn.style.boxShadow   = `0 0 0 3px ${STYLES[r].ring}`;
      } else {
        btn.style.borderColor = '#e6dcfb';
        btn.style.background  = '#fafafa';
        btn.style.boxShadow   = 'none';
      }
    });
    const subtypeEl = document.getElementById('organiser-subtype');
    if (subtypeEl) subtypeEl.style.display = role === 'organiser' ? 'block' : 'none';
  }

  function setSubtype(subtype) {
    selectedSubtype = subtype;
    document.querySelectorAll('.subtype-btn').forEach(btn => {
      if (btn.dataset.subtype === subtype) {
        btn.style.borderColor = '#7c3aed';
        btn.style.boxShadow   = '0 0 0 3px rgba(124,58,237,0.18)';
      } else {
        btn.style.borderColor = '#e6dcfb';
        btn.style.boxShadow   = 'none';
      }
    });
    const clubField = document.getElementById('club-name-field');
    if (clubField) clubField.style.display = subtype === 'club' ? 'block' : 'none';
  }

  setRole('participant');

  document.querySelectorAll('.role-btn').forEach(btn => {
    btn.addEventListener('click', () => setRole(btn.dataset.role));
  });

  document.querySelectorAll('.subtype-btn').forEach(btn => {
    btn.addEventListener('click', () => setSubtype(btn.dataset.subtype));
  });

  // Form submit
  document.getElementById('signup-form')?.addEventListener('submit', async e => {
    e.preventDefault();

    const displayName = (document.getElementById('display-name')).value.trim();
    const email       = (document.getElementById('email')).value.trim().toLowerCase();
    const password    = (document.getElementById('password')).value;
    const confirm     = (document.getElementById('confirm-password')).value;
    const errEl       = document.getElementById('signup-error');
    const btn         = document.getElementById('signup-btn');

    errEl.classList.add('hidden');

    if (!email || !password) {
      errEl.textContent = 'Please enter your email and password.';
      errEl.classList.remove('hidden');
      return;
    }
    if (password.length < 6) {
      errEl.textContent = 'Password must be at least 6 characters.';
      errEl.classList.remove('hidden');
      return;
    }
    if (password !== confirm) {
      errEl.textContent = 'Passwords do not match.';
      errEl.classList.remove('hidden');
      return;
    }

    // Extra validation for club organiser
    if (selectedRole === 'organiser' && selectedSubtype === 'club') {
      const clubName = (document.getElementById('club-name')).value.trim();
      if (!clubName) {
        errEl.textContent = 'Please enter your club or organisation name.';
        errEl.classList.remove('hidden');
        return;
      }
    }

    btn.disabled = true;
    btn.textContent = 'Creating account…';

    const clubName = selectedRole === 'organiser' && selectedSubtype === 'club'
      ? (document.getElementById('club-name')).value.trim()
      : undefined;

    const { data: signUpData, error } = await supabase.auth.signUp({
      email,
      password,
      options: {
        emailRedirectTo: 'https://davidtonkindiffgrav.github.io/petshow/login',
        data: {
          display_name: displayName || email.split('@')[0],
          role: selectedRole,
          ...(selectedRole === 'organiser' && {
            organiser_type: selectedSubtype,
            ...(clubName && { organisation_name: clubName }),
          }),
        },
      },
    });

    if (error) {
      errEl.textContent = error.message;
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Create Account';
      return;
    }

    if (signUpData.session) {
      // Email confirmation is off — user is already logged in, go straight to dashboard
      window.location.href = base + 'choose';
    } else {
      // Email confirmation is on — show the check-your-inbox screen
      document.getElementById('signup-card').classList.add('hidden');
      document.getElementById('success-email').textContent = email;
      document.getElementById('signup-success').classList.remove('hidden');
    }
  });
</script>
