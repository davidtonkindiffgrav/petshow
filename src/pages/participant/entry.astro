---
import ParticipantLayout from '../../layouts/ParticipantLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<ParticipantLayout title="Entry Detail" userInitial="?" dualRole={false}>
  <div id="entry-root" style="max-width:920px;margin:0 auto;padding:24px 22px 70px;">
    <p style="color:#6b7c89;font-size:15px;">Loading…</p>
  </div>
</ParticipantLayout>

<style>
  @media (max-width: 640px) {
    .entry-grid { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  import { getAuth } from '../../lib/auth.js';
  import { supabase } from '../../lib/supabase.js';
  import { zonedDateTime } from '../../lib/voteWindow.js';
  import { renderCertificate, CERT_DEFAULTS } from '../../lib/cert-renderer.js';

  const { session, profile, base } = await getAuth();
  if (!session) { window.location.replace(base + 'login'); throw 0; }

  const dualRole     = profile?.roles?.includes('organiser') ?? false;
  const displayName  = profile?.display_name || session.user.email || '';
  const userInitial  = (displayName[0] || '?').toUpperCase();

  const avatarEl = document.getElementById('hub-avatar-initial');
  if (avatarEl) avatarEl.textContent = userInitial;

  // Inject role switcher for dual-role
  if (dualRole) {
    const slot = document.getElementById('hub-nav-actions');
    if (slot) {
      slot.innerHTML = `<a href="${base}organiser" style="display:inline-flex;align-items:center;gap:7px;font-size:13.5px;font-weight:700;color:#1ba89a;border:1.5px solid #cfeae6;border-radius:10px;padding:8px 13px;text-decoration:none;">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M4 7h16M4 12h16M4 17h10" stroke="#1ba89a" stroke-width="2" stroke-linecap="round"/></svg>
        Organiser View
      </a>`;
    }
  }

  const entryId = new URL(window.location.href).searchParams.get('id');
  if (!entryId) { window.location.replace(base + 'participant'); throw 0; }

  const { data: entry, error } = await supabase
    .from('show_entries')
    .select('id, show_id, category_id, status, photo_url, animal_name, breed, result_place, entry_number, entry_fee_paid, cert_jpg_url, exhibitor_name, created_at')
    .eq('id', entryId)
    .eq('user_id', session.user.id)
    .single();

  if (!error && entry) {
    const [showRes, catRes, judgeRes] = await Promise.all([
      entry.show_id     ? supabase.from('shows').select('id, title, host_org, show_date, entry_close_date, entry_close_time, timezone, currency, results_published_at, cert_design_json, logo_url, org_logo_url, is_judged').eq('id', entry.show_id).single() : { data: null },
      entry.category_id ? supabase.from('show_categories').select('id, name').eq('id', entry.category_id).single() : { data: null },
      entry.show_id     ? supabase.from('show_judges').select('first_name, last_name').eq('show_id', entry.show_id).limit(1).maybeSingle() : { data: null },
    ]);
    entry.shows           = showRes.data || null;
    entry.show_categories = catRes.data  || null;
    const j = judgeRes?.data;
    if (entry.shows && j) entry.shows.judge_name = `${j.first_name || ''} ${j.last_name || ''}`.trim() || null;
  }

  const root = document.getElementById('entry-root');

  if (error || !entry) {
    root.innerHTML = `<p style="color:#e53e3e;font-size:15px;">Entry not found or you don't have permission to view it.</p><a href="${base}participant" style="color:#1ba89a;font-weight:700;">← Back to My Show Hub</a>`;
    throw 0;
  }

  // ── Helpers ──────────────────────────────────────────────────────────────────
  function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function formatDate(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' });
  }

  const currSymbols = { AUD:'$', NZD:'$', USD:'$', GBP:'£', EUR:'€', CAD:'$', ZAR:'R', SGD:'$' };

  function entryKind(e) {
    if (e.shows?.results_published_at) return e.result_place ? 'won' : 'noplace';
    const now = new Date();
    const closeAt = e.shows && zonedDateTime(e.shows.entry_close_date, e.shows.entry_close_time, e.shows.timezone);
    if (closeAt && closeAt > now) return 'open';
    return 'judging';
  }

  function placeLabel(n) {
    if (!n) return '';
    const s = ['th','st','nd','rd'];
    const v = n % 100;
    return n + (s[(v-20)%10] || s[v] || s[0]) + ' Place';
  }

  const kind    = entryKind(entry);
  const show    = entry.shows || {};
  const cat     = entry.show_categories?.name || '';
  const sym     = currSymbols[show.currency] || '$';
  const host    = show.host_org || '';
  const entryNo = entry.entry_number ? `#FTF-${entry.entry_number}` : `#${entry.id.slice(0,8).toUpperCase()}`;

  const statusPills = {
    open:    { text: '✓ ENTRIES OPEN',     bg: '#e3f5f2', color: '#117e72' },
    judging: { text: '⏳ AWAITING JUDGING', bg: '#fef3d6', color: '#b67d12' },
    won:     { text: '🏆 RESULTS IN',       bg: '#e6f7ec', color: '#1d8a4e' },
    noplace: { text: '📋 RESULTS IN',       bg: '#eef1f4', color: '#6b7c89' },
  };
  const pill = statusPills[kind];

  // Timeline node HTML
  function timelineNode({ done, current, label, sub }) {
    let dot, line;
    if (done) {
      dot = `<div style="width:22px;height:22px;border-radius:50%;background:#1ba89a;display:flex;align-items:center;justify-content:center;flex:none;"><svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3.5 8l3 3 6-6.5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>`;
      line = `<div style="width:2px;flex:1;background:#dfe7e9;min-height:18px;"></div>`;
    } else if (current) {
      dot = `<div style="width:22px;height:22px;border-radius:50%;background:#fef3d6;border:2px solid #f0a92b;display:flex;align-items:center;justify-content:center;flex:none;"><div style="width:7px;height:7px;border-radius:50%;background:#f0a92b;"></div></div>`;
      line = `<div style="width:2px;flex:1;background:#dfe7e9;min-height:18px;"></div>`;
    } else {
      dot = `<div style="width:22px;height:22px;border-radius:50%;background:#eef2f3;display:flex;align-items:center;justify-content:center;flex:none;"><div style="width:7px;height:7px;border-radius:50%;background:#c2ccd2;"></div></div>`;
      line = '';
    }
    const labelColor  = (!done && !current) ? '#9aa8b4' : '#0a1f44';
    const subColor    = (!done && !current) ? '#9aa8b4' : '#6b7c89';
    return `
    <div style="display:flex;gap:12px;">
      <div style="display:flex;flex-direction:column;align-items:center;">${dot}${line}</div>
      <div style="padding-bottom:${line ? '14px' : '0'};"><div style="font-size:14px;font-weight:700;color:${labelColor};">${esc(label)}</div>${sub ? `<div style="font-size:12.5px;color:${subColor};">${esc(sub)}</div>` : ''}</div>
    </div>`;
  }

  const node1Done    = true;
  const node2Done    = kind === 'won' || kind === 'noplace';
  const node2Current = kind === 'judging';
  const node3Done    = kind === 'won' || kind === 'noplace';

  const timeline = [
    timelineNode({ done: node1Done,    current: false,        label: 'Entry submitted',       sub: formatDate(entry.created_at) }),
    timelineNode({ done: node2Done,    current: node2Current, label: 'Judging in progress',   sub: node2Done ? 'Judging complete' : node2Current ? 'Expert judges scoring now' : 'Begins after entry closes' }),
    timelineNode({ done: node3Done,    current: false,        label: 'Results published',      sub: show.results_published_at ? formatDate(show.results_published_at) : show.show_date ? 'Expected ' + formatDate(show.show_date) : 'Date TBC' }),
  ].join('');

  const petPhoto = entry.photo_url
    ? `<div style="width:84px;height:84px;border-radius:18px;overflow:hidden;flex:none;"><img src="${esc(entry.photo_url)}" style="width:100%;height:100%;object-fit:cover;" alt="${esc(entry.animal_name)}" /></div>`
    : `<div style="width:84px;height:84px;border-radius:18px;background:linear-gradient(135deg,#1ba89a,#0f6f8f);display:flex;align-items:center;justify-content:center;flex:none;color:#fff;font-size:32px;font-weight:800;">${esc((entry.animal_name||'?')[0].toUpperCase())}</div>`;

  const paidAmount = entry.entry_fee_paid ? `${sym}${Number(entry.entry_fee_paid).toFixed(2)}` : '—';

  root.innerHTML = `
  <a href="${base}participant" style="display:inline-flex;align-items:center;gap:7px;background:none;border:none;color:#48586a;font-size:14px;font-weight:600;cursor:pointer;padding:0;margin-bottom:18px;text-decoration:none;">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="#48586a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    Back to My Show Hub
  </a>

  <!-- Hero -->
  <div style="position:relative;overflow:hidden;background:linear-gradient(115deg,#002d6b,#0b4a8f);border-radius:20px;padding:24px 26px;margin-bottom:18px;">
    <img src="${base}images/ftf_logo_256x212.png" style="position:absolute;right:-10px;bottom:-30px;width:160px;height:auto;opacity:0.13;filter:brightness(0) invert(1);pointer-events:none;" alt="" aria-hidden="true" />
    <span style="display:inline-block;font-size:11px;font-weight:700;letter-spacing:0.04em;color:${pill.color};background:${pill.bg};padding:5px 11px;border-radius:99px;margin-bottom:12px;">${pill.text}</span>
    <h1 style="font-size:27px;font-weight:800;color:#fff;margin:0 0 7px;letter-spacing:-0.01em;">${esc(show.title || 'Untitled Show')}</h1>
    <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;color:#bcd2f0;font-size:13.5px;font-weight:600;">
      ${host ? `<span style="display:flex;align-items:center;gap:6px;">Hosted by ${esc(host)}<svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" fill="#1ba89a"/><path d="M8 12l2.5 2.5L16 9" stroke="#fff" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg></span><span style="opacity:.5;">•</span>` : ''}
      <span>📅 Show Day · ${esc(formatDate(show.show_date))}</span>
    </div>
  </div>

  <!-- Two-column grid -->
  <div style="display:grid;grid-template-columns:1.3fr 1fr;gap:16px;" class="entry-grid">

    <!-- Your Entry -->
    <div style="background:#fff;border:1px solid #e7eef0;border-radius:18px;padding:20px;box-shadow:0 6px 18px rgba(10,31,68,0.04);">
      <div style="font-size:13px;font-weight:700;color:#6b7c89;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:14px;">Your Entry</div>
      <div style="display:flex;gap:15px;align-items:center;margin-bottom:18px;">
        ${petPhoto}
        <div>
          <div style="font-size:22px;font-weight:800;color:#0a1f44;">${esc(entry.animal_name || '—')}</div>
          <div style="font-size:14px;color:#6b7c89;">${esc(entry.breed || '')}</div>
          ${cat ? `<div style="display:inline-block;margin-top:7px;font-size:12px;font-weight:700;color:#1ba89a;background:#e3f5f2;padding:4px 11px;border-radius:99px;">${esc(cat)}</div>` : ''}
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:11px;border-top:1px solid #eef2f3;padding-top:15px;">
        <div style="display:flex;justify-content:space-between;font-size:14px;"><span style="color:#6b7c89;">Entry ID</span><span style="font-weight:700;color:#0a1f44;">${esc(entryNo)}</span></div>
        ${cat ? `<div style="display:flex;justify-content:space-between;font-size:14px;"><span style="color:#6b7c89;">Class</span><span style="font-weight:700;color:#0a1f44;">${esc(cat)}</span></div>` : ''}
        <div style="display:flex;justify-content:space-between;font-size:14px;"><span style="color:#6b7c89;">Submitted</span><span style="font-weight:700;color:#0a1f44;">${esc(formatDate(entry.created_at))}</span></div>
      </div>
      <div style="display:flex;gap:10px;margin-top:18px;">
        <a href="${base}show?id=${esc(show.id)}" style="flex:1;text-align:center;background:#002d6b;color:#fff;font-weight:700;font-size:14px;padding:11px;border-radius:11px;text-decoration:none;">View Show Page</a>
        <button disabled style="flex:none;background:#fff;color:#9aa8b4;font-weight:700;font-size:14px;padding:11px 16px;border-radius:11px;border:1.5px solid #e7eef0;cursor:not-allowed;font-family:inherit;" title="Coming soon">Edit</button>
      </div>
    </div>

    <!-- Right column -->
    <div style="display:flex;flex-direction:column;gap:16px;">

      <!-- Payment -->
      <div style="background:#fff;border:1px solid #e7eef0;border-radius:18px;padding:18px 20px;box-shadow:0 6px 18px rgba(10,31,68,0.04);">
        <div style="font-size:13px;font-weight:700;color:#6b7c89;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:13px;">Payment</div>
        <div style="display:flex;align-items:center;gap:11px;">
          <div style="width:40px;height:40px;border-radius:11px;background:#e6f7ec;display:flex;align-items:center;justify-content:center;flex:none;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9.2" fill="#1d8a4e"/><path d="M8 12l2.5 2.5L16 9" stroke="#fff" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <div style="font-size:15px;font-weight:800;color:#0a1f44;">Paid · ${esc(paidAmount)}</div>
            <div style="font-size:12.5px;color:#6b7c89;">Entry fee</div>
          </div>
        </div>
      </div>

      <!-- Timeline -->
      <div style="background:#fff;border:1px solid #e7eef0;border-radius:18px;padding:18px 20px;box-shadow:0 6px 18px rgba(10,31,68,0.04);">
        <div style="font-size:13px;font-weight:700;color:#6b7c89;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:15px;">What happens next</div>
        <div>${timeline}</div>
      </div>

    </div>
  </div>

  ${kind === 'won' && entry.cert_jpg_url ? `
  <!-- Certificate download -->
  <div style="background:linear-gradient(115deg,#fffbea,#fff8d6);border:1.5px solid #f0d97a;border-radius:18px;padding:20px 22px;margin-top:16px;box-shadow:0 6px 18px rgba(10,31,68,0.04);">
    <div style="display:flex;align-items:flex-start;gap:14px;flex-wrap:wrap;">
      <div style="width:44px;height:44px;border-radius:13px;background:#fff8d6;border:1.5px solid #f0d97a;display:flex;align-items:center;justify-content:center;flex:none;font-size:22px;">🏆</div>
      <div style="flex:1;min-width:180px;">
        <div style="font-size:16px;font-weight:800;color:#0a1f44;margin-bottom:3px;">Your Certificate</div>
        <div style="font-size:13px;color:#6b7c89;">You placed <strong style="color:#8a5a00;">${placeLabel(entry.result_place)}</strong>${cat ? ' in ' + esc(cat) : ''}. Download your award certificate below.</div>
        <div style="display:flex;gap:9px;margin-top:13px;flex-wrap:wrap;">
          <a id="cert-dl-jpg" href="${esc(entry.cert_jpg_url)}" download="certificate-${esc(entry.animal_name || 'award')}.jpg"
            style="display:inline-flex;align-items:center;gap:7px;background:#002d6b;color:#fff;font-weight:700;font-size:13.5px;padding:10px 16px;border-radius:11px;text-decoration:none;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 3v13M7 12l5 5 5-5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 20h14" stroke="#fff" stroke-width="2" stroke-linecap="round"/></svg>
            Download JPG
          </a>
          <button id="cert-dl-pdf"
            style="display:inline-flex;align-items:center;gap:7px;background:#fff;color:#0a1f44;font-weight:700;font-size:13.5px;padding:10px 16px;border-radius:11px;border:1.5px solid #e7eef0;cursor:pointer;font-family:inherit;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 3v13M7 12l5 5 5-5" stroke="#0a1f44" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 20h14" stroke="#0a1f44" stroke-width="2" stroke-linecap="round"/></svg>
            Download PDF
          </button>
        </div>
      </div>
    </div>
  </div>
  ` : ''}

`;
  // PDF download for winners
  const pdfBtn = document.getElementById('cert-dl-pdf');
  if (pdfBtn) {
    pdfBtn.addEventListener('click', async () => {
      pdfBtn.textContent = 'Generating…';
      pdfBtn.disabled = true;
      try {
        const canvas = document.createElement('canvas');
        const design = { ...CERT_DEFAULTS, ...(show.cert_design_json ? JSON.parse(show.cert_design_json) : {}) };
        if (show.is_judged === false) design.show_signature = false;
        await renderCertificate(canvas, { show, entry, category: entry.show_categories, sponsors: [], design });
        const PAGE_PT = { a4: [842, 595], letter: [792, 612] };
        const [W, H] = PAGE_PT[design.page_size || 'a4'];
        const pdfBytes = await buildPdf(canvas, W, H);
        const blob = new Blob([pdfBytes], { type: 'application/pdf' });
        const url  = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = `certificate-${entry.animal_name || 'award'}.pdf`;
        link.click();
        setTimeout(() => URL.revokeObjectURL(url), 5000);
      } catch (err) {
        console.error(err);
        alert('PDF generation failed. Please use the JPG download instead.');
      } finally {
        pdfBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 3v13M7 12l5 5 5-5" stroke="#0a1f44" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 20h14" stroke="#0a1f44" stroke-width="2" stroke-linecap="round"/></svg> Download PDF';
        pdfBtn.disabled = false;
      }
    });
  }

  async function buildPdf(canvas, W, H) {
    const jpegBlob  = await new Promise(res => canvas.toBlob(res, 'image/jpeg', 0.92));
    const jpegBytes = new Uint8Array(await jpegBlob.arrayBuffer());
    const iw = canvas.width, ih = canvas.height;
    const enc = s => typeof s === 'string' ? new TextEncoder().encode(s) : s;
    const parts = []; let pos = 0; const off = {};
    const push = s => { const b = enc(s); parts.push(b); pos += b.length; };
    push('%PDF-1.4\n');
    off[1] = pos; push('1 0 obj\n<< /Type /Catalog /Pages 2 0 R >>\nendobj\n');
    off[2] = pos; push('2 0 obj\n<< /Type /Pages /Kids [3 0 R] /Count 1 >>\nendobj\n');
    off[3] = pos; push(`3 0 obj\n<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ${W} ${H}] /Resources << /XObject << /img 4 0 R >> >> /Contents 5 0 R >>\nendobj\n`);
    off[4] = pos; push(`4 0 obj\n<< /Type /XObject /Subtype /Image /Width ${iw} /Height ${ih} /ColorSpace /DeviceRGB /BitsPerComponent 8 /Filter /DCTDecode /Length ${jpegBytes.length} >>\nstream\n`);
    push(jpegBytes); push('\nendstream\nendobj\n');
    const cs = `q ${W} 0 0 ${H} 0 0 cm /img Do Q`;
    off[5] = pos; push(`5 0 obj\n<< /Length ${cs.length} >>\nstream\n${cs}\nendstream\nendobj\n`);
    const xref = pos;
    push('xref\n0 6\n0000000000 65535 f \n');
    for (let i = 1; i <= 5; i++) push(off[i].toString().padStart(10, '0') + ' 00000 n \n');
    push(`trailer\n<< /Size 6 /Root 1 0 R >>\nstartxref\n${xref}\n%%EOF\n`);
    const total = parts.reduce((n, b) => n + b.length, 0);
    const out = new Uint8Array(total); let p = 0;
    for (const b of parts) { out.set(b, p); p += b.length; }
    return out;
  }
</script>
