---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Entry" description="Show entry detail">

  <div style="background:#F0F7F5;min-height:100vh;padding-bottom:80px">

    <!-- Loading -->
    <div id="state-loading" style="display:flex;align-items:center;justify-content:center;min-height:60vh">
      <div style="width:40px;height:40px;border:3px solid rgba(30,142,126,0.2);border-top-color:#1E8E7E;border-radius:50%;animation:spin 0.8s linear infinite"></div>
    </div>

    <!-- Not found -->
    <div id="state-not-found" style="display:none;align-items:center;justify-content:center;min-height:60vh">
      <div style="text-align:center;max-width:360px;padding:0 24px">
        <div style="font-size:48px;margin-bottom:16px">🐾</div>
        <h2 style="font-size:22px;font-weight:800;color:#143A37;margin-bottom:8px">Entry not found</h2>
        <p style="color:#6B7C79;margin-bottom:24px">This entry may have been removed or the link may be incorrect.</p>
        <a id="link-home" href="#" style="display:inline-flex;align-items:center;gap:8px;background:#1E8E7E;color:white;font-weight:700;font-size:14px;padding:12px 24px;border-radius:10px;text-decoration:none">Browse Shows</a>
      </div>
    </div>

    <!-- Entry content -->
    <div id="state-entry" style="display:none;max-width:600px;margin:0 auto;padding:24px">
      <!-- Back link -->
      <a id="link-show" href="#"
        style="display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:600;color:#1E8E7E;text-decoration:none;margin-bottom:20px">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
        </svg>
        <span id="link-show-label">Back to Show</span>
      </a>

      <!-- Show badge -->
      <div id="show-badge" style="display:none;background:white;border:1px solid #E6EEEC;border-radius:10px;padding:10px 14px;margin-bottom:20px;display:flex;align-items:center;gap:10px">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1E8E7E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <span id="show-title" style="font-size:13px;font-weight:600;color:#143A37"></span>
      </div>

      <!-- Entry card -->
      <div style="background:white;border-radius:20px;border:1px solid #E6EEEC;box-shadow:0 8px 32px rgba(20,58,55,0.08);overflow:hidden">

        <!-- Photo -->
        <div id="entry-photo-wrap" style="aspect-ratio:4/3;background:#E6EEEC;overflow:hidden">
          <div id="entry-photo-placeholder" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:72px;color:#9BB4AF"></div>
        </div>

        <!-- Details -->
        <div style="padding:22px 24px 28px">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
            <span id="entry-number" style="font-size:11px;font-weight:700;background:#E3F5F2;color:#1E8E7E;padding:3px 8px;border-radius:99px"></span>
            <span id="cat-name" style="font-size:11px;font-weight:700;color:#9BB4AF;background:#F5F3FA;padding:3px 8px;border-radius:99px"></span>
          </div>
          <h1 id="entry-name" style="font-size:24px;font-weight:800;color:#143A37;margin:8px 0 4px"></h1>
          <p id="entry-breed" style="font-size:14px;color:#6B7C79;margin:0 0 16px"></p>
          <p id="exhibitor-line" style="font-size:13px;color:#9BB4AF;margin:0 0 20px"></p>

          <!-- Vote CTA (only shown when show is in voting state) -->
          <div id="vote-cta" style="display:none">
            <div style="background:#F0F7F5;border-radius:12px;padding:16px;margin-bottom:4px">
              <p style="font-size:13px;color:#143A37;font-weight:600;margin:0 0 10px">Want to vote for this pet?</p>
              <a id="link-vote" href="#"
                style="display:inline-flex;align-items:center;gap:8px;background:#1E8E7E;color:white;font-weight:700;font-size:14px;padding:12px 22px;border-radius:11px;text-decoration:none">
                Browse &amp; Vote in <span id="vote-cat-name" style="font-weight:800"></span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Non-voting CTA -->
          <div id="browse-cta" style="display:none">
            <a id="link-show-browse" href="#"
              style="display:inline-flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:#1E8E7E;text-decoration:none">
              View full show →
            </a>
          </div>
        </div>
      </div>
    </div>

  </div>

  <style>@keyframes spin{to{transform:rotate(360deg)}}</style>

</BaseLayout>

<script>
  import { supabase } from '../lib/supabase.js';

  const params  = new URLSearchParams(window.location.search);
  const entryId = params.get('id');
  const base    = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');

  function esc(s: any) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  (document.getElementById('link-home') as HTMLAnchorElement).href = base;

  if (!entryId) {
    document.getElementById('state-loading')!.style.display = 'none';
    document.getElementById('state-not-found')!.style.display = 'flex';
  } else {
    supabase
      .from('show_entries')
      .select('id, show_id, category_id, animal_name, breed, photo_url, exhibitor_name, entry_number')
      .eq('id', entryId)
      .eq('status', 'confirmed')
      .single()
      .then(async ({ data: entry, error }) => {
        if (error || !entry) {
          document.getElementById('state-loading')!.style.display = 'none';
          document.getElementById('state-not-found')!.style.display = 'flex';
          return;
        }

        // Load show + category in parallel
        const [showRes, catRes] = await Promise.all([
          supabase.from('shows').select('id, title, is_judged, entry_close_date, results_published_at').eq('id', entry.show_id).single(),
          entry.category_id
            ? supabase.from('show_categories').select('id, name').eq('id', entry.category_id).single()
            : Promise.resolve({ data: null }),
        ]);

        const show = showRes.data;
        const cat  = catRes.data;

        // Is voting open?
        const now = new Date();
        const isVoting = show
          && show.is_judged === false
          && !show.results_published_at
          && show.entry_close_date
          && new Date(show.entry_close_date) <= now;

        // Show page URL
        const showUrl = show ? base + 'show?id=' + encodeURIComponent(show.id) : base;
        const voteUrl = show && cat
          ? base + 'show?id=' + encodeURIComponent(show.id) + '&category=' + encodeURIComponent(cat.id) + '&entry=' + encodeURIComponent(entry.id)
          : showUrl;

        // Populate links
        (document.getElementById('link-show') as HTMLAnchorElement).href = showUrl;
        (document.getElementById('link-show-browse') as HTMLAnchorElement).href = showUrl;
        (document.getElementById('link-vote') as HTMLAnchorElement).href = voteUrl;

        if (show) {
          document.getElementById('show-badge')!.style.display = 'flex';
          document.getElementById('show-title')!.textContent = show.title || 'Untitled Show';
          (document.getElementById('link-show-label') as HTMLElement).textContent = show.title || 'Back to Show';
        }

        // Photo
        const photoWrap = document.getElementById('entry-photo-wrap')!;
        if (entry.photo_url) {
          photoWrap.innerHTML = `<img src="${esc(entry.photo_url)}" alt="${esc(entry.animal_name)}" style="width:100%;height:100%;object-fit:cover">`;
        } else {
          document.getElementById('entry-photo-placeholder')!.textContent = (entry.animal_name || '?')[0].toUpperCase();
        }

        // Details
        if (entry.entry_number) {
          document.getElementById('entry-number')!.textContent = 'Entry #' + entry.entry_number;
        } else {
          (document.getElementById('entry-number') as HTMLElement).style.display = 'none';
        }
        if (cat) {
          document.getElementById('cat-name')!.textContent = cat.name;
          document.getElementById('vote-cat-name')!.textContent = cat.name;
        } else {
          (document.getElementById('cat-name') as HTMLElement).style.display = 'none';
        }

        document.getElementById('entry-name')!.textContent = entry.animal_name || 'Unknown';
        document.getElementById('entry-breed')!.textContent = entry.breed || '';

        const firstName = entry.exhibitor_name?.split(' ')[0];
        if (firstName) {
          document.getElementById('exhibitor-line')!.textContent = 'Entered by ' + firstName;
        }

        // CTA
        if (isVoting) {
          document.getElementById('vote-cta')!.style.display = 'block';
        } else {
          document.getElementById('browse-cta')!.style.display = 'block';
        }

        // Swap loading → content
        document.getElementById('state-loading')!.style.display = 'none';
        document.getElementById('state-entry')!.style.display = 'block';
      });
  }
</script>
