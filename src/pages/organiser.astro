---
import DashboardLayout from '../layouts/DashboardLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<DashboardLayout title="Dashboard" activePage="dashboard">

  <button slot="actions" id="btn-go-shows"
    class="hidden min-[900px]:flex text-[13.5px] font-bold text-[#6f6880] border border-[#b8e4e0] px-4 py-2.5 rounded-btn hover:bg-[#f0fafa] transition-colors">
    All Shows
  </button>

  <!-- Loading -->
  <div id="state-loading" class="flex items-center justify-center h-64">
    <div class="w-8 h-8 border-[3px] border-brand/20 border-t-brand rounded-full animate-spin"></div>
  </div>

  <!-- No shows at all -->
  <div id="state-no-shows" style="display:none" class="flex items-center justify-center min-h-[60vh]">
    <div class="text-center max-w-[380px]">
      <div class="flex justify-center mb-7">
        <img src={`${base}images/ftf_logo_256x212.png`} width="80" style="height:auto;display:block;" alt="" aria-hidden="true" />
      </div>
      <h2 class="text-[28px] font-extrabold text-[#1c1626] tracking-[-0.02em] leading-tight mb-3">Let's get your first show set up!</h2>
      <p class="text-[15px] text-[#6f6880] leading-relaxed mb-8">Once you create and publish a show, your dashboard will come to life — entries, revenue and more will appear here.</p>
      <button id="btn-create-first"
        class="inline-flex items-center gap-2 bg-brand text-white text-[15px] font-bold px-7 py-3.5 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Create a Show
      </button>
    </div>
  </div>

  <!-- Has shows but none published -->
  <div id="state-no-published" style="display:none" class="flex items-center justify-center min-h-[60vh]">
    <div class="text-center max-w-[420px]">
      <div class="w-16 h-16 rounded-full bg-[#f5f3fa] flex items-center justify-center mx-auto mb-5">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#9b94a8" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
      </div>
      <h2 class="text-[20px] font-extrabold text-[#1c1626] tracking-[-0.01em] mb-2">No show published yet</h2>
      <p class="text-[14px] text-[#6f6880] leading-relaxed mb-6">Your live dashboard — entries, revenue, and timeline — will appear here once you publish a show.</p>
      <button id="btn-go-shows-2"
        class="inline-flex items-center gap-1.5 bg-brand text-white text-[14px] font-bold px-6 py-3 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
        Go to Shows
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>
  </div>

  <!-- Dashboard -->
  <div id="state-dashboard" style="display:none">
    <!-- Show banner header -->
    <div id="dash-header"></div>

    <!--
      Left col (2fr): stats (entries+raised | judges) + donut
      Right col (3fr): recent entries | timeline (top row), trend full-width below
    -->
    <div id="dash-main-grid" class="grid gap-4 mt-4">

      <!-- Left column -->
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div id="dash-stats"></div>
        <div id="dash-categories" class="bg-white rounded-card border border-[#b8e4e0] p-5" style="flex:1;"></div>
      </div>

      <!-- Right column -->
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="dash-entries-row" style="display:grid;gap:16px;">
          <div id="dash-entries"  class="bg-white rounded-card border border-[#b8e4e0] p-5"></div>
          <div id="dash-timeline" class="bg-white rounded-card border border-[#b8e4e0] p-5" style="display:flex;flex-direction:column;"></div>
        </div>
        <div id="dash-activity" class="bg-white rounded-card border border-[#b8e4e0] p-5" style="flex:1;"></div>
      </div>

    </div>
  </div>

<style>
  #dash-main-grid {
    grid-template-columns: 1fr;
  }
  #dash-main-grid > div {
    min-width: 0;
  }
  /* Mobile header: banner on top, logo+name below */
  :global(.header-split) {
    display: flex;
    flex-direction: column-reverse;
  }
  :global(.header-left) {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 20px;
    border-top: 1px solid #efebf5;
  }
  :global(.header-banner) {
    height: 110px;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    #dash-main-grid {
      grid-template-columns: 2fr 3fr;
    }
    .dash-entries-row {
      grid-template-columns: 1.2fr 1fr;
    }
    :global(.header-split) {
      flex-direction: row;
      height: 130px;
    }
    :global(.header-left) {
      width: 40%;
      border-top: none;
      border-right: 1px solid #efebf5;
    }
    :global(.header-banner) {
      height: auto;
      flex: 1;
    }
  }

  /* Desktop (default): side-by-side, matching original inline layout */
  :global(.donut-layout) {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  :global(.donut-chart) {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  :global(.donut-legend) {
    flex: 1;
    min-width: 0;
    max-width: 150px;
  }
  /* Mobile: stack legend below donut */
  @media (max-width: 767px) {
    :global(.donut-layout) {
      flex-direction: column;
    }
    :global(.donut-chart) {
      width: 140px;
      flex: none;
    }
    :global(.donut-legend) {
      width: 100%;
      max-width: none;
    }
  }
</style>

</DashboardLayout>

<script>
  import { getAuth } from '../lib/auth.js';
  import { supabase } from '../lib/supabase.js';
  import { zonedDateTime } from '../lib/voteWindow.js';
  import { organiserNet } from '../lib/fees.js';
  import { barLineSvg, donutSvg } from '../lib/charts.js';

  // Module-level state so all helpers can close over these
  let show          = null;
  let entryCount    = 0;
  let totalRaised   = 0;
  let netPerEntry   = 0;   // organiser's take-home per entry (net of platform + Stripe fees)
  let categories    = [];
  let recentEntries = [];
  let trendData     = [];
  let judge         = null;
  let chartMode     = 'bar';    // 'bar' | 'line'
  let chartMetric   = 'entries'; // 'entries' | 'revenue'
  let base          = '';

  const CAT_PALETTE      = ['#1ba89a','#002d6b','#f59e0b','#ef4444','#8b5cf6','#ec4899','#10b981','#f97316'];
  const CURRENCY_SYMBOLS = { GBP:'£', USD:'$', EUR:'€', AUD:'A$', CAD:'C$', NZD:'NZ$', ZAR:'R', SGD:'S$' };

  // ── Helpers ──────────────────────────────────────────────────────────────────

  function derivedStatus() {
    if (!show || show.status !== 'published') return { label: 'Draft', color: '#6f6880', bg: '#f5f3fa' };
    const now       = Date.now();
    const openAt    = zonedDateTime(show.entry_open_date,  show.entry_open_time,  show.timezone);
    const closeAt   = zonedDateTime(show.entry_close_date, show.entry_close_time, show.timezone);
    const showAt    = zonedDateTime(show.show_date,        show.show_time,        show.timezone);
    const openTime  = openAt  ? openAt.getTime()  : null;
    const closeTime = closeAt ? closeAt.getTime() : null;
    const showTime  = showAt  ? showAt.getTime()  : null;
    if (openTime && openTime > now)     return { label: 'Scheduled',        color: '#2563eb', bg: '#eff6ff' };
    if (!closeTime || closeTime >= now) return { label: 'Open for Entries', color: '#16a34a', bg: '#f0fdf4' };
    if (showTime && showTime > now)     return { label: 'Entries Closed',   color: '#d97706', bg: '#fffbeb' };
    if (show.results_published_at)      return { label: 'Results Live',     color: '#16a34a', bg: '#f0fdf4' };
    if (showTime && new Date(showTime).toDateString() === new Date().toDateString()) return { label: 'Show Day', color: '#7c3aed', bg: '#f5f3ff' };
    return                                     { label: 'Ended',            color: '#6b7280', bg: '#f9fafb' };
  }

  function fmtDate(d) {
    return d ? new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : null;
  }

  function fmtShort(d) {
    return d ? new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) : 'TBC';
  }

  function fmtMoney(amount) {
    try {
      return new Intl.NumberFormat('en', { style: 'currency', currency: show?.currency || 'AUD', maximumFractionDigits: 2 }).format(amount);
    } catch { return `$${Number(amount).toFixed(2)}`; }
  }

  function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function sectionLabel(text, mb) {
    return `<p style="font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#9b94a8;margin-bottom:${mb ?? 14}px;">${esc(text)}</p>`;
  }

  // ── Render: Show banner header ────────────────────────────────────────────────

  function renderHeader() {
    const el      = document.getElementById('dash-header');
    const status  = derivedStatus();
    const hasLogo = !!show.logo_url;
    const bannerStyle = show.banner_url
      ? `background:url('${show.banner_url}') center/cover no-repeat`
      : 'background:linear-gradient(135deg,#1ba89a 0%,#002d6b 100%)';

    const logoHtml = hasLogo
      ? `<img src="${esc(show.logo_url)}" style="width:72px;height:72px;border-radius:14px;object-fit:contain;background:#f5f3fa;border:1.5px solid #efebf5;flex-shrink:0;" alt="" />`
      : `<div style="width:72px;height:72px;border-radius:14px;background:#efebf5;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
           <img src="${base}images/ftf_logo_256x212.png" width="40" style="height:auto;display:block;opacity:0.55;" alt="" aria-hidden="true" />
         </div>`;

    el.innerHTML = `
      <div class="bg-white rounded-card border border-[#b8e4e0] overflow-hidden">
        <div class="header-split">

          <!-- Left: logo + show name -->
          <div class="header-left" style="min-width:0;">
            ${logoHtml}
            <div style="min-width:0;">
              <p style="font-size:16px;font-weight:800;color:#1c1626;line-height:1.25;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">${esc(show.title || 'Untitled Show')}</p>
              ${show.host_org ? `<p style="font-size:12px;color:#6f6880;margin-top:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${esc(show.host_org)}</p>` : ''}
            </div>
          </div>

          <!-- Right: banner + status badge -->
          <div class="header-banner" style="${bannerStyle};position:relative;">
            <span style="position:absolute;bottom:12px;right:14px;padding:4px 10px;border-radius:99px;font-size:11px;font-weight:700;background:${status.bg};color:${status.color};">${esc(status.label)}</span>
          </div>

        </div>

        <!-- Date row: full width -->
        <div style="padding:11px 20px 13px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;border-top:1px solid #f5f3fa;">
          ${show.show_date        ? `<span style="font-size:13px;color:#6f6880;display:inline-flex;align-items:center;gap:5px;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>Show Day: ${fmtDate(show.show_date)}</span>` : ''}
          ${show.entry_open_date  ? `<span style="font-size:13px;color:#6f6880;">Entries open: ${fmtDate(show.entry_open_date)}</span>` : ''}
          ${show.entry_close_date ? `<span style="font-size:13px;color:#6f6880;">Close: ${fmtDate(show.entry_close_date)}</span>` : ''}
          ${show.status === 'published'
            ? `<a href="${window.location.origin}${base}show?id=${esc(show.id)}" target="_blank" style="margin-left:auto;font-size:12.5px;font-weight:600;color:#1ba89a;text-decoration:none;">View Show ↗</a>
               <button onclick="window.location.href='${base}organiser/show/?id=${esc(show.id)}'" style="font-size:12.5px;font-weight:600;color:#1ba89a;background:none;border:none;cursor:pointer;padding:0;font-family:inherit;">Settings →</button>`
            : `<button onclick="window.location.href='${base}organiser/show/?id=${esc(show.id)}'" style="margin-left:auto;font-size:12.5px;font-weight:600;color:#1ba89a;background:none;border:none;cursor:pointer;padding:0;font-family:inherit;">Settings →</button>`
          }
        </div>
      </div>`;
  }

  // ── Render: Top stat cards ────────────────────────────────────────────────────

  function renderStats() {
    const el = document.getElementById('dash-stats');

    function card(title, value, style = '') {
      return `<div class="bg-white rounded-card border border-[#b8e4e0] px-4 py-3" style="${style}">
        ${sectionLabel(title, 4)}
        <p style="font-size:20px;font-weight:800;color:#1c1626;line-height:1.2;">${esc(value)}</p>
      </div>`;
    }

    let judgeCard;
    if (judge) {
      const name = `${judge.first_name}${judge.last_name ? ' ' + judge.last_name : ''}`;
      const avatar = judge.photo_url
        ? `<img src="${esc(judge.photo_url)}" style="width:40px;height:40px;border-radius:50%;object-fit:cover;flex-shrink:0;" />`
        : `<div style="width:40px;height:40px;border-radius:50%;background:#e8f5f4;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:800;color:#1ba89a;flex-shrink:0;">${esc(judge.first_name[0].toUpperCase())}</div>`;
      judgeCard = `<div class="bg-white rounded-card border border-[#b8e4e0] px-4 py-3" style="display:flex;align-items:center;gap:12px;">
        <div style="flex:1;min-width:0;">${sectionLabel('Judge', 4)}<p style="font-size:17px;font-weight:800;color:#1c1626;line-height:1.2;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(name)}</p></div>
        ${avatar}
      </div>`;
    } else {
      judgeCard = `<div class="bg-white rounded-card border border-[#b8e4e0] px-4 py-3">
        ${sectionLabel('Judge', 4)}
        <p style="font-size:20px;font-weight:800;color:#1c1626;line-height:1.2;">—</p>
      </div>`;
    }
    el.innerHTML = `
      <div style="display:flex;gap:12px;margin-bottom:12px;">
        ${card('Total Entries', String(entryCount), 'flex:1;min-width:0;')}
        ${card('Total Raised',  fmtMoney(totalRaised), 'flex:1;min-width:0;')}
      </div>
      ${judgeCard}`;
  }

  // ── Render: Recent Entries (left column, full height) ─────────────────────────

  function renderRecentEntries() {
    const el = document.getElementById('dash-entries');
    const catMap = Object.fromEntries(categories.map(c => [c.id, c.name]));

    const header = `
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
        ${sectionLabel('Recent Entries', 0)}
        <span style="font-size:12px;color:#9b94a8;flex-shrink:0;margin-left:12px;">${entryCount > 3 ? `showing 3 of ${entryCount}` : ''}</span>
      </div>`;

    if (!recentEntries.length) {
      el.innerHTML = header + `
        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:48px 0;gap:10px;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.3" stroke-linecap="round" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          <p style="font-size:14px;font-weight:600;color:#4a4357;margin:0;">No entries yet</p>
          <p style="font-size:13px;color:#9b94a8;text-align:center;max-width:200px;margin:0;line-height:1.5;">Entries will appear here as participants sign up.</p>
        </div>`;
      return;
    }

    const rows = recentEntries.map(e => {
      const initials = (e.animal_name || '?')[0].toUpperCase();
      const thumb = e.photo_url
        ? `<img src="${esc(e.photo_url)}" style="width:44px;height:44px;border-radius:10px;object-fit:cover;flex-shrink:0;" alt="" />`
        : `<div style="width:44px;height:44px;border-radius:10px;background:linear-gradient(135deg,#1ba89a,#002d6b);display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:800;color:#fff;flex-shrink:0;">${initials}</div>`;
      const catName  = e.category_id ? (catMap[e.category_id] || 'Unknown category') : 'No category';
      const subLine  = [e.exhibitor_name, e.breed].filter(Boolean).join(' · ');
      const timeAgo  = fmtAgo(e.created_at);
      return `
        <div style="display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid #f5f3fa;">
          ${thumb}
          <div style="flex:1;min-width:0;">
            <div style="font-size:14px;font-weight:700;color:#1c1626;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(e.animal_name || '—')}</div>
            <div style="font-size:12px;color:#9b94a8;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(subLine || catName)}</div>
          </div>
          <div style="text-align:right;flex-shrink:0;">
            <div style="font-size:12px;font-weight:600;color:#4a4357;white-space:nowrap;">${esc(catName)}</div>
            <div style="font-size:11px;color:#c4bed0;margin-top:2px;">${timeAgo}</div>
          </div>
        </div>`;
    }).join('');

    el.innerHTML = header + `<div>${rows}</div>`;
  }

  function fmtAgo(iso) {
    if (!iso) return '';
    const diff = Date.now() - new Date(iso).getTime();
    const m = Math.floor(diff / 60000);
    if (m < 1)  return 'just now';
    if (m < 60) return `${m}m ago`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ago`;
    const d = Math.floor(h / 24);
    return `${d}d ago`;
  }

  // ── Render: Entries by Category (donut left, list right) ─────────────────────

  function renderEntriesByCategory() {
    const el = document.getElementById('dash-categories');

    const isEmpty = entryCount === 0;
    const hasCategories = categories.length > 0;

    // Build donut segments
    const segments = (isEmpty || !hasCategories) ? [] : categories.map((cat, i) => ({
      label: cat.name,
      value: cat.count || 0,
      color: CAT_PALETTE[i % CAT_PALETTE.length],
    }));
    if (!isEmpty && hasCategories) {
      const categorised = categories.reduce((s, c) => s + (c.count || 0), 0);
      const uncategorised = entryCount - categorised;
      if (uncategorised > 0) segments.push({ label: 'Uncategorised', value: uncategorised, color: '#efebf5' });
    }

    const donutMarkup = donutSvg(segments, {
      size: 120,
      strokeWidth: 14,
      radius: 46,
      centerTop: isEmpty ? '' : String(entryCount),
      centerBottom: isEmpty ? '' : 'entries',
    });
    // "No entries" needs two stacked lines that donutSvg's single-line
    // centerBottom can't express — swap in the two-line version for that case.
    const donutInner = isEmpty
      ? donutMarkup.replace(
          /<\/svg>$/,
          `<text x="60" y="54" text-anchor="middle" font-size="11" fill="#9b94a8">No</text><text x="60" y="69" text-anchor="middle" font-size="11" fill="#9b94a8">entries</text></svg>`,
        )
      : donutMarkup;

    const legendRows = hasCategories
      ? categories.map((cat, i) => {
          const color = CAT_PALETTE[i % CAT_PALETTE.length];
          const count = cat.count || 0;
          return `<div style="display:flex;align-items:center;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f5f3fa;gap:6px;">
            <div style="display:flex;align-items:center;gap:6px;min-width:0;">
              <div style="width:7px;height:7px;border-radius:50%;background:${color};flex-shrink:0;"></div>
              <span style="font-size:11px;color:#4a4357;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${esc(cat.name)}</span>
            </div>
            <span style="font-size:11px;font-weight:600;color:#1c1626;flex-shrink:0;">${count}</span>
          </div>`;
        }).join('')
      : `<p style="font-size:11.5px;color:#9b94a8;padding-top:6px;">No categories set up yet</p>`;

    el.innerHTML = `
      ${sectionLabel('Entries by Category', 14)}
      <div class="donut-layout">
        <div class="donut-chart">
          ${donutInner}
        </div>
        <div class="donut-legend">${legendRows}</div>
      </div>`;

    // Wire up floating tooltip for donut segments
    let tip = document.getElementById('donut-tip');
    if (!tip) {
      tip = document.createElement('div');
      tip.id = 'donut-tip';
      tip.style.cssText = 'position:fixed;background:#1c1626;color:#fff;font-size:12px;font-weight:600;padding:5px 11px;border-radius:8px;pointer-events:none;white-space:nowrap;display:none;z-index:200;box-shadow:0 2px 8px rgba(0,0,0,0.18);';
      document.body.appendChild(tip);
    }
    el.querySelectorAll('circle[data-label]').forEach(circle => {
      circle.addEventListener('mouseenter', () => {
        tip.textContent = circle.dataset.label;
        tip.style.display = 'block';
      });
      circle.addEventListener('mousemove', e => {
        tip.style.left = (e.clientX + 14) + 'px';
        tip.style.top  = (e.clientY - 32) + 'px';
      });
      circle.addEventListener('mouseleave', () => { tip.style.display = 'none'; });
    });
  }

  // ── Render: Timeline (portrait vertical list, proportional spacing) ─────────────

  function renderTimeline() {
    const el        = document.getElementById('dash-timeline');
    const openDate  = zonedDateTime(show.entry_open_date,  show.entry_open_time,  show.timezone);
    const closeDate = zonedDateTime(show.entry_close_date, show.entry_close_time, show.timezone);
    const showDate  = zonedDateTime(show.show_date,        show.show_time,        show.timezone);
    const today     = new Date();

    // Build steps with timestamps for proportion calculation
    const steps = [
      { label: 'Entries Open',  date: fmtShort(openDate  ?? null), past: openDate  && today >= openDate,  ms: openDate?.getTime()  ?? null },
      { label: 'Entries Close', date: fmtShort(closeDate ?? null), past: closeDate && today > closeDate,  ms: closeDate?.getTime() ?? null },
      { label: 'Show Day',      date: fmtShort(showDate  ?? null), past: showDate  && today > showDate,   ms: showDate?.getTime()  ?? null },
    ];

    // Total span across all known dates — used to size connectors proportionally
    const knownMs  = steps.map(s => s.ms).filter(Boolean);
    const spanMs   = knownMs.length >= 2 ? knownMs[knownMs.length - 1] - knownMs[0] : 0;

    // Build alternating step-rows and connector-rows so connectors can flex-grow
    const rows = [];
    steps.forEach((s, i) => {
      const isLast  = i === steps.length - 1;
      const next    = steps[i + 1];

      let flexVal = 1;
      if (!isLast && spanMs > 0 && s.ms && next.ms) {
        flexVal = Math.max(0.15, (next.ms - s.ms) / spanMs * (steps.length - 1));
      }

      const dotBg    = s.past ? '#1ba89a' : 'white';
      const dotBdr   = s.past ? '#1ba89a' : '#b8e4e0';
      const lblColor = s.past ? '#1ba89a' : '#4a4357';
      const lineColor = (s.past && next?.past) ? '#1ba89a' : '#efebf5';

      // Step row: fixed size, contains dot + label
      rows.push(`
        <div style="display:flex;gap:10px;flex-shrink:0;align-items:flex-start;">
          <div style="width:14px;display:flex;justify-content:center;flex-shrink:0;padding-top:2px;">
            <div style="width:12px;height:12px;border-radius:50%;background:${dotBg};border:2px solid ${dotBdr};flex-shrink:0;"></div>
          </div>
          <div>
            <p style="font-size:11px;font-weight:700;color:${lblColor};line-height:1.2;margin:0;">${esc(s.label)}</p>
            <p style="font-size:10.5px;color:#9b94a8;margin:3px 0 0;">${esc(s.date)}</p>
          </div>
        </div>`);

      // Connector row: grows proportionally, contains only the vertical line
      if (!isLast) {
        rows.push(`
          <div style="display:flex;gap:10px;flex:${flexVal};min-height:16px;">
            <div style="width:14px;display:flex;flex-direction:column;align-items:center;flex-shrink:0;">
              <div style="width:2px;flex:1;background:${lineColor};border-radius:1px;"></div>
            </div>
            <div></div>
          </div>`);
      }
    });

    el.innerHTML = `
      ${sectionLabel('Timeline', 16)}
      <div style="display:flex;flex-direction:column;flex:1;min-height:0;">${rows.join('')}</div>`;
  }

  // ── Render: Recent Activity ───────────────────────────────────────────────────

  function buildTrendDays() {
    const days = [];
    for (let i = 4; i >= 0; i--) {
      const d = new Date();
      d.setDate(d.getDate() - i);
      const key        = d.toISOString().slice(0, 10);
      const shortLabel = i === 0 ? 'Today' : d.toLocaleDateString('en-GB', { weekday: 'short' });
      const fullLabel  = i === 0 ? 'Today' : i === 1 ? 'Yesterday'
                       : d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
      days.push({ key, shortLabel, fullLabel, count: 0 });
    }
    for (const e of trendData) {
      const key = e.created_at.slice(0, 10);
      const day = days.find(d => d.key === key);
      if (day) day.count++;
    }
    return days;
  }

  function trendDayValue(day) {
    return chartMetric === 'entries' ? day.count : day.count * netPerEntry;
  }

  function trendFmtVal(val) {
    if (chartMetric === 'entries') return String(val);
    const sym = CURRENCY_SYMBOLS[show.currency] || '$';
    return `${sym}${Number.isInteger(val) ? val : val.toFixed(2)}`;
  }

  function buildTrendSvg(days) {
    // highlightIndex is pinned at 6 to preserve this page's existing visual
    // behavior exactly (the 5-day trend array has no index 6, so "today" was
    // never actually highlighted here before this extraction — not fixing
    // that as part of a pure refactor).
    return barLineSvg(
      days.map(d => ({ label: d.shortLabel, value: trendDayValue(d) })),
      { mode: chartMode, formatValue: trendFmtVal, highlightIndex: 6 },
    );
  }

  function renderRecentActivity() {
    const el   = document.getElementById('dash-activity');
    const days = buildTrendDays();
    const sym  = CURRENCY_SYMBOLS[show.currency] || '$';

    const totalEntries = days.reduce((s, d) => s + d.count, 0);
    const totalRev     = totalEntries * netPerEntry;
    const summaryText  = chartMetric === 'entries'
      ? `${totalEntries} entr${totalEntries === 1 ? 'y' : 'ies'} in last 5 days`
      : `${sym}${Number.isInteger(totalRev) ? totalRev : totalRev.toFixed(2)} raised in last 5 days`;

    // Legend (newest first)
    const legendRows = [...days].reverse().map((day, i) => {
      const val     = trendDayValue(day);
      const isToday = i === 0;
      return `<div style="display:flex;align-items:center;justify-content:space-between;padding:1px 0;">
        <div style="display:flex;align-items:center;gap:4px;">
          <div style="width:5px;height:5px;border-radius:50%;background:${val > 0 ? '#1ba89a' : '#efebf5'};flex-shrink:0;"></div>
          <span style="font-size:10px;color:${isToday ? '#1ba89a' : '#6f6880'};font-weight:${isToday ? '700' : '400'};">${day.fullLabel}</span>
        </div>
        <span style="font-size:10px;font-weight:700;color:${val > 0 ? '#1c1626' : '#c4bed0'};">${trendFmtVal(val)}</span>
      </div>`;
    }).join('');

    // Toggle button helpers
    const hasRevenue = (show.entry_fee || 0) > 0;
    const mBtn = (metric, label) => {
      const active   = chartMetric === metric;
      const disabled = metric === 'revenue' && !hasRevenue;
      return `<button id="metric-${metric}" ${disabled ? 'disabled' : ''} style="flex:1;padding:3px 4px;font-size:10.5px;font-weight:600;border:none;cursor:${disabled ? 'not-allowed' : 'pointer'};font-family:inherit;background:${active ? '#1ba89a' : 'transparent'};color:${active ? '#fff' : disabled ? '#d0ccd8' : '#9b94a8'};border-radius:5px;line-height:1.4;text-align:center;opacity:${disabled ? '0.5' : '1'};">${label}</button>`;
    };
    const cBtn = (mode, label) => {
      const active = chartMode === mode;
      return `<button id="chart-${mode}" style="flex:1;padding:3px 4px;font-size:10.5px;font-weight:600;border:none;cursor:pointer;font-family:inherit;background:${active ? '#002d6b' : 'transparent'};color:${active ? '#fff' : '#9b94a8'};border-radius:5px;line-height:1.4;text-align:center;">${label}</button>`;
    };

    el.innerHTML = `
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
        ${sectionLabel('Entry Trend', 0)}
        <span style="font-size:11px;color:#9b94a8;">${summaryText}</span>
      </div>
      <div style="display:flex;gap:16px;align-items:flex-start;">
        <div style="flex:1;min-width:0;">
          ${buildTrendSvg(days)}
        </div>
        <div style="width:116px;flex-shrink:0;display:flex;flex-direction:column;gap:7px;">
          <div style="display:flex;flex-direction:column;gap:3px;">
            <div style="display:flex;background:#f5f3fa;border-radius:7px;padding:2px;">
              ${mBtn('entries', 'Entries')}
              ${mBtn('revenue', 'Revenue')}
            </div>
            <div style="display:flex;background:#f5f3fa;border-radius:7px;padding:2px;">
              ${cBtn('bar', 'Bar')}
              ${cBtn('line', 'Line')}
            </div>
          </div>
          <div style="border-top:1px solid #f5f3fa;padding-top:6px;">
            ${legendRows}
          </div>
        </div>
      </div>`;

    // Wire toggles (re-render on click — instant, no network)
    ['entries', 'revenue'].forEach(metric => {
      document.getElementById(`metric-${metric}`)?.addEventListener('click', () => {
        if (chartMetric === metric) return;
        chartMetric = metric;
        renderRecentActivity();
      });
    });
    ['bar', 'line'].forEach(mode => {
      document.getElementById(`chart-${mode}`)?.addEventListener('click', () => {
        if (chartMode === mode) return;
        chartMode = mode;
        renderRecentActivity();
      });
    });
  }

  // ── Init ─────────────────────────────────────────────────────────────────────

  const auth = await getAuth();
  base = auth.base;

  if (!auth.session) {
    window.location.replace(base + 'login');
  } else {
    const { session, profile } = auth;
    const name = profile?.display_name || session.user.email?.split('@')[0] || 'Organiser';

    const avatarEl = document.getElementById('sidebar-avatar');
    const nameEl   = document.getElementById('sidebar-username');
    const badgeEl  = document.getElementById('sidebar-role-badge');
    if (avatarEl) {
      if (profile?.avatar_url) {
        avatarEl.innerHTML = `<img src="${profile.avatar_url}" alt="" style="width:100%;height:100%;object-fit:cover;">`;
      } else {
        avatarEl.textContent = name.charAt(0).toUpperCase();
      }
    }
    if (nameEl)   nameEl.textContent   = name;
    if (badgeEl)  badgeEl.textContent  = profile?.organiser_type === 'club' ? 'Club Organiser' : 'Organiser';
    document.getElementById('sidebar-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = base + 'login';
    });

    document.getElementById('btn-go-shows').onclick     = () => { window.location.href = base + 'organiser/shows'; };
    document.getElementById('btn-go-shows-2').onclick   = () => { window.location.href = base + 'organiser/shows'; };
    document.getElementById('btn-create-first').onclick = () => { window.location.href = base + 'organiser/new-show'; };

    const uid      = session.user.id;
    const params   = new URLSearchParams(window.location.search);
    const override = params.get('show');

    if (override) {
      const { data } = await supabase.from('shows').select('*').eq('id', override).eq('created_by', uid).single();
      show = data;
    } else {
      const { data: showRows } = await supabase.from('shows').select('*').eq('created_by', uid).eq('status', 'published').is('archived_at', null).order('created_at', { ascending: false }).limit(1);
      show = showRows?.[0] ?? null;
    }

    document.getElementById('state-loading').style.display = 'none';

    if (!show) {
      const { count } = await supabase.from('shows').select('*', { count: 'exact', head: true }).eq('created_by', uid);
      document.getElementById(count === 0 ? 'state-no-shows' : 'state-no-published').style.display = 'flex';
    } else {
      const sevenDaysAgo = new Date(Date.now() - 5 * 86400000).toISOString();
      const [countRes, catsRes, catCountRes, recentRes, trendRes, judgeRes, feesRes] = await Promise.all([
        supabase.from('show_entries').select('*', { count: 'exact', head: true }).eq('show_id', show.id).eq('status', 'confirmed'),
        supabase.from('show_categories').select('id, name').eq('show_id', show.id),
        supabase.from('show_entries').select('category_id').eq('show_id', show.id).eq('status', 'confirmed'),
        supabase.from('show_entries').select('id, animal_name, exhibitor_name, breed, photo_url, category_id, created_at').eq('show_id', show.id).eq('status', 'confirmed').order('created_at', { ascending: false }).limit(3),
        supabase.from('show_entries').select('created_at').eq('show_id', show.id).eq('status', 'confirmed').gte('created_at', sevenDaysAgo),
        supabase.from('show_judges').select('first_name, last_name, photo_url').eq('show_id', show.id).limit(1).maybeSingle(),
        supabase.from('platform_settings').select('key, value').or('key.like.service_fee_%,key.like.stripe_fee_%'),
      ]);
      entryCount  = countRes.count ?? 0;
      // "Raised" figures show the organiser's take-home (net of platform + Stripe
      // fees), never the all-in amount exhibitors paid.
      const serviceFees = {};
      for (const r of (feesRes.data || [])) serviceFees[r.key] = parseFloat(r.value) || 0;
      netPerEntry = organiserNet(show.entry_fee || 0, show.currency || 'AUD', serviceFees) ?? 0;
      totalRaised = entryCount * netPerEntry;
      categories  = catsRes.data || [];
      judge       = judgeRes.data || null;

      // Build per-category count map
      const catCounts = {};
      for (const row of (catCountRes.data || [])) {
        const k = row.category_id || '__none__';
        catCounts[k] = (catCounts[k] || 0) + 1;
      }
      // Attach counts to categories array
      categories    = categories.map(c => ({ ...c, count: catCounts[c.id] || 0 }));
      recentEntries = recentRes.data  || [];
      trendData     = trendRes.data   || [];

      document.getElementById('state-dashboard').style.display = 'block';
      renderHeader();
      renderStats();
      renderRecentEntries();
      renderEntriesByCategory();
      renderTimeline();
      renderRecentActivity();
    }
  }
</script>
