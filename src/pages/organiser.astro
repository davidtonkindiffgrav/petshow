---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Dashboard" activePage="dashboard">

  <button slot="actions" id="new-show-btn" style="display:none" class="inline-flex items-center gap-2 bg-brand text-white text-[13.5px] font-bold px-4 py-2.5 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    New Show
  </button>

  <!-- Loading -->
  <div id="state-loading" class="flex items-center justify-center h-64">
    <div class="w-8 h-8 border-[3px] border-brand/20 border-t-brand rounded-full animate-spin"></div>
  </div>

  <!-- Empty state -->
  <div id="state-empty" style="display:none" class="flex items-center justify-center min-h-[70vh]">
    <div class="text-center max-w-[420px]">
      <div class="w-24 h-24 rounded-full bg-brand-tint flex items-center justify-center mx-auto mb-7">
        <svg width="52" height="52" viewBox="0 0 48 48" fill="none" aria-hidden="true">
          <ellipse cx="24" cy="31" rx="11" ry="9" fill="#1ba89a"/>
          <ellipse cx="11" cy="23" rx="5.5" ry="6" fill="#1ba89a"/>
          <ellipse cx="37" cy="23" rx="5.5" ry="6" fill="#1ba89a"/>
          <ellipse cx="17" cy="14" rx="5" ry="5.5" fill="#20b7ac"/>
          <ellipse cx="31" cy="14" rx="5" ry="5.5" fill="#20b7ac"/>
        </svg>
      </div>
      <h2 class="text-[28px] font-extrabold text-[#1c1626] tracking-[-0.02em] leading-tight mb-3">
        Let's get your first show set up!
      </h2>
      <p class="text-[15px] text-[#6f6880] leading-relaxed mb-8">
        Once you create a show, your dashboard will come to life — entries, judges, results and more will all appear here.
      </p>
      <button id="create-show-btn" class="inline-flex items-center gap-2 bg-brand text-white text-[15px] font-bold px-7 py-3.5 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Create a Show
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Populated state -->
  <div id="state-populated" style="display:none">
    <p class="text-[14px] text-[#6f6880]">
      You have <span id="shows-count"></span> show<span id="shows-plural"></span>.
      <a id="view-shows-link" href="#" class="text-brand font-semibold hover:underline ml-1">View all shows →</a>
    </p>
  </div>

</DashboardLayout>

<script>
  import { getAuth } from '../lib/auth.js';
  import { supabase } from '../lib/supabase.js';

  const { session, profile, base } = await getAuth();

  if (!session) {
    window.location.replace(base + 'login');
  } else {
    // Fill in sidebar user info
    const name = profile?.display_name || session.user.email?.split('@')[0] || 'Organiser';
    const avatarEl   = document.getElementById('sidebar-avatar');
    const nameEl     = document.getElementById('sidebar-username');
    const badgeEl    = document.getElementById('sidebar-role-badge');
    if (avatarEl)  avatarEl.textContent  = name.charAt(0).toUpperCase();
    if (nameEl)    nameEl.textContent    = name;
    if (badgeEl)   badgeEl.textContent   = profile?.organiser_type === 'club' ? 'Club Organiser' : 'Organiser';

    document.getElementById('sidebar-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = base + 'login';
    });

    // Query shows count — fall back to empty state if table doesn't exist yet
    const { count, error } = await supabase
      .from('shows')
      .select('*', { count: 'exact', head: true })
      .eq('created_by', session.user.id);

    const loadingEl    = document.getElementById('state-loading');
    const emptyEl      = document.getElementById('state-empty');
    const populatedEl  = document.getElementById('state-populated');
    const newShowBtn   = document.getElementById('new-show-btn');
    if (loadingEl) loadingEl.style.display = 'none';

    if (error || !count) {
      if (emptyEl) emptyEl.style.display = 'flex';
      document.getElementById('create-show-btn')?.addEventListener('click', () => {
        window.location.href = base + 'organiser/new-show';
      });
    } else {
      if (populatedEl) {
        document.getElementById('shows-count').textContent = String(count);
        document.getElementById('shows-plural').textContent = count === 1 ? '' : 's';
        document.getElementById('view-shows-link').href = base + 'organiser/shows';
        populatedEl.style.display = 'block';
      }
      if (newShowBtn) {
        newShowBtn.style.display = 'inline-flex';
        newShowBtn.addEventListener('click', () => {
          window.location.href = base + 'organiser/new-show';
        });
      }
    }
  }
</script>
