  // ── Init ─────────────────────────────────────────────────────────────────────
  (async () => {
    const auth = await getAuth();
    mgmtBase = auth.base;
    if (!auth.session) { window.location.replace(mgmtBase + 'login'); return; }

    const name = auth.profile?.display_name || auth.session.user.email?.split('@')[0] || 'Organiser';
    const avatarEl = document.getElementById('sidebar-avatar');
    const nameEl   = document.getElementById('sidebar-username');
    const badgeEl  = document.getElementById('sidebar-role-badge');
    if (avatarEl) {
      if (auth.profile?.avatar_url) {
        avatarEl.innerHTML = `<img src="${auth.profile.avatar_url}" alt="" style="width:100%;height:100%;object-fit:cover;">`;
      } else {
        avatarEl.textContent = name.charAt(0).toUpperCase();
      }
    }
    if (nameEl)   nameEl.textContent   = name;
    if (badgeEl)  badgeEl.textContent  = auth.profile?.organiser_type === 'club' ? 'Club Organiser' : 'Organiser';
    document.getElementById('sidebar-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = mgmtBase + 'login';
    });

    showId = new URLSearchParams(window.location.search).get('id');
    if (!showId) { window.location.replace(mgmtBase + 'organiser/shows'); return; }

    uid = auth.session.user.id;
    const [showRes, catsRes, judgesRes, sponsorsRes, awardsRes, feeRes, sjRes, payoutRes] = await Promise.all([
      supabase.from('shows').select('*').eq('id', showId).eq('created_by', uid).single(),
      supabase.from('show_categories').select('*').eq('show_id', showId),
      supabase.from('show_judges').select('*').eq('show_id', showId),
      supabase.from('show_sponsors').select('*').eq('show_id', showId),
      supabase.from('awards').select('*').eq('show_id', showId),
      supabase.from('platform_settings').select('key, value').or('key.like.service_fee_%,key.like.min_entry_fee_%,key.like.stripe_fee_%,key.eq.max_upload_mb'),
      supabase.from('saved_judges').select('*').eq('organiser_id', uid).order('first_name'),
      supabase.from('show_payout_details').select('*').eq('show_id', showId).maybeSingle(),
    ]);

    if (!showRes.data) { window.location.replace(mgmtBase + 'organiser/shows'); return; }

    show        = showRes.data;
    if (show.fundraising_goal) {
      (feeRes.data || []).forEach(r => { serviceFees[r.key] = parseFloat(r.value) || 0; });
      const { count } = await supabase.from('show_entries')
        .select('id', { count: 'exact', head: true }).eq('show_id', showId).eq('status', 'confirmed');
      const confirmedCount = count || 0;
      if (show.fundraising_goal_type === 'entries') {
        goalTotal = confirmedCount;
      } else {
        const netPerEntry = organiserNet(show.entry_fee || 0, show.currency || 'AUD', serviceFees) ?? 0;
        goalTotal = confirmedCount * netPerEntry;
      }
    }
    if (show.is_judged === true) {
      const { count } = await supabase.from('judge_rankings')
        .select('show_id', { count: 'exact', head: true }).eq('show_id', showId);
      judgingOrVotingStarted = (count || 0) > 0;
    } else if (show.is_judged === false) {
      const { count } = await supabase.from('public_votes')
        .select('show_id', { count: 'exact', head: true }).eq('show_id', showId);
      judgingOrVotingStarted = (count || 0) > 0;
    }
    categories  = catsRes.data     || [];
    judges      = judgesRes.data   || [];
    sponsors    = sponsorsRes.data || [];
    awards      = awardsRes.data   || [];
    savedJudges = sjRes.data       || [];
    payoutDetails = payoutRes.data || null;
    loadedCategoryIds = new Set(categories.map(c => c.id));
    loadedAwardIds    = new Set(awards.map(a => a.id));
    (feeRes.data || []).forEach(r => {
      if (r.key === 'max_upload_mb') maxUploadMb = parseFloat(r.value) || 5;
      else serviceFees[r.key] = parseFloat(r.value) || 0;
    });
    document.querySelectorAll('.upload-size-hint').forEach(el => {
      el.textContent = el.textContent.replace(/\d+ MB/, `${maxUploadMb} MB`);
    });
    document.getElementById('page-loading').style.display = 'none';
    document.getElementById('page-content').style.display = 'block';

    renderPageHeader();
    renderAllHeaders();
    initMgmtTimezoneSelect();
    populateAllForms();
    wireAllHandlers();
  })();

  // ── Drawer open / close ───────────────────────────────────────────────────────
  function openDrawer(id) {
    document.querySelectorAll('#edit-drawer [id^="panel-"]').forEach(p => { p.style.display = 'none'; });
    const panel = document.getElementById(`panel-${id}`);
    if (panel) panel.style.display = 'block';
    document.getElementById('drawer-title').textContent = SECTION_TITLES[id] || id;

    const drawer   = document.getElementById('edit-drawer');
    const backdrop = document.getElementById('drawer-backdrop');
    drawer.style.transform   = 'translateX(0)';
    backdrop.style.opacity   = '1';
    backdrop.style.pointerEvents = 'auto';

    // Scroll drawer body to top
    drawer.querySelector('.flex-1.overflow-y-auto').scrollTop = 0;

    // Re-init panels that need fresh state each open
    if (id === 'classes')  initClassesPanel();
    if (id === 'awards')   initAwardsPanel();
    if (id === 'judging' && show.is_judged === true) {
      rebuildJudgePanels();
      renderMgmtJudgeDisplay();
    }
    if (id === 'branding') {
      initBrandingWidget('branding-logo-widget',   'logo');
      initBrandingWidget('branding-org-widget',    'orgLogo');
      initBrandingWidget('branding-banner-widget', 'banner');
      selectCard(document.getElementById('branding-logo-source-cards'), show.logo_source || 'show');
    }
    if (id === 'sponsorship') initBrandingWidget('mgmt-sponsor-logo-widget', 'sponsorLogo');

    // Highlight the active card
    document.querySelectorAll('.section-card').forEach(c => c.classList.remove('ring-2', 'ring-brand'));
    document.getElementById(`card-${id}`)?.classList.add('ring-2', 'ring-brand');
  }

  function closeDrawer() {
    const drawer   = document.getElementById('edit-drawer');
    const backdrop = document.getElementById('drawer-backdrop');
    drawer.style.transform   = 'translateX(100%)';
    backdrop.style.opacity   = '0';
    backdrop.style.pointerEvents = 'none';
    document.querySelectorAll('.section-card').forEach(c => c.classList.remove('ring-2', 'ring-brand'));
  }

  // ── Page header ──────────────────────────────────────────────────────────────
  function renderPageHeader() {
    document.getElementById('show-title-display').textContent = show.title || 'Untitled Show';
    document.title = `${show.title || 'Show'} — Fur to Feathers`;

    const st    = showStatus();
    const badge = document.getElementById('show-status-badge');
    badge.textContent     = st.label;
    badge.style.background = st.bg;
    badge.style.color      = st.color;

    const sym     = CURRENCY_SYMBOLS[show.currency] || 'A$';
    const feeText = show.entry_fee > 0 ? ` · ${sym}${Number(show.entry_fee).toFixed(2)} entry fee` : ' · Fee not set';
    const dateText = show.show_date
      ? new Date(show.show_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
      : 'Date not set';
    document.getElementById('show-meta').textContent = `${dateText} · ${categories.length} categor${categories.length !== 1 ? 'ies' : 'y'}${feeText}`;

    const publishBtn = document.getElementById('btn-publish');
    if (show.status === 'published') {
      publishBtn.textContent = 'Unpublish';
      publishBtn.classList.replace('bg-brand', 'bg-[#f0fafa]');
      publishBtn.classList.replace('text-white', 'text-[#6f6880]');
      publishBtn.classList.remove('shadow-btn-primary');
    } else {
      publishBtn.textContent = 'Publish';
      publishBtn.classList.replace('bg-[#f0fafa]', 'bg-brand');
      publishBtn.classList.replace('text-[#6f6880]', 'text-white');
      publishBtn.classList.add('shadow-btn-primary');
    }
    document.getElementById('btn-back').onclick = () => {
      window.location.href = mgmtBase + 'organiser/shows';
    };
    publishBtn.onclick = handlePublish;

    const actionLinks = document.getElementById('show-action-links');
    // One status-dependent button: drafts get a preview (with the unpublished
    // warning banner); anything else links to the real public page
    const isDraft = show.status === 'draft';
    const viewUrl = isDraft
      ? `${mgmtBase}show?id=${showId}&preview=1`
      : `${window.location.origin}${mgmtBase}show?id=${showId}`;
    let linksHtml = `<a href="${viewUrl}" target="_blank" class="text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors" style="text-decoration:none">${isDraft ? 'Preview Show →' : 'View Show ↗'}</a>`;
    if (show.status === 'published') {
      linksHtml += `<button id="btn-copy-url" class="text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors">Copy URL</button>`;
    }
    actionLinks.innerHTML = linksHtml;
    if (show.status === 'published') {
      document.getElementById('btn-copy-url').onclick = () => {
        const url = `${window.location.origin}${mgmtBase}show?id=${showId}`;
        navigator.clipboard.writeText(url);
        const btn = document.getElementById('btn-copy-url');
        btn.textContent = 'Copied! ✓';
        setTimeout(() => { btn.textContent = 'Copy URL'; }, 1800);
      };
    }

    // Archive button — always render, enabled/disabled based on conditions
    const archiveBtn = document.getElementById('btn-archive');
    if (archiveBtn) {
      if (!show.archived_at) {
        archiveBtn.style.display = '';
        const reason = archiveBlockedReason();
        if (reason) {
          archiveBtn.disabled = true;
          archiveBtn.title    = reason;
          archiveBtn.className = 'text-[13px] font-semibold px-3 py-2 rounded-btn border border-[#e8e4ef] text-[#c4bed0] cursor-not-allowed transition-colors';
        } else {
          archiveBtn.disabled = false;
          archiveBtn.title    = '';
          archiveBtn.className = 'text-[13px] font-semibold px-3 py-2 rounded-btn border border-red-200 text-red-400 hover:bg-red-50 transition-colors';
          archiveBtn.onclick = openArchiveModal;
        }
      } else {
        archiveBtn.style.display = 'none';
      }
    }
  }

  function showStatus() {
    if (show.archived_at) return { label: 'Archived', color: '#92400e', bg: '#fef3c7' };
    if (show.status === 'draft') return { label: 'Draft', color: '#6f6880', bg: '#f5f3fa' };
    const now = new Date();
    const openAt = zonedDateTime(show.entry_open_date, show.entry_open_time, show.timezone);
    if (openAt && openAt.getTime() > now.getTime()) return { label: 'Scheduled', color: '#2563eb', bg: '#eff6ff' };
    const close = getEntriesCloseInfo(show, goalTotal, now);
    if (close.isOpen) return { label: 'Open for Entries', color: '#16a34a', bg: '#f0fdf4' };
    return { label: 'Closed', color: '#6b7280', bg: '#f9fafb' };
  }

  // ── Archive ───────────────────────────────────────────────────────────────────

  function archiveBlockedReason() {
    if (show.status !== 'published')       return 'The show must be published before archiving.';
    if (!show.results_published_at)        return 'Results must be published before archiving.';
    if (!show.show_date || new Date(show.show_date) > new Date()) return 'The show date must have passed before archiving.';
    return null;
  }

  async function openArchiveModal() {
    const summaryEl = document.getElementById('archive-photo-summary');
    summaryEl.innerHTML = '<span class="text-[#9b94a8]">Counting photos…</span>';
    document.getElementById('archive-modal').style.display = 'flex';

    const { data: allEntries } = await supabase
      .from('show_entries')
      .select('id, photo_url, result_place')
      .eq('show_id', showId)
      .eq('status', 'confirmed');

    const entries = allEntries || [];
    const toDelete  = entries.filter(e => !e.result_place && e.photo_url);
    const toKeep    = entries.filter(e =>  e.result_place && e.photo_url);

    summaryEl.innerHTML = `
      <div class="bg-amber-50 border border-amber-200 rounded-[10px] p-4 space-y-2">
        <p class="font-bold text-[#92400e] flex items-center gap-2">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          This action cannot be undone
        </p>
        <p class="text-[#92400e]"><strong>${toDelete.length}</strong> non-placing photo${toDelete.length !== 1 ? 's' : ''} will be permanently deleted.</p>
        <p class="text-[#92400e]"><strong>${toKeep.length}</strong> winner / runner-up photo${toKeep.length !== 1 ? 's' : ''} will be kept.</p>
      </div>`;

    document.getElementById('archive-confirm').onclick = () => archiveShow(entries);
  }

  async function archiveShow(entries) {
    const confirmBtn = document.getElementById('archive-confirm');
    const cancelBtn  = document.getElementById('archive-cancel');
    confirmBtn.textContent = 'Archiving…';
    confirmBtn.disabled = true;
    cancelBtn.disabled  = true;

    try {
      // Delete non-placing photos from storage
      const toDelete = entries.filter(e => !e.result_place && e.photo_url);
      if (toDelete.length) {
        const paths = toDelete
          .map(e => { const m = e.photo_url.match(/\/show-assets\/(.+)/); return m ? m[1] : null; })
          .filter(Boolean);
        if (paths.length) await supabase.storage.from('show-assets').remove(paths);
        // Null out photo_url on non-placing entries
        const ids = toDelete.map(e => e.id);
        await supabase.from('show_entries').update({ photo_url: null }).in('id', ids);
      }

      // Mark show as archived
      const { error } = await supabase
        .from('shows')
        .update({ archived_at: new Date().toISOString() })
        .eq('id', showId);
      if (error) throw error;

      window.location.href = mgmtBase + 'organiser/shows';
    } catch (err) {
      confirmBtn.textContent = 'Archive Show';
      confirmBtn.disabled = false;
      cancelBtn.disabled  = false;
      showPageError('Archive failed: ' + err.message);
      document.getElementById('archive-modal').style.display = 'none';
    }
  }

  async function handlePublish() {
    const btn = document.getElementById('btn-publish');
    if (show.status !== 'published') {
      const { data: existing } = await supabase
        .from('shows').select('id, title').eq('created_by', uid).eq('status', 'published').neq('id', showId).maybeSingle();
      if (existing) {
        showPageError(`"${existing.title || 'Another show'}" is already published. Unpublish it before publishing this show.`);
        return;
      }
      openPublishShowModal();
      return;
    }
    if (!confirm('Unpublish this show? It will be hidden from the public entry page.')) return;
    btn.textContent = 'Saving…';
    btn.disabled = true;
    const { error } = await supabase.from('shows').update({ status: 'draft' }).eq('id', showId);
    btn.disabled = false;
    if (error) { showPageError(error.message); return; }
    show.status = 'draft';
    renderPageHeader();
  }

  async function doPublishShow() {
    const cta = document.getElementById('publish-show-cta');
    const errEl = document.getElementById('publish-show-modal-error');
    errEl.style.display = 'none';
    cta.textContent = 'Publishing…';
    cta.disabled = true;
    const { error } = await supabase.from('shows').update({ status: 'published' }).eq('id', showId);
    if (error) {
      errEl.textContent = error.message;
      errEl.style.display = 'block';
      cta.textContent = 'Publish Show';
      cta.disabled = false;
      return;
    }
    show.status = 'published';
    closePublishShowModal();
    renderPageHeader();
  }

  // ── Publish Show readiness checklist ────────────────────────────────────────
  // Mirrors the amber/"Setup needed" vs grey/"Not used" conditions computed in
  // renderAllHeaders() below — keep the two in sync if a section's rules change.
  function getPublishReadiness() {
    const required = [];
    const optional = [];

    if (!(show.title && show.show_date)) {
      required.push({ label: 'Show Basics', detail: 'Show name and show date must be set.', panelId: 'basics' });
    }
    const needsCharityNum = show.org_type === 'registered_charity' || show.org_type === 'non_profit';
    if (needsCharityNum && !show.charity_number) {
      required.push({ label: 'Charity / Non-Profit Number', detail: 'Required for registered charities and non-profits.', panelId: 'basics' });
    }
    if (!show.breed_scope) {
      required.push({ label: 'Breed & Eligibility', detail: 'Choose which breeds or animals are eligible to enter.', panelId: 'breed' });
    }
    if (categories.length === 0) {
      required.push({ label: 'Categories', detail: 'Add at least one category for entrants to enter.', panelId: 'classes' });
    }
    if (show.has_sponsor !== true && show.has_sponsor !== false) {
      required.push({ label: 'Sponsorship', detail: 'Choose whether this show has a sponsor.', panelId: 'sponsorship' });
    }
    if (show.is_judged !== true && show.is_judged !== false) {
      required.push({ label: 'Judging', detail: 'Choose expert judging or public voting.', panelId: 'judging' });
    }
    if (!(show.entry_fee > 0)) {
      required.push({ label: 'Fundraising & Fees', detail: 'Set an entry fee before publishing.', panelId: 'fundraising' });
    }

    const uploadedCount = [show.logo_url, show.org_logo_url, show.banner_url].filter(Boolean).length;
    if (uploadedCount < 3) {
      optional.push({
        label: 'Branding',
        confirmLabel: 'Publish without setting up Branding',
        detail: uploadedCount === 0 ? 'No logos or banner uploaded yet.' : `${3 - uploadedCount} of 3 images still missing.`,
        panelId: 'branding',
      });
    }
    if (show.is_judged === true && !judges[0]) {
      optional.push({
        label: 'Judge Assignment',
        confirmLabel: "I'll assign a judge later",
        detail: 'No judge has been assigned to this show yet.',
        panelId: 'judging',
      });
    }
    // Certificates/physical prizes are per-category and optional now (no
    // forced whole-show yes/no decision, unlike Sponsorship/Judging) —
    // flagged as a soft nudge only.
    if (categories.filter(c => c.has_certificate || c.award_id).length === 0) {
      optional.push({
        label: 'Awards & Prizes',
        confirmLabel: 'Publish without setting up Awards & Prizes',
        detail: 'No categories have a certificate or physical prize set up yet.',
        panelId: 'awards',
      });
    }

    return { required, optional };
  }

  function requiredIssueRow({ label, detail, panelId }) {
    return `
      <div class="flex items-start gap-3 p-3 rounded-[10px] border border-[#fde68a] bg-[#fffbeb]">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true">
          <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <span class="min-w-0">
          <span class="block text-[13px] font-semibold text-[#92400e]">${esc(label)}</span>
          <span class="block text-[12px] mt-0.5 text-[#92400e]">${esc(detail)}</span>
          <button type="button" class="fix-link inline-block text-[12px] font-semibold text-brand hover:text-brand-dark mt-1" data-panel="${esc(panelId)}">Set up now →</button>
        </span>
      </div>`;
  }

  function optionalCheckRow({ label, confirmLabel, detail, panelId }) {
    return `
      <div class="p-3 rounded-[10px] border border-[#efebf5] hover:border-brand/40 transition-colors">
        <span class="block text-[10.5px] font-bold text-[#9b94a8] uppercase tracking-wide mb-1">${esc(label)}</span>
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" class="publish-show-optional-check mt-0.5 w-4 h-4 accent-brand shrink-0" />
          <span class="min-w-0 text-[13px] font-semibold text-[#1c1626]">${esc(confirmLabel)}</span>
        </label>
        <span class="block text-[12px] mt-1 pl-7" style="color:#b45309">⚠ ${esc(detail)}</span>
        <button type="button" class="fix-link inline-block text-[12px] font-semibold text-brand hover:text-brand-dark mt-1 pl-7" data-panel="${esc(panelId)}">Set up now →</button>
      </div>`;
  }

  function publishShowIcon(ready) {
    return ready
      ? `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`
      : `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`;
  }

  function openPublishShowModal() {
    const { required, optional } = getPublishReadiness();

    const iconEl      = document.getElementById('publish-show-icon');
    const titleEl      = document.getElementById('publish-show-title');
    const subtitleEl   = document.getElementById('publish-show-subtitle');
    const infoBoxEl    = document.getElementById('publish-show-info-box');
    const reqWrapEl    = document.getElementById('publish-show-required-wrap');
    const optWrapEl    = document.getElementById('publish-show-optional-wrap');
    const ackWrapEl    = document.getElementById('publish-show-ack-wrap');
    const footerEl     = document.getElementById('publish-show-footer');

    document.getElementById('publish-show-modal-error').style.display = 'none';
    iconEl.className = `w-11 h-11 rounded-full flex items-center justify-center shrink-0 ${required.length ? 'bg-[#fffbeb]' : 'bg-brand-tint'}`;
    iconEl.innerHTML = publishShowIcon(required.length === 0);

    if (required.length > 0) {
      titleEl.textContent = "This Show Isn't Ready to Publish Yet";
      subtitleEl.textContent = show.title || 'Untitled Show';
      infoBoxEl.style.display = 'none';
      reqWrapEl.style.display = 'block';
      document.getElementById('publish-show-required-list').innerHTML = required.map(requiredIssueRow).join('');
      optWrapEl.style.display = 'none';
      ackWrapEl.style.display = 'none';
      footerEl.innerHTML = `<button id="publish-show-close" class="flex-1 text-[14px] font-semibold text-[#4a4357] border border-[#e0dce8] rounded-[10px] py-2.5 hover:bg-[#f7f5fb] transition-colors">Close</button>`;
      document.getElementById('publish-show-close').addEventListener('click', closePublishShowModal);
    } else {
      reqWrapEl.style.display = 'none';
      footerEl.innerHTML = `
        <button id="publish-show-cancel" class="flex-1 text-[14px] font-semibold text-[#4a4357] border border-[#e0dce8] rounded-[10px] py-2.5 hover:bg-[#f7f5fb] transition-colors">Cancel</button>
        <button id="publish-show-cta" disabled class="flex-1 text-[14px] font-bold rounded-[10px] py-2.5 transition-colors bg-[#f5f3fa] text-[#c4bed0] cursor-not-allowed">Publish Show</button>`;
      document.getElementById('publish-show-cancel').addEventListener('click', closePublishShowModal);
      document.getElementById('publish-show-cta').addEventListener('click', doPublishShow);

      if (optional.length > 0) {
        titleEl.textContent = 'Almost Ready to Publish';
        subtitleEl.textContent = 'Everything required is set up. Confirm you’re happy to leave these for later.';
        infoBoxEl.style.display = 'none';
        optWrapEl.style.display = 'block';
        document.getElementById('publish-show-optional-list').innerHTML = optional.map(optionalCheckRow).join('');
        ackWrapEl.style.display = 'none';
      } else {
        titleEl.textContent = 'Publish This Show?';
        subtitleEl.textContent = 'You’re about to make this show public and visible to the world.';
        infoBoxEl.style.display = 'block';
        optWrapEl.style.display = 'none';
        ackWrapEl.style.display = 'block';
        document.getElementById('publish-show-ack-list').innerHTML =
          `<label class="flex items-start gap-3 p-3 rounded-[10px] border border-[#efebf5] cursor-pointer hover:border-brand/40 transition-colors">
            <input type="checkbox" class="publish-show-ack-check mt-0.5 w-4 h-4 accent-brand shrink-0" />
            <span class="block text-[13px] font-semibold text-[#1c1626]">I've checked all my settings and I'm ready to make this show public</span>
          </label>`;
      }
      updatePublishShowCta();
    }

    document.getElementById('publish-show-modal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closePublishShowModal() {
    document.getElementById('publish-show-modal').style.display = 'none';
    document.body.style.overflow = '';
  }

  function updatePublishShowCta() {
    const cta = document.getElementById('publish-show-cta');
    if (!cta) return;
    const optChecks = document.querySelectorAll('.publish-show-optional-check');
    const ackCheck  = document.querySelector('.publish-show-ack-check');
    const allChecked = [...optChecks].every(c => c.checked) && (!ackCheck || ackCheck.checked);
    cta.disabled = !allChecked;
    cta.className = `flex-1 text-[14px] font-bold rounded-[10px] py-2.5 transition-colors ${
      allChecked ? 'bg-brand text-white shadow-btn-primary hover:bg-brand-dark' : 'bg-[#f5f3fa] text-[#c4bed0] cursor-not-allowed'
    }`;
  }

  function wirePublishShowModal() {
    const modal = document.getElementById('publish-show-modal');
    modal.addEventListener('click', e => {
      if (e.target === e.currentTarget) { closePublishShowModal(); return; }
      const fixBtn = e.target.closest('.fix-link');
      if (fixBtn) {
        closePublishShowModal();
        openDrawer(fixBtn.dataset.panel);
      }
    });
    modal.addEventListener('change', e => {
      if (e.target.matches('.publish-show-optional-check, .publish-show-ack-check')) updatePublishShowCta();
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && modal.style.display === 'flex') closePublishShowModal();
    });
  }

  // ── Card header rendering ────────────────────────────────────────────────────
  const DOT_TEXT_COLORS = { '#22c55e': '#16a34a', '#fbbf24': '#d97706', '#c4bed0': '#9b94a8' };

  // setHeader(id, dot, statusText, title, rows, actionLabel)
  // rows = array of [label, value] pairs shown below the title
  function setHeader(id, dot, statusText, title, rows, actionLabel) {
    const el = document.getElementById(`hdr-${id}`);
    if (!el) return;
    const textColor = DOT_TEXT_COLORS[dot] || '#9b94a8';
    const rowsHtml = rows.length
      ? `<div class="space-y-2 border-t border-[#f5f3fa] mt-3 pt-3">${
          rows.map(([lbl, val]) =>
            `<div class="flex items-start gap-2">
              <span class="text-[10.5px] font-bold text-[#c4bed0] uppercase tracking-wide w-[84px] shrink-0 leading-[1.7]">${lbl}</span>
              <span class="text-[12.5px] text-[#4a4357] font-medium leading-snug">${val}</span>
            </div>`
          ).join('')
        }</div>`
      : '';
    el.innerHTML = `
      <div class="flex items-start justify-between gap-2">
        <div>
          <div class="flex items-center gap-1.5 mb-1.5">
            <span class="w-2 h-2 rounded-full shrink-0" style="background:${dot}"></span>
            <span class="text-[10.5px] font-bold uppercase tracking-wide" style="color:${textColor}">${statusText}</span>
          </div>
          <p class="text-[15px] font-extrabold text-[#1c1626] leading-tight">${title}</p>
        </div>
        <button class="action-btn text-[13px] font-bold text-brand hover:underline shrink-0 mt-1" data-panel="${id}">${actionLabel}</button>
      </div>
      ${rowsHtml}`;
  }

  function renderAllHeaders() {
    function fmtDate(d) {
      return d ? new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '—';
    }
    function tzAbbr(ianaZone) {
      if (!ianaZone) return '';
      try {
        const parts = Intl.DateTimeFormat('en', { timeZone: ianaZone, timeZoneName: 'short' }).formatToParts(new Date());
        return parts.find(p => p.type === 'timeZoneName')?.value || '';
      } catch { return ''; }
    }
    function fmtDateTime(d, t) {
      if (!d) return '—';
      const date = new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
      if (!t) return date;
      const abbr = tzAbbr(show.timezone);
      return `${date} at ${t}${abbr ? ' (' + abbr + ')' : ''}`;
    }

    const closesText = show.close_entries_on_goal
      ? (show.entry_close_date
          ? `${fmtDateTime(show.entry_close_date, show.entry_close_time)} or on goal, whichever's first`
          : `On reaching goal (${show.fundraising_goal_type === 'entries' ? 'entry count' : 'amount raised'})`)
      : (show.entry_close_date ? fmtDateTime(show.entry_close_date, show.entry_close_time) : 'Manual close only');

    const basicsConfigured = !!(show.title && show.show_date);
    setHeader('basics', basicsConfigured ? '#22c55e' : '#fbbf24', basicsConfigured ? 'Configured' : 'Setup needed', 'Show Basics', [
      ['Name',      show.title || '—'],
      ['Show day / results', fmtDateTime(show.show_date, show.show_time)],
      ...(show.entry_open_date ? [['Opens', fmtDateTime(show.entry_open_date, show.entry_open_time)]] : []),
      ['Closes',    closesText],
      ['Org type',  ORG_TYPE_LABELS[show.org_type] || '—'],
    ], 'Edit');

    setHeader('showtype', '#22c55e', 'Configured', 'Animal Type', [
      ['Animal', show.animal_type ? show.animal_type.charAt(0).toUpperCase() + show.animal_type.slice(1) : 'Dog'],
    ], 'Edit');

    if (show.breed_scope) {
      const filter = show.breed_scope === 'breed_specific' ? show.breed_filter
                   : show.breed_scope === 'group_specific'  ? show.group_filter : null;
      setHeader('breed', '#22c55e', 'Configured', 'Breed & Eligibility', [
        ['Scope',  BREED_SCOPE_LABELS[show.breed_scope]],
        ...(filter ? [['Filter', filter]] : []),
      ], 'Edit');
    } else {
      setHeader('breed', '#fbbf24', 'Setup needed', 'Breed & Eligibility', [
        ['Scope', '—'],
      ], 'Set Up');
    }

    if (categories.length > 0) {
      const preview = categories.slice(0, 3).map(c => c.name).join(', ')
        + (categories.length > 3 ? ` +${categories.length - 3} more` : '');
      setHeader('classes', '#22c55e', 'Configured', 'Categories', [
        ['Count',      `${categories.length} categor${categories.length !== 1 ? 'ies' : 'y'}`],
        ['Categories', preview],
      ], 'Edit');
    } else {
      setHeader('classes', '#fbbf24', 'Setup needed', 'Categories', [
        ['Count', 'None added yet'],
      ], 'Set Up');
    }

    if (show.has_sponsor === true) {
      const rows = [['Status', 'Sponsor added']];
      if (sponsors[0]?.name)    rows.push(['Name',    sponsors[0].name]);
      if (sponsors[0]?.website) rows.push(['Website', sponsors[0].website]);
      if (sponsors[0]?.logo_url) rows.push(['Logo',
        `<img src="${sponsors[0].logo_url}" style="height:26px;max-width:90px;object-fit:contain;border-radius:5px;background:#f0fafa;border:1px solid #efebf5;display:inline-block;vertical-align:middle" alt="Sponsor logo" />`]);
      setHeader('sponsorship', '#22c55e', 'Configured', 'Sponsorship', rows, 'Edit');
    } else if (show.has_sponsor === false) {
      setHeader('sponsorship', '#c4bed0', 'Not used', 'Sponsorship', [
        ['Status', 'No sponsor for this show'],
      ], 'Enable');
    } else {
      setHeader('sponsorship', '#fbbf24', 'Setup needed', 'Sponsorship', [
        ['Status', '—'],
      ], 'Set Up');
    }

    if (show.is_judged === true) {
      const rows = [['Method', 'Expert judges']];
      if (judges[0]?.first_name) {
        rows.push(['Judge', `${judges[0].first_name} ${judges[0].last_name || ''}`.trim()]);
      } else {
        rows.push(['Judge', 'Not yet assigned']);
      }
      setHeader('judging', '#22c55e', 'Configured', 'Judging', rows, 'Edit');
    } else if (show.is_judged === false) {
      setHeader('judging', '#c4bed0', 'Public voting', 'Judging', [
        ['Method', 'Public voting'],
        ['Votes open', show.vote_open_mode === 'on_entries_open' ? 'When entries open' : 'When entries close'],
      ], 'Edit');
    } else {
      setHeader('judging', '#fbbf24', 'Setup needed', 'Judging', [
        ['Method', '—'],
      ], 'Set Up');
    }

    // Certificates and physical prizes are independent per-category facts
    // now, each optional (no whole-show yes/no to key off) — so this
    // simplifies to two states covering either one.
    const certCount     = categories.filter(c => c.has_certificate).length;
    const physicalCount = categories.filter(c => c.award_id).length;
    if (certCount > 0 || physicalCount > 0) {
      setHeader('awards', '#22c55e', 'Configured', 'Awards & Prizes', [
        ['Certificates', `${certCount} of ${categories.length} categories`],
        ['Physical prizes', `${physicalCount} of ${categories.length} categories`],
      ], 'Edit');
    } else {
      setHeader('awards', '#fbbf24', 'Setup needed', 'Awards & Prizes', [
        ['Status', '—'],
      ], 'Set Up');
    }

    const sym = CURRENCY_SYMBOLS[show.currency] || 'A$';
    const net = organiserNet(Number(show.entry_fee) || 0, show.currency || 'AUD', serviceFees);
    const feeText = show.entry_fee > 0
      ? `${sym}${Number(show.entry_fee).toFixed(2)} all-in${net != null ? ` (you receive ≈ ${sym}${net.toFixed(2)})` : ''}`
      : 'Not set';
    if (show.entry_fee > 0) {
      setHeader('fundraising', '#22c55e', 'Configured', 'Fundraising & Fees', [
        ['Entry fee', feeText],
        ['Goal',      show.fundraising_goal ? `${sym}${Number(show.fundraising_goal).toFixed(2)}` : 'Not set'],
        ['Currency',  show.currency || 'AUD'],
      ], 'Edit');
    } else {
      setHeader('fundraising', '#fbbf24', 'Setup needed', 'Fundraising & Fees', [
        ['Entry fee', '—'],
      ], 'Set Up');
    }

    if (payoutDetails) {
      const verified = !!payoutDetails.verified_at;
      setHeader('payout', verified ? '#22c55e' : '#fbbf24', verified ? 'Verified' : 'Saved — pending review', 'Payout Details', [
        ['Bank',    payoutDetails.bank_name || '—'],
        ['Account', payoutDetails.account_number ? `••••${String(payoutDetails.account_number).slice(-4)}` : '—'],
      ], 'Edit');
    } else {
      setHeader('payout', '#fbbf24', 'Setup needed', 'Payout Details', [
        ['Status', 'Not entered yet'],
      ], 'Set Up');
    }

    renderBrandingHeader();
  }

  function renderBrandingHeader() {
    const hdr = document.getElementById('hdr-branding');
    if (!hdr) return;

    // Remove default padding — we control layout ourselves
    hdr.className = 'card-header';

    const uploadedCount = [show.logo_url, show.org_logo_url, show.banner_url].filter(Boolean).length;
    const statusText = uploadedCount === 3 ? 'Uploaded' : uploadedCount > 0 ? 'Partial' : 'Not uploaded';
    const dot        = uploadedCount === 3 ? '#22c55e'  : uploadedCount > 0 ? '#fbbf24' : '#c4bed0';
    const textColor  = uploadedCount === 3 ? '#16a34a'  : uploadedCount > 0 ? '#d97706' : '#9b94a8';

    const bannerMiddle = show.banner_url
      ? `<img src="${show.banner_url}" style="width:100%;height:100%;object-fit:cover;object-position:right center;display:block;border-radius:8px;" alt="" />`
      : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#f5f3fa;border-radius:8px;">
           <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
         </div>`;

    function thumbRow(label, url) {
      const thumb = url
        ? `<img src="${url}" style="width:26px;height:26px;object-fit:contain;border-radius:5px;background:#f0fafa;flex-shrink:0;border:1px solid #efebf5;" alt="" />`
        : '';
      return `<div style="display:flex;align-items:center;gap:8px;">
        <span style="font-size:10.5px;font-weight:700;color:#c4bed0;text-transform:uppercase;letter-spacing:0.05em;width:84px;flex-shrink:0;">${label}</span>
        <span style="display:flex;align-items:center;gap:6px;">
          ${thumb}
          <span style="font-size:12.5px;color:#4a4357;font-weight:500;">${url ? 'Uploaded' : 'Not set'}</span>
        </span>
      </div>`;
    }

    hdr.innerHTML = `
      <div style="display:flex;align-items:stretch;height:78px;overflow:hidden;">
        <div style="padding:16px 14px;flex-shrink:0;">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:5px;">
            <span style="width:8px;height:8px;border-radius:50%;background:${dot};flex-shrink:0;display:inline-block;"></span>
            <span style="font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:${textColor};">${statusText}</span>
          </div>
          <p style="font-size:15px;font-weight:800;color:#1c1626;line-height:1.2;margin:0;">Branding</p>
        </div>
        <div style="flex:1;padding:8px 6px;overflow:hidden;">
          ${bannerMiddle}
        </div>
        <div style="padding:16px 14px;flex-shrink:0;display:flex;align-items:flex-start;">
          <button class="action-btn text-[13px] font-bold text-brand hover:underline" data-panel="branding" style="background:none;border:none;cursor:pointer;padding:0;font-family:inherit;">Edit</button>
        </div>
      </div>
      <div style="padding:0 16px 16px;display:flex;flex-direction:column;gap:8px;border-top:1px solid #f5f3fa;margin-top:0;padding-top:12px;">
        ${thumbRow('Show Logo', show.logo_url)}
        ${thumbRow('Org Logo',  show.org_logo_url)}
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:10.5px;font-weight:700;color:#c4bed0;text-transform:uppercase;letter-spacing:0.05em;width:84px;flex-shrink:0;">Banner</span>
          <span style="font-size:12.5px;color:#4a4357;font-weight:500;">${show.banner_url ? 'Uploaded' : 'Not set'}</span>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:10.5px;font-weight:700;color:#c4bed0;text-transform:uppercase;letter-spacing:0.05em;width:84px;flex-shrink:0;">Website</span>
          ${show.website_url
            ? `<a href="${/^https?:\/\//i.test(show.website_url) ? show.website_url : 'https://' + show.website_url}" target="_blank" rel="noopener noreferrer" style="font-size:12.5px;color:#1ba89a;font-weight:500;text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:220px;">${show.website_url}</a>`
            : `<span style="font-size:12.5px;color:#4a4357;font-weight:500;">Not set</span>`}
        </div>
      </div>`;
  }

  // ── Timezone select ──────────────────────────────────────────────────────────
  function initMgmtTimezoneSelect() {
    const sel = document.getElementById('mgmt-timezone');
    if (!sel) return;
    sel.innerHTML = TIMEZONES.map(g =>
      `<optgroup label="${g.group}">${g.zones.map(z =>
        `<option value="${z.id}">${z.label}</option>`
      ).join('')}</optgroup>`
    ).join('');
    const preferred = show.timezone || Intl.DateTimeFormat().resolvedOptions().timeZone;
    sel.value = preferred;
    if (!sel.value) sel.value = 'Australia/Sydney';
  }

  // ── Populate forms ───────────────────────────────────────────────────────────
  function toDateVal(v) { return v ? String(v).slice(0, 10) : ''; }

  function setField(id, val) {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
    if (el) el.value = String(val ?? '');
  }

  function populateAllForms() {
    setField('mgmt-title',            show.title || '');
    setField('mgmt-entry-open',       toDateVal(show.entry_open_date));
    setField('mgmt-entry-open-time',  show.entry_open_time  || '12:00');
    setField('mgmt-entry-close',      toDateVal(show.entry_close_date));
    setField('mgmt-entry-close-time', show.entry_close_time || '12:00');
    {
      const hasCloseDate = !!show.entry_close_date;
      const toggle = document.getElementById('mgmt-entry-close-toggle');
      toggle.dataset.on = String(hasCloseDate);
      toggle.style.background = hasCloseDate ? '#1ba89a' : '#c4bed0';
      toggle.querySelector('span').style.transform = hasCloseDate ? 'translateX(16px)' : 'translateX(0)';
    }
    updateCloseStatusUI();
    setField('mgmt-show-date',        toDateVal(show.show_date));
    setField('mgmt-show-time',        show.show_time || '');
    const tzSel = document.getElementById('mgmt-timezone');
    if (tzSel && show.timezone) (tzSel as HTMLSelectElement).value = show.timezone;
    setField('mgmt-host-org',         show.host_org || '');
    setField('mgmt-description',      show.description || '');
    setField('mgmt-about',            show.about || '');
    setField('mgmt-contact-email',    show.contact_email || '');
    setField('mgmt-contact-phone',    show.contact_phone || '');
    setField('mgmt-charity-number',   show.charity_number || '');
    setField('branding-website-url',  show.website_url || '');
    if (show.org_type) {
      selectCard(document.getElementById('mgmt-org-type-cards'), show.org_type);
      const charityField = document.getElementById('mgmt-charity-field');
      if (charityField) charityField.style.display = (show.org_type === 'registered_charity' || show.org_type === 'non_profit') ? 'block' : 'none';
    }

    selectCard(document.getElementById('mgmt-animal-type-cards'), show.animal_type || 'dog');

    if (show.breed_scope) selectCard(document.getElementById('mgmt-breed-scope-cards'), show.breed_scope);
    setField('mgmt-breed', show.breed_filter || '');
    setField('mgmt-group', show.group_filter || '');
    updateBreedFields();

    if (show.has_sponsor === true) {
      setYN('mgmt-sponsor-yn', 'yes');
      const sponsorForm = document.getElementById('mgmt-sponsor-form');
      if (sponsorForm) sponsorForm.style.display = 'block';
      setField('mgmt-sponsor-name',    sponsors[0]?.name || '');
      setField('mgmt-sponsor-website', sponsors[0]?.website || '');
    } else if (show.has_sponsor === false) {
      setYN('mgmt-sponsor-yn', 'no');
    }

    if (show.is_judged === true) {
      setYN('mgmt-judging-yn', 'yes');
      const judgeForm = document.getElementById('mgmt-judge-form');
      if (judgeForm) judgeForm.style.display = 'block';
      rebuildJudgePanels();
      renderMgmtJudgeDisplay();
    } else if (show.is_judged === false) {
      setYN('mgmt-judging-yn', 'no');
      document.getElementById('mgmt-vote-timing').style.display = 'block';
      selectCard(document.getElementById('mgmt-vote-timing-cards'), show.vote_open_mode || 'after_entries_close');
    }

    // Award row rendering itself happens in initAwardsPanel(), fired when the
    // drawer opens (mirrors Classes' initClassesPanel() pattern) — this just
    // restores the Yes/No + form-visible state.
    const anyAwards = awards.length > 0 || show.has_digital_certs === true || show.has_physical_prizes === true;
    if (anyAwards) {
      setYN('mgmt-awards-yn', 'yes');
      const awardsForm = document.getElementById('mgmt-awards-form');
      if (awardsForm) awardsForm.style.display = 'block';
    }

    setField('mgmt-currency', show.currency || 'AUD');
    if (show.fundraising_goal) setField('mgmt-fund-goal', show.fundraising_goal);
    setField('mgmt-goal-type', show.fundraising_goal_type || 'amount');
    setToggle('mgmt-public-toggle', show.show_fundraising_publicly === true);
    setToggle('mgmt-close-on-goal-toggle', show.close_entries_on_goal === true);
    setFeeValue(Number(show.entry_fee) || getMin(show.currency || 'AUD') || 3);
    applyCurrencySymbol(show.currency || 'AUD');
    updateGoalTypeUI();
    updatePublicToggleAvailability();

    setField('payout-holder-name',       payoutDetails?.account_holder_name || '');
    setField('payout-address-line1',     payoutDetails?.beneficiary_address_line1 || '');
    setField('payout-city',              payoutDetails?.beneficiary_city || '');
    setField('payout-region',            payoutDetails?.beneficiary_region || '');
    setField('payout-postcode',          payoutDetails?.beneficiary_postcode || '');
    setField('payout-beneficiary-country', payoutDetails?.beneficiary_country || '');
    setField('payout-bank-name',         payoutDetails?.bank_name || '');
    setField('payout-bank-address',      payoutDetails?.bank_address || '');
    setField('payout-account-currency',  payoutDetails?.account_currency || show.currency || 'AUD');
    setField('payout-account-number',    payoutDetails?.account_number || '');
    setField('payout-swift-bic',         payoutDetails?.swift_bic || '');
    setField('payout-iban',              payoutDetails?.iban || '');
    setField('payout-local-code',        payoutDetails?.local_bank_code || '');
    setField('payout-notes',             payoutDetails?.notes || '');
    setField('payout-bank-country',      payoutDetails?.bank_country || '');
    updatePayoutBankCountryFields(payoutDetails?.bank_country || '');
    const verifiedBanner = document.getElementById('payout-verified-banner');
    if (verifiedBanner) verifiedBanner.style.display = payoutDetails?.verified_at ? 'block' : 'none';
  }

  // Relabels/toggles the IBAN and local-bank-code fields based on the selected
  // bank country — mirrors the s1-charity-field conditional-visibility pattern.
  function updatePayoutBankCountryFields(country) {
    const ibanRequired = document.getElementById('payout-iban-required');
    const ibanOptional = document.getElementById('payout-iban-optional');
    const needsIban = IBAN_COUNTRIES.includes(country);
    if (ibanRequired) ibanRequired.style.display = needsIban ? 'inline' : 'none';
    if (ibanOptional) ibanOptional.style.display = needsIban ? 'none' : 'inline';

    const localField = document.getElementById('payout-local-code-field');
    const localLabelEl = document.getElementById('payout-local-code-label');
    const isKnownCountry = LOCAL_CODE_LABELS.hasOwnProperty(country);
    const knownLabel = LOCAL_CODE_LABELS[country];
    if (isKnownCountry && !knownLabel) {
      // Known country whose account number already encodes the bank/branch (e.g. NZ) or that uses IBAN instead
      if (localField) localField.style.display = 'none';
    } else if (isKnownCountry) {
      if (localField) localField.style.display = 'block';
      if (localLabelEl) localLabelEl.innerHTML = `${knownLabel} <span class="text-red-400">*</span>`;
    } else {
      // Unselected or "Other" — show the generic field but don't require it
      if (localField) localField.style.display = 'block';
      if (localLabelEl) localLabelEl.innerHTML = `Local Bank/Routing Code <span class="text-[#9b94a8] font-normal">(optional)</span>`;
    }
  }

  // Fundraising progress can only be shown publicly once a goal is set — otherwise
  // the public page renders a permanently-0% bar with no goal to reach. Same
  // condition gates auto-close-on-goal, since there's nothing to trigger it on.
  // Once judging/voting has started, the whole goal setup is locked — changing
  // it after scores/votes exist could contradict already-published results.
  function updatePublicToggleAvailability() {
    const goalVal = parseFloat((document.getElementById('mgmt-fund-goal') as HTMLInputElement).value) || 0;
    const enabled = goalVal > 0 && !judgingOrVotingStarted;
    const toggle = document.getElementById('mgmt-public-toggle') as HTMLButtonElement;
    const hint = document.getElementById('mgmt-public-toggle-hint');
    toggle.disabled = !enabled;
    hint.textContent = judgingOrVotingStarted
      ? 'Judging/voting has started, so this can no longer be changed.'
      : (enabled ? 'Show a progress bar on the public page' : 'Set a fundraising goal above to enable');
    if (!enabled && !judgingOrVotingStarted) setToggle('mgmt-public-toggle', false);

    const closeToggle = document.getElementById('mgmt-close-on-goal-toggle') as HTMLButtonElement;
    const closeHint = document.getElementById('mgmt-close-on-goal-hint');
    closeToggle.disabled = !enabled;
    closeHint.textContent = judgingOrVotingStarted
      ? 'Judging/voting has started, so this can no longer be changed.'
      : (enabled ? "Works alongside (or instead of) an entries-close date — whichever's first wins" : 'Set a fundraising goal above to enable');
    if (!enabled && !judgingOrVotingStarted) setToggle('mgmt-close-on-goal-toggle', false);

    (document.getElementById('mgmt-fund-goal') as HTMLInputElement).disabled = judgingOrVotingStarted;
    (document.getElementById('mgmt-goal-type') as HTMLSelectElement).disabled = judgingOrVotingStarted;
    const lockNotice = document.getElementById('mgmt-fundraising-lock-notice');
    if (lockNotice) lockNotice.style.display = judgingOrVotingStarted ? 'block' : 'none';
  }

  // ── Wire up all handlers ─────────────────────────────────────────────────────
  function wireAllHandlers() {
    // Open drawer via card action buttons
    document.getElementById('sections-grid').addEventListener('click', e => {
      const btn = e.target.closest('.action-btn');
      if (btn) openDrawer(btn.dataset.panel);
    });

    // Archive modal
    document.getElementById('archive-cancel').addEventListener('click', () => {
      document.getElementById('archive-modal').style.display = 'none';
    });
    document.getElementById('archive-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) document.getElementById('archive-modal').style.display = 'none';
    });

    // Show Day / Results Day help modal
    document.getElementById('show-date-help-btn').addEventListener('click', () => {
      document.getElementById('show-date-modal').style.display = 'flex';
    });
    document.getElementById('show-date-modal-x').addEventListener('click', closeShowDateModal);
    document.getElementById('show-date-modal-ok').addEventListener('click', closeShowDateModal);
    document.getElementById('show-date-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeShowDateModal();
    });

    // Publish Show modal
    wirePublishShowModal();

    // Close drawer — X button, backdrop, Escape key, cancel buttons
    document.getElementById('drawer-close').addEventListener('click', closeDrawer);
    document.getElementById('drawer-backdrop').addEventListener('click', closeDrawer);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeDrawer(); document.getElementById('archive-modal').style.display = 'none'; closeShowDateModal(); } });
    document.getElementById('edit-drawer').addEventListener('click', e => {
      if (e.target.closest('.cancel-btn')) closeDrawer();
    });

    // Save buttons — published shows get a confirmation first, since changes
    // go live immediately for entrants and the public
    const confirmIfPublished = fn => () => {
      if (show.status === 'published'
          && !confirm('This show is PUBLISHED — the changes you are about to save will be visible to the public and existing entrants immediately.\n\nSave changes anyway?')) {
        return;
      }
      fn();
    };
    document.querySelector('#panel-basics .save-btn').addEventListener('click', confirmIfPublished(saveBasics));
    document.querySelector('#panel-showtype .save-btn').addEventListener('click', confirmIfPublished(saveShowType));
    document.querySelector('#panel-breed .save-btn').addEventListener('click', confirmIfPublished(saveBreed));
    document.querySelector('#panel-classes .save-btn').addEventListener('click', confirmIfPublished(saveClasses));
    document.querySelector('#panel-sponsorship .save-btn').addEventListener('click', confirmIfPublished(saveSponsorship));
    document.querySelector('#panel-judging .save-btn').addEventListener('click', confirmIfPublished(saveJudging));
    document.querySelector('#panel-awards .save-btn').addEventListener('click', confirmIfPublished(saveAwards));
    document.querySelector('#panel-fundraising .save-btn').addEventListener('click', confirmIfPublished(saveFundraising));
    document.querySelector('#panel-payout .save-btn').addEventListener('click', confirmIfPublished(savePayout));
    document.querySelector('#panel-branding .save-btn').addEventListener('click', confirmIfPublished(saveBranding));

    // Org type
    document.getElementById('mgmt-org-type-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectCard(document.getElementById('mgmt-org-type-cards'), btn.dataset.value);
        const needsNum = btn.dataset.value === 'registered_charity' || btn.dataset.value === 'non_profit';
        document.getElementById('mgmt-charity-field').style.display = needsNum ? 'block' : 'none';
      });
    });

    document.getElementById('mgmt-close-now-btn').addEventListener('click', closeEntriesNow);
    document.getElementById('mgmt-entry-close-toggle').addEventListener('click', () => {
      if (judgingOrVotingStarted) return;
      const btn = document.getElementById('mgmt-entry-close-toggle');
      const on = btn.dataset.on !== 'true';
      btn.dataset.on = String(on);
      btn.style.background = on ? '#1ba89a' : '#c4bed0';
      btn.querySelector('span').style.transform = on ? 'translateX(16px)' : 'translateX(0)';
      updateCloseStatusUI();
    });

    // Animal type
    document.getElementById('mgmt-animal-type-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => selectCard(document.getElementById('mgmt-animal-type-cards'), btn.dataset.value));
    });

    // Breed scope
    document.getElementById('mgmt-breed-scope-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectCard(document.getElementById('mgmt-breed-scope-cards'), btn.dataset.value);
        updateBreedFields();
      });
    });
    initMgmtBreedCombobox();

    // Classes — add a category
    document.getElementById('mgmt-add-class').addEventListener('click', () => {
      mgmtClasses.push({ id: crypto.randomUUID(), name: '', description: '', award_id: null, has_certificate: true });
      renderClassesRows();
    });

    // Sponsorship
    setupYN('mgmt-sponsor-yn', val => {
      document.getElementById('mgmt-sponsor-form').style.display = val === 'yes' ? 'block' : 'none';
    });

    // Judging
    setupYN('mgmt-judging-yn', val => {
      document.getElementById('mgmt-judge-form').style.display = val === 'yes' ? 'block' : 'none';
      document.getElementById('mgmt-vote-timing').style.display = val === 'no' ? 'block' : 'none';
      if (val === 'no' && !getSelectedCard('mgmt-vote-timing-cards')) {
        selectCard(document.getElementById('mgmt-vote-timing-cards'), show.vote_open_mode || 'after_entries_close');
      }
      if (val === 'yes' && document.getElementById('mgmt-judge-panels').children.length === 0) {
        rebuildJudgePanels();
      }
    });
    document.getElementById('mgmt-vote-timing-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => selectCard(document.getElementById('mgmt-vote-timing-cards'), btn.dataset.value));
    });
    document.addEventListener('click', () => {
      document.querySelectorAll('.judge-picker-dropdown').forEach(d => { d.style.display = 'none'; });
    });

    // Awards
    setupYN('mgmt-awards-yn', val => {
      document.getElementById('mgmt-awards-form').style.display = val === 'yes' ? 'block' : 'none';
    });
    document.getElementById('mgmt-add-award').addEventListener('click', () => {
      mgmtAwards.push({
        id: crypto.randomUUID(), name: '', physical_description: '', image_url: null, sponsor_id: null,
      });
      renderAwardRows();
    });

    // Fundraising
    setupToggle('mgmt-public-toggle', () => {});
    setupToggle('mgmt-close-on-goal-toggle', () => {});
    document.getElementById('mgmt-goal-type').addEventListener('change', updateGoalTypeUI);
    document.getElementById('mgmt-fund-goal').addEventListener('input', updatePublicToggleAvailability);
    document.getElementById('mgmt-currency').addEventListener('change', e => applyCurrencySymbol(e.target.value));
    document.getElementById('mgmt-fee-minus').addEventListener('click', () => setFeeValue(getFeeValue() - 1));
    document.getElementById('mgmt-fee-plus').addEventListener('click', () => setFeeValue(getFeeValue() + 1));

    // Branding: logo source toggle
    document.getElementById('branding-logo-source-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => selectCard(document.getElementById('branding-logo-source-cards'), btn.dataset.value));
    });

    // Payout details: bank country drives the IBAN/local-code field labels
    document.getElementById('payout-bank-country').addEventListener('change', e => {
      updatePayoutBankCountryFields(e.target.value);
    });
  }

  // ── Save handlers ─────────────────────────────────────────────────────────────
  async function saveSection(panelId, payload, postSave) {
    const panel   = document.getElementById(`panel-${panelId}`);
    const saveBtn = panel?.querySelector('.save-btn');
    const errEl   = panel?.querySelector('.panel-error');
    if (errEl) { errEl.style.display = 'none'; errEl.textContent = ''; }
    const orig = saveBtn?.textContent;
    if (saveBtn) { saveBtn.textContent = 'Saving…'; saveBtn.disabled = true; }

    const { error } = await supabase.from('shows').update(payload).eq('id', showId);

    if (saveBtn) { saveBtn.textContent = orig; saveBtn.disabled = false; }
    if (error) { if (errEl) { errEl.textContent = error.message; errEl.style.display = 'block'; } return; }

    Object.assign(show, payload);
    if (postSave) await postSave();
    renderAllHeaders();
    closeDrawer();
  }

  function initBrandingWidget(widgetId, key) {
    const el      = document.getElementById(widgetId);
    if (!el) return;
    const input   = el.querySelector('.upload-input');
    const trigger = el.querySelector('.upload-trigger');
    const preview = el.querySelector('.upload-preview');
    const label   = el.querySelector('.upload-label');
    const icon    = el.querySelector('.upload-icon');
    // Restore current image
    const currentUrl = key === 'logo' ? show?.logo_url
      : key === 'orgLogo'     ? show?.org_logo_url
      : key === 'sponsorLogo' ? sponsors[0]?.logo_url
      : show?.banner_url;
    if (currentUrl) {
      preview.src = currentUrl; preview.classList.remove('hidden');
      if (icon) icon.classList.add('hidden');
      label.textContent = 'Click to replace';
    } else {
      preview.src = ''; preview.classList.add('hidden');
      if (icon) icon.classList.remove('hidden');
      label.textContent = 'Click to upload';
    }
    // Clear any previously queued file / removal
    pendingBranding[key] = null;
    brandingRemoval[key] = false;
    input.value = '';

    let removeBtn = el.querySelector('.upload-remove');
    if (!removeBtn) {
      removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'upload-remove';
      removeBtn.textContent = 'Remove image';
      removeBtn.style.cssText = 'background:none;border:none;color:#ef4444;font-size:11.5px;font-weight:600;cursor:pointer;margin-top:6px;padding:0;font-family:inherit';
      el.appendChild(removeBtn);
    }
    removeBtn.style.display = currentUrl ? 'inline-block' : 'none';
    removeBtn.onclick = () => {
      pendingBranding[key] = null;
      brandingRemoval[key] = true;
      preview.src = ''; preview.classList.add('hidden');
      if (icon) icon.classList.remove('hidden');
      label.textContent = 'Click to upload (removal unsaved)';
      input.value = '';
      removeBtn.style.display = 'none';
    };

    function processFile(file) {
      if (!file) return;
      if (file.size > maxUploadMb * 1024 * 1024) { label.textContent = `Too large (max ${maxUploadMb} MB)`; return; }
      pendingBranding[key] = file;
      brandingRemoval[key] = false;
      const reader = new FileReader();
      reader.onload = e => {
        preview.src = e.target.result; preview.classList.remove('hidden');
        if (icon) icon.classList.add('hidden');
        label.textContent = 'Click to replace (unsaved)';
        removeBtn.style.display = 'inline-block';
      };
      reader.readAsDataURL(file);
    }

    trigger.onclick  = () => input.click();
    input.onchange   = () => processFile(input.files[0]);

    trigger.ondragover = e => {
      e.preventDefault();
      trigger.style.borderColor = '#1ba89a';
      trigger.style.background  = 'rgba(27,168,154,0.06)';
    };
    trigger.ondragleave = () => {
      trigger.style.borderColor = '';
      trigger.style.background  = '';
    };
    trigger.ondrop = e => {
      e.preventDefault();
      trigger.style.borderColor = '';
      trigger.style.background  = '';
      processFile(e.dataTransfer.files[0]);
    };
  }

  async function saveBranding() {
    const panel   = document.getElementById('panel-branding');
    const saveBtn = panel?.querySelector('.save-btn');
    const errEl   = panel?.querySelector('.panel-error');
    if (errEl) { errEl.style.display = 'none'; errEl.textContent = ''; }
    if (saveBtn) { saveBtn.textContent = 'Saving…'; saveBtn.disabled = true; }
    try {
      const updates: any = {
        logo_source: getSelectedCard('branding-logo-source-cards') || 'show',
        website_url: (document.getElementById('branding-website-url') as HTMLInputElement).value.trim() || null,
      };
      if (pendingBranding.logo || pendingBranding.orgLogo || pendingBranding.banner) {
        showUploadOverlay('Uploading images…');
        try {
          if (pendingBranding.logo)    updates.logo_url     = await uploadImage(`shows/${showId}/logo`,     pendingBranding.logo);
          if (pendingBranding.orgLogo) updates.org_logo_url = await uploadImage(`shows/${showId}/org-logo`, pendingBranding.orgLogo);
          if (pendingBranding.banner)  updates.banner_url   = await uploadImage(`shows/${showId}/banner`,   pendingBranding.banner);
        } finally { hideUploadOverlay(); }
      }
      if (brandingRemoval.logo)    updates.logo_url     = null;
      if (brandingRemoval.orgLogo) updates.org_logo_url = null;
      if (brandingRemoval.banner)  updates.banner_url   = null;
      {
        const { error } = await supabase.from('shows').update(updates).eq('id', showId);
        if (error) throw error;
        Object.assign(show, updates);
      }
      pendingBranding = { logo: null, orgLogo: null, banner: null };
      brandingRemoval = { logo: false, orgLogo: false, banner: false };
      renderAllHeaders();
      closeDrawer();
    } catch (err) {
      if (errEl) { errEl.textContent = err.message || 'Upload failed'; errEl.style.display = 'block'; }
    } finally {
      if (saveBtn) { saveBtn.textContent = 'Save changes'; saveBtn.disabled = false; }
    }
  }

  async function saveBasics() {
    const title   = document.getElementById('mgmt-title').value.trim();
    const email   = document.getElementById('mgmt-contact-email').value.trim();
    const orgType = getSelectedCard('mgmt-org-type-cards');
    if (!title) return showPanelError('basics', 'Please enter a show name.');
    if (!email || !email.includes('@')) return showPanelError('basics', 'Please enter a valid contact email.');
    if (!orgType) return showPanelError('basics', 'Please select a type of organisation.');
    const needsNum = orgType === 'registered_charity' || orgType === 'non_profit';
    const charityNum = document.getElementById('mgmt-charity-number').value.trim();
    if (needsNum && !charityNum) return showPanelError('basics', 'Please enter your Charity / Non-Profit Number.');

    const hasCloseDate = document.getElementById('mgmt-entry-close-toggle').dataset.on === 'true';
    if (!judgingOrVotingStarted && hasCloseDate && !document.getElementById('mgmt-entry-close').value) {
      return showPanelError('basics', 'Please choose an entries-close date, or turn off the toggle to leave entries open indefinitely.');
    }

    const dateError = getDateOrderError({
      entry_open_date:  document.getElementById('mgmt-entry-open').value || null,
      entry_open_time:  document.getElementById('mgmt-entry-open-time').value || null,
      entry_close_date: judgingOrVotingStarted ? show.entry_close_date : (hasCloseDate ? (document.getElementById('mgmt-entry-close').value || null) : null),
      entry_close_time: judgingOrVotingStarted ? show.entry_close_time : (hasCloseDate ? (document.getElementById('mgmt-entry-close-time').value || null) : null),
      show_date: document.getElementById('mgmt-show-date').value || null,
      show_time: document.getElementById('mgmt-show-time').value || null,
      timezone: document.getElementById('mgmt-timezone').value || null,
    });
    if (dateError) return showPanelError('basics', dateError);

    await saveSection('basics', {
      title, org_type: orgType,
      host_org: document.getElementById('mgmt-host-org').value.trim() || null,
      description: (document.getElementById('mgmt-description') as HTMLTextAreaElement).value.trim() || null,
      about: (document.getElementById('mgmt-about') as HTMLTextAreaElement).value.trim() || null,
      charity_number: needsNum ? charityNum || null : null,
      contact_email: email,
      contact_phone: document.getElementById('mgmt-contact-phone').value.trim() || null,
      entry_open_date:   document.getElementById('mgmt-entry-open').value        || null,
      entry_open_time:   document.getElementById('mgmt-entry-open-time').value   || null,
      entry_close_date:  judgingOrVotingStarted ? show.entry_close_date : (hasCloseDate ? (document.getElementById('mgmt-entry-close').value || null) : null),
      entry_close_time:  judgingOrVotingStarted ? show.entry_close_time : (hasCloseDate ? (document.getElementById('mgmt-entry-close-time').value || null) : null),
      show_date:         document.getElementById('mgmt-show-date').value          || null,
      show_time:         document.getElementById('mgmt-show-time').value          || null,
      timezone:          document.getElementById('mgmt-timezone').value           || null,
    });
    document.getElementById('show-title-display').textContent = title || 'Untitled Show';
    updateCloseStatusUI();
  }

  function updateCloseStatusUI() {
    const hasCloseDate = document.getElementById('mgmt-entry-close-toggle').dataset.on === 'true';
    document.getElementById('mgmt-entry-close-date-wrap').style.display = hasCloseDate ? 'flex' : 'none';
    document.getElementById('mgmt-entry-close-hint').style.display = hasCloseDate ? 'none' : 'block';
    document.getElementById('mgmt-entry-close-required-mark').style.display = hasCloseDate ? 'inline' : 'none';
    document.getElementById('mgmt-entry-close-toggle').toggleAttribute('disabled', judgingOrVotingStarted);
    document.getElementById('mgmt-entry-close').toggleAttribute('disabled', judgingOrVotingStarted);
    document.getElementById('mgmt-entry-close-time').toggleAttribute('disabled', judgingOrVotingStarted);
    document.getElementById('mgmt-close-lock-notice').style.display = judgingOrVotingStarted ? 'block' : 'none';

    const close = getEntriesCloseInfo(show, goalTotal);
    const statusEl  = document.getElementById('mgmt-close-status');
    const closeBtn  = document.getElementById('mgmt-close-now-btn') as HTMLButtonElement;
    if (!close.isOpen) {
      const reasonLabel = { date: 'entry deadline', goal: 'fundraising goal reached', manual: 'organiser', show_date: 'show day' }[close.reason] || close.reason;
      statusEl.textContent = `Entries closed (${reasonLabel}).`;
      closeBtn.style.display = 'none';
    } else {
      statusEl.textContent = 'Entries are open.';
      closeBtn.style.display = '';
    }
  }

  async function closeEntriesNow() {
    if (!confirm('Close entries now? Exhibitors will no longer be able to enter this show.')) return;
    const { error } = await supabase.from('shows')
      .update({ entries_closed_at: new Date().toISOString(), entries_closed_reason: 'manual' })
      .eq('id', showId);
    if (error) return showPanelError('basics', 'Could not close entries: ' + error.message);
    show.entries_closed_at = new Date().toISOString();
    show.entries_closed_reason = 'manual';
    updateCloseStatusUI();
    renderPageHeader();
  }

  async function saveShowType() {
    const animalType = getSelectedCard('mgmt-animal-type-cards');
    await saveSection('showtype', { show_type: 'fun_stakes', animal_type: animalType || 'dog' });
  }

  async function saveBreed() {
    const scope = getSelectedCard('mgmt-breed-scope-cards');
    if (!scope) return showPanelError('breed', 'Please select a breed scope.');
    await saveSection('breed', {
      breed_scope:   scope,
      breed_filter:  scope === 'breed_specific'  ? document.getElementById('mgmt-breed').value.trim() || null : null,
      group_filter:  scope === 'group_specific'  ? document.getElementById('mgmt-group').value.trim() || null : null,
    });
  }

  // Upserts by stable client-generated id (instead of delete+reinsert) so
  // show_entries.category_id / awards.award_id links survive an edit that
  // only touches an unrelated row. Shared by the Classes panel save and the
  // Awards panel save (which only changes award_id on rows Classes owns).
  async function upsertCategories(rows) {
    const currentIds = new Set(rows.map(c => c.id));
    const removedIds = [...loadedCategoryIds].filter(id => !currentIds.has(id));
    if (removedIds.length) await supabase.from('show_categories').delete().in('id', removedIds);
    if (rows.length) {
      await supabase.from('show_categories').upsert(
        rows.map(c => ({ id: c.id, show_id: showId, name: c.name.trim(), description: c.description || null, award_id: c.award_id || null, has_certificate: !!c.has_certificate })),
        { onConflict: 'id' }
      );
    }
    const { data } = await supabase.from('show_categories').select('*').eq('show_id', showId);
    categories = data || [];
    loadedCategoryIds = new Set(categories.map(c => c.id));
  }

  async function saveClasses() {
    const valid = mgmtClasses.filter(c => c.name.trim());
    if (valid.length === 0) return showPanelError('classes', 'Please add at least one category.');
    await saveSection('classes', {}, async () => { await upsertCategories(valid); });
  }

  async function saveSponsorship() {
    const val = getYNValue('mgmt-sponsor-yn');
    if (!val) return showPanelError('sponsorship', 'Please make a selection.');
    if (val === 'yes') {
      const name = document.getElementById('mgmt-sponsor-name').value.trim();
      if (!name) return showPanelError('sponsorship', 'Please enter a sponsor name.');
      let logoUrl = brandingRemoval.sponsorLogo ? null : (sponsors[0]?.logo_url || null);
      if (pendingBranding.sponsorLogo) {
        showUploadOverlay('Uploading images…');
        try {
          logoUrl = await uploadImage(`sponsors/${showId}/sponsor-0`, pendingBranding.sponsorLogo);
        } catch (err) {
          return showPanelError('sponsorship', err.message || 'Logo upload failed — please try again.');
        } finally { hideUploadOverlay(); }
      }
      await saveSection('sponsorship', { has_sponsor: true }, async () => {
        const sponsorId = sponsors[0]?.id || crypto.randomUUID();
        await supabase.from('show_sponsors').upsert([{
          id: sponsorId, show_id: showId, name,
          website: document.getElementById('mgmt-sponsor-website').value.trim() || null, logo_url: logoUrl,
        }], { onConflict: 'id' });
        await supabase.from('show_sponsors').delete().eq('show_id', showId).neq('id', sponsorId);
        const { data } = await supabase.from('show_sponsors').select('*').eq('show_id', showId);
        sponsors = data || [];
        pendingBranding.sponsorLogo = null;
        brandingRemoval.sponsorLogo = false;
      });
    } else {
      await saveSection('sponsorship', { has_sponsor: false }, async () => {
        await supabase.from('show_sponsors').delete().eq('show_id', showId);
        sponsors = [];
      });
    }
  }

  async function saveJudging() {
    const val = getYNValue('mgmt-judging-yn');
    if (!val) return showPanelError('judging', 'Please make a selection.');
    if (val === 'yes') {
      const panels = Array.from(document.querySelectorAll('#mgmt-judge-panels .judge-panel'));
      // Check for judge book duplicates before saving
      let hasDuplicates = false;
      for (const p of panels) {
        if (p.dataset.savedId) continue; // came from picker or already resolved
        const em = p.querySelector('.j-email').value.trim().toLowerCase();
        if (!em) continue;
        const match = savedJudges.find(sj => sj.email?.toLowerCase() === em);
        if (!match) continue;
        showDuplicatePrompt(p, match);
        hasDuplicates = true;
      }
      if (hasDuplicates) return;

      const newJudges = panels.map(p => ({
        show_id:    showId,
        first_name: p.querySelector('.j-first').value.trim(),
        last_name:  p.querySelector('.j-last').value.trim(),
        email:      p.querySelector('.j-email').value.trim(),
        phone:      p.querySelector('.j-phone').value.trim() || null,
        photo_url:  p.querySelector('.j-photo-url').value || null,
      }));

      // Judges can't also be exhibitors in the same show
      const judgeEmails = newJudges.map(j => j.email?.toLowerCase()).filter(Boolean);
      if (judgeEmails.length) {
        const { data: entryRows } = await supabase.from('show_entries')
          .select('exhibitor_email').eq('show_id', showId).not('exhibitor_email', 'is', null);
        const entryEmails = new Set((entryRows || []).map((r: any) => r.exhibitor_email.toLowerCase()));
        const clash = judgeEmails.find(em => entryEmails.has(em));
        if (clash) return showPanelError('judging', `An exhibitor with the email ${clash} has entered this show and can't be assigned as a judge.`);
      }

      // Save ticked judges to saved_judges (skip duplicates by email)
      for (const p of panels) {
        if (!p.querySelector('.j-save')?.checked) continue;
        const fn = p.querySelector('.j-first').value.trim();
        const ln = p.querySelector('.j-last').value.trim();
        const em = p.querySelector('.j-email').value.trim() || null;
        const ph = p.querySelector('.j-phone').value.trim() || null;
        const pu = p.querySelector('.j-photo-url').value || null;
        if (!fn || !ln) continue;
        if (em && savedJudges.some(sj => sj.email?.toLowerCase() === em.toLowerCase())) continue;
        const { data: newSJ } = await supabase.from('saved_judges')
          .insert({ organiser_id: show.created_by, first_name: fn, last_name: ln, email: em, phone: ph, photo_url: pu })
          .select().single();
        if (newSJ) savedJudges.push(newSJ);
      }
      await saveSection('judging', { is_judged: true, judge_count: 1 }, async () => {
        await supabase.from('show_judges').delete().eq('show_id', showId);
        if (newJudges.some(j => j.first_name)) await supabase.from('show_judges').insert(newJudges.filter(j => j.first_name));
        const { data } = await supabase.from('show_judges').select('*').eq('show_id', showId);
        judges = data || [];
        renderMgmtJudgeDisplay();
      });
    } else {
      const voteMode = getSelectedCard('mgmt-vote-timing-cards') || 'after_entries_close';
      await saveSection('judging', { is_judged: false, vote_open_mode: voteMode }, async () => {
        await supabase.from('show_judges').delete().eq('show_id', showId);
        judges = [];
      });
    }
  }

  async function saveAwards() {
    const val = getYNValue('mgmt-awards-yn');
    if (!val) return showPanelError('awards', 'Please make a selection.');
    if (val === 'yes') {
      const validAwards = mgmtAwards.filter(a => a.name.trim());
      await saveSection('awards', {}, async () => {
        const currentAwardIds = new Set(validAwards.map(a => a.id));
        const removedAwardIds = [...loadedAwardIds].filter(id => !currentAwardIds.has(id));
        if (removedAwardIds.length) await supabase.from('awards').delete().in('id', removedAwardIds);
        if (validAwards.length) {
          await supabase.from('awards').upsert(validAwards.map(a => ({
            id: a.id, show_id: showId, name: a.name.trim(),
            physical_description: a.physical_description || null,
            image_url: a.image_url || null, sponsor_id: a.sponsor_id || null,
          })), { onConflict: 'id' });
        }
        const { data } = await supabase.from('awards').select('*').eq('show_id', showId);
        awards = data || [];
        loadedAwardIds = currentAwardIds;
        // Persist the category -> award_id assignments staged in mgmtAssignments.
        // has_certificate isn't editable from this panel (that's Classes' job) —
        // carry the current value through unchanged rather than defaulting it.
        const catRows = mgmtAssignments.map(a => {
          const src = categories.find(c => c.id === a.id);
          return { id: a.id, name: src?.name || a.name, description: src?.description || null, award_id: a.award_id, has_certificate: !!src?.has_certificate };
        });
        await upsertCategories(catRows);
      });
    } else {
      await saveSection('awards', {}, async () => {
        await supabase.from('awards').delete().eq('show_id', showId);
        awards = [];
        loadedAwardIds = new Set();
        const catRows = categories.map(c => ({ id: c.id, name: c.name, description: c.description, award_id: null, has_certificate: !!c.has_certificate }));
        await upsertCategories(catRows);
      });
    }
  }

  async function saveFundraising() {
    const currency = document.getElementById('mgmt-currency').value || 'AUD';
    const entryFee = getFeeValue();
    const minFee   = getMin(currency);
    if (minFee == null) return showPanelError('fundraising', 'Fee settings could not be loaded — please refresh the page.');
    if (entryFee < minFee) return showPanelError('fundraising', `Entry fee must be at least ${CURRENCY_SYMBOLS[currency] || ''}${minFee}.`);
    const payload: Record<string, any> = { currency, entry_fee: entryFee, is_fundraising: true };
    if (!judgingOrVotingStarted) {
      const goal = parseFloat((document.getElementById('mgmt-fund-goal') as HTMLInputElement).value) || null;
      payload.fundraising_goal = goal;
      payload.fundraising_goal_type = (document.getElementById('mgmt-goal-type') as HTMLSelectElement).value || 'amount';
      payload.show_fundraising_publicly = goal > 0 && document.getElementById('mgmt-public-toggle').dataset.on === 'true';
      payload.close_entries_on_goal = goal > 0 && document.getElementById('mgmt-close-on-goal-toggle').dataset.on === 'true';
    }
    await saveSection('fundraising', payload);
    updateCloseStatusUI();
  }

  async function savePayout() {
    const holderName   = document.getElementById('payout-holder-name').value.trim();
    const addressLine1 = document.getElementById('payout-address-line1').value.trim();
    const city         = document.getElementById('payout-city').value.trim();
    const region       = document.getElementById('payout-region').value.trim();
    const postcode     = document.getElementById('payout-postcode').value.trim();
    const benCountry   = document.getElementById('payout-beneficiary-country').value;
    const bankName     = document.getElementById('payout-bank-name').value.trim();
    const bankCountry  = document.getElementById('payout-bank-country').value;
    const bankAddress  = document.getElementById('payout-bank-address').value.trim();
    const currency     = document.getElementById('payout-account-currency').value;
    const accountNum   = document.getElementById('payout-account-number').value.trim();
    const swiftBic     = document.getElementById('payout-swift-bic').value.trim();
    const iban         = document.getElementById('payout-iban').value.trim();
    const localCode    = document.getElementById('payout-local-code').value.trim();
    const notes        = document.getElementById('payout-notes').value.trim();

    if (!holderName)   return showPanelError('payout', 'Please enter the account holder name.');
    if (!addressLine1 || !city || !postcode || !benCountry) return showPanelError('payout', 'Please complete the beneficiary address.');
    if (!bankName || !bankCountry) return showPanelError('payout', 'Please enter the bank name and country.');
    if (!currency)     return showPanelError('payout', 'Please select the account currency.');
    if (!accountNum)   return showPanelError('payout', 'Please enter the account number.');
    if (!swiftBic)     return showPanelError('payout', 'Please enter the SWIFT/BIC code.');
    if (IBAN_COUNTRIES.includes(bankCountry) && !iban) return showPanelError('payout', 'IBAN is required for this bank country.');
    if (LOCAL_CODE_LABELS.hasOwnProperty(bankCountry) && LOCAL_CODE_LABELS[bankCountry] && !localCode) {
      return showPanelError('payout', `Please enter the ${LOCAL_CODE_LABELS[bankCountry]}.`);
    }

    await saveSection('payout', {}, async () => {
      const { error } = await supabase.from('show_payout_details').upsert({
        show_id: showId,
        account_holder_name: holderName,
        beneficiary_address_line1: addressLine1,
        beneficiary_city: city,
        beneficiary_region: region || null,
        beneficiary_postcode: postcode,
        beneficiary_country: benCountry,
        bank_name: bankName,
        bank_country: bankCountry,
        bank_address: bankAddress || null,
        account_currency: currency,
        account_number: accountNum,
        swift_bic: swiftBic,
        iban: iban || null,
        local_bank_code: localCode || null,
        local_bank_code_label: LOCAL_CODE_LABELS[bankCountry] || null,
        notes: notes || null,
      }, { onConflict: 'show_id' });
      if (error) { showPanelError('payout', error.message); throw error; }
      const { data } = await supabase.from('show_payout_details').select('*').eq('show_id', showId).maybeSingle();
      payoutDetails = data || null;
    });
  }

