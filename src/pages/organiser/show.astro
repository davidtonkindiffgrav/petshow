  // ── Init ─────────────────────────────────────────────────────────────────────
  (async () => {
    const auth = await getAuth();
    mgmtBase = auth.base;
    if (!auth.session) { window.location.replace(mgmtBase + 'login'); return; }

    const name = auth.profile?.display_name || auth.session.user.email?.split('@')[0] || 'Organiser';
    const avatarEl = document.getElementById('sidebar-avatar');
    const nameEl   = document.getElementById('sidebar-username');
    const badgeEl  = document.getElementById('sidebar-role-badge');
    if (avatarEl) avatarEl.textContent = name.charAt(0).toUpperCase();
    if (nameEl)   nameEl.textContent   = name;
    if (badgeEl)  badgeEl.textContent  = auth.profile?.organiser_type === 'club' ? 'Club Organiser' : 'Organiser';
    document.getElementById('sidebar-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = mgmtBase + 'login';
    });

    showId = new URLSearchParams(window.location.search).get('id');
    if (!showId) { window.location.replace(mgmtBase + 'organiser/shows'); return; }

    uid = auth.session.user.id;
    const [showRes, catsRes, judgesRes, sponsorsRes, prizesRes, feeRes, sjRes] = await Promise.all([
      supabase.from('shows').select('*').eq('id', showId).eq('created_by', uid).single(),
      supabase.from('show_categories').select('*').eq('show_id', showId),
      supabase.from('show_judges').select('*').eq('show_id', showId),
      supabase.from('show_sponsors').select('*').eq('show_id', showId),
      supabase.from('show_prizes').select('description').eq('show_id', showId),
      supabase.from('platform_settings').select('key, value').or('key.like.service_fee_%,key.eq.max_upload_mb'),
      supabase.from('saved_judges').select('*').eq('organiser_id', uid).order('first_name'),
    ]);

    if (!showRes.data) { window.location.replace(mgmtBase + 'organiser/shows'); return; }

    show        = showRes.data;
    categories  = catsRes.data     || [];
    judges      = judgesRes.data   || [];
    sponsors    = sponsorsRes.data || [];
    prizes      = prizesRes.data   || [];
    savedJudges = sjRes.data       || [];
    (feeRes.data || []).forEach(r => {
      if (r.key === 'max_upload_mb') maxUploadMb = parseFloat(r.value) || 5;
      else serviceFees[r.key] = parseFloat(r.value) || 0;
    });
    document.querySelectorAll('.upload-size-hint').forEach(el => {
      el.textContent = el.textContent.replace(/\d+ MB/, `${maxUploadMb} MB`);
    });
    document.getElementById('page-loading').style.display = 'none';
    document.getElementById('page-content').style.display = 'block';

    renderPageHeader();
    renderAllHeaders();
    initMgmtTimezoneSelect();
    populateAllForms();
    wireAllHandlers();
  })();

  // ── Drawer open / close ───────────────────────────────────────────────────────
  function openDrawer(id) {
    document.querySelectorAll('#edit-drawer [id^="panel-"]').forEach(p => { p.style.display = 'none'; });
    const panel = document.getElementById(`panel-${id}`);
    if (panel) panel.style.display = 'block';
    document.getElementById('drawer-title').textContent = SECTION_TITLES[id] || id;

    const drawer   = document.getElementById('edit-drawer');
    const backdrop = document.getElementById('drawer-backdrop');
    drawer.style.transform   = 'translateX(0)';
    backdrop.style.opacity   = '1';
    backdrop.style.pointerEvents = 'auto';

    // Scroll drawer body to top
    drawer.querySelector('.flex-1.overflow-y-auto').scrollTop = 0;

    // Re-init panels that need fresh state each open
    if (id === 'classes')  initClassesPanel();
    if (id === 'judging' && show.is_judged === true) {
      rebuildJudgePanels();
      renderMgmtJudgeDisplay();
    }
    if (id === 'branding') {
      initBrandingWidget('branding-logo-widget',   'logo');
      initBrandingWidget('branding-org-widget',    'orgLogo');
      initBrandingWidget('branding-banner-widget', 'banner');
      selectCard(document.getElementById('branding-logo-source-cards'), show.logo_source || 'show');
    }

    // Highlight the active card
    document.querySelectorAll('.section-card').forEach(c => c.classList.remove('ring-2', 'ring-brand'));
    document.getElementById(`card-${id}`)?.classList.add('ring-2', 'ring-brand');
  }

  function closeDrawer() {
    const drawer   = document.getElementById('edit-drawer');
    const backdrop = document.getElementById('drawer-backdrop');
    drawer.style.transform   = 'translateX(100%)';
    backdrop.style.opacity   = '0';
    backdrop.style.pointerEvents = 'none';
    document.querySelectorAll('.section-card').forEach(c => c.classList.remove('ring-2', 'ring-brand'));
  }

  // ── Page header ──────────────────────────────────────────────────────────────
  function renderPageHeader() {
    document.getElementById('show-title-display').textContent = show.title || 'Untitled Show';
    document.title = `${show.title || 'Show'} — Fur to Feathers`;

    const st    = showStatus();
    const badge = document.getElementById('show-status-badge');
    badge.textContent     = st.label;
    badge.style.background = st.bg;
    badge.style.color      = st.color;

    const sym     = CURRENCY_SYMBOLS[show.currency] || 'A$';
    const feeText = show.entry_fee > 0 ? ` · ${sym}${show.entry_fee} entry fee` : ' · Fee not set';
    const dateText = show.show_date
      ? new Date(show.show_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
      : 'Date not set';
    document.getElementById('show-meta').textContent = `${dateText} · ${categories.length} class${categories.length !== 1 ? 'es' : ''}${feeText}`;

    const publishBtn = document.getElementById('btn-publish');
    if (show.status === 'published') {
      publishBtn.textContent = 'Unpublish';
      publishBtn.classList.replace('bg-brand', 'bg-[#f0fafa]');
      publishBtn.classList.replace('text-white', 'text-[#6f6880]');
      publishBtn.classList.remove('shadow-btn-primary');
    } else {
      publishBtn.textContent = 'Publish';
      publishBtn.classList.replace('bg-[#f0fafa]', 'bg-brand');
      publishBtn.classList.replace('text-[#6f6880]', 'text-white');
      publishBtn.classList.add('shadow-btn-primary');
    }
    document.getElementById('btn-back').onclick = () => {
      window.location.href = mgmtBase + 'organiser/shows';
    };
    publishBtn.onclick = handlePublish;

    const actionLinks = document.getElementById('show-action-links');
    const previewUrl  = `${mgmtBase}show?id=${showId}&preview=1`;
    let linksHtml = `<a href="${previewUrl}" target="_blank" class="text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors" style="text-decoration:none">Preview →</a>`;
    if (show.status === 'published') {
      const showUrl = `${window.location.origin}${mgmtBase}show?id=${showId}`;
      linksHtml += `<a href="${showUrl}" target="_blank" class="text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors" style="text-decoration:none">View Show ↗</a>`;
      linksHtml += `<button id="btn-copy-url" class="text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors">Copy URL</button>`;
    }
    actionLinks.innerHTML = linksHtml;
    if (show.status === 'published') {
      document.getElementById('btn-copy-url').onclick = () => {
        const url = `${window.location.origin}${mgmtBase}show?id=${showId}`;
        navigator.clipboard.writeText(url);
        const btn = document.getElementById('btn-copy-url');
        btn.textContent = 'Copied! ✓';
        setTimeout(() => { btn.textContent = 'Copy URL'; }, 1800);
      };
    }

    // Archive button — always render, enabled/disabled based on conditions
    const archiveBtn = document.getElementById('btn-archive');
    if (archiveBtn) {
      if (!show.archived_at) {
        archiveBtn.style.display = '';
        const reason = archiveBlockedReason();
        if (reason) {
          archiveBtn.disabled = true;
          archiveBtn.title    = reason;
          archiveBtn.className = 'text-[13px] font-semibold px-3 py-2 rounded-btn border border-[#e8e4ef] text-[#c4bed0] cursor-not-allowed transition-colors';
        } else {
          archiveBtn.disabled = false;
          archiveBtn.title    = '';
          archiveBtn.className = 'text-[13px] font-semibold px-3 py-2 rounded-btn border border-red-200 text-red-400 hover:bg-red-50 transition-colors';
          archiveBtn.onclick = openArchiveModal;
        }
      } else {
        archiveBtn.style.display = 'none';
      }
    }
  }

  function showStatus() {
    if (show.archived_at) return { label: 'Archived', color: '#92400e', bg: '#fef3c7' };
    if (show.status === 'draft') return { label: 'Draft', color: '#6f6880', bg: '#f5f3fa' };
    const now = Date.now();
    if (show.entry_open_date && new Date(show.entry_open_date).getTime() > now) return { label: 'Scheduled', color: '#2563eb', bg: '#eff6ff' };
    if (show.entry_close_date && new Date(show.entry_close_date).getTime() >= now) return { label: 'Open for Entries', color: '#16a34a', bg: '#f0fdf4' };
    return { label: 'Closed', color: '#6b7280', bg: '#f9fafb' };
  }

  // ── Archive ───────────────────────────────────────────────────────────────────

  function archiveBlockedReason() {
    if (show.status !== 'published')       return 'The show must be published before archiving.';
    if (!show.results_published_at)        return 'Results must be published before archiving.';
    if (!show.show_date || new Date(show.show_date) > new Date()) return 'The show date must have passed before archiving.';
    return null;
  }

  async function openArchiveModal() {
    const summaryEl = document.getElementById('archive-photo-summary');
    summaryEl.innerHTML = '<span class="text-[#9b94a8]">Counting photos…</span>';
    document.getElementById('archive-modal').style.display = 'flex';

    const { data: allEntries } = await supabase
      .from('show_entries')
      .select('id, photo_url, result_place')
      .eq('show_id', showId)
      .eq('status', 'confirmed');

    const entries = allEntries || [];
    const toDelete  = entries.filter(e => !e.result_place && e.photo_url);
    const toKeep    = entries.filter(e =>  e.result_place && e.photo_url);

    summaryEl.innerHTML = `
      <div class="bg-amber-50 border border-amber-200 rounded-[10px] p-4 space-y-2">
        <p class="font-bold text-[#92400e] flex items-center gap-2">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          This action cannot be undone
        </p>
        <p class="text-[#92400e]"><strong>${toDelete.length}</strong> non-placing photo${toDelete.length !== 1 ? 's' : ''} will be permanently deleted.</p>
        <p class="text-[#92400e]"><strong>${toKeep.length}</strong> winner / runner-up photo${toKeep.length !== 1 ? 's' : ''} will be kept.</p>
      </div>`;

    document.getElementById('archive-confirm').onclick = () => archiveShow(entries);
  }

  async function archiveShow(entries) {
    const confirmBtn = document.getElementById('archive-confirm');
    const cancelBtn  = document.getElementById('archive-cancel');
    confirmBtn.textContent = 'Archiving…';
    confirmBtn.disabled = true;
    cancelBtn.disabled  = true;

    try {
      // Delete non-placing photos from storage
      const toDelete = entries.filter(e => !e.result_place && e.photo_url);
      if (toDelete.length) {
        const paths = toDelete
          .map(e => { const m = e.photo_url.match(/\/show-assets\/(.+)/); return m ? m[1] : null; })
          .filter(Boolean);
        if (paths.length) await supabase.storage.from('show-assets').remove(paths);
        // Null out photo_url on non-placing entries
        const ids = toDelete.map(e => e.id);
        await supabase.from('show_entries').update({ photo_url: null }).in('id', ids);
      }

      // Mark show as archived
      const { error } = await supabase
        .from('shows')
        .update({ archived_at: new Date().toISOString() })
        .eq('id', showId);
      if (error) throw error;

      window.location.href = mgmtBase + 'organiser/shows';
    } catch (err) {
      confirmBtn.textContent = 'Archive Show';
      confirmBtn.disabled = false;
      cancelBtn.disabled  = false;
      showPageError('Archive failed: ' + err.message);
      document.getElementById('archive-modal').style.display = 'none';
    }
  }

  async function handlePublish() {
    const btn = document.getElementById('btn-publish');
    if (show.status !== 'published') {
      const needsNum = show.org_type === 'registered_charity' || show.org_type === 'non_profit';
      if (needsNum && !show.charity_number) {
        showPageError('A Charity / Non-Profit Number is required before publishing. Please update Show Basics.');
        return;
      }
      const { data: existing } = await supabase
        .from('shows').select('id, title').eq('created_by', uid).eq('status', 'published').neq('id', showId).maybeSingle();
      if (existing) {
        showPageError(`"${existing.title || 'Another show'}" is already published. Unpublish it before publishing this show.`);
        return;
      }
    }
    if (show.status === 'published') {
      if (!confirm('Unpublish this show? It will be hidden from the public entry page.')) return;
    }
    const newStatus = show.status === 'published' ? 'draft' : 'published';
    btn.textContent = 'Saving…';
    btn.disabled = true;
    const { error } = await supabase.from('shows').update({ status: newStatus }).eq('id', showId);
    btn.disabled = false;
    if (error) { showPageError(error.message); return; }
    show.status = newStatus;
    renderPageHeader();
  }

  // ── Card header rendering ────────────────────────────────────────────────────
  const DOT_TEXT_COLORS = { '#22c55e': '#16a34a', '#fbbf24': '#d97706', '#c4bed0': '#9b94a8' };

  // setHeader(id, dot, statusText, title, rows, actionLabel)
  // rows = array of [label, value] pairs shown below the title
  function setHeader(id, dot, statusText, title, rows, actionLabel) {
    const el = document.getElementById(`hdr-${id}`);
    if (!el) return;
    const textColor = DOT_TEXT_COLORS[dot] || '#9b94a8';
    const rowsHtml = rows.length
      ? `<div class="space-y-2 border-t border-[#f5f3fa] mt-3 pt-3">${
          rows.map(([lbl, val]) =>
            `<div class="flex items-start gap-2">
              <span class="text-[10.5px] font-bold text-[#c4bed0] uppercase tracking-wide w-[84px] shrink-0 leading-[1.7]">${lbl}</span>
              <span class="text-[12.5px] text-[#4a4357] font-medium leading-snug">${val}</span>
            </div>`
          ).join('')
        }</div>`
      : '';
    el.innerHTML = `
      <div class="flex items-start justify-between gap-2">
        <div>
          <div class="flex items-center gap-1.5 mb-1.5">
            <span class="w-2 h-2 rounded-full shrink-0" style="background:${dot}"></span>
            <span class="text-[10.5px] font-bold uppercase tracking-wide" style="color:${textColor}">${statusText}</span>
          </div>
          <p class="text-[15px] font-extrabold text-[#1c1626] leading-tight">${title}</p>
        </div>
        <button class="action-btn text-[13px] font-bold text-brand hover:underline shrink-0 mt-1" data-panel="${id}">${actionLabel}</button>
      </div>
      ${rowsHtml}`;
  }

  function renderAllHeaders() {
    function fmtDate(d) {
      return d ? new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '—';
    }
    function tzAbbr(ianaZone) {
      if (!ianaZone) return '';
      try {
        const parts = Intl.DateTimeFormat('en', { timeZone: ianaZone, timeZoneName: 'short' }).formatToParts(new Date());
        return parts.find(p => p.type === 'timeZoneName')?.value || '';
      } catch { return ''; }
    }
    function fmtDateTime(d, t) {
      if (!d) return '—';
      const date = new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
      if (!t) return date;
      const abbr = tzAbbr(show.timezone);
      return `${date} at ${t}${abbr ? ' (' + abbr + ')' : ''}`;
    }

    setHeader('basics', '#22c55e', 'Configured', 'Show Basics', [
      ['Name',      show.title || '—'],
      ['Show date', fmtDate(show.show_date)],
      ...(show.entry_open_date ? [['Opens', fmtDateTime(show.entry_open_date, show.entry_open_time)]] : []),
      ['Closes',    fmtDateTime(show.entry_close_date, show.entry_close_time)],
      ['Org type',  ORG_TYPE_LABELS[show.org_type] || '—'],
    ], 'Edit');

    if (show.show_type) {
      setHeader('showtype', '#22c55e', 'Configured', 'Show Type', [
        ['Type',   SHOW_TYPE_LABELS[show.show_type]],
        ['Animal', show.animal_type ? show.animal_type.charAt(0).toUpperCase() + show.animal_type.slice(1) : 'Dog'],
      ], 'Edit');
    } else {
      setHeader('showtype', '#fbbf24', 'Setup needed', 'Show Type', [
        ['Type',   '—'],
        ['Animal', '—'],
      ], 'Set Up');
    }

    if (show.breed_scope) {
      const filter = show.breed_scope === 'breed_specific' ? show.breed_filter
                   : show.breed_scope === 'group_specific'  ? show.group_filter : null;
      setHeader('breed', '#22c55e', 'Configured', 'Breed & Eligibility', [
        ['Scope',  BREED_SCOPE_LABELS[show.breed_scope]],
        ...(filter ? [['Filter', filter]] : []),
      ], 'Edit');
    } else {
      setHeader('breed', '#fbbf24', 'Setup needed', 'Breed & Eligibility', [
        ['Scope', '—'],
      ], 'Set Up');
    }

    if (categories.length > 0) {
      const preview = categories.slice(0, 3).map(c => c.name).join(', ')
        + (categories.length > 3 ? ` +${categories.length - 3} more` : '');
      setHeader('classes', '#22c55e', 'Configured', 'Classes', [
        ['Count',   `${categories.length} class${categories.length !== 1 ? 'es' : ''}`],
        ['Classes', preview],
      ], 'Edit');
    } else {
      setHeader('classes', '#fbbf24', 'Setup needed', 'Classes', [
        ['Count', 'None added yet'],
      ], 'Set Up');
    }

    if (show.has_sponsor === true) {
      const rows = [['Status', 'Sponsor added']];
      if (sponsors[0]?.name)    rows.push(['Name',    sponsors[0].name]);
      if (sponsors[0]?.website) rows.push(['Website', sponsors[0].website]);
      setHeader('sponsorship', '#22c55e', 'Configured', 'Sponsorship', rows, 'Edit');
    } else if (show.has_sponsor === false) {
      setHeader('sponsorship', '#c4bed0', 'Not used', 'Sponsorship', [
        ['Status', 'No sponsor for this show'],
      ], 'Enable');
    } else {
      setHeader('sponsorship', '#fbbf24', 'Setup needed', 'Sponsorship', [
        ['Status', '—'],
      ], 'Set Up');
    }

    if (show.is_judged === true) {
      const rows = [['Method', 'Expert judges']];
      if (judges[0]?.first_name) {
        rows.push(['Judge', `${judges[0].first_name} ${judges[0].last_name || ''}`.trim()]);
      } else {
        rows.push(['Judge', 'Not yet assigned']);
      }
      setHeader('judging', '#22c55e', 'Configured', 'Judging', rows, 'Edit');
    } else if (show.is_judged === false) {
      setHeader('judging', '#c4bed0', 'Public voting', 'Judging', [
        ['Method', 'Public voting'],
      ], 'Edit');
    } else {
      setHeader('judging', '#fbbf24', 'Setup needed', 'Judging', [
        ['Method', '—'],
      ], 'Set Up');
    }

    const hasCerts    = show.has_digital_certs === true;
    const hasPhysical = show.has_physical_prizes === true;
    const noAwards    = show.has_digital_certs === false && show.has_physical_prizes === false;
    if (hasCerts || hasPhysical) {
      const rows = [
        ['Certs',    hasCerts    ? 'Digital certificates' : 'None'],
        ['Physical', hasPhysical ? 'Physical prizes'      : 'None'],
      ];
      if (hasPhysical && show.prize_source) rows.push(['Source', show.prize_source.charAt(0).toUpperCase() + show.prize_source.slice(1)]);
      setHeader('awards', '#22c55e', 'Configured', 'Awards & Prizes', rows, 'Edit');
    } else if (noAwards) {
      setHeader('awards', '#c4bed0', 'Not used', 'Awards & Prizes', [
        ['Status', 'No awards for this show'],
      ], 'Enable');
    } else {
      setHeader('awards', '#fbbf24', 'Setup needed', 'Awards & Prizes', [
        ['Certs',    '—'],
        ['Physical', '—'],
      ], 'Set Up');
    }

    const sym    = CURRENCY_SYMBOLS[show.currency] || 'A$';
    const pct    = serviceFees['service_fee_pct'];
    const floor  = serviceFees[`service_fee_floor_${show.currency || 'AUD'}`];
    const svcFee = (pct != null && floor != null)
      ? Math.max(floor, (show.entry_fee || 0) * pct / 100)
      : null;
    const feeTotal = svcFee != null ? (show.entry_fee || 0) + svcFee : null;
    const feeText = show.entry_fee > 0
      ? (feeTotal != null ? `${sym}${feeTotal.toFixed(2)} (${sym}${Number(show.entry_fee).toFixed(2)} + ${sym}${svcFee.toFixed(2)} platform fee)` : 'Error')
      : 'Not set';
    if (show.is_fundraising === true) {
      setHeader('fundraising', '#22c55e', 'Configured', 'Fundraising & Fees', [
        ['Status',    'Fundraising active'],
        ['Entry fee', feeText],
        ['Goal',      show.fundraising_goal ? `${sym}${show.fundraising_goal}` : 'Not set'],
        ['Currency',  show.currency || 'AUD'],
      ], 'Edit');
    } else if (show.is_fundraising === false) {
      setHeader('fundraising', '#c4bed0', 'No fundraising', 'Fundraising & Fees', [
        ['Entry fee', feeText],
        ['Currency',  show.currency || 'AUD'],
      ], 'Edit');
    } else {
      setHeader('fundraising', '#fbbf24', 'Setup needed', 'Fundraising & Fees', [
        ['Status',    '—'],
        ['Entry fee', '—'],
      ], 'Set Up');
    }

    renderBrandingHeader();
  }

  function renderBrandingHeader() {
    const hdr = document.getElementById('hdr-branding');
    if (!hdr) return;

    // Remove default padding — we control layout ourselves
    hdr.className = 'card-header';

    const uploadedCount = [show.logo_url, show.org_logo_url, show.banner_url].filter(Boolean).length;
    const statusText = uploadedCount === 3 ? 'Uploaded' : uploadedCount > 0 ? 'Partial' : 'Not uploaded';
    const dot        = uploadedCount === 3 ? '#22c55e'  : uploadedCount > 0 ? '#fbbf24' : '#c4bed0';
    const textColor  = uploadedCount === 3 ? '#16a34a'  : uploadedCount > 0 ? '#d97706' : '#9b94a8';

    const bannerMiddle = show.banner_url
      ? `<img src="${show.banner_url}" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;border-radius:8px;" alt="" />`
      : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#f5f3fa;border-radius:8px;">
           <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
         </div>`;

    function thumbRow(label, url) {
