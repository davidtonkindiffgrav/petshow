  // ─── Category tooltip ────────────────────────────────────────────────────────
  const _tip = document.createElement('div');
  _tip.style.cssText = 'display:none;position:fixed;z-index:9999;background:#1c1626;color:#fff;font-size:12px;line-height:1.5;border-radius:8px;padding:7px 11px;max-width:220px;pointer-events:none;box-shadow:0 4px 14px rgba(0,0,0,0.22);';
  document.body.appendChild(_tip);

  function _posTip(e) {
    const x = e.clientX + 14, y = e.clientY + 16;
    _tip.style.left = Math.min(x, window.innerWidth  - _tip.offsetWidth  - 8) + 'px';
    _tip.style.top  = Math.min(y, window.innerHeight - _tip.offsetHeight - 8) + 'px';
  }

  function attachTooltip(el, desc) {
    if (!desc) return;
    el.addEventListener('mouseenter', e => { _tip.textContent = desc; _tip.style.display = 'block'; _posTip(e); });
    el.addEventListener('mousemove', _posTip);
    el.addEventListener('mouseleave', () => { _tip.style.display = 'none'; });
  }

  // ─── Classes panel ───────────────────────────────────────────────────────────
  // Mirrors the new-show wizard's type-first flow (new-show.astro's Step 4) —
  // no preset toggle buttons; organisers type category rows directly, with a
  // handful of suggested presets offered as fill-in-the-blank shortcuts.
  function initClassesPanel() {
    mgmtClasses = categories.map(c => ({ id: c.id, name: c.name, description: c.description || '', award_id: c.award_id || null, has_certificate: !!c.has_certificate }));
    if (mgmtClasses.length === 0) mgmtClasses.push({ id: crypto.randomUUID(), name: '', description: '', award_id: null, has_certificate: true });
    renderClassesRows();
  }

  function renderClassesRows() {
    const list = document.getElementById('mgmt-classes-list');
    list.innerHTML = '';
    mgmtClasses.forEach((cls, i) => appendClassRow(i));
    renderClassesSuggestions();
  }

  function appendClassRow(idx) {
    const cls = mgmtClasses[idx];
    const list = document.getElementById('mgmt-classes-list');
    const row = document.createElement('div');
    row.className = 'border border-[#efebf5] rounded-[13px] p-3.5 bg-[#fafafc]';
    row.innerHTML = `
      <div class="flex items-start gap-2 mb-2.5">
        <div class="flex-1">
          <label class="block text-[10.5px] font-bold text-[#9b94a8] uppercase tracking-wide mb-1">Category Name</label>
          <input type="text" value="${esc(cls.name)}" placeholder="e.g. Best Rescue"
            class="cls-name-input w-full border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[13px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <button type="button" class="cls-remove shrink-0 text-[#c4bed0] hover:text-red-400 transition-colors mt-[22px]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="mb-2.5">
        <label class="block text-[10.5px] font-bold text-[#9b94a8] uppercase tracking-wide mb-1">Description <span class="normal-case font-medium text-[#c4bed0]">(shown as a tooltip to entrants)</span></label>
        <input type="text" value="${esc(cls.description || '')}" placeholder="Briefly describe this category"
          class="cls-desc-input w-full border border-[#efebf5] rounded-[11px] px-3 py-2 text-[12.5px] text-[#6f6880] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
      </div>
      <label class="flex items-center gap-2 cursor-pointer select-none">
        <input type="checkbox" class="cls-cert-checkbox w-4 h-4 accent-brand" ${cls.has_certificate ? 'checked' : ''} />
        <span class="text-[12px] font-semibold text-[#4a4357]">🎓 Award a certificate to this category's winners</span>
      </label>
    `;
    row.querySelector('.cls-name-input').addEventListener('input', e => { mgmtClasses[idx].name = e.target.value; });
    row.querySelector('.cls-desc-input').addEventListener('input', e => { mgmtClasses[idx].description = e.target.value; });
    row.querySelector('.cls-cert-checkbox').addEventListener('change', e => { mgmtClasses[idx].has_certificate = e.target.checked; });
    row.querySelector('.cls-remove').addEventListener('click', () => {
      mgmtClasses.splice(idx, 1);
      renderClassesRows();
    });
    list.appendChild(row);
  }

  function renderClassesSuggestions() {
    const wrap = document.getElementById('mgmt-classes-suggestions');
    wrap.innerHTML = '';
    const existingNames = new Set(mgmtClasses.map(c => c.name));
    FUN_STAKES.filter(cat => cat.suggested).forEach(cat => {
      const already = existingNames.has(cat.name);
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'rounded-full border-2 px-3.5 py-1.5 text-[12.5px] font-semibold transition-all';
      btn.style.borderColor = '#b8e4e0';
      btn.style.background  = 'white';
      btn.style.color       = already ? '#c4bed0' : '#4a4357';
      btn.style.cursor      = already ? 'default' : 'pointer';
      btn.disabled = already;
      btn.textContent = already ? `${cat.name} ✓` : `+ ${cat.name}`;
      attachTooltip(btn, cat.description);
      btn.addEventListener('click', () => {
        if (existingNames.has(cat.name)) return;
        _tip.style.display = 'none';
        const blankIdx = mgmtClasses.findIndex(c => !c.name.trim());
        if (blankIdx !== -1) {
          mgmtClasses[blankIdx].name = cat.name;
          mgmtClasses[blankIdx].description = cat.description;
        } else {
          mgmtClasses.push({ id: crypto.randomUUID(), name: cat.name, description: cat.description, award_id: null, has_certificate: true });
        }
        renderClassesRows();
      });
      wrap.appendChild(btn);
    });
  }

  function showDuplicatePrompt(panel, match) {
    if (panel.querySelector('.j-dup-prompt')) return;
    const emailInput  = panel.querySelector('.j-email');
    const photoCircle = panel.querySelector('.judge-photo-circle');
    const photoBtn    = panel.querySelector('.judge-photo-btn');
    const prompt = document.createElement('div');
    prompt.className = 'j-dup-prompt rounded-[10px] p-3 flex items-start gap-3 flex-wrap';
    prompt.style.cssText = 'background:#fffbeb;border:1px solid #fde68a;margin-top:4px;';
    prompt.innerHTML = `
      <div class="flex-1 min-w-0">
        <p class="text-[12.5px] font-semibold" style="color:#92400e">${esc(match.first_name)} ${esc(match.last_name)} is already in your judge book.</p>
        <p class="text-[12px] mt-0.5" style="color:#b45309">Would you like to reuse their saved details?</p>
      </div>
      <div class="flex gap-2 shrink-0">
        <button type="button" class="j-dup-yes text-[12px] font-bold text-white bg-brand px-3 py-1.5 rounded-btn hover:bg-brand-dark transition-colors">Yes, reuse</button>
        <button type="button" class="j-dup-no text-[12px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-1.5 rounded-btn hover:bg-[#f0fafa] transition-colors">No</button>
      </div>`;
    prompt.querySelector('.j-dup-yes').addEventListener('click', () => {
      panel.querySelector('.j-first').value     = match.first_name;
      panel.querySelector('.j-last').value      = match.last_name;
      emailInput.value                           = match.email || '';
      panel.querySelector('.j-phone').value     = match.phone || '';
      panel.querySelector('.j-photo-url').value = match.photo_url || '';
      if (match.photo_url && photoCircle) {
        photoCircle.innerHTML = `<img src="${match.photo_url}" class="w-full h-full object-cover" />`;
        if (photoBtn) photoBtn.textContent = 'Replace photo';
        const rm = panel.querySelector('.judge-photo-remove');
        if (rm) rm.style.display = '';
      }
      panel.dataset.savedId = match.id;
      prompt.remove();
    });
    prompt.querySelector('.j-dup-no').addEventListener('click', () => {
      emailInput.value = '';
      emailInput.focus();
      prompt.remove();
    });
    emailInput.after(prompt);
  }

  function renderMgmtJudgeDisplay() {
