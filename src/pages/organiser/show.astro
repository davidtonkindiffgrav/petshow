---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Settings" activePage="shows">

  <!-- Loading -->
  <div id="page-loading" class="flex items-center justify-center h-64">
    <div class="w-8 h-8 border-[3px] border-brand/20 border-t-brand rounded-full animate-spin"></div>
  </div>

  <!-- Main content -->
  <div id="page-content" style="display:none">

    <!-- Show header -->
    <div class="flex items-start justify-between gap-4 mb-7 flex-wrap">
      <div class="min-w-0">
        <div class="flex items-center gap-3 mb-1 flex-wrap">
          <h2 id="show-title-display" class="text-[24px] font-extrabold text-[#1c1626] tracking-[-0.02em]">—</h2>
          <span id="show-status-badge" class="inline-flex items-center px-2.5 py-1 rounded-full text-[12px] font-bold">—</span>
        </div>
        <p id="show-meta" class="text-[14px] text-[#6f6880]">—</p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <button id="btn-back"
          class="text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors">
          ← All Shows
        </button>
        <div id="show-action-links" class="flex items-center gap-2"></div>
        <button id="btn-archive" style="display:none"
          class="text-[13px] font-semibold px-3 py-2 rounded-btn border transition-colors">
          Archive
        </button>
        <button id="btn-publish"
          class="bg-brand text-white text-[13px] font-bold px-4 py-2 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
          Publish Now
        </button>
      </div>
    </div>

    <!-- Page error -->
    <p id="page-error" style="display:none"
      class="text-[13px] text-red-500 bg-red-50 border border-red-100 rounded-[11px] px-4 py-3 mb-5"></p>

    <!-- Section cards grid — headers only, no inline panels -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-6 gap-4" id="sections-grid">
      <div class="section-card bg-white rounded-card border border-[#b8e4e0] xl:col-span-2" id="card-basics">
        <div class="card-header p-5" id="hdr-basics"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0] relative overflow-hidden xl:col-span-1" id="card-showtype">
        <div class="card-header p-5" id="hdr-showtype"></div>
        <span class="absolute bottom-1 right-2 pointer-events-none leading-none" style="font-size:clamp(28px, 6vw, 66px)">🐕</span>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0] xl:col-span-1" id="card-breed">
        <div class="card-header p-5" id="hdr-breed"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0] xl:col-span-2" id="card-classes">
        <div class="card-header p-5" id="hdr-classes"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0] xl:col-span-2" id="card-sponsorship">
        <div class="card-header p-5" id="hdr-sponsorship"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0] xl:col-span-2" id="card-judging">
        <div class="card-header p-5" id="hdr-judging"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0] xl:col-span-2" id="card-awards">
        <div class="card-header p-5" id="hdr-awards"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0] xl:col-span-2" id="card-fundraising">
        <div class="card-header p-5" id="hdr-fundraising"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0] xl:col-span-2" id="card-payout">
        <div class="card-header p-5" id="hdr-payout"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0] xl:col-span-2" id="card-branding">
        <div class="card-header p-5" id="hdr-branding"></div>
      </div>
    </div>
  </div>

  <!-- ── Archive confirmation modal ──────────────────────────────────────────── -->
  <div id="archive-modal" style="display:none" class="fixed inset-0 z-[200] bg-black/50 flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="archive-modal-title">
    <div class="bg-white rounded-[20px] w-full max-w-[440px] shadow-2xl">
      <div class="p-6">
        <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
        </div>
        <h2 id="archive-modal-title" class="text-[18px] font-extrabold text-[#1c1626] text-center mb-2">Archive This Show?</h2>
        <p class="text-[13px] text-[#6f6880] text-center mb-5 leading-relaxed">The show will be hidden from your dashboard and replaced with a lightweight results page showing winners and sponsors only.</p>
        <div id="archive-photo-summary" class="rounded-[12px] p-4 mb-5 text-[13px] leading-relaxed"></div>
        <div class="flex gap-3">
          <button id="archive-cancel" class="flex-1 border border-[#b8e4e0] text-[#6f6880] text-[13px] font-semibold py-2.5 rounded-btn hover:bg-[#f0fafa] transition-colors">Cancel</button>
          <button id="archive-confirm" class="flex-1 bg-red-500 text-white text-[13px] font-bold py-2.5 rounded-btn hover:bg-red-600 transition-colors">Archive Show</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Publish Show confirmation modal ─────────────────────────────────────── -->
  <div id="publish-show-modal" style="display:none"
    class="fixed inset-0 z-[200] bg-black/50 flex items-center justify-center p-4"
    role="dialog" aria-modal="true" aria-labelledby="publish-show-title">
    <div class="bg-white rounded-[20px] w-full max-w-[520px] shadow-2xl max-h-[90vh] overflow-y-auto">
      <div class="p-6">

        <div class="flex items-start gap-3 mb-4">
          <div id="publish-show-icon" class="w-11 h-11 rounded-full bg-brand-tint flex items-center justify-center shrink-0"></div>
          <div class="min-w-0">
            <h2 id="publish-show-title" class="text-[18px] font-extrabold text-[#1c1626]">Publish This Show?</h2>
            <p id="publish-show-subtitle" class="text-[13px] text-[#6f6880] mt-0.5"></p>
          </div>
        </div>

        <div id="publish-show-info-box" style="display:none" class="rounded-[12px] bg-[#f0fafa] border border-brand/15 p-4 mb-4">
          <p class="text-[11px] font-bold text-[#4a4357] uppercase tracking-wider mb-2">What happens when you publish</p>
          <ul class="space-y-1.5 text-[13px] text-[#4a4357] leading-snug">
            <li class="flex gap-2"><span class="text-brand font-bold shrink-0">•</span><span>The show becomes <strong>public</strong> and visible to everyone.</span></li>
            <li class="flex gap-2"><span class="text-brand font-bold shrink-0">•</span><span>Entrants can start entering according to your entry dates.</span></li>
            <li class="flex gap-2"><span class="text-brand font-bold shrink-0">•</span><span>You can still edit settings after publishing, but changes go live immediately.</span></li>
          </ul>
        </div>

        <div id="publish-show-required-wrap" style="display:none" class="mb-4">
          <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider mb-2">Needs your attention</p>
          <div id="publish-show-required-list" class="space-y-2"></div>
        </div>

        <div id="publish-show-optional-wrap" style="display:none" class="mb-4">
          <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider mb-2">Optional — not set up yet</p>
          <div id="publish-show-optional-list" class="space-y-2"></div>
        </div>

        <div id="publish-show-ack-wrap" style="display:none" class="mb-4">
          <div id="publish-show-ack-list"></div>
        </div>

        <div id="publish-show-modal-error" style="display:none"
          class="rounded-[10px] p-3 mb-4 text-[13px] bg-[#fef2f2] border border-[#fecaca] text-[#b91c1c]"></div>

        <div id="publish-show-footer" class="flex gap-3">
          <button id="publish-show-cancel"
            class="flex-1 text-[14px] font-semibold text-[#4a4357] border border-[#e0dce8] rounded-[10px] py-2.5 hover:bg-[#f7f5fb] transition-colors">
            Cancel
          </button>
          <button id="publish-show-cta" disabled
            class="flex-1 text-[14px] font-bold rounded-[10px] py-2.5 transition-colors bg-[#f5f3fa] text-[#c4bed0] cursor-not-allowed">
            Publish Show
          </button>
        </div>

      </div>
    </div>
  </div>

  <!-- ── Show Day / Results Day help modal ────────────────────────────────────── -->
  <div id="show-date-modal" style="display:none" class="fixed inset-0 z-[200] bg-black/50 flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="show-date-modal-title">
    <div class="bg-white rounded-[20px] w-full max-w-[480px] shadow-2xl max-h-[85vh] overflow-y-auto">
      <div class="p-6">
        <div class="flex items-start justify-between gap-3 mb-3">
          <h2 id="show-date-modal-title" class="text-[17px] font-extrabold text-[#1c1626] leading-snug">Show Day / Results Day</h2>
          <button type="button" id="show-date-modal-x" aria-label="Close"
            class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-[#9b94a8] hover:bg-[#f5f3fa] hover:text-[#1c1626] transition-colors">✕</button>
        </div>
        <p class="text-[13.5px] text-[#4a4357] leading-relaxed mb-4">This is the day your show wraps up — what happens on it depends on how winners are decided.</p>

        <div class="space-y-3 mb-4">
          <div class="bg-[#F0F7F5] border border-[#b8e4e0] rounded-[12px] px-4 py-3">
            <p class="text-[12.5px] font-bold text-[#143A37] mb-1">Expert judged</p>
            <p class="text-[12px] text-[#4a7a74] leading-relaxed">This is the day judging takes place and results can be published. Entries must close before this date.</p>
          </div>
          <div class="bg-[#F0F7F5] border border-[#b8e4e0] rounded-[12px] px-4 py-3">
            <p class="text-[12.5px] font-bold text-[#143A37] mb-1">Public voting</p>
            <p class="text-[12px] text-[#4a7a74] leading-relaxed">Voting closes the moment this date arrives (at the start time, or midnight if no time is set). You publish the results once voting ends.</p>
          </div>
        </div>

        <p class="text-[11.5px] text-[#9b94a8] leading-relaxed mb-5">Start time is optional — entries can never stay open past this date, even if you're using a fundraising goal to close them early.</p>

        <button type="button" id="show-date-modal-ok" class="w-full bg-brand text-white text-[14px] font-bold py-3 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">Got it</button>
      </div>
    </div>
  </div>

  <!-- ── Backdrop ──────────────────────────────────────────────────────────────── -->
  <div id="drawer-backdrop"
    class="fixed inset-0 bg-black/30 z-40 transition-opacity duration-300 opacity-0 pointer-events-none"></div>

  <!-- ── Side drawer ────────────────────────────────────────────────────────────── -->
  <div id="edit-drawer"
    class="fixed top-0 right-0 h-full w-full max-w-[500px] bg-white shadow-2xl z-50 flex flex-col transition-transform duration-300 ease-in-out"
    style="transform:translateX(100%)">

    <!-- Drawer header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-[#efebf5] shrink-0 bg-white">
      <div>
        <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider mb-0.5">Editing</p>
        <h3 id="drawer-title" class="text-[17px] font-extrabold text-[#1c1626]">—</h3>
      </div>
      <button id="drawer-close"
        class="w-8 h-8 rounded-full bg-[#f0fafa] flex items-center justify-center text-[#6f6880] hover:bg-brand/10 hover:text-brand transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Drawer body — scrollable, panels shown/hidden by JS -->
    <div class="flex-1 overflow-y-auto">

      <!-- Panel: Show Basics -->
      <div id="panel-basics" style="display:none" class="p-6 space-y-4">
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Show Name <span class="text-red-400">*</span></label>
          <input type="text" id="mgmt-title" placeholder="e.g. Spring Paws Charity Show 2025"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Entries Open</label>
          <div class="flex gap-2">
            <input type="date" id="mgmt-entry-open"
              class="flex-1 min-w-0 border border-[#b8e4e0] rounded-[11px] px-4 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
            <input type="time" id="mgmt-entry-open-time"
              class="shrink-0 border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
          </div>
        </div>
        <div id="mgmt-entry-close-wrap">
          <div class="flex items-center justify-between mb-1.5">
            <label class="text-[13px] font-semibold text-[#4a4357]">Entries Close <span id="mgmt-entry-close-required-mark" class="text-red-400">*</span></label>
            <button type="button" id="mgmt-entry-close-toggle" data-on="true" aria-label="Toggle entries-close date"
              class="shrink-0 w-9 h-5 rounded-full bg-[#1ba89a] transition-colors relative flex items-center px-0.5 disabled:opacity-40 disabled:cursor-not-allowed">
              <span class="w-4 h-4 rounded-full bg-white shadow transition-transform" style="transform:translateX(16px)"></span>
            </button>
          </div>
          <div id="mgmt-entry-close-date-wrap" class="flex gap-2">
            <input type="date" id="mgmt-entry-close"
              class="flex-1 min-w-0 border border-[#b8e4e0] rounded-[11px] px-4 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
            <input type="time" id="mgmt-entry-close-time"
              class="shrink-0 border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
          </div>
          <p id="mgmt-entry-close-hint" class="text-[11.5px] text-[#9b94a8] mt-1.5">Off — entries stay open indefinitely, e.g. until your fundraising goal is met (Fundraising panel), or until you close them manually below.</p>
          <p id="mgmt-close-lock-notice" style="display:none" class="text-[11.5px] text-amber-brand mt-2">Judging/voting has started, so this can no longer be changed.</p>
        </div>
        <div id="mgmt-close-now-wrap" class="flex items-center justify-between gap-3 bg-[#f9f8fc] border border-[#efebf5] rounded-[11px] px-4 py-3">
          <div>
            <p id="mgmt-close-status" class="text-[12.5px] font-semibold text-[#1c1626]">—</p>
            <p class="text-[11.5px] text-[#9b94a8]">You can close entries early at any time.</p>
          </div>
          <button type="button" id="mgmt-close-now-btn"
            class="shrink-0 text-[12.5px] font-bold text-red-400 border border-red-200 px-3 py-2 rounded-btn hover:bg-red-50 transition-colors">Close Entries Now</button>
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Timezone <span class="text-[#9b94a8] font-normal">(for entry &amp; show times)</span></label>
          <select id="mgmt-timezone"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-2.5 text-[14px] text-[#1c1626] bg-white focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors">
            <!-- populated by initMgmtTimezoneSelect() -->
          </select>
        </div>
        <div>
          <label class="flex items-center gap-1.5 text-[13px] font-semibold text-[#4a4357] mb-1.5">
            Show Day / Results Day <span class="text-red-400">*</span> <span class="text-[#9b94a8] font-normal">&amp; start time</span>
            <button type="button" id="show-date-help-btn" aria-label="What does this date mean?"
              class="w-[17px] h-[17px] rounded-full border border-[#b8e4e0] text-brand text-[11px] font-bold leading-none inline-flex items-center justify-center hover:bg-brand hover:text-white transition-colors cursor-pointer">?</button>
          </label>
          <div class="flex gap-2">
            <input type="date" id="mgmt-show-date"
              class="flex-1 min-w-0 border border-[#b8e4e0] rounded-[11px] px-4 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
            <input type="time" id="mgmt-show-time"
              class="shrink-0 border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
          </div>
          <p class="text-[11.5px] text-[#9b94a8] mt-1.5">Start time is optional. For public voting shows, voting closes when the show starts.</p>
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Host Organisation / Club</label>
          <input type="text" id="mgmt-host-org" placeholder="Your club or organisation name"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Show Description</label>
          <p class="text-[12px] text-[#9b94a8] mb-1.5">A short summary shown at the top of your public show page.</p>
          <textarea id="mgmt-description" rows="3" placeholder="e.g. Our annual charity dog show raising funds for the local shelter"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors resize-none"></textarea>
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Tell Us About Your Cause</label>
          <p class="text-[12px] text-[#9b94a8] mb-1.5">The full story — what you're raising money for and why it matters. Shown in its own section on your public show page.</p>
          <textarea id="mgmt-about" rows="6" placeholder="Share the story behind your cause — who benefits, why it matters, and how funds will be used…"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors resize-none"></textarea>
        </div>
        <div>
          <p class="text-[13px] font-semibold text-[#4a4357] mb-2">Type of Organisation <span class="text-red-400">*</span></p>
          <div class="grid grid-cols-3 gap-2" id="mgmt-org-type-cards">
            <button type="button" data-value="non_profit" class="sel-card flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#b8e4e0] bg-white px-2 py-3 text-center transition-all cursor-pointer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/></svg>
              <span class="text-[10.5px] font-bold text-[#1c1626] leading-tight">Non-Profit<br>Fundraiser</span>
            </button>
            <button type="button" data-value="registered_charity" class="sel-card flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#b8e4e0] bg-white px-2 py-3 text-center transition-all cursor-pointer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span class="text-[10.5px] font-bold text-[#1c1626] leading-tight">Registered<br>Charity</span>
            </button>
            <button type="button" data-value="commercial" disabled class="flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#efebf5] bg-[#fafafa] px-2 py-3 text-center opacity-50 cursor-not-allowed">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9b94a8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
              <span class="text-[10.5px] font-bold text-[#9b94a8] leading-tight">Commercial<br>Organisation</span>
              <span class="text-[9px] font-bold text-[#9b94a8] uppercase tracking-wide">Coming soon</span>
            </button>
          </div>
        </div>
        <div id="mgmt-charity-field" style="display:none">
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Charity / Non-Profit Number <span class="text-red-400">*</span></label>
          <input type="text" id="mgmt-charity-number" placeholder="e.g. 1234567"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
          <p class="text-[11.5px] text-[#9b94a8] mt-1.5">Required to publish your show.</p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Contact Email <span class="text-red-400">*</span></label>
