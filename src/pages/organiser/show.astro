---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Settings" activePage="shows">

  <!-- Loading -->
  <div id="page-loading" class="flex items-center justify-center h-64">
    <div class="w-8 h-8 border-[3px] border-brand/20 border-t-brand rounded-full animate-spin"></div>
  </div>

  <!-- Main content -->
  <div id="page-content" style="display:none">

    <!-- Show header -->
    <div class="flex items-start justify-between gap-4 mb-7 flex-wrap">
      <div class="min-w-0">
        <div class="flex items-center gap-3 mb-1 flex-wrap">
          <h2 id="show-title-display" class="text-[24px] font-extrabold text-[#1c1626] tracking-[-0.02em]">—</h2>
          <span id="show-status-badge" class="inline-flex items-center px-2.5 py-1 rounded-full text-[12px] font-bold">—</span>
        </div>
        <p id="show-meta" class="text-[14px] text-[#6f6880]">—</p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <button id="btn-back"
          class="text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors">
          ← All Shows
        </button>
        <div id="show-action-links" class="flex items-center gap-2"></div>
        <button id="btn-archive" style="display:none"
          class="text-[13px] font-semibold px-3 py-2 rounded-btn border transition-colors">
          Archive
        </button>
        <button id="btn-publish"
          class="bg-brand text-white text-[13px] font-bold px-4 py-2 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
          Publish Now
        </button>
      </div>
    </div>

    <!-- Page error -->
    <p id="page-error" style="display:none"
      class="text-[13px] text-red-500 bg-red-50 border border-red-100 rounded-[11px] px-4 py-3 mb-5"></p>

    <!-- Section cards grid — headers only, no inline panels -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4" id="sections-grid">
      <div class="section-card bg-white rounded-card border border-[#b8e4e0]" id="card-basics">
        <div class="card-header p-5" id="hdr-basics"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0]" id="card-showtype">
        <div class="card-header p-5" id="hdr-showtype"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0]" id="card-breed">
        <div class="card-header p-5" id="hdr-breed"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0]" id="card-classes">
        <div class="card-header p-5" id="hdr-classes"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0]" id="card-sponsorship">
        <div class="card-header p-5" id="hdr-sponsorship"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0]" id="card-judging">
        <div class="card-header p-5" id="hdr-judging"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0]" id="card-awards">
        <div class="card-header p-5" id="hdr-awards"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0]" id="card-fundraising">
        <div class="card-header p-5" id="hdr-fundraising"></div>
      </div>
      <div class="section-card bg-white rounded-card border border-[#b8e4e0]" id="card-branding">
        <div class="card-header p-5" id="hdr-branding"></div>
      </div>
    </div>
  </div>

  <!-- ── Archive confirmation modal ──────────────────────────────────────────── -->
  <div id="archive-modal" style="display:none" class="fixed inset-0 z-[200] bg-black/50 flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="archive-modal-title">
    <div class="bg-white rounded-[20px] w-full max-w-[440px] shadow-2xl">
      <div class="p-6">
        <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
        </div>
        <h2 id="archive-modal-title" class="text-[18px] font-extrabold text-[#1c1626] text-center mb-2">Archive This Show?</h2>
        <p class="text-[13px] text-[#6f6880] text-center mb-5 leading-relaxed">The show will be hidden from your dashboard and replaced with a lightweight results page showing winners and sponsors only.</p>
        <div id="archive-photo-summary" class="rounded-[12px] p-4 mb-5 text-[13px] leading-relaxed"></div>
        <div class="flex gap-3">
          <button id="archive-cancel" class="flex-1 border border-[#b8e4e0] text-[#6f6880] text-[13px] font-semibold py-2.5 rounded-btn hover:bg-[#f0fafa] transition-colors">Cancel</button>
          <button id="archive-confirm" class="flex-1 bg-red-500 text-white text-[13px] font-bold py-2.5 rounded-btn hover:bg-red-600 transition-colors">Archive Show</button>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Backdrop ──────────────────────────────────────────────────────────────── -->
  <div id="drawer-backdrop"
    class="fixed inset-0 bg-black/30 z-40 transition-opacity duration-300 opacity-0 pointer-events-none"></div>

  <!-- ── Side drawer ────────────────────────────────────────────────────────────── -->
  <div id="edit-drawer"
    class="fixed top-0 right-0 h-full w-full max-w-[500px] bg-white shadow-2xl z-50 flex flex-col transition-transform duration-300 ease-in-out"
    style="transform:translateX(100%)">

    <!-- Drawer header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-[#efebf5] shrink-0 bg-white">
      <div>
        <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider mb-0.5">Editing</p>
        <h3 id="drawer-title" class="text-[17px] font-extrabold text-[#1c1626]">—</h3>
      </div>
      <button id="drawer-close"
        class="w-8 h-8 rounded-full bg-[#f0fafa] flex items-center justify-center text-[#6f6880] hover:bg-brand/10 hover:text-brand transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- Drawer body — scrollable, panels shown/hidden by JS -->
    <div class="flex-1 overflow-y-auto">

      <!-- Panel: Show Basics -->
      <div id="panel-basics" style="display:none" class="p-6 space-y-4">
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Show Name <span class="text-red-400">*</span></label>
          <input type="text" id="mgmt-title" placeholder="e.g. Spring Paws Charity Show 2025"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Entries Open</label>
          <div class="flex gap-2">
            <input type="date" id="mgmt-entry-open"
              class="flex-1 min-w-0 border border-[#b8e4e0] rounded-[11px] px-4 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
            <input type="time" id="mgmt-entry-open-time"
              class="shrink-0 border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
          </div>
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Entries Close <span class="text-red-400">*</span></label>
          <div class="flex gap-2">
            <input type="date" id="mgmt-entry-close"
              class="flex-1 min-w-0 border border-[#b8e4e0] rounded-[11px] px-4 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
            <input type="time" id="mgmt-entry-close-time"
              class="shrink-0 border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
          </div>
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Timezone <span class="text-[#9b94a8] font-normal">(for entry open &amp; close times)</span></label>
          <select id="mgmt-timezone"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-2.5 text-[14px] text-[#1c1626] bg-white focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors">
            <!-- populated by initMgmtTimezoneSelect() -->
          </select>
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Show Date <span class="text-red-400">*</span></label>
          <input type="date" id="mgmt-show-date"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Host Organisation / Club</label>
          <input type="text" id="mgmt-host-org" placeholder="Your club or organisation name"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <div>
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Show Description</label>
          <textarea id="mgmt-description" rows="3" placeholder="Briefly describe your show — what's special about it, what animals compete, any cause you're supporting…"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors resize-none"></textarea>
        </div>
        <div>
          <p class="text-[13px] font-semibold text-[#4a4357] mb-2">Type of Organisation <span class="text-red-400">*</span></p>
          <div class="grid grid-cols-3 gap-2" id="mgmt-org-type-cards">
            <button type="button" data-value="non_profit" class="sel-card flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#b8e4e0] bg-white px-2 py-3 text-center transition-all cursor-pointer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/></svg>
              <span class="text-[10.5px] font-bold text-[#1c1626] leading-tight">Non-Profit<br>Fundraiser</span>
            </button>
            <button type="button" data-value="registered_charity" class="sel-card flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#b8e4e0] bg-white px-2 py-3 text-center transition-all cursor-pointer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span class="text-[10.5px] font-bold text-[#1c1626] leading-tight">Registered<br>Charity</span>
            </button>
            <button type="button" data-value="commercial" disabled class="flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#efebf5] bg-[#fafafa] px-2 py-3 text-center opacity-50 cursor-not-allowed">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9b94a8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
              <span class="text-[10.5px] font-bold text-[#9b94a8] leading-tight">Commercial<br>Organisation</span>
              <span class="text-[9px] font-bold text-[#9b94a8] uppercase tracking-wide">Coming soon</span>
            </button>
          </div>
        </div>
        <div id="mgmt-charity-field" style="display:none">
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Charity / Non-Profit Number <span class="text-red-400">*</span></label>
          <input type="text" id="mgmt-charity-number" placeholder="e.g. 1234567"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
          <p class="text-[11.5px] text-[#9b94a8] mt-1.5">Required to publish your show.</p>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Contact Email <span class="text-red-400">*</span></label>
            <input type="email" id="mgmt-contact-email"
              class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-2.5 text-[14px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
          </div>
          <div>
            <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Contact Phone <span class="text-[#9b94a8] font-normal">(optional)</span></label>
            <input type="tel" id="mgmt-contact-phone" placeholder="+44 7700 000000"
              class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-2.5 text-[14px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
          </div>
        </div>
        <p class="panel-error text-[12px] text-red-500" style="display:none"></p>
        <div class="drawer-actions flex justify-end gap-3 pt-2 pb-2">
          <button class="cancel-btn text-[13px] font-semibold text-[#9b94a8] hover:text-[#1c1626] px-3 py-2 transition-colors">Cancel</button>
          <button class="save-btn bg-brand text-white text-[13px] font-bold px-5 py-2.5 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">Save changes</button>
        </div>
      </div>

      <!-- Panel: Show Type -->
      <div id="panel-showtype" style="display:none" class="p-6 space-y-5">
        <div>
          <p class="text-[13px] font-semibold text-[#4a4357] mb-2.5">Type of Show <span class="text-red-400">*</span></p>
          <div class="grid grid-cols-2 gap-2" id="mgmt-show-type-cards">
            <button type="button" data-value="beauty_contest" class="sel-card flex flex-col items-center gap-2 rounded-[13px] border-2 border-[#b8e4e0] bg-white p-3 text-center transition-all cursor-pointer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <span class="text-[12px] font-bold text-[#1c1626]">Beauty Contest</span>
            </button>
            <button type="button" data-value="fun_stakes" class="sel-card flex flex-col items-center gap-2 rounded-[13px] border-2 border-[#b8e4e0] bg-white p-3 text-center transition-all cursor-pointer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
              <span class="text-[12px] font-bold text-[#1c1626]">Fun Stakes</span>
            </button>
            <button type="button" data-value="memorial" class="sel-card flex flex-col items-center gap-2 rounded-[13px] border-2 border-[#b8e4e0] bg-white p-3 text-center transition-all cursor-pointer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/></svg>
              <span class="text-[12px] font-bold text-[#1c1626]">Memorial Show</span>
            </button>
            <button type="button" data-value="other" disabled class="flex flex-col items-center gap-2 rounded-[13px] border-2 border-[#efebf5] bg-[#fafafa] p-3 text-center opacity-50 cursor-not-allowed">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9b94a8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span class="text-[12px] font-bold text-[#9b94a8]">Other <span class="text-[10px] font-normal">(soon)</span></span>
            </button>
          </div>
        </div>
        <div>
          <p class="text-[13px] font-semibold text-[#4a4357] mb-2">Animal Type <span class="text-red-400">*</span></p>
          <div class="grid grid-cols-4 gap-2" id="mgmt-animal-type-cards">
            <button type="button" data-value="dog" class="sel-card flex flex-col items-center gap-1 rounded-[11px] border-2 border-[#b8e4e0] bg-white px-2 py-2.5 text-center transition-all cursor-pointer">
              <span class="text-[20px]">🐕</span>
              <span class="text-[11px] font-bold text-[#1c1626]">Dog</span>
            </button>
            {['Cat 🐱','Rabbit 🐰','Guinea Pig 🐹','Bird 🐦'].map(a => (
              <button type="button" disabled class="flex flex-col items-center gap-1 rounded-[11px] border-2 border-[#efebf5] bg-[#fafafa] px-2 py-2.5 text-center opacity-40 cursor-not-allowed">
                <span class="text-[20px]">{a.split(' ').at(-1)}</span>
                <span class="text-[11px] font-bold text-[#9b94a8]">{a.split(' ')[0]}</span>
              </button>
            ))}
          </div>
          <p class="text-[11px] text-[#9b94a8] mt-1.5">More animal types coming soon.</p>
        </div>
        <p class="panel-error text-[12px] text-red-500" style="display:none"></p>
        <div class="drawer-actions flex justify-end gap-3 pt-2 pb-2">
          <button class="cancel-btn text-[13px] font-semibold text-[#9b94a8] hover:text-[#1c1626] px-3 py-2 transition-colors">Cancel</button>
          <button class="save-btn bg-brand text-white text-[13px] font-bold px-5 py-2.5 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">Save changes</button>
        </div>
      </div>

      <!-- Panel: Breed & Eligibility -->
      <div id="panel-breed" style="display:none" class="p-6 space-y-4">
        <div>
          <p class="text-[13px] font-semibold text-[#4a4357] mb-2.5">Breed Scope <span class="text-red-400">*</span></p>
          <div class="grid grid-cols-3 gap-2" id="mgmt-breed-scope-cards">
            <button type="button" data-value="all" class="sel-card flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#b8e4e0] bg-white p-3 text-center transition-all cursor-pointer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <span class="text-[11px] font-bold text-[#1c1626]">All Breeds</span>
            </button>
            <button type="button" data-value="breed_specific" class="sel-card flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#b8e4e0] bg-white p-3 text-center transition-all cursor-pointer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
              <span class="text-[11px] font-bold text-[#1c1626]">Breed Specific</span>
            </button>
            <button type="button" data-value="group_specific" class="sel-card flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#b8e4e0] bg-white p-3 text-center transition-all cursor-pointer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span class="text-[11px] font-bold text-[#1c1626]">Group Specific</span>
            </button>
          </div>
        </div>
        <div id="mgmt-breed-field" style="display:none">
          <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Breed Name <span class="text-red-400">*</span></label>
          <div class="relative">
            <input type="text" id="mgmt-breed" placeholder="Search breeds…" autocomplete="off"
              role="combobox" aria-expanded="false" aria-autocomplete="list" aria-controls="mgmt-breed-listbox"
              class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[14px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
