            ? `<a href="${/^https?:\/\//i.test(show.website_url) ? show.website_url : 'https://' + show.website_url}" target="_blank" rel="noopener noreferrer" style="font-size:12.5px;color:#1ba89a;font-weight:500;text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:220px;">${show.website_url}</a>`
            : `<span style="font-size:12.5px;color:#4a4357;font-weight:500;">Not set</span>`}
        </div>
      </div>`;
  }

  // ── Timezone select ──────────────────────────────────────────────────────────
  function initMgmtTimezoneSelect() {
    const sel = document.getElementById('mgmt-timezone');
    if (!sel) return;
    sel.innerHTML = TIMEZONES.map(g =>
      `<optgroup label="${g.group}">${g.zones.map(z =>
        `<option value="${z.id}">${z.label}</option>`
      ).join('')}</optgroup>`
    ).join('');
    const preferred = show.timezone || Intl.DateTimeFormat().resolvedOptions().timeZone;
    sel.value = preferred;
    if (!sel.value) sel.value = 'Australia/Sydney';
  }

  // ── Populate forms ───────────────────────────────────────────────────────────
  function toDateVal(v) { return v ? String(v).slice(0, 10) : ''; }

  function setField(id, val) {
    const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
    if (el) el.value = String(val ?? '');
  }

  function populateAllForms() {
    setField('mgmt-title',            show.title || '');
    setField('mgmt-entry-open',       toDateVal(show.entry_open_date));
    setField('mgmt-entry-open-time',  show.entry_open_time  || '12:00');
    setField('mgmt-entry-close',      toDateVal(show.entry_close_date));
    setField('mgmt-entry-close-time', show.entry_close_time || '12:00');
    setField('mgmt-show-date',        toDateVal(show.show_date));
    const tzSel = document.getElementById('mgmt-timezone');
    if (tzSel && show.timezone) (tzSel as HTMLSelectElement).value = show.timezone;
    setField('mgmt-host-org',         show.host_org || '');
    setField('mgmt-description',      show.description || '');
    setField('mgmt-contact-email',    show.contact_email || '');
    setField('mgmt-contact-phone',    show.contact_phone || '');
    setField('mgmt-charity-number',   show.charity_number || '');
    setField('branding-website-url',  show.website_url || '');
    if (show.org_type) {
      selectCard(document.getElementById('mgmt-org-type-cards'), show.org_type);
      const charityField = document.getElementById('mgmt-charity-field');
      if (charityField) charityField.style.display = (show.org_type === 'registered_charity' || show.org_type === 'non_profit') ? 'block' : 'none';
    }

    if (show.show_type) selectCard(document.getElementById('mgmt-show-type-cards'), show.show_type);
    selectCard(document.getElementById('mgmt-animal-type-cards'), show.animal_type || 'dog');

    if (show.breed_scope) selectCard(document.getElementById('mgmt-breed-scope-cards'), show.breed_scope);
    setField('mgmt-breed', show.breed_filter || '');
    setField('mgmt-group', show.group_filter || '');
    updateBreedFields();

    if (show.has_sponsor === true) {
      setYN('mgmt-sponsor-yn', 'yes');
      const sponsorForm = document.getElementById('mgmt-sponsor-form');
      if (sponsorForm) sponsorForm.style.display = 'block';
      setField('mgmt-sponsor-name',    sponsors[0]?.name || '');
      setField('mgmt-sponsor-website', sponsors[0]?.website || '');
    } else if (show.has_sponsor === false) {
      setYN('mgmt-sponsor-yn', 'no');
    }

    if (show.is_judged === true) {
      setYN('mgmt-judging-yn', 'yes');
      const judgeForm = document.getElementById('mgmt-judge-form');
      if (judgeForm) judgeForm.style.display = 'block';
      rebuildJudgePanels();
      renderMgmtJudgeDisplay();
    } else if (show.is_judged === false) {
      setYN('mgmt-judging-yn', 'no');
    }

    const anyAwards = show.has_digital_certs === true || show.has_physical_prizes === true;
    const noAwards  = show.has_digital_certs === false && show.has_physical_prizes === false;
    if (anyAwards || noAwards) {
      setYN('mgmt-awards-yn', anyAwards ? 'yes' : 'no');
      if (anyAwards) {
        const awardsForm = document.getElementById('mgmt-awards-form');
        if (awardsForm) awardsForm.style.display = 'block';
        setToggle('mgmt-certs-toggle', show.has_digital_certs === true);
        setToggle('mgmt-physical-toggle', show.has_physical_prizes === true);
        if (show.has_physical_prizes === true) {
          const physicalForm = document.getElementById('mgmt-physical-form');
          if (physicalForm) physicalForm.style.display = 'block';
          if (show.prize_source) selectCard(document.getElementById('mgmt-prize-source-cards'), show.prize_source);
          prizes.forEach(p => addPrizeRow(p.description));
        }
      }
    }

    setField('mgmt-currency', show.currency || 'AUD');
    applyCurrencySymbol(show.currency || 'AUD');
    if (show.is_fundraising === true) {
      setYN('mgmt-fundraising-yn', 'yes');
      const fundForm = document.getElementById('mgmt-fundraising-form');
      if (fundForm) fundForm.style.display = 'block';
      if (show.fundraising_goal) setField('mgmt-fund-goal', show.fundraising_goal);
      setToggle('mgmt-public-toggle', show.show_fundraising_publicly === true);
    } else if (show.is_fundraising === false) {
      setYN('mgmt-fundraising-yn', 'no');
    }
    setField('mgmt-entry-fee', show.entry_fee || 0);
  }

  // ── Wire up all handlers ─────────────────────────────────────────────────────
  function wireAllHandlers() {
    // Open drawer via card action buttons
    document.getElementById('sections-grid').addEventListener('click', e => {
      const btn = e.target.closest('.action-btn');
      if (btn) openDrawer(btn.dataset.panel);
    });

    // Archive modal
    document.getElementById('archive-cancel').addEventListener('click', () => {
      document.getElementById('archive-modal').style.display = 'none';
    });
    document.getElementById('archive-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) document.getElementById('archive-modal').style.display = 'none';
    });

    // Close drawer — X button, backdrop, Escape key, cancel buttons
    document.getElementById('drawer-close').addEventListener('click', closeDrawer);
    document.getElementById('drawer-backdrop').addEventListener('click', closeDrawer);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeDrawer(); document.getElementById('archive-modal').style.display = 'none'; } });
    document.getElementById('edit-drawer').addEventListener('click', e => {
