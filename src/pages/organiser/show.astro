  // ─── Category tooltip ────────────────────────────────────────────────────────
  const _tip = document.createElement('div');
  _tip.style.cssText = 'display:none;position:fixed;z-index:9999;background:#1c1626;color:#fff;font-size:12px;line-height:1.5;border-radius:8px;padding:7px 11px;max-width:220px;pointer-events:none;box-shadow:0 4px 14px rgba(0,0,0,0.22);';
  document.body.appendChild(_tip);

  function _posTip(e) {
    const x = e.clientX + 14, y = e.clientY + 16;
    _tip.style.left = Math.min(x, window.innerWidth  - _tip.offsetWidth  - 8) + 'px';
    _tip.style.top  = Math.min(y, window.innerHeight - _tip.offsetHeight - 8) + 'px';
  }

  function attachTooltip(el, desc) {
    if (!desc) return;
    el.addEventListener('mouseenter', e => { _tip.textContent = desc; _tip.style.display = 'block'; _posTip(e); });
    el.addEventListener('mousemove', _posTip);
    el.addEventListener('mouseleave', () => { _tip.style.display = 'none'; });
  }

  // ─── Classes panel ───────────────────────────────────────────────────────────
  function initClassesPanel() {
    const isFun = show.show_type === 'fun_stakes';
    document.getElementById('mgmt-classes-fun').style.display = isFun ? 'block' : 'none';
    document.getElementById('mgmt-classes-std').style.display = isFun ? 'none'  : 'block';

    const existingMap = new Map(categories.map(c => [c.name, c.description || '']));
    const presets     = isFun ? FUN_STAKES : STANDARD_CLASSES;
    const presetNames = new Set(presets.map(c => c.name));
    const defaultAll  = categories.length === 0 && !isFun;

    mgmtClasses = presets.map(cat => ({
      name:        cat.name,
      description: cat.description,
      enabled:     defaultAll || existingMap.has(cat.name),
      custom:      false,
    }));

    categories.filter(c => !presetNames.has(c.name)).forEach(c => {
      mgmtClasses.push({ name: c.name, description: c.description || '', enabled: true, custom: true });
    });

    if (isFun) renderFunPanel(); else renderStdPanel();
  }

  function renderFunPanel() {
    const grid      = document.getElementById('mgmt-fun-grid');
    const customDiv = document.getElementById('mgmt-fun-custom');
    grid.innerHTML = '';
    customDiv.innerHTML = '';

    mgmtClasses.filter(c => !c.custom).forEach(cat => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'text-left rounded-[11px] border-2 px-3 py-2.5 text-[12.5px] font-semibold transition-all cursor-pointer';
      btn.style.borderColor = cat.enabled ? '#1ba89a' : '#b8e4e0';
      btn.style.background  = cat.enabled ? '#f0fafa' : 'white';
      btn.style.color       = cat.enabled ? '#1c1626' : '#9b94a8';
      btn.textContent = cat.name;
      attachTooltip(btn, cat.description);
      btn.addEventListener('click', () => {
        cat.enabled = !cat.enabled;
        btn.style.borderColor = cat.enabled ? '#1ba89a' : '#b8e4e0';
        btn.style.background  = cat.enabled ? '#f0fafa' : 'white';
        btn.style.color       = cat.enabled ? '#1c1626' : '#9b94a8';
      });
      grid.appendChild(btn);
    });

    mgmtClasses.filter(c => c.custom).forEach(cat => customDiv.appendChild(buildCustomRow(cat)));
  }

  function renderStdPanel() {
    const list      = document.getElementById('mgmt-std-list');
    const customDiv = document.getElementById('mgmt-std-custom');
    list.innerHTML = '';
    customDiv.innerHTML = '';

    mgmtClasses.filter(c => !c.custom).forEach(cat => {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 p-3 border border-[#efebf5] rounded-[11px]';
      row.innerHTML = `
        <button type="button" class="cls-toggle w-10 h-6 rounded-full ${cat.enabled ? 'bg-brand' : 'bg-[#efebf5]'} transition-colors relative flex items-center px-0.5 shrink-0">
          <span class="w-5 h-5 rounded-full bg-white shadow transition-transform ${cat.enabled ? 'translate-x-4' : ''}"></span>
        </button>
        <span class="text-[13.5px] font-semibold flex-1 ${cat.enabled ? 'text-[#1c1626]' : 'text-[#9b94a8] line-through'}">${cat.name}</span>
      `;
      attachTooltip(row, cat.description);
      row.querySelector('.cls-toggle').addEventListener('click', () => {
        cat.enabled = !cat.enabled;
        renderStdPanel();
      });
      list.appendChild(row);
    });

    mgmtClasses.filter(c => c.custom).forEach(cat => customDiv.appendChild(buildCustomRow(cat)));
  }

  function buildCustomRow(cat) {
    const row = document.createElement('div');
    row.className = 'space-y-1.5';

    const nameInput = document.createElement('input');
    nameInput.type = 'text';
    nameInput.value = cat.name;
    nameInput.placeholder = 'Category name';
    nameInput.className = 'w-full border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[13px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors';
    nameInput.addEventListener('input', e => { cat.name = e.target.value; });

    const descInput = document.createElement('input');
    descInput.type = 'text';
    descInput.value = cat.description || '';
    descInput.placeholder = 'Description (shown as tooltip to entrants)';
    descInput.className = 'w-full border border-[#efebf5] rounded-[11px] px-3 py-2 text-[12.5px] text-[#6f6880] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors';
    descInput.addEventListener('input', e => { cat.description = e.target.value; });

    const rmBtn = document.createElement('button');
    rmBtn.type = 'button';
    rmBtn.className = 'shrink-0 text-[#c4bed0] hover:text-red-400 transition-colors p-1';
    rmBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
    rmBtn.addEventListener('click', () => {
      const i = mgmtClasses.indexOf(cat);
      if (i > -1) mgmtClasses.splice(i, 1);
      row.remove();
    });

    const header = document.createElement('div');
    header.className = 'flex items-center gap-2';
    header.appendChild(nameInput);
    header.appendChild(rmBtn);
    row.appendChild(header);
    row.appendChild(descInput);
    return row;
  }

  function showDuplicatePrompt(panel, match) {
    if (panel.querySelector('.j-dup-prompt')) return;
    const emailInput  = panel.querySelector('.j-email');
    const photoCircle = panel.querySelector('.judge-photo-circle');
    const photoBtn    = panel.querySelector('.judge-photo-btn');
    const prompt = document.createElement('div');
    prompt.className = 'j-dup-prompt rounded-[10px] p-3 flex items-start gap-3 flex-wrap';
    prompt.style.cssText = 'background:#fffbeb;border:1px solid #fde68a;margin-top:4px;';
    prompt.innerHTML = `
      <div class="flex-1 min-w-0">
        <p class="text-[12.5px] font-semibold" style="color:#92400e">${esc(match.first_name)} ${esc(match.last_name)} is already in your judge book.</p>
        <p class="text-[12px] mt-0.5" style="color:#b45309">Would you like to reuse their saved details?</p>
      </div>
      <div class="flex gap-2 shrink-0">
        <button type="button" class="j-dup-yes text-[12px] font-bold text-white bg-brand px-3 py-1.5 rounded-btn hover:bg-brand-dark transition-colors">Yes, reuse</button>
        <button type="button" class="j-dup-no text-[12px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-1.5 rounded-btn hover:bg-[#f0fafa] transition-colors">No</button>
      </div>`;
    prompt.querySelector('.j-dup-yes').addEventListener('click', () => {
      panel.querySelector('.j-first').value     = match.first_name;
      panel.querySelector('.j-last').value      = match.last_name;
      emailInput.value                           = match.email || '';
      panel.querySelector('.j-phone').value     = match.phone || '';
      panel.querySelector('.j-photo-url').value = match.photo_url || '';
      if (match.photo_url && photoCircle) {
        photoCircle.innerHTML = `<img src="${match.photo_url}" class="w-full h-full object-cover" />`;
        if (photoBtn) photoBtn.textContent = 'Replace photo';
      }
      panel.dataset.savedId = match.id;
      prompt.remove();
    });
    prompt.querySelector('.j-dup-no').addEventListener('click', () => {
      emailInput.value = '';
      emailInput.focus();
      prompt.remove();
    });
    emailInput.after(prompt);
  }

  function renderMgmtJudgeDisplay() {
    const el = document.getElementById('mgmt-judge-current');
    if (!el) return;
    const judge = judges[0];
    if (judge?.first_name) {
      const photo = judge.photo_url
        ? `<img src="${escAttr(judge.photo_url)}" class="w-10 h-10 rounded-full object-cover shrink-0" />`
        : `<div class="w-10 h-10 rounded-full bg-brand-tint flex items-center justify-center text-brand font-extrabold text-[14px] shrink-0">${escAttr(judge.first_name[0].toUpperCase())}</div>`;
      el.className = 'flex items-center gap-3 p-3.5 rounded-[12px] border border-[#b8e4e0] bg-[#f0fafa]';
      el.innerHTML = `${photo}<div>
        <p class="text-[13.5px] font-bold text-[#1c1626]">${escAttr(judge.first_name)} ${escAttr(judge.last_name || '')}</p>
        ${judge.email ? `<p class="text-[12px] text-[#9b94a8]">${escAttr(judge.email)}</p>` : ''}
      </div>`;
    } else {
      el.className = 'flex items-center gap-3 p-3.5 rounded-[12px] border border-[#efebf5]';
      el.innerHTML = `
        <div class="w-10 h-10 rounded-full border-2 border-dashed border-[#c4bed0] flex items-center justify-center shrink-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
        </div>
        <div>
          <p class="text-[13px] font-semibold text-[#9b94a8]">No judge assigned yet</p>
          <p class="text-[12px] text-[#c4bed0]">Fill in the details below ↓</p>
        </div>`;
    }
  }

  function rebuildJudgePanels() {
    const container = document.getElementById('mgmt-judge-panels');
    container.innerHTML = '';
    { const i = 0;
      const j = judges[i] || { first_name: '', last_name: '', email: '', phone: '', photo_url: '' };
      const p = document.createElement('div');
      p.className = 'judge-panel border border-[#efebf5] rounded-[12px] p-4 space-y-3';

      const pickerHtml = savedJudges.length > 0 ? `
        <div class="relative judge-picker-wrap">
          <button type="button" class="judge-picker-btn text-[12px] font-semibold text-brand flex items-center gap-1.5 hover:underline">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Saved judges
          </button>
          <div class="judge-picker-dropdown" style="display:none;position:absolute;left:0;top:100%;margin-top:4px;z-index:30;background:white;border:1px solid #e6dcfb;border-radius:12px;box-shadow:0 4px 20px rgba(0,0,0,0.10);min-width:220px;overflow:hidden;padding:4px 0;">
            ${savedJudges.map(sj => `<button type="button" class="judge-pick-item w-full text-left px-4 py-2.5 hover:bg-[#f0fafa] transition-colors" data-id="${sj.id}"><span style="display:block;font-size:13px;font-weight:600;color:#1c1626;">${escAttr(sj.first_name)} ${escAttr(sj.last_name)}</span>${sj.email ? `<span style="display:block;font-size:11.5px;color:#9b94a8;">${escAttr(sj.email)}</span>` : ''}</button>`).join('')}
          </div>
        </div>` : '';

      const photoPreview = j.photo_url
        ? `<img src="${escAttr(j.photo_url)}" class="w-full h-full object-cover" />`
        : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`;

      p.innerHTML = `
        <div class="flex items-center justify-between">
          <p class="text-[12px] font-bold text-[#6f6880] uppercase tracking-wide">Judge</p>
          ${pickerHtml}
        </div>
        <div class="grid grid-cols-2 gap-3">
          <input type="text" class="j-first border border-[#b8e4e0] rounded-[10px] px-3 py-2 text-[13px] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" placeholder="First name" value="${escAttr(j.first_name)}" />
          <input type="text" class="j-last border border-[#b8e4e0] rounded-[10px] px-3 py-2 text-[13px] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" placeholder="Last name" value="${escAttr(j.last_name)}" />
        </div>
        <input type="email" class="j-email w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2 text-[13px] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" placeholder="Email address" value="${escAttr(j.email)}" />
        <input type="tel"   class="j-phone w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2 text-[13px] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" placeholder="Phone (optional)" value="${escAttr(j.phone || '')}" />
        <input type="hidden" class="j-photo-url" value="${escAttr(j.photo_url || '')}" />
        <label class="flex items-center gap-2 pt-1 cursor-pointer select-none">
          <input type="checkbox" class="j-save w-4 h-4 accent-brand" />
          <span class="text-[12px] text-[#9b94a8]">Save to my judge book</span>
        </label>
        <div class="flex items-center gap-3 pt-2 border-t border-[#f5f3f8]">
          <div class="w-10 h-10 rounded-full border-2 border-dashed border-[#b8e4e0] bg-[#f0fafa] flex items-center justify-center overflow-hidden judge-photo-circle shrink-0 cursor-pointer">
            ${photoPreview}
          </div>
          <div>
            <p class="text-[12px] font-semibold text-[#4a4357]">Profile Photo <span class="text-[11px] text-[#9b94a8] font-normal">(optional)</span></p>
            <button type="button" class="judge-photo-btn text-[12px] font-semibold text-brand hover:underline">${j.photo_url ? 'Replace photo' : 'Upload photo'}</button>
            <input type="file" class="judge-photo-input hidden" accept="image/jpeg,image/png,image/webp" />
          </div>
        </div>`;

      const pickerBtn = p.querySelector('.judge-picker-btn');
      const dropdown  = p.querySelector('.judge-picker-dropdown');
      if (pickerBtn && dropdown) {
        pickerBtn.addEventListener('click', e => {
          e.stopPropagation();
          document.querySelectorAll('.judge-picker-dropdown').forEach(d => { if (d !== dropdown) d.style.display = 'none'; });
          dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
        });
        p.querySelectorAll('.judge-pick-item').forEach(btn => {
          btn.addEventListener('click', () => {
            const sj = savedJudges.find(s => s.id === btn.dataset.id);
            if (!sj) return;
            p.querySelector('.j-first').value = sj.first_name;
            p.querySelector('.j-last').value  = sj.last_name;
            p.querySelector('.j-email').value = sj.email || '';
            p.querySelector('.j-phone').value = sj.phone || '';
            p.querySelector('.j-photo-url').value = sj.photo_url || '';
            const circle = p.querySelector('.judge-photo-circle');
            const pBtn   = p.querySelector('.judge-photo-btn');
            if (sj.photo_url) {
              circle.innerHTML = `<img src="${sj.photo_url}" class="w-full h-full object-cover" />`;
              pBtn.textContent = 'Replace photo';
            } else {
              circle.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`;
              pBtn.textContent = 'Upload photo';
            }
            p.dataset.savedId = sj.id;
            dropdown.style.display = 'none';
          });
        });
      }

      const photoBtn     = p.querySelector('.judge-photo-btn');
      const photoInput   = p.querySelector('.judge-photo-input');
      const photoCircle  = p.querySelector('.judge-photo-circle');
      const photoUrlInput = p.querySelector('.j-photo-url');

      async function processJudgePhoto(file) {
        if (!file || file.size > maxUploadMb * 1024 * 1024) return;
        photoBtn.textContent = 'Uploading…';
        try {
          const url = await uploadImage(`judges/${showId}/judge-${i}`, file);
          photoUrlInput.value = url;
          photoCircle.innerHTML = `<img src="${url}" class="w-full h-full object-cover" />`;
          photoBtn.textContent = 'Replace photo';
        } catch { photoBtn.textContent = 'Failed — try again'; }
      }

      photoBtn.addEventListener('click', () => photoInput.click());
      photoInput.addEventListener('change', () => processJudgePhoto(photoInput.files[0]));
      photoCircle.addEventListener('click', () => photoInput.click());
      photoCircle.addEventListener('dragover', e => { e.preventDefault(); photoCircle.style.borderColor = '#1ba89a'; photoCircle.style.background = 'rgba(27,168,154,0.10)'; });
      photoCircle.addEventListener('dragleave', () => { photoCircle.style.borderColor = ''; photoCircle.style.background = ''; });
      photoCircle.addEventListener('drop', e => { e.preventDefault(); photoCircle.style.borderColor = ''; photoCircle.style.background = ''; processJudgePhoto(e.dataTransfer.files[0]); });

      container.appendChild(p);
    }
  }

  function addPrizeRow(description) {
    const list = document.getElementById('mgmt-prize-list');
    const row  = document.createElement('div');
    row.className = 'flex items-center gap-2';
    row.innerHTML = `
      <input type="text" value="${escAttr(description)}" placeholder="e.g. £50 Pet Store Voucher"
        class="flex-1 border border-[#b8e4e0] rounded-[10px] px-3 py-2 text-[13px] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
      <button type="button" class="rm-prize text-[#c4bed0] hover:text-red-400 transition-colors p-1">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>`;
    row.querySelector('.rm-prize').addEventListener('click', () => row.remove());
    list.appendChild(row);
  }

  function updateFeeBreakdown(code) {
    const sym    = CURRENCY_SYMBOLS[code] || code;
    const entry  = parseFloat(document.getElementById('mgmt-entry-fee')?.value) || 0;
    const pct    = serviceFees['service_fee_pct'];
    const floor  = serviceFees[`service_fee_floor_${code}`];
    const amountEl  = document.getElementById('mgmt-svc-amount');
    const totalEl   = document.getElementById('mgmt-total-charge');
    const previewEl = document.getElementById('mgmt-entrant-preview');
    if (pct == null || floor == null) {
      if (amountEl)  amountEl.textContent  = 'Error';
      if (totalEl)   totalEl.textContent   = 'Error';
      if (previewEl) previewEl.textContent = 'Error';
      return;
    }
    const svcFee = Math.max(floor, entry * pct / 100);
    const total  = entry + svcFee;
    if (amountEl)  amountEl.textContent  = `${sym}${svcFee.toFixed(2)}`;
    if (totalEl)   totalEl.textContent   = `${sym}${total.toFixed(2)}`;
    if (previewEl) previewEl.textContent = `Entry = ${sym}${total.toFixed(2)} (${sym}${entry.toFixed(2)} + ${sym}${svcFee.toFixed(2)} platform fee)`;
  }

  function applyCurrencySymbol(code) {
    const sym = CURRENCY_SYMBOLS[code] || code;
    const goalEl = document.getElementById('mgmt-sym-goal');
    const feeEl  = document.getElementById('mgmt-sym-fee');
    const hintEl = document.getElementById('mgmt-fee-hint');
    if (goalEl) goalEl.textContent = sym;
    if (feeEl)  feeEl.textContent  = sym;
    const minFee = MIN_ENTRY_FEE[code] || 1;
    if (hintEl) hintEl.textContent = `Minimum ${sym}${minFee.toFixed(2)}. Entry fees are required for all shows.`;
    const feeInput = document.getElementById('mgmt-entry-fee') as HTMLInputElement;
    if (feeInput) feeInput.min = String(minFee);
    updateFeeBreakdown(code);
  }

  // ── Shared card / toggle helpers ─────────────────────────────────────────────
  function selectCard(container, value) {
    if (!container) return;
    container.querySelectorAll('[data-value]').forEach(card => {
      if (card.disabled) return;
      const active = card.dataset.value === value;
      card.dataset.selected  = active ? 'true' : 'false';
      card.style.borderColor = active ? '#1ba89a' : '#b8e4e0';
      card.style.background  = active ? '#f0fafa' : 'white';
      card.style.boxShadow   = active ? '0 0 0 3px rgba(27,168,154,0.18)' : 'none';
    });
  }

  function getSelectedCard(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return null;
    const active = el.querySelector('[data-selected="true"]');
    return active ? active.dataset.value : null;
  }

  function setupToggle(btnId, onChange) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.addEventListener('click', () => {
      const on = btn.dataset.on !== 'true';
      btn.dataset.on = String(on);
      btn.style.background = on ? '#1ba89a' : '#e8f7f6';
      btn.querySelector('span').style.transform = on ? 'translateX(20px)' : 'translateX(0)';
      onChange(on);
    });
  }

  function setToggle(btnId, on) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.dataset.on = String(on);
    btn.style.background = on ? '#1ba89a' : '#e8f7f6';
    btn.querySelector('span').style.transform = on ? 'translateX(20px)' : 'translateX(0)';
  }

  function setupYN(containerId, onChange) {
    const el = document.getElementById(containerId);
    if (!el) return;
    el.querySelectorAll('.yn').forEach(btn => {
      btn.addEventListener('click', () => {
        el.querySelectorAll('.yn').forEach(b => {
          b.dataset.selected = 'false';
          b.style.borderColor = '#b8e4e0'; b.style.background = 'white'; b.style.boxShadow = 'none';
        });
        btn.dataset.selected  = 'true';
        btn.style.borderColor = '#1ba89a';
        btn.style.background  = '#f0fafa';
        btn.style.boxShadow   = '0 0 0 3px rgba(27,168,154,0.18)';
        onChange(btn.dataset.value);
      });
    });
  }

  function setYN(containerId, value) {
    const el = document.getElementById(containerId);
    if (!el || !value) return;
    el.querySelectorAll('.yn').forEach(btn => {
      const active = btn.dataset.value === value;
      btn.dataset.selected  = active ? 'true' : 'false';
      btn.style.borderColor = active ? '#1ba89a' : '#b8e4e0';
      btn.style.background  = active ? '#f0fafa' : 'white';
      btn.style.boxShadow   = active ? '0 0 0 3px rgba(27,168,154,0.18)' : 'none';
    });
  }

  function getYNValue(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return null;
    const active = el.querySelector('[data-selected="true"]');
    return active ? active.dataset.value : null;
  }

  function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function escAttr(s) {
    return String(s || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }
</script>
