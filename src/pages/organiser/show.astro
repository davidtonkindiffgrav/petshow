      el.className = 'flex items-center gap-3 p-3.5 rounded-[12px] border border-[#b8e4e0] bg-[#f0fafa]';
      el.innerHTML = `${photo}<div>
        <p class="text-[13.5px] font-bold text-[#1c1626]">${escAttr(judge.first_name)} ${escAttr(judge.last_name || '')}</p>
        ${judge.email ? `<p class="text-[12px] text-[#9b94a8]">${escAttr(judge.email)}</p>` : ''}
      </div>`;
    } else {
      el.className = 'flex items-center gap-3 p-3.5 rounded-[12px] border border-[#efebf5]';
      el.innerHTML = `
        <div class="w-10 h-10 rounded-full border-2 border-dashed border-[#c4bed0] flex items-center justify-center shrink-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
        </div>
        <div>
          <p class="text-[13px] font-semibold text-[#9b94a8]">No judge assigned yet</p>
          <p class="text-[12px] text-[#c4bed0]">Fill in the details below ↓</p>
        </div>`;
    }
