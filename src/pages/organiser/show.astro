        : '';
      return `<div style="display:flex;align-items:center;gap:8px;">
        <span style="font-size:10.5px;font-weight:700;color:#c4bed0;text-transform:uppercase;letter-spacing:0.05em;width:84px;flex-shrink:0;">${label}</span>
        <span style="display:flex;align-items:center;gap:6px;">
          ${thumb}
          <span style="font-size:12.5px;color:#4a4357;font-weight:500;">${url ? 'Uploaded' : 'Not set'}</span>
        </span>
      </div>`;
    }

    hdr.innerHTML = `
      <div style="display:flex;align-items:stretch;height:78px;overflow:hidden;">
        <div style="padding:16px 14px;flex-shrink:0;">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:5px;">
            <span style="width:8px;height:8px;border-radius:50%;background:${dot};flex-shrink:0;display:inline-block;"></span>
            <span style="font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:${textColor};">${statusText}</span>
          </div>
          <p style="font-size:15px;font-weight:800;color:#1c1626;line-height:1.2;margin:0;">Branding</p>
        </div>
        <div style="flex:1;padding:8px 6px;overflow:hidden;">
          ${bannerMiddle}
        </div>
        <div style="padding:16px 14px;flex-shrink:0;display:flex;align-items:flex-start;">
          <button class="action-btn text-[13px] font-bold text-brand hover:underline" data-panel="branding" style="background:none;border:none;cursor:pointer;padding:0;font-family:inherit;">Edit</button>
        </div>
      </div>
      <div style="padding:0 16px 16px;display:flex;flex-direction:column;gap:8px;border-top:1px solid #f5f3fa;margin-top:0;padding-top:12px;">
        ${thumbRow('Show Logo', show.logo_url)}
        ${thumbRow('Org Logo',  show.org_logo_url)}
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:10.5px;font-weight:700;color:#c4bed0;text-transform:uppercase;letter-spacing:0.05em;width:84px;flex-shrink:0;">Banner</span>
          <span style="font-size:12.5px;color:#4a4357;font-weight:500;">${show.banner_url ? 'Uploaded' : 'Not set'}</span>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:10.5px;font-weight:700;color:#c4bed0;text-transform:uppercase;letter-spacing:0.05em;width:84px;flex-shrink:0;">Website</span>
