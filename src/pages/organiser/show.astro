  function rebuildJudgePanels() {
    const container = document.getElementById('mgmt-judge-panels');
    container.innerHTML = '';
    { const i = 0;
      const j = judges[i] || { first_name: '', last_name: '', email: '', phone: '', photo_url: '' };
      const p = document.createElement('div');
      p.className = 'judge-panel border border-[#efebf5] rounded-[12px] p-4 space-y-3';

      const pickerHtml = savedJudges.length > 0 ? `
        <div class="relative judge-picker-wrap">
          <button type="button" class="judge-picker-btn text-[12px] font-semibold text-brand flex items-center gap-1.5 hover:underline">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Saved judges
          </button>
          <div class="judge-picker-dropdown" style="display:none;position:absolute;left:0;top:100%;margin-top:4px;z-index:30;background:white;border:1px solid #e6dcfb;border-radius:12px;box-shadow:0 4px 20px rgba(0,0,0,0.10);min-width:220px;overflow:hidden;padding:4px 0;">
            ${savedJudges.map(sj => `<button type="button" class="judge-pick-item w-full text-left px-4 py-2.5 hover:bg-[#f0fafa] transition-colors" data-id="${sj.id}"><span style="display:block;font-size:13px;font-weight:600;color:#1c1626;">${escAttr(sj.first_name)} ${escAttr(sj.last_name)}</span>${sj.email ? `<span style="display:block;font-size:11.5px;color:#9b94a8;">${escAttr(sj.email)}</span>` : ''}</button>`).join('')}
          </div>
        </div>` : '';

      const photoPreview = j.photo_url
        ? `<img src="${escAttr(j.photo_url)}" class="w-full h-full object-cover" />`
        : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`;

      p.innerHTML = `
        <div class="flex items-center justify-between">
          <p class="text-[12px] font-bold text-[#6f6880] uppercase tracking-wide">Judge</p>
          ${pickerHtml}
        </div>
        <div class="grid grid-cols-2 gap-3">
          <input type="text" class="j-first border border-[#b8e4e0] rounded-[10px] px-3 py-2 text-[13px] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" placeholder="First name" value="${escAttr(j.first_name)}" />
          <input type="text" class="j-last border border-[#b8e4e0] rounded-[10px] px-3 py-2 text-[13px] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" placeholder="Last name" value="${escAttr(j.last_name)}" />
        </div>
        <input type="email" class="j-email w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2 text-[13px] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" placeholder="Email address" value="${escAttr(j.email)}" />
        <input type="tel"   class="j-phone w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2 text-[13px] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" placeholder="Phone (optional)" value="${escAttr(j.phone || '')}" />
        <input type="hidden" class="j-photo-url" value="${escAttr(j.photo_url || '')}" />
        <label class="flex items-center gap-2 pt-1 cursor-pointer select-none">
          <input type="checkbox" class="j-save w-4 h-4 accent-brand" />
          <span class="text-[12px] text-[#9b94a8]">Save to my judge book</span>
        </label>
        <div class="flex items-center gap-3 pt-2 border-t border-[#f5f3f8]">
          <div class="w-10 h-10 rounded-full border-2 border-dashed border-[#b8e4e0] bg-[#f0fafa] flex items-center justify-center overflow-hidden judge-photo-circle shrink-0 cursor-pointer">
            ${photoPreview}
          </div>
          <div>
            <p class="text-[12px] font-semibold text-[#4a4357]">Profile Photo <span class="text-[11px] text-[#9b94a8] font-normal">(optional)</span></p>
            <button type="button" class="judge-photo-btn text-[12px] font-semibold text-brand hover:underline">${j.photo_url ? 'Replace photo' : 'Upload photo'}</button>
            <button type="button" class="judge-photo-remove text-[12px] font-semibold text-red-400 hover:underline ml-2" style="${j.photo_url ? '' : 'display:none'}">Remove</button>
            <input type="file" class="judge-photo-input hidden" accept="image/jpeg,image/png,image/webp" />
          </div>
        </div>`;

      const pickerBtn = p.querySelector('.judge-picker-btn');
      const dropdown  = p.querySelector('.judge-picker-dropdown');
      if (pickerBtn && dropdown) {
        pickerBtn.addEventListener('click', e => {
          e.stopPropagation();
          document.querySelectorAll('.judge-picker-dropdown').forEach(d => { if (d !== dropdown) d.style.display = 'none'; });
          dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
        });
        p.querySelectorAll('.judge-pick-item').forEach(btn => {
          btn.addEventListener('click', () => {
            const sj = savedJudges.find(s => s.id === btn.dataset.id);
            if (!sj) return;
            p.querySelector('.j-first').value = sj.first_name;
            p.querySelector('.j-last').value  = sj.last_name;
            p.querySelector('.j-email').value = sj.email || '';
            p.querySelector('.j-phone').value = sj.phone || '';
            p.querySelector('.j-photo-url').value = sj.photo_url || '';
            const circle = p.querySelector('.judge-photo-circle');
            const pBtn   = p.querySelector('.judge-photo-btn');
            if (sj.photo_url) {
              circle.innerHTML = `<img src="${sj.photo_url}" class="w-full h-full object-cover" />`;
              pBtn.textContent = 'Replace photo';
            } else {
              circle.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`;
              pBtn.textContent = 'Upload photo';
            }
            p.dataset.savedId = sj.id;
            dropdown.style.display = 'none';
          });
        });
      }

      const photoBtn     = p.querySelector('.judge-photo-btn');
      const photoInput   = p.querySelector('.judge-photo-input');
      const photoCircle  = p.querySelector('.judge-photo-circle');
      const photoUrlInput = p.querySelector('.j-photo-url');
      const photoRemove  = p.querySelector('.judge-photo-remove');

      async function processJudgePhoto(file) {
        if (!file || file.size > maxUploadMb * 1024 * 1024) return;
        photoBtn.textContent = 'Uploading…';
        showUploadOverlay('Uploading photo…');
        try {
          const url = await uploadImage(`judges/${showId}/judge-${i}`, file);
          photoUrlInput.value = url;
          photoCircle.innerHTML = `<img src="${url}" class="w-full h-full object-cover" />`;
          photoBtn.textContent = 'Replace photo';
          if (photoRemove) photoRemove.style.display = '';
        } catch { photoBtn.textContent = 'Failed — try again'; }
        finally { hideUploadOverlay(); }
      }

      photoRemove?.addEventListener('click', () => {
        photoUrlInput.value = '';
        photoCircle.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`;
        photoBtn.textContent = 'Upload photo';
        photoInput.value = '';
        photoRemove.style.display = 'none';
      });

      photoBtn.addEventListener('click', () => photoInput.click());
      photoInput.addEventListener('change', () => processJudgePhoto(photoInput.files[0]));
      photoCircle.addEventListener('click', () => photoInput.click());
      photoCircle.addEventListener('dragover', e => { e.preventDefault(); photoCircle.style.borderColor = '#1ba89a'; photoCircle.style.background = 'rgba(27,168,154,0.10)'; });
      photoCircle.addEventListener('dragleave', () => { photoCircle.style.borderColor = ''; photoCircle.style.background = ''; });
      photoCircle.addEventListener('drop', e => { e.preventDefault(); photoCircle.style.borderColor = ''; photoCircle.style.background = ''; processJudgePhoto(e.dataTransfer.files[0]); });

      container.appendChild(p);
    }
  }

  // ─── Awards panel ────────────────────────────────────────────────────────────
  // Mirrors the wizard's Step 7 (new-show.astro) — award "definition" rows
  // (Tier 1) plus a category->award assignment list (Tier 2). Rebuilds its
  // working arrays fresh from the shared categories/awards/sponsors module
  // state every time the drawer opens, decoupled from the Classes panel's
  // own mgmtClasses scratch state (these are independently-opened panels).
  function initAwardsPanel() {
    mgmtAwards      = awards.map(a => ({ ...a }));
    mgmtAssignments = categories.map(c => ({ id: c.id, name: c.name, award_id: c.award_id || null }));
    renderAwardRows();
  }

  function renderAwardRows() {
    const list = document.getElementById('mgmt-awards-list');
    list.innerHTML = '';
    mgmtAwards.forEach((award, i) => appendAwardRow(i));
    renderAwardAssignments();
  }

  function appendAwardRow(idx) {
    const award = mgmtAwards[idx];
    const list = document.getElementById('mgmt-awards-list');
    const row = document.createElement('div');
    row.className = 'border border-[#efebf5] rounded-[13px] p-3.5 bg-[#fafafc]';
    const sponsor = sponsors[0];
    const hasSponsorOption = !!(sponsor?.id && sponsor?.name);
    row.innerHTML = `
      <div class="flex items-start gap-2 mb-2.5">
        <div class="flex-1">
          <label class="block text-[10.5px] font-bold text-[#9b94a8] uppercase tracking-wide mb-1">Prize Name</label>
          <input type="text" value="${esc(award.name)}" placeholder="e.g. $50 Pet Store Voucher"
            class="award-name-input w-full border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[13px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <button type="button" class="award-remove shrink-0 text-[#c4bed0] hover:text-red-400 transition-colors mt-[22px]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="mb-2.5">
        <label class="block text-[10.5px] font-bold text-[#9b94a8] uppercase tracking-wide mb-1">Prize Description</label>
        <input type="text" value="${esc(award.physical_description || '')}" placeholder="e.g. Rosette + squeaky toy pack"
          class="award-desc-input w-full border border-[#efebf5] rounded-[11px] px-3 py-2 text-[12.5px] text-[#6f6880] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
      </div>
      <div class="mb-2.5">
        <label class="block text-[10.5px] font-bold text-[#9b94a8] uppercase tracking-wide mb-1">Prize Photo <span class="normal-case font-medium text-[#c4bed0]">(optional)</span></label>
        <div class="flex items-center gap-3">
          <img class="award-image-preview ${award.image_url ? '' : 'hidden'} h-9 rounded object-contain shrink-0" src="${award.image_url ? esc(award.image_url) : ''}" />
          <button type="button" class="award-image-btn text-[12px] font-semibold text-brand hover:underline">${award.image_url ? 'Replace photo' : 'Upload photo'}</button>
          <input type="file" class="award-image-input hidden" accept="image/jpeg,image/png,image/webp" />
        </div>
      </div>
      ${hasSponsorOption ? `
      <div class="mb-1">
        <label class="block text-[10.5px] font-bold text-[#9b94a8] uppercase tracking-wide mb-1">Sponsor <span class="normal-case font-medium text-[#c4bed0]">(optional)</span></label>
        <select class="award-sponsor-select w-full border border-[#b8e4e0] rounded-[11px] px-3 py-2 text-[12.5px] text-[#1c1626] bg-white focus:outline-none focus:ring-2 focus:ring-brand transition-colors">
          <option value="">No sponsor attribution</option>
          <option value="${sponsor.id}" ${award.sponsor_id === sponsor.id ? 'selected' : ''}>${esc(sponsor.name)}</option>
        </select>
      </div>` : ''}
      <button type="button" class="award-apply-all text-[11.5px] font-semibold text-brand hover:underline mt-2">Apply to all categories</button>
    `;
    list.appendChild(row);

    row.querySelector('.award-name-input').addEventListener('input', e => {
      const hadName = award.name.trim().length > 0;
      award.name = e.target.value;
      const hasName = award.name.trim().length > 0;
      if (!hadName && hasName && mgmtAwards.filter(a => a.name.trim()).length === 1) {
        mgmtAssignments.forEach(a => { if (!a.award_id) a.award_id = award.id; });
      }
      renderAwardAssignments();
    });
    row.querySelector('.award-remove').addEventListener('click', () => {
      mgmtAssignments.forEach(a => { if (a.award_id === award.id) a.award_id = null; });
      mgmtAwards.splice(idx, 1);
      renderAwardRows();
    });
    row.querySelector('.award-desc-input').addEventListener('input', e => { award.physical_description = e.target.value; });
    const sponsorSelect = row.querySelector('.award-sponsor-select');
    if (sponsorSelect) sponsorSelect.addEventListener('change', e => { award.sponsor_id = e.target.value || null; });
    row.querySelector('.award-apply-all').addEventListener('click', () => {
      mgmtAssignments.forEach(a => { a.award_id = award.id; });
      renderAwardAssignments();
    });

    const imgInput = row.querySelector('.award-image-input');
    const imgBtn   = row.querySelector('.award-image-btn');
    const imgPreview = row.querySelector('.award-image-preview');
    imgBtn.addEventListener('click', () => imgInput.click());
    imgInput.addEventListener('change', async () => {
      const file = imgInput.files[0];
      if (!file) return;
      if (file.size > maxUploadMb * 1024 * 1024) { imgBtn.textContent = `File too large (max ${maxUploadMb} MB)`; return; }
      imgBtn.textContent = 'Uploading…';
      showUploadOverlay();
      try {
        const url = await uploadImage(`awards/${showId}/${award.id}`, file);
        award.image_url = url;
        imgPreview.src = url;
        imgPreview.classList.remove('hidden');
        imgBtn.textContent = 'Replace photo';
      } catch { imgBtn.textContent = 'Upload failed — try again'; }
      finally { hideUploadOverlay(); }
    });
  }

  function renderAwardAssignments() {
    const wrap = document.getElementById('mgmt-assign-list');
    if (!wrap) return;
    if (mgmtAssignments.length === 0) {
      wrap.innerHTML = `<p class="text-[12.5px] text-[#9b94a8] py-3">Add categories in the Categories panel first.</p>`;
      return;
    }
    const validAwards = mgmtAwards.filter(a => a.name.trim());
    wrap.innerHTML = mgmtAssignments.map((cls, i) => {
      const options = ['<option value="">No award</option>']
        .concat(validAwards.map(a => `<option value="${a.id}" ${cls.award_id === a.id ? 'selected' : ''}>${esc(a.name)}</option>`));
      return `
        <div class="flex items-center justify-between gap-3 py-2.5 border-b border-[#f5f3f8] last:border-0">
          <span class="text-[13px] text-[#1c1626] font-medium">${esc(cls.name)}</span>
          <select data-idx="${i}" class="award-assign-select border border-[#b8e4e0] rounded-[10px] px-2.5 py-1.5 text-[12.5px] text-[#1c1626] bg-white focus:outline-none focus:ring-2 focus:ring-brand">
            ${options.join('')}
          </select>
        </div>`;
    }).join('');
    wrap.querySelectorAll('.award-assign-select').forEach(sel => {
      sel.addEventListener('change', e => {
        const i = parseInt(e.target.dataset.idx, 10);
        mgmtAssignments[i].award_id = e.target.value || null;
      });
    });
  }

  function getFeeValue() {
    return parseInt(document.getElementById('mgmt-entry-fee').value, 10) || 0;
  }

  function setFeeValue(v) {
    const code = document.getElementById('mgmt-currency')?.value || 'AUD';
    const min  = getMin(code);
    const val  = min != null ? clampFee(v, min) : Math.max(1, Math.round(v) || 1);
    document.getElementById('mgmt-entry-fee').value = String(val);
    const minus = document.getElementById('mgmt-fee-minus');
    if (minus) minus.disabled = (min != null && val <= min);
    updateFeeBreakdown(code);
  }

  function updateFeeBreakdown(code) {
    const sym   = CURRENCY_SYMBOLS[code] || code;
    const total = getFeeValue();
    const netEl = document.getElementById('mgmt-net-amount');
    const bdEl  = document.getElementById('mgmt-fee-breakdown');
    const net   = organiserNet(total, code, serviceFees);
    if (net == null) {
      if (netEl) netEl.textContent = 'Error';
      if (bdEl)  bdEl.textContent  = 'Fee settings unavailable — please refresh or contact support.';
      return;
    }
    const pf = platformFee(total, code, serviceFees);
    const sf = stripeFeeEstimate(total, code, serviceFees);
    if (netEl) netEl.textContent = `${sym}${net.toFixed(2)}`;
    if (bdEl)  bdEl.innerHTML = feeBreakdownRows(sym, total, pf, sf, net);
  }

  function feeBreakdownRows(sym, total, pf, sf, net) {
    const row = (label, value) =>
      `<div class="flex items-center justify-between"><span class="text-[12px] text-[#6f6880]">${label}</span><span class="text-[12px] font-semibold text-[#1c1626]">${value}</span></div>`;
    return [
      row('Entrant pays', `${sym}${total.toFixed(2)}`),
      row('Platform fee', `− ${sym}${pf.toFixed(2)}`),
      row('Card processing (estimate)', `− ${sym}${sf.toFixed(2)}`),
      `<div class="flex items-center justify-between border-t border-[#b8e4e0] pt-1.5"><span class="text-[12px] font-bold text-[#1c1626]">You receive per entry</span><span class="text-[13px] font-extrabold text-brand">≈ ${sym}${net.toFixed(2)}</span></div>`,
    ].join('');
  }

  function applyCurrencySymbol(code) {
    const sym = CURRENCY_SYMBOLS[code] || code;
    const goalEl = document.getElementById('mgmt-sym-goal');
    const feeEl  = document.getElementById('mgmt-sym-fee');
    const hintEl = document.getElementById('mgmt-fee-hint');
    if (goalEl) goalEl.textContent = sym;
    if (feeEl)  feeEl.textContent  = sym;
    const minFee = getMin(code);
    if (hintEl) hintEl.textContent = minFee != null
      ? `Minimum ${sym}${Number(minFee).toFixed(2)}`
      : 'Error — fee settings unavailable. Please refresh the page.';
    setFeeValue(getFeeValue());
  }

  // Toggles the $ prefix / placeholder on the goal input between money and a
  // plain entry count, depending on which the organiser is measuring towards.
  function updateGoalTypeUI() {
    const type = (document.getElementById('mgmt-goal-type') as HTMLSelectElement).value;
    const symEl = document.getElementById('mgmt-sym-goal');
    const input = document.getElementById('mgmt-fund-goal') as HTMLInputElement;
    if (type === 'entries') {
      symEl.style.display = 'none';
      input.classList.remove('pl-11'); input.classList.add('pl-4');
      input.placeholder = 'e.g. 100';
    } else {
      symEl.style.display = '';
      input.classList.remove('pl-4'); input.classList.add('pl-11');
      input.placeholder = '0.00';
    }
  }

  function closeShowDateModal() {
    document.getElementById('show-date-modal').style.display = 'none';
  }

  // ── Shared card / toggle helpers ─────────────────────────────────────────────
  function selectCard(container, value) {
    if (!container) return;
    container.querySelectorAll('[data-value]').forEach(card => {
      if (card.disabled) return;
      const active = card.dataset.value === value;
      card.dataset.selected  = active ? 'true' : 'false';
      card.style.borderColor = active ? '#1ba89a' : '#b8e4e0';
      card.style.background  = active ? '#f0fafa' : 'white';
      card.style.boxShadow   = active ? '0 0 0 3px rgba(27,168,154,0.18)' : 'none';
    });
  }

  function getSelectedCard(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return null;
    const active = el.querySelector('[data-selected="true"]');
    return active ? active.dataset.value : null;
  }

  function setupToggle(btnId, onChange) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.addEventListener('click', () => {
      const on = btn.dataset.on !== 'true';
      btn.dataset.on = String(on);
      btn.style.background = on ? '#1ba89a' : '#c4bed0';
      btn.querySelector('span').style.transform = on ? 'translateX(20px)' : 'translateX(0)';
      onChange(on);
    });
  }

  function setToggle(btnId, on) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.dataset.on = String(on);
    btn.style.background = on ? '#1ba89a' : '#c4bed0';
    btn.querySelector('span').style.transform = on ? 'translateX(20px)' : 'translateX(0)';
  }

  function setupYN(containerId, onChange) {
    const el = document.getElementById(containerId);
    if (!el) return;
    el.querySelectorAll('.yn').forEach(btn => {
      btn.addEventListener('click', () => {
        el.querySelectorAll('.yn').forEach(b => {
          b.dataset.selected = 'false';
          b.style.borderColor = '#b8e4e0'; b.style.background = 'white'; b.style.boxShadow = 'none';
        });
        btn.dataset.selected  = 'true';
        btn.style.borderColor = '#1ba89a';
        btn.style.background  = '#f0fafa';
        btn.style.boxShadow   = '0 0 0 3px rgba(27,168,154,0.18)';
        onChange(btn.dataset.value);
      });
    });
  }

  function setYN(containerId, value) {
    const el = document.getElementById(containerId);
    if (!el || !value) return;
    el.querySelectorAll('.yn').forEach(btn => {
      const active = btn.dataset.value === value;
      btn.dataset.selected  = active ? 'true' : 'false';
      btn.style.borderColor = active ? '#1ba89a' : '#b8e4e0';
      btn.style.background  = active ? '#f0fafa' : 'white';
      btn.style.boxShadow   = active ? '0 0 0 3px rgba(27,168,154,0.18)' : 'none';
    });
  }

  function getYNValue(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return null;
    const active = el.querySelector('[data-selected="true"]');
    return active ? active.dataset.value : null;
  }

  function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function escAttr(s) {
    return String(s || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }
</script>
