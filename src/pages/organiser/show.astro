  // ── Save handlers ─────────────────────────────────────────────────────────────
  async function saveSection(panelId, payload, postSave) {
    const panel   = document.getElementById(`panel-${panelId}`);
    const saveBtn = panel?.querySelector('.save-btn');
    const errEl   = panel?.querySelector('.panel-error');
    if (errEl) { errEl.style.display = 'none'; errEl.textContent = ''; }
    const orig = saveBtn?.textContent;
    if (saveBtn) { saveBtn.textContent = 'Saving…'; saveBtn.disabled = true; }

    const { error } = await supabase.from('shows').update(payload).eq('id', showId);

    if (saveBtn) { saveBtn.textContent = orig; saveBtn.disabled = false; }
    if (error) { if (errEl) { errEl.textContent = error.message; errEl.style.display = 'block'; } return; }

    Object.assign(show, payload);
    if (postSave) await postSave();
    renderAllHeaders();
    closeDrawer();
  }

  function initBrandingWidget(widgetId, key) {
    const el      = document.getElementById(widgetId);
    if (!el) return;
    const input   = el.querySelector('.upload-input');
    const trigger = el.querySelector('.upload-trigger');
    const preview = el.querySelector('.upload-preview');
    const label   = el.querySelector('.upload-label');
    const icon    = el.querySelector('.upload-icon');
    // Restore current image
    const currentUrl = key === 'logo' ? show?.logo_url : key === 'orgLogo' ? show?.org_logo_url : show?.banner_url;
    if (currentUrl) {
      preview.src = currentUrl; preview.classList.remove('hidden');
      if (icon) icon.classList.add('hidden');
      label.textContent = 'Click to replace';
    } else {
      preview.src = ''; preview.classList.add('hidden');
      if (icon) icon.classList.remove('hidden');
      label.textContent = 'Click to upload';
    }
    // Clear any previously queued file
    pendingBranding[key] = null;
    input.value = '';
    function processFile(file) {
      if (!file) return;
      if (file.size > maxUploadMb * 1024 * 1024) { label.textContent = `Too large (max ${maxUploadMb} MB)`; return; }
      pendingBranding[key] = file;
      const reader = new FileReader();
      reader.onload = e => {
        preview.src = e.target.result; preview.classList.remove('hidden');
        if (icon) icon.classList.add('hidden');
        label.textContent = 'Click to replace (unsaved)';
      };
      reader.readAsDataURL(file);
    }

    trigger.onclick  = () => input.click();
    input.onchange   = () => processFile(input.files[0]);

    trigger.ondragover = e => {
      e.preventDefault();
      trigger.style.borderColor = '#1ba89a';
      trigger.style.background  = 'rgba(27,168,154,0.06)';
    };
    trigger.ondragleave = () => {
      trigger.style.borderColor = '';
      trigger.style.background  = '';
    };
    trigger.ondrop = e => {
      e.preventDefault();
      trigger.style.borderColor = '';
      trigger.style.background  = '';
      processFile(e.dataTransfer.files[0]);
    };
  }

  async function saveBranding() {
    const panel   = document.getElementById('panel-branding');
    const saveBtn = panel?.querySelector('.save-btn');
    const errEl   = panel?.querySelector('.panel-error');
    if (errEl) { errEl.style.display = 'none'; errEl.textContent = ''; }
    if (saveBtn) { saveBtn.textContent = 'Saving…'; saveBtn.disabled = true; }
    try {
      const updates: any = {
        logo_source: getSelectedCard('branding-logo-source-cards') || 'show',
        website_url: (document.getElementById('branding-website-url') as HTMLInputElement).value.trim() || null,
      };
      if (pendingBranding.logo)    updates.logo_url     = await uploadImage(`shows/${showId}/logo`,     pendingBranding.logo);
      if (pendingBranding.orgLogo) updates.org_logo_url = await uploadImage(`shows/${showId}/org-logo`, pendingBranding.orgLogo);
      if (pendingBranding.banner)  updates.banner_url   = await uploadImage(`shows/${showId}/banner`,   pendingBranding.banner);
      {
        const { error } = await supabase.from('shows').update(updates).eq('id', showId);
        if (error) throw error;
        Object.assign(show, updates);
      }
      pendingBranding = { logo: null, orgLogo: null, banner: null };
      renderAllHeaders();
      closeDrawer();
    } catch (err) {
      if (errEl) { errEl.textContent = err.message || 'Upload failed'; errEl.style.display = 'block'; }
    } finally {
      if (saveBtn) { saveBtn.textContent = 'Save changes'; saveBtn.disabled = false; }
    }
  }

  async function saveBasics() {
    const title   = document.getElementById('mgmt-title').value.trim();
    const email   = document.getElementById('mgmt-contact-email').value.trim();
    const orgType = getSelectedCard('mgmt-org-type-cards');
    if (!title) return showPanelError('basics', 'Please enter a show name.');
    if (!email || !email.includes('@')) return showPanelError('basics', 'Please enter a valid contact email.');
    if (!orgType) return showPanelError('basics', 'Please select a type of organisation.');
    const needsNum = orgType === 'registered_charity' || orgType === 'non_profit';
    const charityNum = document.getElementById('mgmt-charity-number').value.trim();
    if (needsNum && !charityNum) return showPanelError('basics', 'Please enter your Charity / Non-Profit Number.');
    await saveSection('basics', {
      title, org_type: orgType,
      host_org: document.getElementById('mgmt-host-org').value.trim() || null,
      description: (document.getElementById('mgmt-description') as HTMLTextAreaElement).value.trim() || null,
      charity_number: needsNum ? charityNum || null : null,
      contact_email: email,
      contact_phone: document.getElementById('mgmt-contact-phone').value.trim() || null,
      entry_open_date:   document.getElementById('mgmt-entry-open').value        || null,
      entry_open_time:   document.getElementById('mgmt-entry-open-time').value   || null,
      entry_close_date:  document.getElementById('mgmt-entry-close').value       || null,
      entry_close_time:  document.getElementById('mgmt-entry-close-time').value  || null,
      show_date:         document.getElementById('mgmt-show-date').value          || null,
      timezone:          document.getElementById('mgmt-timezone').value           || null,
