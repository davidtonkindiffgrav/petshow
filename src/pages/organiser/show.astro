  async function saveJudging() {
    const val = getYNValue('mgmt-judging-yn');
    if (!val) return showPanelError('judging', 'Please make a selection.');
    if (val === 'yes') {
      const panels = Array.from(document.querySelectorAll('#mgmt-judge-panels .judge-panel'));
      // Check for judge book duplicates before saving
      let hasDuplicates = false;
      for (const p of panels) {
        if (p.dataset.savedId) continue; // came from picker or already resolved
        const em = p.querySelector('.j-email').value.trim().toLowerCase();
        if (!em) continue;
        const match = savedJudges.find(sj => sj.email?.toLowerCase() === em);
        if (!match) continue;
        showDuplicatePrompt(p, match);
        hasDuplicates = true;
      }
      if (hasDuplicates) return;

      const newJudges = panels.map(p => ({
        show_id:    showId,
        first_name: p.querySelector('.j-first').value.trim(),
        last_name:  p.querySelector('.j-last').value.trim(),
        email:      p.querySelector('.j-email').value.trim(),
        phone:      p.querySelector('.j-phone').value.trim() || null,
        photo_url:  p.querySelector('.j-photo-url').value || null,
      }));
      // Save ticked judges to saved_judges (skip duplicates by email)
      for (const p of panels) {
        if (!p.querySelector('.j-save')?.checked) continue;
        const fn = p.querySelector('.j-first').value.trim();
        const ln = p.querySelector('.j-last').value.trim();
        const em = p.querySelector('.j-email').value.trim() || null;
        const ph = p.querySelector('.j-phone').value.trim() || null;
        const pu = p.querySelector('.j-photo-url').value || null;
        if (!fn || !ln) continue;
        if (em && savedJudges.some(sj => sj.email?.toLowerCase() === em.toLowerCase())) continue;
        const { data: newSJ } = await supabase.from('saved_judges')
          .insert({ organiser_id: show.created_by, first_name: fn, last_name: ln, email: em, phone: ph, photo_url: pu })
          .select().single();
        if (newSJ) savedJudges.push(newSJ);
      }
      await saveSection('judging', { is_judged: true, judge_count: 1 }, async () => {
        await supabase.from('show_judges').delete().eq('show_id', showId);
        if (newJudges.some(j => j.first_name)) await supabase.from('show_judges').insert(newJudges.filter(j => j.first_name));
        const { data } = await supabase.from('show_judges').select('*').eq('show_id', showId);
        judges = data || [];
        renderMgmtJudgeDisplay();
      });
    } else {
      await saveSection('judging', { is_judged: false }, async () => {
        await supabase.from('show_judges').delete().eq('show_id', showId);
        judges = [];
      });
    }
  }

