  // ─── Publish / Save draft ───────────────────────────────────────────────────
  async function finalSave(status) {
    if (!show.id) return;
    await supabase.from('shows').update({ status, wizard_step: 10 }).eq('id', show.id);
    window.location.href = status === 'published'
      ? `${base}show/?id=${show.id}`
      : base + 'organiser';
  }

  // ─── Draft resume ────────────────────────────────────────────────────────────
  async function loadDraft(id) {
    const [{ data }, { data: sponsorData }, { data: judgesData }, { data: prizesData }, { data: cats }] = await Promise.all([
      supabase.from('shows').select('*').eq('id', id).single(),
      supabase.from('show_sponsors').select('*').eq('show_id', id),
      supabase.from('show_judges').select('*').eq('show_id', id),
      supabase.from('show_prizes').select('description').eq('show_id', id),
      supabase.from('show_categories').select('name, description').eq('show_id', id),
    ]);
    if (!data) return;

    Object.assign(show, {
      id: data.id,
      title: data.title || '',
      host_org: data.host_org || '',
      description: data.description || null,
      website_url: data.website_url || null,
      org_type: data.org_type,
      charity_number: data.charity_number || '',
      contact_email: data.contact_email || '',
      contact_phone: data.contact_phone || '',
      entry_open_date: (data.entry_open_date || '').slice(0, 10),
      entry_close_date: (data.entry_close_date || '').slice(0, 10),
      show_date: (data.show_date || '').slice(0, 10),
      show_time: data.show_time || '',
      vote_open_mode: data.vote_open_mode || 'after_entries_close',
      show_type: data.show_type,
      animal_type: data.animal_type || 'dog',
      breed_scope: data.breed_scope || 'all',
      breed_filter: data.breed_filter || '',
      group_filter: data.group_filter || '',
      has_sponsor: data.has_sponsor,
      sponsors: sponsorData?.length > 0
        ? sponsorData.map(s => ({ name: s.name || '', website: s.website || '', logo_url: s.logo_url || '' }))
        : [{ name: '', website: '', logo_url: '' }],
      is_judged: data.is_judged,
      judge_setup: data.judge_setup || 'later',
      judges: judgesData?.length > 0
        ? judgesData.map(j => ({ first_name: j.first_name || '', last_name: j.last_name || '', email: j.email || '', phone: j.phone || '', photo_url: j.photo_url || '' }))
        : [],
      has_digital_certs: data.has_digital_certs,
      has_physical_prizes: data.has_physical_prizes,
      prize_source: data.prize_source,
      prizes: prizesData?.map(p => p.description) || [],
      classes: cats?.length > 0 ? cats.map(c => ({ name: c.name, description: c.description || '', enabled: true, custom: false })) : [],
      is_fundraising: data.is_fundraising ?? true,
      fundraising_goal: data.fundraising_goal,
      show_fundraising_publicly: data.show_fundraising_publicly,
      currency: data.currency || 'AUD',
      entry_fee: data.entry_fee || 0,
      logo_url: data.logo_url || '',
      banner_url: data.banner_url || '',
      org_logo_url: data.org_logo_url || '',
      logo_source: data.logo_source || 'show',
      timezone: data.timezone || show.timezone,
      entry_open_time: data.entry_open_time || '',
      entry_close_time: data.entry_close_time || '',
    });

    // Restore upload previews
    if (show.logo_url)     restoreUploadPreview(document.getElementById('s9-logo-widget'),     show.logo_url);
    if (show.banner_url)   restoreUploadPreview(document.getElementById('s9-banner-widget'),   show.banner_url);
    if (show.org_logo_url) restoreUploadPreview(document.getElementById('s9-org-logo-widget'), show.org_logo_url);
    selectCard(document.getElementById('s9-logo-source-cards'), show.logo_source || 'show');
    if (show.sponsors[0]?.logo_url) restoreUploadPreview(document.getElementById('s5-logo-widget'), show.sponsors[0].logo_url);

    // Step 1
    document.getElementById('s1-title').value         = show.title;
    document.getElementById('s1-host-org').value      = show.host_org;
    document.getElementById('s1-description').value   = show.description || '';
    document.getElementById('s1-about').value          = show.about || '';
    document.getElementById('s1-website-url').value   = show.website_url || '';
    document.getElementById('s1-entry-open').value       = show.entry_open_date;
    document.getElementById('s1-entry-open-time').value  = show.entry_open_time  || '12:00';
    document.getElementById('s1-entry-close').value      = show.entry_close_date;
    document.getElementById('s1-entry-close-time').value = show.entry_close_time || '12:00';
    document.getElementById('s1-show-date').value        = show.show_date;
    document.getElementById('s1-show-time').value        = show.show_time || '';
    document.getElementById('s1-contact-email').value    = show.contact_email;
    document.getElementById('s1-contact-phone').value    = show.contact_phone;
    const tzSel = document.getElementById('s1-timezone');
    if (tzSel && show.timezone) tzSel.value = show.timezone;
    if (show.org_type) selectCard(document.getElementById('org-type-cards'), show.org_type);
    if (show.org_type === 'registered_charity' || show.org_type === 'non_profit') {
      document.getElementById('s1-charity-field').style.display = 'block';
      document.getElementById('s1-charity-number').value = show.charity_number;
    }

    // Step 2
    if (show.animal_type) selectCard(document.getElementById('animal-type-cards'), show.animal_type);

    // Step 3
    selectCard(document.getElementById('breed-scope-cards'), show.breed_scope);
    updateBreedFields();
    document.getElementById('s3-breed').value = show.breed_filter;
    document.getElementById('s3-group').value = show.group_filter;

    // Step 5 — sponsor
    if (show.has_sponsor !== null) {
      setYNA('sponsor-choice', show.has_sponsor === true ? 'yes' : show.has_sponsor === false ? 'no' : 'later');
      if (show.has_sponsor) {
        document.getElementById('s5-sponsor-form').style.display = 'block';
        document.getElementById('s5-sponsor-name').value    = show.sponsors[0]?.name || '';
        document.getElementById('s5-sponsor-website').value = show.sponsors[0]?.website || '';
      }
    }

    // Step 6 — judging
    if (show.is_judged !== null) {
      setYNA('judging-choice', show.is_judged === true ? 'yes' : show.is_judged === false ? 'no' : 'later');
      if (show.is_judged === false) {
        document.getElementById('s6-vote-timing').style.display = 'block';
        selectCard(document.getElementById('vote-timing-cards'), show.vote_open_mode || 'after_entries_close');
      }
      if (show.is_judged) {
        document.getElementById('s6-judge-form').style.display = 'block';
        if (show.judge_setup) {
          selectCard(document.getElementById('judge-setup-cards'), show.judge_setup);
          if (show.judge_setup === 'now') {
            document.getElementById('s6-judge-fields').style.display = 'block';
            updateJudgePanels();
          }
        }
      }
    }

    // Step 7 — awards
    const awardsSet = data.has_digital_certs !== null || data.has_physical_prizes !== null;
    if (awardsSet) {
      setYNA('awards-choice', 'yes');
      document.getElementById('s7-awards-form').style.display = 'block';
      setToggle('s7-certs-toggle', !!show.has_digital_certs);
      setToggle('s7-physical-toggle', !!show.has_physical_prizes);
      if (show.has_physical_prizes) {
        document.getElementById('s7-physical-form').style.display = 'block';
        if (show.prize_source) selectCard(document.getElementById('prize-source-cards'), show.prize_source);
        const list = document.getElementById('s7-prize-list');
        list.innerHTML = '';
        show.prizes.forEach((desc, idx) => {
          const row = document.createElement('div');
          row.className = 'flex items-center gap-2';
          row.innerHTML = `
            <input type="text" value="${esc(desc)}" placeholder="e.g. $50 Pet Store Voucher"
              class="flex-1 border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[14px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
            <button type="button" class="prize-remove text-[#c4bed0] hover:text-red-400 transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          `;
          row.querySelector('input').addEventListener('input', e => { show.prizes[idx] = e.target.value; });
          row.querySelector('.prize-remove').addEventListener('click', () => { row.remove(); show.prizes.splice(idx, 1); });
          list.appendChild(row);
        });
      }
    }

    // Step 8 — fees
    if (show.fundraising_goal) document.getElementById('s8-fund-goal').value = show.fundraising_goal;
    setToggle('s8-public-toggle', !!show.show_fundraising_publicly);
    if (show.currency) document.getElementById('s8-currency').value = show.currency;
    setFeeValue(Number(show.entry_fee) || getMin(show.currency || 'AUD') || 3);
    applyCurrencySymbol(show.currency || 'AUD');
    updatePublicToggleAvailability();

    goToStep(Math.min(data.wizard_step || 1, 10));
  }

  // ─── Upload widget helpers ────────────────────────────────────────────────────
  function initUploadWidget(el, getPath, onUrl) {
    if (!el) return;
    const input   = el.querySelector('.upload-input');
    const trigger = el.querySelector('.upload-trigger');
    const preview = el.querySelector('.upload-preview');
    const label   = el.querySelector('.upload-label');
    const icon    = el.querySelector('.upload-icon');

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'upload-remove';
    removeBtn.textContent = 'Remove image';
    removeBtn.style.cssText = 'display:none;background:none;border:none;color:#ef4444;font-size:11.5px;font-weight:600;cursor:pointer;margin-top:6px;padding:0;font-family:inherit';
    el.appendChild(removeBtn);
    removeBtn.addEventListener('click', () => {
      preview.src = '';
      preview.classList.add('hidden');
      if (icon) icon.classList.remove('hidden');
      label.textContent = 'Click to upload';
      input.value = '';
      removeBtn.style.display = 'none';
      onUrl(null);
    });

    async function processFile(file) {
      if (!file) return;
      if (file.size > maxUploadMb * 1024 * 1024) { label.textContent = `File too large (max ${maxUploadMb} MB)`; return; }
      const path = getPath();
      if (!path) { label.textContent = 'Save show progress first'; return; }
      label.textContent = 'Uploading…';
      showUploadOverlay();
      try {
        const url = await uploadImage(path, file);
        preview.src = url;
        preview.classList.remove('hidden');
        if (icon) icon.classList.add('hidden');
        label.textContent = 'Click to replace';
        removeBtn.style.display = 'inline-block';
        onUrl(url);
      } catch { label.textContent = 'Upload failed — try again'; }
      finally { hideUploadOverlay(); }
    }

    trigger.addEventListener('click', () => input.click());
    input.addEventListener('change', () => processFile(input.files[0]));

    trigger.addEventListener('dragover', e => {
      e.preventDefault();
      trigger.style.borderColor = '#1ba89a';
      trigger.style.background  = 'rgba(27,168,154,0.06)';
    });
    trigger.addEventListener('dragleave', () => {
      trigger.style.borderColor = '';
      trigger.style.background  = '';
    });
    trigger.addEventListener('drop', e => {
      e.preventDefault();
      trigger.style.borderColor = '';
      trigger.style.background  = '';
      processFile(e.dataTransfer.files[0]);
    });
  }

  function restoreUploadPreview(el, url) {
    if (!el || !url) return;
    const preview = el.querySelector('.upload-preview');
    const label   = el.querySelector('.upload-label');
    const icon    = el.querySelector('.upload-icon');
    const removeBtn = el.querySelector('.upload-remove');
    if (preview) { preview.src = url; preview.classList.remove('hidden'); }
    if (icon)    icon.classList.add('hidden');
    if (label)   label.textContent = 'Click to replace';
    if (removeBtn) removeBtn.style.display = 'inline-block';
  }

  // ─── Misc helpers ────────────────────────────────────────────────────────────
  function updateBreedFields() {
    document.getElementById('s3-breed-field').style.display = show.breed_scope === 'breed_specific' ? 'block' : 'none';
    document.getElementById('s3-group-field').style.display = show.breed_scope === 'group_specific' ? 'block' : 'none';
  }

  // ─── Timezone select ─────────────────────────────────────────────────────────
  function initTimezoneSelect() {
    const sel = document.getElementById('s1-timezone');
    if (!sel) return;
    sel.innerHTML = TIMEZONES.map(g =>
      `<optgroup label="${g.group}">${g.zones.map(z =>
        `<option value="${z.id}">${z.label}</option>`
      ).join('')}</optgroup>`
    ).join('');
    // Prefer show.timezone (which is already set from profile default or browser detection)
    sel.value = show.timezone || Intl.DateTimeFormat().resolvedOptions().timeZone;
    // If the browser tz isn't in our curated list, the assignment silently fails — fall back
    if (!sel.value) sel.value = 'Australia/Sydney';
  }

  // ─── Category tooltip ────────────────────────────────────────────────────────
  const _tip = document.createElement('div');
  _tip.style.cssText = 'display:none;position:fixed;z-index:9999;background:#1c1626;color:#fff;font-size:12px;line-height:1.5;border-radius:8px;padding:7px 11px;max-width:220px;pointer-events:none;box-shadow:0 4px 14px rgba(0,0,0,0.22);';
  document.body.appendChild(_tip);

  function _posTip(e) {
    const x = e.clientX + 14, y = e.clientY + 16;
    _tip.style.left = Math.min(x, window.innerWidth  - _tip.offsetWidth  - 8) + 'px';
    _tip.style.top  = Math.min(y, window.innerHeight - _tip.offsetHeight - 8) + 'px';
  }

  function attachTooltip(el, desc) {
    if (!desc) return;
    el.addEventListener('mouseenter', e => { _tip.textContent = desc; _tip.style.display = 'block'; _posTip(e); });
    el.addEventListener('mousemove', _posTip);
    el.addEventListener('mouseleave', () => { _tip.style.display = 'none'; });
  }

  // ─── Event listeners setup ──────────────────────────────────────────────────
  function initCardGroups() {
    // Step 1: org type
    document.getElementById('org-type-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectCard(document.getElementById('org-type-cards'), btn.dataset.value);
        const needsNum = btn.dataset.value === 'registered_charity' || btn.dataset.value === 'non_profit';
        document.getElementById('s1-charity-field').style.display = needsNum ? 'block' : 'none';
      });
    });
    // Step 2: animal type
    document.getElementById('animal-type-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => { selectCard(document.getElementById('animal-type-cards'), btn.dataset.value); });
    });
    // Default animal: dog
    selectCard(document.getElementById('animal-type-cards'), 'dog');
    // Step 3: breed scope
    document.getElementById('breed-scope-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectCard(document.getElementById('breed-scope-cards'), btn.dataset.value);
        show.breed_scope = btn.dataset.value;
        updateBreedFields();
      });
    });
    selectCard(document.getElementById('breed-scope-cards'), 'all');
    // Step 4: add category
    document.getElementById('s4-add-funstakes').addEventListener('click', () => {
      show.classes.push({ name: '', description: '', enabled: true, custom: true });
      renderFunStakesCategories();
    });
    // Step 5: sponsorship YNA
    setupYNA('sponsor-choice', val => {
      document.getElementById('s5-sponsor-form').style.display = val === 'yes' ? 'block' : 'none';
    });
    // Step 6: judging YNA + judge count + setup cards
    setupYNA('judging-choice', val => {
      document.getElementById('s6-judge-form').style.display = val === 'yes' ? 'block' : 'none';
      document.getElementById('s6-vote-timing').style.display = val === 'no' ? 'block' : 'none';
      if (val === 'no' && !getSelectedCard('vote-timing-cards')) {
        selectCard(document.getElementById('vote-timing-cards'), show.vote_open_mode || 'after_entries_close');
      }
    });
    document.getElementById('vote-timing-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectCard(document.getElementById('vote-timing-cards'), btn.dataset.value);
        show.vote_open_mode = btn.dataset.value;
      });
    });
    document.getElementById('judge-setup-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectCard(document.getElementById('judge-setup-cards'), btn.dataset.value);
        show.judge_setup = btn.dataset.value;
        document.getElementById('s6-judge-fields').style.display = btn.dataset.value === 'now' ? 'block' : 'none';
        if (btn.dataset.value === 'now') updateJudgePanels();
      });
    });
    // Step 7: awards YNA + toggles + prize source
    setupYNA('awards-choice', val => {
      document.getElementById('s7-awards-form').style.display = val === 'yes' ? 'block' : 'none';
    });
    setupToggle('s7-certs-toggle', on => { show.has_digital_certs = on; });
    setupToggle('s7-physical-toggle', on => {
      show.has_physical_prizes = on;
      document.getElementById('s7-physical-form').style.display = on ? 'block' : 'none';
    });
    document.getElementById('prize-source-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => { selectCard(document.getElementById('prize-source-cards'), btn.dataset.value); });
    });
    document.getElementById('s7-add-prize').addEventListener('click', addPrizeRow);
    // Close judge picker dropdowns when clicking outside
    document.addEventListener('click', () => {
      document.querySelectorAll('.judge-picker-dropdown').forEach(d => { d.style.display = 'none'; });
    });
    // Step 8: public toggle + currency selector + fee stepper
    setupToggle('s8-public-toggle', on => { show.show_fundraising_publicly = on; });
    document.getElementById('s8-fund-goal').addEventListener('input', updatePublicToggleAvailability);
    document.getElementById('s8-currency').addEventListener('change', e => {
      applyCurrencySymbol(e.target.value);
    });
    document.getElementById('s8-fee-minus').addEventListener('click', () => setFeeValue(getFeeValue() - 1));
    document.getElementById('s8-fee-plus').addEventListener('click', () => setFeeValue(getFeeValue() + 1));
    // Step 5: sponsor logo
    initUploadWidget(
      document.getElementById('s5-logo-widget'),
      () => show.id ? `sponsors/${show.id}/sponsor-0` : null,
      url => { show.sponsors[0].logo_url = url; }
    );
    // Step 9: logo source toggle
    document.getElementById('s9-logo-source-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectCard(document.getElementById('s9-logo-source-cards'), btn.dataset.value);
        show.logo_source = btn.dataset.value;
      });
    });
    selectCard(document.getElementById('s9-logo-source-cards'), show.logo_source || 'show');
    // Step 9: branding widgets
    initUploadWidget(
      document.getElementById('s9-logo-widget'),
      () => show.id ? `shows/${show.id}/logo` : null,
      url => { show.logo_url = url; }
    );
    initUploadWidget(
      document.getElementById('s9-org-logo-widget'),
      () => show.id ? `shows/${show.id}/org-logo` : null,
      url => { show.org_logo_url = url; }
    );
    initUploadWidget(
      document.getElementById('s9-banner-widget'),
      () => show.id ? `shows/${show.id}/banner` : null,
      url => { show.banner_url = url; }
    );
  }

  function getFeeValue() {
    return parseInt(document.getElementById('s8-entry-fee').value, 10) || 0;
  }

  function setFeeValue(v) {
    const code = document.getElementById('s8-currency')?.value || 'AUD';
    const min  = getMin(code);
    const val  = min != null ? clampFee(v, min) : Math.max(1, Math.round(v) || 1);
    document.getElementById('s8-entry-fee').value = String(val);
    const minus = document.getElementById('s8-fee-minus');
    if (minus) minus.disabled = (min != null && val <= min);
    updateFeeBreakdown(code);
  }

  function updateFeeBreakdown(code) {
    const sym   = CURRENCY_SYMBOLS[code] || code;
    const total = getFeeValue();
    const netEl = document.getElementById('s8-net-amount');
    const bdEl  = document.getElementById('s8-fee-breakdown');
    const net   = organiserNet(total, code, serviceFees);
    if (net == null) {
      if (netEl) netEl.textContent = 'Error';
      if (bdEl)  bdEl.textContent  = 'Fee settings unavailable — please refresh or contact support.';
      return;
    }
    const pf = platformFee(total, code, serviceFees);
    const sf = stripeFeeEstimate(total, code, serviceFees);
    if (netEl) netEl.textContent = `${sym}${net.toFixed(2)}`;
    if (bdEl)  bdEl.innerHTML = feeBreakdownRows(sym, total, pf, sf, net);
  }

  function feeBreakdownRows(sym, total, pf, sf, net) {
    const row = (label, value) =>
      `<div class="flex items-center justify-between"><span class="text-[12px] text-[#6f6880]">${label}</span><span class="text-[12px] font-semibold text-[#1c1626]">${value}</span></div>`;
    return [
      row('Entrant pays', `${sym}${total.toFixed(2)}`),
      row('Platform fee', `− ${sym}${pf.toFixed(2)}`),
      row('Card processing (estimate)', `− ${sym}${sf.toFixed(2)}`),
      `<div class="flex items-center justify-between border-t border-[#b8e4e0] pt-1.5"><span class="text-[12px] font-bold text-[#1c1626]">You receive per entry</span><span class="text-[13px] font-extrabold text-brand">≈ ${sym}${net.toFixed(2)}</span></div>`,
    ].join('');
  }

  function applyCurrencySymbol(code) {
    const sym = CURRENCY_SYMBOLS[code] || code;
    document.getElementById('s8-symbol-fee').textContent = sym;
    document.getElementById('s8-symbol-goal').textContent = sym;
    const minFee2 = getMin(code);
    document.getElementById('s8-fee-hint').textContent = minFee2 != null
      ? `Minimum ${sym}${minFee2}`
      : 'Error — fee settings unavailable. Please refresh the page.';
    setFeeValue(getFeeValue());
  }

  // Fundraising progress can only be shown publicly once a goal is set — otherwise
  // the public page renders a permanently-0% bar with no goal to reach.
  function updatePublicToggleAvailability() {
    const goalVal = parseFloat(document.getElementById('s8-fund-goal').value) || 0;
    const enabled = goalVal > 0;
    const toggle = document.getElementById('s8-public-toggle');
    const hint = document.getElementById('s8-public-toggle-hint');
    toggle.disabled = !enabled;
    hint.textContent = enabled
      ? 'Show a progress bar on the public show page'
      : 'Set a fundraising goal above to enable';
    if (!enabled) setToggle('s8-public-toggle', false);
  }

  function setupEventListeners() {
    document.getElementById('btn-next').addEventListener('click', async () => {
      if (!validateStep(currentStep)) return;
      readStep(currentStep);
      const btnNext = document.getElementById('btn-next');
      btnNext.textContent = 'Saving…';
      btnNext.disabled = true;
      const stepOk = await saveShow(currentStep);
      btnNext.innerHTML = 'Continue <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
      btnNext.disabled = false;
      if (stepOk !== false) goToStep(currentStep + 1);
    });

    document.getElementById('btn-back').addEventListener('click', () => { goToStep(currentStep - 1); });

    document.getElementById('action-save-draft').addEventListener('click', async () => {
      readStep(currentStep);
      await saveShow(currentStep);
      window.location.href = base + 'organiser';
    });

    document.getElementById('btn-publish').addEventListener('click', async () => {
      document.getElementById('btn-publish').textContent = 'Publishing…';
      await finalSave('published');
    });

    document.getElementById('btn-save-draft-final').addEventListener('click', async () => {
      await finalSave('draft');
    });

    document.getElementById('draft-continue').addEventListener('click', async () => {
      document.getElementById('draft-banner').style.display = 'none';
      if (draftShow) await loadDraft(draftShow.id);
    });

    document.getElementById('draft-fresh').addEventListener('click', () => {
      document.getElementById('draft-banner').style.display = 'none';
      draftShow = null;
    });
  }

  // ─── Breed combobox ─────────────────────────────────────────────────────────
  function initBreedCombobox() {
    const input   = document.getElementById('s3-breed');
    const listbox = document.getElementById('s3-breed-listbox');
    if (!input || !listbox) return;

    let activeIdx = -1;

    function getMatches(q) {
      return searchBreeds(q);
    }

    function renderList(matches) {
      listbox.innerHTML = matches.length
        ? matches.map((b, i) =>
            `<li role="option" data-idx="${i}" class="px-4 py-2.5 text-[14px] text-[#1c1626] cursor-pointer hover:bg-[#e8f7f6]">${b}</li>`
          ).join('')
        : `<li class="px-4 py-3 text-[14px] text-[#9b94a8]">No breeds found</li>`;
    }

    function openList(q) {
      renderList(getMatches(q));
      listbox.classList.remove('hidden');
      input.setAttribute('aria-expanded', 'true');
      activeIdx = -1;
    }

    function closeList() {
      listbox.classList.add('hidden');
      input.setAttribute('aria-expanded', 'false');
      activeIdx = -1;
    }

    function setActive(idx) {
      const items = listbox.querySelectorAll('[role="option"]');
      items.forEach((el, i) => el.classList.toggle('bg-[#e8f7f6]', i === idx));
      activeIdx = idx;
      if (items[idx]) items[idx].scrollIntoView({ block: 'nearest' });
    }

    input.addEventListener('input',  () => openList(input.value.trim()));
    input.addEventListener('focus',  () => openList(input.value.trim()));

    input.addEventListener('keydown', e => {
      const items = listbox.querySelectorAll('[role="option"]');
      if      (e.key === 'ArrowDown')              { e.preventDefault(); setActive(Math.min(activeIdx + 1, items.length - 1)); }
      else if (e.key === 'ArrowUp')                { e.preventDefault(); setActive(Math.max(activeIdx - 1, 0)); }
      else if (e.key === 'Enter' && activeIdx >= 0){ e.preventDefault(); input.value = items[activeIdx].textContent; closeList(); }
      else if (e.key === 'Escape')                 { closeList(); }
    });

    listbox.addEventListener('mousedown', e => {
      const li = e.target.closest('[role="option"]');
      if (li) { input.value = li.textContent; closeList(); }
    });

    document.addEventListener('click', e => {
      if (!input.contains(e.target) && !listbox.contains(e.target)) closeList();
    });
  }
</script>
