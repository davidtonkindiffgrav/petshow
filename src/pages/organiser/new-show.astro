  // ─── State ──────────────────────────────────────────────────────────────────
  const show = {
    id: null,
    title: '', host_org: '', org_type: null, charity_number: '',
    contact_email: '', contact_phone: '',
    entry_open_date: '', entry_close_date: '', show_date: '',
    show_type: null, animal_type: 'dog',
    breed_scope: 'all', breed_filter: '', group_filter: '',
    has_sponsor: null, sponsors: [{ name: '', website: '', logo_url: '' }],
    is_judged: null, judge_count: 1, judge_setup: 'later',
    judges: [],
    has_digital_certs: null, has_physical_prizes: null, prize_source: null,
    prizes: [],
    is_fundraising: true,
    show_fundraising_publicly: null,
    currency: 'AUD', entry_fee: 0,
    classes: [],
    logo_url: '', banner_url: '', org_logo_url: '',
    wizard_step: 1,
  };

  const CURRENCY_SYMBOLS = { GBP: '£', USD: '$', EUR: '€', AUD: 'A$', CAD: 'C$', NZD: 'NZ$', ZAR: 'R', SGD: 'S$' };

  let currentStep = 1;
  let session, profile, base;
  let draftShow   = null;
  let serviceFees = {};
  let savedJudges = [];
  const esc = s => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

  // ─── Auth ───────────────────────────────────────────────────────────────────
  const auth = await getAuth();
  session = auth.session;
  profile = auth.profile;
  base    = auth.base;

  if (!session) {
    window.location.replace(base + 'login');
  } else {
    // Sidebar
    const name = profile?.display_name || session.user.email?.split('@')[0] || 'Organiser';
    const avatarEl = document.getElementById('sidebar-avatar');
    const nameEl   = document.getElementById('sidebar-username');
    const badgeEl  = document.getElementById('sidebar-role-badge');
    if (avatarEl) avatarEl.textContent = name.charAt(0).toUpperCase();
    if (nameEl)   nameEl.textContent   = name;
    if (badgeEl)  badgeEl.textContent  = profile?.organiser_type === 'club' ? 'Club Organiser' : 'Organiser';
    document.getElementById('sidebar-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = base + 'login';
    });

    // Pre-fill
    show.contact_email = session.user.email || '';
    document.getElementById('s1-contact-email').value = show.contact_email;

    if (profile?.organisation_id) {
      const { data: org } = await supabase.from('organisations').select('name').eq('id', profile.organisation_id).single();
      if (org) { show.host_org = org.name; document.getElementById('s1-host-org').value = org.name; }
    }

    // Check for existing draft (skip banner if we're loading a specific show via ?id=)
    const urlIdEarly = new URLSearchParams(window.location.search).get('id');
    if (!urlIdEarly) {
      const { data: drafts } = await supabase
        .from('shows').select('id, title, wizard_step').eq('created_by', session.user.id)
        .eq('status', 'draft').order('created_at', { ascending: false }).limit(1);

      if (drafts && drafts.length > 0) {
        draftShow = drafts[0];
        document.getElementById('draft-title').textContent = draftShow.title || 'Untitled Show';
        document.getElementById('draft-banner').style.display = 'flex';
      }
    }

    const { data: feeSettings } = await supabase
      .from('platform_settings').select('key, value').in('key', ['service_fee_AUD', 'service_fee_NZD']);
    (feeSettings || []).forEach(r => { serviceFees[r.key] = parseFloat(r.value) || 0; });

    const { data: sjData } = await supabase
      .from('saved_judges').select('*').eq('organiser_id', session.user.id).order('first_name');
    if (sjData) savedJudges = sjData;

    setupEventListeners();
    initCardGroups();
    initBreedCombobox();

    const urlId = new URLSearchParams(window.location.search).get('id');
    if (urlId) {
      document.getElementById('draft-banner').style.display = 'none';
      await loadDraft(urlId);
    } else {
      goToStep(1);
    }
  }

  // ─── Navigation ─────────────────────────────────────────────────────────────
  function goToStep(n) {
    document.getElementById(`step-${currentStep}`).style.display = 'none';
    currentStep = n;
    document.getElementById(`step-${currentStep}`).style.display = 'block';
    document.getElementById('step-error').style.display = 'none';
    updateProgress();
    updateNav();
    if (n === 4) initStep4();
    if (n === 6) updateJudgePanels();
    if (n === 8) applyCurrencySymbol(show.currency || 'AUD');
    if (n === 10) buildReview();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  // Exposed globally so inline onclick="goToStep(n)" in the review step works
  window.goToStep = goToStep;

  function updateProgress() {
    document.getElementById('prog-num').textContent = String(currentStep);
    document.getElementById('prog-name').textContent = STEP_NAMES[currentStep - 1];
    document.getElementById('prog-bar').style.width = `${(currentStep / 10) * 100}%`;
  }

  function updateNav() {
    const backBtn  = document.getElementById('btn-back');
    const nextBtn  = document.getElementById('btn-next');
    const draftBtn = document.getElementById('action-save-draft');
    backBtn.style.display  = currentStep > 1 ? 'inline-flex' : 'none';
    nextBtn.style.display  = currentStep < 10 ? 'inline-flex' : 'none';
    draftBtn.style.display = currentStep > 1 ? 'inline-flex' : 'none';
  }

  function showError(msg) {
    const el = document.getElementById('step-error');
    el.textContent = msg;
    el.style.display = 'block';
    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ─── Card selection helper ───────────────────────────────────────────────────
  function selectCard(container, value) {
    container.querySelectorAll('[data-value]').forEach(card => {
      if (card.disabled) return;
      const active = card.dataset.value === value;
      card.dataset.selected    = active ? 'true' : 'false';
      card.style.borderColor   = active ? '#1ba89a' : '#b8e4e0';
      card.style.background    = active ? '#f0fafa' : 'white';
      card.style.boxShadow     = active ? '0 0 0 3px rgba(27,168,154,0.18)' : 'none';
    });
  }

  function getSelectedCard(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return null;
    const active = el.querySelector('[data-selected="true"]');
    return active ? active.dataset.value : null;
  }

  // ─── Toggle switch helper ───────────────────────────────────────────────────
  function setupToggle(btnId, onChange) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.addEventListener('click', () => {
      const on = btn.dataset.on !== 'true';
      btn.dataset.on = String(on);
      btn.style.background = on ? '#1ba89a' : '#efebf5';
      btn.querySelector('span').style.transform = on ? 'translateX(20px)' : 'translateX(0)';
      onChange(on);
    });
  }

  function setToggle(btnId, on) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.dataset.on = String(on);
    btn.style.background = on ? '#1ba89a' : '#efebf5';
    btn.querySelector('span').style.transform = on ? 'translateX(20px)' : 'translateX(0)';
  }

  // ─── YNA (Yes/No/Add Later) helper ──────────────────────────────────────────
  function setupYNA(containerId, onChange) {
    const el = document.getElementById(containerId);
    el.querySelectorAll('.yna').forEach(btn => {
      btn.addEventListener('click', () => {
        el.querySelectorAll('.yna').forEach(b => {
          b.dataset.selected = 'false';
          b.style.borderColor = '#b8e4e0'; b.style.background = 'white'; b.style.boxShadow = 'none';
        });
        btn.dataset.selected  = 'true';
        btn.style.borderColor = '#1ba89a';
        btn.style.background  = '#f0fafa';
        btn.style.boxShadow   = '0 0 0 3px rgba(27,168,154,0.18)';
        onChange(btn.dataset.value);
      });
    });
  }

  function setYNA(containerId, value) {
    const el = document.getElementById(containerId);
    if (!el || !value) return;
    el.querySelectorAll('.yna').forEach(btn => {
      const active = btn.dataset.value === value;
      btn.dataset.selected  = active ? 'true' : 'false';
      btn.style.borderColor = active ? '#1ba89a' : '#b8e4e0';
      btn.style.background  = active ? '#f0fafa' : 'white';
      btn.style.boxShadow   = active ? '0 0 0 3px rgba(27,168,154,0.18)' : 'none';
    });
  }

  // ─── Validation ─────────────────────────────────────────────────────────────
  function validateStep(n) {
    if (n === 1) {
      if (!document.getElementById('s1-title').value.trim()) return showError('Please enter a show name.'), false;
      if (!document.getElementById('s1-entry-close').value) return showError('Please set an entries close date.'), false;
      if (!document.getElementById('s1-show-date').value) return showError('Please set a show date.'), false;
      if (!getSelectedCard('org-type-cards')) return showError('Please select your type of organisation.'), false;
      const orgType = getSelectedCard('org-type-cards');
      if (orgType === 'non_profit' || orgType === 'registered_charity') {
        if (!document.getElementById('s1-charity-number').value.trim()) return showError('Please enter your Charity / Non-Profit Number to continue.'), false;
      }
      const email = document.getElementById('s1-contact-email').value.trim();
      if (!email || !email.includes('@')) return showError('Please enter a valid contact email.'), false;
      return true;
    }
    if (n === 2) {
      if (!getSelectedCard('show-type-cards')) return showError('Please select a show type.'), false;
      return true;
    }
    if (n === 3) {
      const scope = getSelectedCard('breed-scope-cards');
      if (!scope) return showError('Please select a breed scope.'), false;
      if (scope === 'breed_specific' && !document.getElementById('s3-breed').value.trim()) return showError('Please enter a breed name.'), false;
      if (scope === 'group_specific' && !document.getElementById('s3-group').value.trim()) return showError('Please enter a group name.'), false;
      return true;
    }
    if (n === 4) {
      if (show.classes.filter(c => c.enabled).length === 0) return showError('Please enable at least one class.'), false;
      return true;
    }
    if (n === 5) {
      const choice = getSelectedCard('sponsor-choice') || getYNAValue('sponsor-choice');
      if (!choice) return showError('Please make a selection.'), false;
      if (choice === 'yes' && !document.getElementById('s5-sponsor-name').value.trim()) return showError('Please enter a sponsor name.'), false;
      return true;
    }
    if (n === 6) {
      const choice = getYNAValue('judging-choice');
      if (!choice) return showError('Please make a selection.'), false;
      if (choice === 'yes') {
        const setup = getSelectedCard('judge-setup-cards');
        if (!setup) return showError('Please choose a judge setup option.'), false;
        if (setup === 'now') {
          for (let i = 0; i < show.judge_count; i++) {
            const fn = document.getElementById(`judge-fn-${i}`)?.value.trim();
            const ln = document.getElementById(`judge-ln-${i}`)?.value.trim();
            const em = document.getElementById(`judge-em-${i}`)?.value.trim();
            if (!fn || !ln || !em) return showError(`Please fill in all required fields for Judge ${i + 1}.`), false;
          }
        }
      }
      return true;
    }
    if (n === 7) {
      const choice = getYNAValue('awards-choice');
      if (!choice) return showError('Please make a selection.'), false;
      return true;
    }
    if (n === 8) {
      const fee = parseFloat(document.getElementById('s8-entry-fee').value);
      if (isNaN(fee) || fee < 0) return showError('Please enter a valid entry fee (0 for free).'), false;
      return true;
    }
    return true;
  }

  function getYNAValue(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return null;
    const active = el.querySelector('.yna[data-selected="true"]');
    return active ? active.dataset.value : null;
  }

  // ─── Read step values into show state ───────────────────────────────────────
  function readStep(n) {
    if (n === 1) {
      show.title          = document.getElementById('s1-title').value.trim();
      show.entry_open_date = document.getElementById('s1-entry-open').value || null;
      show.entry_close_date = document.getElementById('s1-entry-close').value || null;
      show.show_date      = document.getElementById('s1-show-date').value || null;
      show.host_org       = document.getElementById('s1-host-org').value.trim();
      show.org_type       = getSelectedCard('org-type-cards');
      show.charity_number = document.getElementById('s1-charity-number').value.trim();
      show.contact_email  = document.getElementById('s1-contact-email').value.trim();
      show.contact_phone  = document.getElementById('s1-contact-phone').value.trim();
    }
    if (n === 2) {
      show.show_type   = getSelectedCard('show-type-cards');
      show.animal_type = getSelectedCard('animal-type-cards') || 'dog';
    }
    if (n === 3) {
      show.breed_scope  = getSelectedCard('breed-scope-cards') || 'all';
      show.breed_filter = document.getElementById('s3-breed').value.trim();
      show.group_filter = document.getElementById('s3-group').value.trim();
    }
    if (n === 4) {
      // classes already updated in real-time via toggle handlers
    }
    if (n === 5) {
      const choice = getYNAValue('sponsor-choice');
      show.has_sponsor = choice === 'yes' ? true : choice === 'no' ? false : null;
      if (choice === 'yes') {
        show.sponsors = [{ name: document.getElementById('s5-sponsor-name').value.trim(), website: document.getElementById('s5-sponsor-website').value.trim() }];
      }
    }
    if (n === 6) {
      const choice = getYNAValue('judging-choice');
      show.is_judged    = choice === 'yes' ? true : choice === 'no' ? false : null;
      show.judge_setup  = getSelectedCard('judge-setup-cards') || 'later';
      if (choice === 'yes' && show.judge_setup === 'now') {
        show.judges = Array.from({ length: show.judge_count }, (_, i) => ({
          first_name: document.getElementById(`judge-fn-${i}`)?.value.trim() || '',
          last_name:  document.getElementById(`judge-ln-${i}`)?.value.trim() || '',
          email:      document.getElementById(`judge-em-${i}`)?.value.trim() || '',
          phone:      document.getElementById(`judge-ph-${i}`)?.value.trim() || '',
          photo_url:  show.judges[i]?.photo_url || '',
        }));
      }
    }
    if (n === 7) {
      const choice = getYNAValue('awards-choice');
      show.has_digital_certs   = choice === 'yes' ? document.getElementById('s7-certs-toggle').dataset.on === 'true' : null;
      show.has_physical_prizes = choice === 'yes' ? document.getElementById('s7-physical-toggle').dataset.on === 'true' : null;
      show.prize_source        = choice === 'yes' ? getSelectedCard('prize-source-cards') : null;
      if (choice !== 'yes') { show.has_digital_certs = null; show.has_physical_prizes = null; }
    }
    if (n === 8) {
      show.is_fundraising            = true;
      show.show_fundraising_publicly = document.getElementById('s8-public-toggle').dataset.on === 'true';
      show.currency                  = document.getElementById('s8-currency').value || 'AUD';
      show.entry_fee                 = parseFloat(document.getElementById('s8-entry-fee').value) || 0;
    }
  }

  // ─── Supabase save ───────────────────────────────────────────────────────────
  async function saveShow(completedStep) {
    const payload = {
      title: show.title, org_type: show.org_type, charity_number: show.charity_number || null,
      contact_email: show.contact_email, contact_phone: show.contact_phone || null,
      entry_open_date: show.entry_open_date || null, entry_close_date: show.entry_close_date || null,
      show_date: show.show_date || null,
      show_type: show.show_type, animal_type: show.animal_type,
      breed_scope: show.breed_scope, breed_filter: show.breed_filter || null, group_filter: show.group_filter || null,
      has_sponsor: show.has_sponsor, is_judged: show.is_judged,
      judge_count: show.judge_count, judge_setup: show.judge_setup,
      has_digital_certs: show.has_digital_certs, has_physical_prizes: show.has_physical_prizes,
      prize_source: show.prize_source, is_fundraising: show.is_fundraising,
      donation_type: show.donation_type, fundraising_goal: show.fundraising_goal || null,
      show_fundraising_publicly: show.show_fundraising_publicly, donation_receipts: show.donation_receipts,
      logo_url: show.logo_url || null, banner_url: show.banner_url || null, org_logo_url: show.org_logo_url || null,
      currency: show.currency, entry_fee: show.entry_fee, status: 'draft',
      wizard_step: completedStep + 1,
    };

    if (!show.id) {
      payload.created_by = session.user.id;
      if (profile?.organisation_id) payload.organisation_id = profile.organisation_id;
      const { data, error } = await supabase.from('shows').insert(payload).select('id').single();
      if (!error && data) show.id = data.id;
    } else {
      await supabase.from('shows').update(payload).eq('id', show.id);
    }

    // Save categories for step 4
    if (completedStep === 4 && show.id) {
      await supabase.from('show_categories').delete().eq('show_id', show.id);
      const enabled = show.classes.filter(c => c.enabled);
      if (enabled.length > 0) {
        await supabase.from('show_categories').insert(enabled.map(c => ({ show_id: show.id, name: c.name })));
      }
    }

    // Save judges for step 6
    if (completedStep === 6 && show.id) {
      await supabase.from('show_judges').delete().eq('show_id', show.id);
      if (show.is_judged && show.judge_setup === 'now' && show.judges.length > 0) {
        await supabase.from('show_judges').insert(show.judges.map(j => ({ show_id: show.id, ...j })));
      }
      // Save ticked judges to saved_judges (skip duplicates by email)
      if (show.is_judged && show.judge_setup === 'now') {
        for (let i = 0; i < show.judge_count; i++) {
          if (!document.getElementById(`judge-save-${i}`)?.checked) continue;
          const fn = document.getElementById(`judge-fn-${i}`)?.value.trim();
          const ln = document.getElementById(`judge-ln-${i}`)?.value.trim();
          const em = document.getElementById(`judge-em-${i}`)?.value.trim() || null;
          const ph = document.getElementById(`judge-ph-${i}`)?.value.trim() || null;
          if (!fn || !ln) continue;
          if (em && savedJudges.some(sj => sj.email?.toLowerCase() === em.toLowerCase())) continue;
          const { data: newSJ } = await supabase.from('saved_judges')
            .insert({ organiser_id: session.user.id, first_name: fn, last_name: ln, email: em, phone: ph })
            .select().single();
          if (newSJ) savedJudges.push(newSJ);
        }
      }
    }

    // Save sponsor for step 5
    if (completedStep === 5 && show.id) {
      await supabase.from('show_sponsors').delete().eq('show_id', show.id);
      if (show.has_sponsor && show.sponsors[0]?.name) {
        await supabase.from('show_sponsors').insert(show.sponsors.filter(s => s.name).map(s => ({ show_id: show.id, ...s })));
      }
    }

    // Save prizes for step 7
    if (completedStep === 7 && show.id) {
      await supabase.from('show_prizes').delete().eq('show_id', show.id);
      if (show.has_physical_prizes && show.prizes.length > 0) {
        await supabase.from('show_prizes').insert(show.prizes.filter(p => p).map(p => ({ show_id: show.id, description: p })));
      }
    }
  }

  // ─── Step 4 init ─────────────────────────────────────────────────────────────
  function initStep4() {
    const isBeauty  = show.show_type === 'beauty_contest' || show.show_type === 'memorial';
    const isFun     = show.show_type === 'fun_stakes';
    document.getElementById('s4-standard').style.display  = isBeauty ? 'block' : 'none';
    document.getElementById('s4-funstakes').style.display = isFun    ? 'block' : 'none';
    document.getElementById('s4-desc').textContent = isFun
      ? 'Choose the fun categories for your show.'
      : 'Select the classes for your show. Disable any you don\'t need, or add custom ones.';

    if (isBeauty) {
      if (show.classes.length === 0) {
        show.classes = STANDARD_CLASSES.map(name => ({ name, enabled: true, custom: false }));
      }
      renderStandardClasses();
    }
    if (isFun) {
      renderFunStakesCategories();
    }
  }

  function renderStandardClasses() {
    const list = document.getElementById('s4-class-list');
    list.innerHTML = '';
    show.classes.forEach((cls, i) => {
      if (cls.custom) return;
      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 p-3 border border-[#efebf5] rounded-[11px]';
      row.innerHTML = `
        <button type="button" data-idx="${i}" class="cls-toggle w-10 h-6 rounded-full ${cls.enabled ? 'bg-brand' : 'bg-[#efebf5]'} transition-colors relative flex items-center px-0.5 shrink-0">
          <span class="w-5 h-5 rounded-full bg-white shadow transition-transform ${cls.enabled ? 'translate-x-4' : ''}"></span>
        </button>
        <span class="text-[13.5px] font-semibold text-[#1c1626] flex-1 ${cls.enabled ? '' : 'text-[#9b94a8] line-through'}">${cls.name}</span>
      `;
      list.appendChild(row);
    });
    // Re-append custom classes
    show.classes.forEach((cls, i) => {
      if (!cls.custom) return;
      appendCustomClassRow(i, cls.name);
    });
    // Toggle handlers
    list.querySelectorAll('.cls-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const i = parseInt(btn.dataset.idx);
        show.classes[i].enabled = !show.classes[i].enabled;
        renderStandardClasses();
      });
    });
  }

  function appendCustomClassRow(idx, value) {
    const list = document.getElementById('s4-class-list');
    const row = document.createElement('div');
    row.dataset.customIdx = String(idx);
    row.className = 'flex items-center gap-2';
    row.innerHTML = `
      <input type="text" value="${value}" placeholder="Class name"
        class="flex-1 border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[14px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
      <button type="button" data-idx="${idx}" class="custom-remove text-[#c4bed0] hover:text-red-400 transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    `;
    row.querySelector('input').addEventListener('input', e => { show.classes[idx].name = e.target.value; });
    row.querySelector('.custom-remove').addEventListener('click', () => {
      show.classes.splice(idx, 1);
      renderStandardClasses();
    });
    list.appendChild(row);
  }

  function renderFunStakesCategories() {
    const list = document.getElementById('s4-funstakes-list');
    list.innerHTML = '';
    const selected = new Set(show.classes.filter(c => c.enabled).map(c => c.name));
    FUN_STAKES.forEach(cat => {
      const on = selected.has(cat);
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'text-left rounded-[11px] border-2 px-3 py-2.5 text-[12.5px] font-semibold transition-all cursor-pointer';
      btn.style.borderColor = on ? '#1ba89a' : '#b8e4e0';
      btn.style.background  = on ? '#f0fafa' : 'white';
      btn.textContent = cat;
      btn.addEventListener('click', () => {
        const isOn = btn.style.borderColor === 'rgb(124, 58, 237)';
        btn.style.borderColor = isOn ? '#b8e4e0' : '#1ba89a';
        btn.style.background  = isOn ? 'white'   : '#f0fafa';
        if (isOn) {
          show.classes = show.classes.filter(c => c.name !== cat);
        } else {
          show.classes.push({ name: cat, enabled: true, custom: false });
        }
      });
      list.appendChild(btn);
    });
  }

  // ─── Judge panels ────────────────────────────────────────────────────────────
  function updateJudgePanels() {
    const container = document.getElementById('s6-judge-panels');
    container.innerHTML = '';
    for (let i = 0; i < show.judge_count; i++) {
      const j = show.judges[i] || { first_name: '', last_name: '', email: '', phone: '', photo_url: '' };
      const panel = document.createElement('div');
      panel.className = 'border border-[#efebf5] rounded-[14px] p-4 space-y-3';

      const pickerHtml = savedJudges.length > 0 ? `
        <div class="relative judge-picker-wrap">
          <button type="button" class="judge-picker-btn text-[12.5px] font-semibold text-brand flex items-center gap-1.5 hover:underline">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Saved judges
          </button>
          <div class="judge-picker-dropdown" style="display:none;position:absolute;left:0;top:100%;margin-top:4px;z-index:30;background:white;border:1px solid #e6dcfb;border-radius:12px;box-shadow:0 4px 20px rgba(0,0,0,0.10);min-width:230px;overflow:hidden;padding:4px 0;">
            ${savedJudges.map(sj => `<button type="button" class="judge-pick-item w-full text-left px-4 py-2.5 hover:bg-[#f0fafa] transition-colors" data-id="${sj.id}"><span style="display:block;font-size:13px;font-weight:600;color:#1c1626;">${esc(sj.first_name)} ${esc(sj.last_name)}</span>${sj.email ? `<span style="display:block;font-size:11.5px;color:#9b94a8;">${esc(sj.email)}</span>` : ''}</button>`).join('')}
          </div>
        </div>` : '';

      panel.innerHTML = `
        <div class="flex items-center justify-between">
          <p class="text-[13px] font-bold text-brand">Judge ${i + 1}</p>
          ${pickerHtml}
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[12px] font-semibold text-[#4a4357] mb-1">First Name <span class="text-red-400">*</span></label>
            <input type="text" id="judge-fn-${i}" value="${esc(j.first_name)}"
              class="w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-[#4a4357] mb-1">Last Name <span class="text-red-400">*</span></label>
            <input type="text" id="judge-ln-${i}" value="${esc(j.last_name)}"
              class="w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[12px] font-semibold text-[#4a4357] mb-1">Email <span class="text-red-400">*</span></label>
            <input type="email" id="judge-em-${i}" value="${esc(j.email)}"
              class="w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-[#4a4357] mb-1">Phone <span class="text-[#9b94a8] font-normal">(optional)</span></label>
            <input type="tel" id="judge-ph-${i}" value="${esc(j.phone || '')}"
              class="w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
          </div>
        </div>
        <label class="flex items-center gap-2 pt-1 cursor-pointer select-none">
          <input type="checkbox" id="judge-save-${i}" class="w-4 h-4 accent-brand" />
          <span class="text-[12.5px] text-[#6f6880]">Save to my judge book</span>
        </label>
        <div class="flex items-center gap-3 pt-2 border-t border-[#f5f3f8]">
          <div class="w-10 h-10 rounded-full border-2 border-dashed border-[#b8e4e0] bg-[#f0fafa] flex items-center justify-center overflow-hidden judge-photo-circle shrink-0">
            ${j.photo_url ? `<img src="${esc(j.photo_url)}" class="w-full h-full object-cover" />` : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`}
          </div>
          <div>
            <p class="text-[12px] font-semibold text-[#4a4357]">Profile Photo <span class="text-[11px] text-[#9b94a8] font-normal">(optional)</span></p>
            <button type="button" class="judge-photo-btn text-[12px] font-semibold text-brand hover:underline">${j.photo_url ? 'Replace photo' : 'Upload photo'}</button>
            <input type="file" class="judge-photo-input hidden" accept="image/jpeg,image/png,image/webp" />
          </div>
        </div>
      `;

      const pickerBtn = panel.querySelector('.judge-picker-btn');
      const dropdown  = panel.querySelector('.judge-picker-dropdown');
      if (pickerBtn && dropdown) {
        pickerBtn.addEventListener('click', e => {
          e.stopPropagation();
          document.querySelectorAll('.judge-picker-dropdown').forEach(d => { if (d !== dropdown) d.style.display = 'none'; });
          dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
        });
        panel.querySelectorAll('.judge-pick-item').forEach(btn => {
          btn.addEventListener('click', () => {
            const sj = savedJudges.find(s => s.id === btn.dataset.id);
            if (!sj) return;
            document.getElementById(`judge-fn-${i}`).value = sj.first_name;
            document.getElementById(`judge-ln-${i}`).value = sj.last_name;
            document.getElementById(`judge-em-${i}`).value = sj.email || '';
            document.getElementById(`judge-ph-${i}`).value = sj.phone || '';
            dropdown.style.display = 'none';
          });
        });
      }
      // Judge photo upload
      const photoBtn    = panel.querySelector('.judge-photo-btn');
      const photoInput  = panel.querySelector('.judge-photo-input');
      const photoCircle = panel.querySelector('.judge-photo-circle');
      photoBtn.addEventListener('click', () => photoInput.click());
      photoInput.addEventListener('change', async () => {
        const file = photoInput.files[0];
        if (!file || file.size > 2 * 1024 * 1024 || !show.id) return;
        photoBtn.textContent = 'Uploading…';
        try {
          const url = await uploadImage(`judges/${show.id}/judge-${i}`, file);
          if (!show.judges[i]) show.judges[i] = {};
          show.judges[i].photo_url = url;
          photoCircle.innerHTML = `<img src="${url}" class="w-full h-full object-cover" />`;
          photoBtn.textContent = 'Replace photo';
        } catch { photoBtn.textContent = 'Failed — try again'; }
      });

      container.appendChild(panel);
    }
  }

  // ─── Prize rows ──────────────────────────────────────────────────────────────
  function addPrizeRow() {
    const idx = show.prizes.length;
    show.prizes.push('');
    const list = document.getElementById('s7-prize-list');
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2';
    row.innerHTML = `
      <input type="text" placeholder="e.g. £50 Pet Store Voucher"
        class="flex-1 border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[14px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
      <button type="button" class="prize-remove text-[#c4bed0] hover:text-red-400 transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    `;
    row.querySelector('input').addEventListener('input', e => { show.prizes[idx] = e.target.value; });
    row.querySelector('.prize-remove').addEventListener('click', () => { row.remove(); show.prizes.splice(idx, 1); });
    list.appendChild(row);
  }

  // ─── Review ─────────────────────────────────────────────────────────────────
  function pendingBadge() {
    return `<span class="inline-flex items-center gap-1 text-[11px] font-bold text-amber-dark bg-amber-tint px-2 py-0.5 rounded-full">⚠ Add Later</span>`;
  }

  function reviewRow(label, value, step) {
    const isPending = value === null || value === undefined;
    return `
      <div class="flex items-start justify-between gap-4 py-3 border-b border-[#efebf5] last:border-0">
        <span class="text-[13px] font-semibold text-[#4a4357] shrink-0 w-36">${label}</span>
        <span class="text-[13px] text-[#1c1626] flex-1">${isPending ? pendingBadge() : value}</span>
        <button type="button" class="text-[12px] font-semibold text-brand hover:underline shrink-0" onclick="goToStep(${step})">Edit</button>
      </div>`;
  }

  function buildReview() {
    const SHOW_TYPE_LABELS = { beauty_contest: 'Beauty Contest', fun_stakes: 'Fun Stakes', memorial: 'Memorial Show', other: 'Other' };
    const ORG_TYPE_LABELS  = { non_profit: 'Non-Profit Fundraiser', registered_charity: 'Registered Charity', commercial: 'Commercial Organisation' };
    const SCOPE_LABELS     = { all: 'All Breeds', breed_specific: `Breed Specific: ${show.breed_filter || '—'}`, group_specific: `Group Specific: ${show.group_filter || '—'}` };
    const classes = show.classes.filter(c => c.enabled).map(c => c.name).join(', ') || '—';
    const judges  = show.is_judged === true ? (show.judge_setup === 'now' ? `${show.judge_count} judge(s) — set up` : `${show.judge_count} judge(s) — invite later`) : show.is_judged === false ? 'Public voting' : null;

    document.getElementById('s10-review').innerHTML = `
      <div class="border border-[#efebf5] rounded-[14px] overflow-hidden">
        <div class="bg-[#f0fafa] px-5 py-3 border-b border-[#efebf5]">
          <p class="text-[12px] font-bold text-brand uppercase tracking-wide">Show Basics</p>
        </div>
        <div class="px-5">
          ${reviewRow('Show Name', show.title, 1)}
          ${reviewRow('Show Date', show.show_date || '—', 1)}
          ${reviewRow('Entries Close', show.entry_close_date || '—', 1)}
          ${reviewRow('Organisation', ORG_TYPE_LABELS[show.org_type] || '—', 1)}
          ${reviewRow('Contact', show.contact_email, 1)}
        </div>
      </div>
      <div class="border border-[#efebf5] rounded-[14px] overflow-hidden">
        <div class="bg-[#f0fafa] px-5 py-3 border-b border-[#efebf5]">
          <p class="text-[12px] font-bold text-brand uppercase tracking-wide">Show Type & Classes</p>
        </div>
        <div class="px-5">
          ${reviewRow('Show Type', SHOW_TYPE_LABELS[show.show_type] || '—', 2)}
          ${reviewRow('Animal Type', show.animal_type || 'Dog', 2)}
          ${reviewRow('Breed Scope', SCOPE_LABELS[show.breed_scope] || '—', 3)}
          ${reviewRow('Classes', classes, 4)}
        </div>
      </div>
      <div class="border border-[#efebf5] rounded-[14px] overflow-hidden">
        <div class="bg-[#f0fafa] px-5 py-3 border-b border-[#efebf5]">
          <p class="text-[12px] font-bold text-brand uppercase tracking-wide">Sponsorship, Judging & Awards</p>
        </div>
        <div class="px-5">
          ${reviewRow('Sponsor', show.has_sponsor === true ? (show.sponsors[0]?.name || 'Yes') : show.has_sponsor === false ? 'No sponsor' : null, 5)}
          ${reviewRow('Judging', judges, 6)}
          ${reviewRow('Awards', show.has_digital_certs === null && show.has_physical_prizes === null && show.has_digital_certs !== false ? null : `Certs: ${show.has_digital_certs ? 'Yes' : 'No'} · Physical: ${show.has_physical_prizes ? 'Yes' : 'No'}`, 7)}
        </div>
      </div>
      <div class="border border-[#efebf5] rounded-[14px] overflow-hidden">
        <div class="bg-[#f0fafa] px-5 py-3 border-b border-[#efebf5]">
          <p class="text-[12px] font-bold text-brand uppercase tracking-wide">Fundraising & Entry Fees</p>
        </div>
        <div class="px-5">
          ${reviewRow('Currency', show.currency || 'AUD', 8)}
          ${reviewRow('Entry Fee', show.entry_fee === 0 ? 'Free' : `${CURRENCY_SYMBOLS[show.currency] || show.currency}${show.entry_fee}`, 8)}
          ${reviewRow('Public Progress', show.show_fundraising_publicly ? 'Visible' : 'Hidden', 8)}
        </div>
      </div>`;
  }

  // ─── Publish / Save draft ───────────────────────────────────────────────────
  async function finalSave(status) {
    if (!show.id) return;
    await supabase.from('shows').update({ status, wizard_step: 10 }).eq('id', show.id);
    window.location.href = status === 'published'
      ? `${base}show/?id=${show.id}`
      : base + 'organiser';
  }

  // ─── Draft resume ────────────────────────────────────────────────────────────
  async function loadDraft(id) {
    const [{ data }, { data: sponsorData }, { data: judgesData }, { data: prizesData }, { data: cats }] = await Promise.all([
      supabase.from('shows').select('*').eq('id', id).single(),
      supabase.from('show_sponsors').select('*').eq('show_id', id),
      supabase.from('show_judges').select('*').eq('show_id', id),
      supabase.from('show_prizes').select('description').eq('show_id', id),
      supabase.from('show_categories').select('name').eq('show_id', id),
    ]);
    if (!data) return;

    Object.assign(show, {
      id: data.id,
      title: data.title || '',
      host_org: data.host_org || '',
      org_type: data.org_type,
      charity_number: data.charity_number || '',
      contact_email: data.contact_email || '',
      contact_phone: data.contact_phone || '',
      entry_open_date: (data.entry_open_date || '').slice(0, 10),
      entry_close_date: (data.entry_close_date || '').slice(0, 10),
      show_date: (data.show_date || '').slice(0, 10),
      show_type: data.show_type,
      animal_type: data.animal_type || 'dog',
      breed_scope: data.breed_scope || 'all',
      breed_filter: data.breed_filter || '',
      group_filter: data.group_filter || '',
      has_sponsor: data.has_sponsor,
      sponsors: sponsorData?.length > 0
        ? sponsorData.map(s => ({ name: s.name || '', website: s.website || '', logo_url: s.logo_url || '' }))
        : [{ name: '', website: '', logo_url: '' }],
      is_judged: data.is_judged,
      judge_count: data.judge_count || 1,
      judge_setup: data.judge_setup || 'later',
      judges: judgesData?.length > 0
        ? judgesData.map(j => ({ first_name: j.first_name || '', last_name: j.last_name || '', email: j.email || '', phone: j.phone || '', photo_url: j.photo_url || '' }))
        : [],
      has_digital_certs: data.has_digital_certs,
      has_physical_prizes: data.has_physical_prizes,
      prize_source: data.prize_source,
      prizes: prizesData?.map(p => p.description) || [],
      classes: cats?.length > 0 ? cats.map(c => ({ name: c.name, enabled: true, custom: false })) : [],
      is_fundraising: data.is_fundraising ?? true,
      show_fundraising_publicly: data.show_fundraising_publicly,
      currency: data.currency || 'AUD',
      entry_fee: data.entry_fee || 0,
      logo_url: data.logo_url || '',
      banner_url: data.banner_url || '',
      org_logo_url: data.org_logo_url || '',
    });

    // Restore upload previews
    if (show.logo_url)     restoreUploadPreview(document.getElementById('s9-logo-widget'),     show.logo_url);
    if (show.banner_url)   restoreUploadPreview(document.getElementById('s9-banner-widget'),   show.banner_url);
    if (show.org_logo_url) restoreUploadPreview(document.getElementById('s9-org-logo-widget'), show.org_logo_url);
    if (show.sponsors[0]?.logo_url) restoreUploadPreview(document.getElementById('s5-logo-widget'), show.sponsors[0].logo_url);

    // Step 1
    document.getElementById('s1-title').value         = show.title;
    document.getElementById('s1-host-org').value      = show.host_org;
    document.getElementById('s1-entry-open').value    = show.entry_open_date;
    document.getElementById('s1-entry-close').value   = show.entry_close_date;
    document.getElementById('s1-show-date').value     = show.show_date;
    document.getElementById('s1-contact-email').value = show.contact_email;
    document.getElementById('s1-contact-phone').value = show.contact_phone;
    if (show.org_type) selectCard(document.getElementById('org-type-cards'), show.org_type);
    if (show.org_type === 'registered_charity' || show.org_type === 'non_profit') {
      document.getElementById('s1-charity-field').style.display = 'block';
      document.getElementById('s1-charity-number').value = show.charity_number;
    }

    // Step 2
    if (show.show_type)   selectCard(document.getElementById('show-type-cards'),   show.show_type);
    if (show.animal_type) selectCard(document.getElementById('animal-type-cards'), show.animal_type);

    // Step 3
    selectCard(document.getElementById('breed-scope-cards'), show.breed_scope);
    updateBreedFields();
    document.getElementById('s3-breed').value = show.breed_filter;
    document.getElementById('s3-group').value = show.group_filter;

    // Step 5 — sponsor
    if (show.has_sponsor !== null) {
      setYNA('sponsor-choice', show.has_sponsor === true ? 'yes' : show.has_sponsor === false ? 'no' : 'later');
      if (show.has_sponsor) {
        document.getElementById('s5-sponsor-form').style.display = 'block';
        document.getElementById('s5-sponsor-name').value    = show.sponsors[0]?.name || '';
        document.getElementById('s5-sponsor-website').value = show.sponsors[0]?.website || '';
      }
    }

    // Step 6 — judging
    if (show.is_judged !== null) {
      setYNA('judging-choice', show.is_judged === true ? 'yes' : show.is_judged === false ? 'no' : 'later');
      if (show.is_judged) {
        document.getElementById('s6-judge-form').style.display = 'block';
        document.getElementById('judge-count-display').textContent = String(show.judge_count);
        if (show.judge_setup) {
          selectCard(document.getElementById('judge-setup-cards'), show.judge_setup);
          if (show.judge_setup === 'now') {
            document.getElementById('s6-judge-fields').style.display = 'block';
            updateJudgePanels();
          }
        }
      }
    }

    // Step 7 — awards
    const awardsSet = data.has_digital_certs !== null || data.has_physical_prizes !== null;
    if (awardsSet) {
      setYNA('awards-choice', 'yes');
      document.getElementById('s7-awards-form').style.display = 'block';
      setToggle('s7-certs-toggle', !!show.has_digital_certs);
      setToggle('s7-physical-toggle', !!show.has_physical_prizes);
      if (show.has_physical_prizes) {
        document.getElementById('s7-physical-form').style.display = 'block';
        if (show.prize_source) selectCard(document.getElementById('prize-source-cards'), show.prize_source);
        const list = document.getElementById('s7-prize-list');
        list.innerHTML = '';
        show.prizes.forEach((desc, idx) => {
          const row = document.createElement('div');
          row.className = 'flex items-center gap-2';
          row.innerHTML = `
            <input type="text" value="${esc(desc)}" placeholder="e.g. $50 Pet Store Voucher"
              class="flex-1 border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[14px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
            <button type="button" class="prize-remove text-[#c4bed0] hover:text-red-400 transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          `;
          row.querySelector('input').addEventListener('input', e => { show.prizes[idx] = e.target.value; });
          row.querySelector('.prize-remove').addEventListener('click', () => { row.remove(); show.prizes.splice(idx, 1); });
          list.appendChild(row);
        });
      }
    }

    // Step 8 — fees
    document.getElementById('s8-entry-fee').value = String(show.entry_fee || '');
    setToggle('s8-public-toggle', !!show.show_fundraising_publicly);
    if (show.currency) {
      document.getElementById('s8-currency').value = show.currency;
      applyCurrencySymbol(show.currency);
    }

    goToStep(Math.min(data.wizard_step || 1, 10));
  }

  // ─── Upload widget helpers ────────────────────────────────────────────────────
  function initUploadWidget(el, getPath, onUrl) {
    if (!el) return;
    const input   = el.querySelector('.upload-input');
    const trigger = el.querySelector('.upload-trigger');
    const preview = el.querySelector('.upload-preview');
    const label   = el.querySelector('.upload-label');
    const icon    = el.querySelector('.upload-icon');
    trigger.addEventListener('click', () => input.click());
    input.addEventListener('change', async () => {
      const file = input.files[0];
      if (!file) return;
      if (file.size > 2 * 1024 * 1024) { label.textContent = 'File too large (max 2 MB)'; return; }
      const path = getPath();
      if (!path) { label.textContent = 'Save show progress first'; return; }
      label.textContent = 'Uploading…';
      try {
        const url = await uploadImage(path, file);
        preview.src = url;
        preview.classList.remove('hidden');
        if (icon) icon.classList.add('hidden');
        label.textContent = 'Click to replace';
        onUrl(url);
      } catch { label.textContent = 'Upload failed — try again'; }
    });
  }

  function restoreUploadPreview(el, url) {
    if (!el || !url) return;
    const preview = el.querySelector('.upload-preview');
    const label   = el.querySelector('.upload-label');
    const icon    = el.querySelector('.upload-icon');
    if (preview) { preview.src = url; preview.classList.remove('hidden'); }
    if (icon)    icon.classList.add('hidden');
    if (label)   label.textContent = 'Click to replace';
  }

  // ─── Misc helpers ────────────────────────────────────────────────────────────
  function updateBreedFields() {
    document.getElementById('s3-breed-field').style.display = show.breed_scope === 'breed_specific' ? 'block' : 'none';
    document.getElementById('s3-group-field').style.display = show.breed_scope === 'group_specific' ? 'block' : 'none';
  }

  // ─── Event listeners setup ──────────────────────────────────────────────────
  function initCardGroups() {
    // Step 1: org type
    document.getElementById('org-type-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectCard(document.getElementById('org-type-cards'), btn.dataset.value);
        const needsNum = btn.dataset.value === 'registered_charity' || btn.dataset.value === 'non_profit';
        document.getElementById('s1-charity-field').style.display = needsNum ? 'block' : 'none';
      });
    });
    // Step 2: show type + animal type
    document.getElementById('show-type-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => { selectCard(document.getElementById('show-type-cards'), btn.dataset.value); });
    });
    document.getElementById('animal-type-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => { selectCard(document.getElementById('animal-type-cards'), btn.dataset.value); });
    });
    // Default animal: dog
    selectCard(document.getElementById('animal-type-cards'), 'dog');
    // Step 3: breed scope
    document.getElementById('breed-scope-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectCard(document.getElementById('breed-scope-cards'), btn.dataset.value);
        show.breed_scope = btn.dataset.value;
        updateBreedFields();
      });
    });
    selectCard(document.getElementById('breed-scope-cards'), 'all');
    // Step 4: add custom class
    document.getElementById('s4-add-class').addEventListener('click', () => {
      const idx = show.classes.length;
      show.classes.push({ name: '', enabled: true, custom: true });
      appendCustomClassRow(idx, '');
    });
    document.getElementById('s4-add-funstakes').addEventListener('click', () => {
      const div = document.getElementById('s4-custom-funstakes');
      const idx = show.classes.length;
      show.classes.push({ name: '', enabled: true, custom: true });
      const row = document.createElement('div');
      row.className = 'flex items-center gap-2';
      row.innerHTML = `<input type="text" placeholder="Custom category" class="flex-1 border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[14px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" /><button type="button" class="text-[#c4bed0] hover:text-red-400 transition-colors"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>`;
      row.querySelector('input').addEventListener('input', e => { show.classes[idx].name = e.target.value; });
      row.querySelector('button').addEventListener('click', () => { row.remove(); show.classes.splice(idx, 1); });
      div.appendChild(row);
    });
    // Step 5: sponsorship YNA
    setupYNA('sponsor-choice', val => {
      document.getElementById('s5-sponsor-form').style.display = val === 'yes' ? 'block' : 'none';
    });
    // Step 6: judging YNA + judge count + setup cards
    setupYNA('judging-choice', val => {
      document.getElementById('s6-judge-form').style.display = val === 'yes' ? 'block' : 'none';
    });
    document.getElementById('judge-minus').addEventListener('click', () => {
      if (show.judge_count > 1) { show.judge_count--; document.getElementById('judge-count-display').textContent = String(show.judge_count); updateJudgePanels(); }
    });
    document.getElementById('judge-plus').addEventListener('click', () => {
      if (show.judge_count < 7) { show.judge_count++; document.getElementById('judge-count-display').textContent = String(show.judge_count); updateJudgePanels(); }
    });
    document.getElementById('judge-setup-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => {
        selectCard(document.getElementById('judge-setup-cards'), btn.dataset.value);
        show.judge_setup = btn.dataset.value;
        document.getElementById('s6-judge-fields').style.display = btn.dataset.value === 'now' ? 'block' : 'none';
        if (btn.dataset.value === 'now') updateJudgePanels();
      });
    });
    // Step 7: awards YNA + toggles + prize source
    setupYNA('awards-choice', val => {
      document.getElementById('s7-awards-form').style.display = val === 'yes' ? 'block' : 'none';
    });
    setupToggle('s7-certs-toggle', on => { show.has_digital_certs = on; });
    setupToggle('s7-physical-toggle', on => {
      show.has_physical_prizes = on;
      document.getElementById('s7-physical-form').style.display = on ? 'block' : 'none';
    });
    document.getElementById('prize-source-cards').querySelectorAll('[data-value]').forEach(btn => {
      btn.addEventListener('click', () => { selectCard(document.getElementById('prize-source-cards'), btn.dataset.value); });
    });
    document.getElementById('s7-add-prize').addEventListener('click', addPrizeRow);
    // Close judge picker dropdowns when clicking outside
    document.addEventListener('click', () => {
      document.querySelectorAll('.judge-picker-dropdown').forEach(d => { d.style.display = 'none'; });
    });
    // Step 8: public toggle + currency selector
    setupToggle('s8-public-toggle', on => { show.show_fundraising_publicly = on; });
    document.getElementById('s8-currency').addEventListener('change', e => {
      applyCurrencySymbol(e.target.value);
    });
    document.getElementById('s8-entry-fee').addEventListener('input', () => {
      updateFeeBreakdown(document.getElementById('s8-currency')?.value || 'AUD');
    });
    // Step 5: sponsor logo
    initUploadWidget(
      document.getElementById('s5-logo-widget'),
      () => show.id ? `sponsors/${show.id}/sponsor-0` : null,
      url => { show.sponsors[0].logo_url = url; }
    );
    // Step 9: branding widgets
    initUploadWidget(
      document.getElementById('s9-logo-widget'),
      () => show.id ? `shows/${show.id}/logo` : null,
      url => { show.logo_url = url; }
    );
    initUploadWidget(
      document.getElementById('s9-org-logo-widget'),
      () => show.id ? `shows/${show.id}/org-logo` : null,
      url => { show.org_logo_url = url; }
    );
    initUploadWidget(
      document.getElementById('s9-banner-widget'),
      () => show.id ? `shows/${show.id}/banner` : null,
      url => { show.banner_url = url; }
    );
  }

  function updateFeeBreakdown(code) {
    const sym    = CURRENCY_SYMBOLS[code] || code;
    const svcFee = serviceFees[`service_fee_${code}`] ?? 1.10;
    const entry  = parseFloat(document.getElementById('s8-entry-fee')?.value) || 0;
    const total  = entry + svcFee;
    const amountEl  = document.getElementById('s8-svc-amount');
    const totalEl   = document.getElementById('s8-total-charge');
    const previewEl = document.getElementById('s8-entrant-preview');
    if (amountEl)  amountEl.textContent  = `${sym}${svcFee.toFixed(2)}`;
    if (totalEl)   totalEl.textContent   = `${sym}${total.toFixed(2)}`;
    if (previewEl) previewEl.textContent = `Entry = ${sym}${total.toFixed(2)} (${sym}${entry.toFixed(2)} + ${sym}${svcFee.toFixed(2)} platform fee)`;
  }

  function applyCurrencySymbol(code) {
    const sym = CURRENCY_SYMBOLS[code] || code;
    document.getElementById('s8-symbol-fee').textContent = sym;
    document.getElementById('s8-fee-hint').textContent   = `Set to ${sym}0 for a free show.`;
    updateFeeBreakdown(code);
  }

  function setupEventListeners() {
    document.getElementById('btn-next').addEventListener('click', async () => {
      if (!validateStep(currentStep)) return;
      readStep(currentStep);
      const btnNext = document.getElementById('btn-next');
      btnNext.textContent = 'Saving…';
      btnNext.disabled = true;
      await saveShow(currentStep);
      btnNext.innerHTML = 'Continue <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
      btnNext.disabled = false;
      goToStep(currentStep + 1);
    });

    document.getElementById('btn-back').addEventListener('click', () => { goToStep(currentStep - 1); });

    document.getElementById('action-save-draft').addEventListener('click', async () => {
      readStep(currentStep);
      await saveShow(currentStep);
      window.location.href = base + 'organiser';
    });

    document.getElementById('btn-publish').addEventListener('click', async () => {
      document.getElementById('btn-publish').textContent = 'Publishing…';
      await finalSave('published');
    });

    document.getElementById('btn-save-draft-final').addEventListener('click', async () => {
      await finalSave('draft');
    });

    document.getElementById('draft-continue').addEventListener('click', async () => {
      document.getElementById('draft-banner').style.display = 'none';
      if (draftShow) await loadDraft(draftShow.id);
    });

    document.getElementById('draft-fresh').addEventListener('click', () => {
      document.getElementById('draft-banner').style.display = 'none';
      draftShow = null;
    });
  }

  // ─── Breed combobox ─────────────────────────────────────────────────────────
  function initBreedCombobox() {
    const input   = document.getElementById('s3-breed');
    const listbox = document.getElementById('s3-breed-listbox');
    if (!input || !listbox) return;

    let activeIdx = -1;

    function getMatches(q) {
      if (!q) return DOG_BREEDS.slice(0, 8);
      const lq = q.toLowerCase();
      return DOG_BREEDS.filter(b => b.toLowerCase().includes(lq)).slice(0, 60);
    }

    function renderList(matches) {
      listbox.innerHTML = matches.length
        ? matches.map((b, i) =>
            `<li role="option" data-idx="${i}" class="px-4 py-2.5 text-[14px] text-[#1c1626] cursor-pointer hover:bg-[#e8f7f6]">${b}</li>`
          ).join('')
        : `<li class="px-4 py-3 text-[14px] text-[#9b94a8]">No breeds found</li>`;
    }

    function openList(q) {
      renderList(getMatches(q));
      listbox.classList.remove('hidden');
      input.setAttribute('aria-expanded', 'true');
      activeIdx = -1;
    }

    function closeList() {
      listbox.classList.add('hidden');
      input.setAttribute('aria-expanded', 'false');
      activeIdx = -1;
    }

    function setActive(idx) {
      const items = listbox.querySelectorAll('[role="option"]');
      items.forEach((el, i) => el.classList.toggle('bg-[#e8f7f6]', i === idx));
      activeIdx = idx;
      if (items[idx]) items[idx].scrollIntoView({ block: 'nearest' });
    }

    input.addEventListener('input',  () => openList(input.value.trim()));
    input.addEventListener('focus',  () => openList(input.value.trim()));

    input.addEventListener('keydown', e => {
      const items = listbox.querySelectorAll('[role="option"]');
      if      (e.key === 'ArrowDown')              { e.preventDefault(); setActive(Math.min(activeIdx + 1, items.length - 1)); }
      else if (e.key === 'ArrowUp')                { e.preventDefault(); setActive(Math.max(activeIdx - 1, 0)); }
      else if (e.key === 'Enter' && activeIdx >= 0){ e.preventDefault(); input.value = items[activeIdx].textContent; closeList(); }
      else if (e.key === 'Escape')                 { closeList(); }
    });

    listbox.addEventListener('mousedown', e => {
      const li = e.target.closest('[role="option"]');
      if (li) { input.value = li.textContent; closeList(); }
    });

    document.addEventListener('click', e => {
      if (!input.contains(e.target) && !listbox.contains(e.target)) closeList();
    });
  }
</script>
