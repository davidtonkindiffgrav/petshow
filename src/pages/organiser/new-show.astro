        <p class="text-[13px] font-semibold text-[#4a4357] mb-2">Which logo appears on the public show page?</p>
        <div class="grid grid-cols-2 gap-3" id="s9-logo-source-cards">
          <button type="button" data-value="show" class="sel-card flex items-center gap-2.5 rounded-[11px] border-2 border-[#b8e4e0] bg-white px-4 py-3 text-left transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <div>
              <p class="text-[12px] font-bold text-[#1c1626]">Show Logo</p>
              <p class="text-[11px] text-[#9b94a8]">Specific to this event</p>
            </div>
          </button>
          <button type="button" data-value="club" class="sel-card flex items-center gap-2.5 rounded-[11px] border-2 border-[#b8e4e0] bg-white px-4 py-3 text-left transition-all cursor-pointer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <div>
              <p class="text-[12px] font-bold text-[#1c1626]">Club Logo</p>
              <p class="text-[11px] text-[#9b94a8]">Your organisation logo</p>
            </div>
          </button>
        </div>
      </div>

      <!-- Show Banner -->
      <div>
        <label class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Show Banner <span class="text-[#9b94a8] font-normal">(optional)</span></label>
        <div id="s9-banner-widget">
          <input type="file" class="upload-input hidden" accept="image/jpeg,image/png,image/webp" />
          <div class="upload-trigger flex items-center gap-4 border-2 border-dashed border-[#b8e4e0] rounded-[14px] px-6 py-5 cursor-pointer hover:bg-brand-tint/50 transition-colors">
            <img class="upload-preview hidden h-14 rounded-lg object-cover shrink-0" />
            <svg class="upload-icon shrink-0" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9b94a8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <div>
              <span class="upload-label block text-[13px] text-[#9b94a8] font-medium">Click to upload a banner image</span>
              <span class="upload-size-hint text-[11px] text-[#c4bed0]">JPG, PNG, WebP · max 2 MB · recommended 1400×600 — keep the focal point on the right half</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── Step 10: Review & Publish ─────────────────────────────────────── -->
    <div id="step-10" style="display:none" class="bg-white rounded-card shadow-winner-card p-8">
      <h2 class="text-[21px] font-extrabold text-[#1c1626] tracking-[-0.02em] mb-1">Review & Publish</h2>
      <p class="text-[14px] text-[#6f6880] mb-7">Check everything looks right before going live.</p>
      <div id="s10-review" class="space-y-3 mb-8"></div>

      <div class="flex flex-col sm:flex-row gap-3 pt-6 border-t border-[#efebf5]">
        <button id="btn-publish"
          class="flex-1 inline-flex items-center justify-center gap-2 bg-brand text-white text-[15px] font-bold py-3.5 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Publish Now
        </button>
        <button id="btn-save-draft-final"
          class="flex-1 inline-flex items-center justify-center gap-2 text-[#6f6880] border border-[#b8e4e0] text-[15px] font-bold py-3.5 rounded-btn hover:bg-[#f0fafa] transition-colors">
          Save as Draft
        </button>
        <button disabled
          class="flex-1 inline-flex items-center justify-center gap-2 text-[#c4bed0] border border-[#efebf5] text-[15px] font-bold py-3.5 rounded-btn cursor-not-allowed relative">
          Schedule
          <span class="absolute -top-2 -right-1 text-[10px] font-bold bg-[#efebf5] text-[#9b94a8] px-1.5 py-0.5 rounded-full">Soon</span>
        </button>
      </div>
    </div>

    <!-- Navigation buttons -->
    <div class="flex items-center justify-between mt-6">
      <button id="btn-back" style="display:none"
        class="inline-flex items-center gap-2 text-[13.5px] font-semibold text-[#6f6880] hover:text-[#1c1626] transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back
      </button>
      <div id="nav-spacer" class="flex-1"></div>
      <button id="btn-next"
        class="inline-flex items-center gap-2 bg-brand text-white text-[14px] font-bold px-6 py-3 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
        Continue
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </button>
    </div>

  </div>
</DashboardLayout>

<script>
  import { getAuth } from '../../lib/auth.js';
  import { supabase } from '../../lib/supabase.js';
  import { uploadImage } from '../../lib/storage.js';
  import { showUploadOverlay, hideUploadOverlay } from '../../lib/uploadOverlay.js';
  import { FUN_STAKES } from '../../lib/show-categories.js';
  import { minEntryFee, platformFee, stripeFeeEstimate, organiserNet, clampFee } from '../../lib/fees.js';
  import { searchBreeds } from '../../lib/dog-breeds.js';

  // ─── Constants ──────────────────────────────────────────────────────────────
  const STEP_NAMES = [
    'Show Basics', 'Animal Type', 'Breed & Eligibility', 'Classes',
    'Sponsorship', 'Judging', 'Awards & Prizes', 'Fundraising',
    'Branding', 'Review & Publish',
  ];

  // ─── State ──────────────────────────────────────────────────────────────────
  const show = {
    id: null,
    title: '', host_org: '', org_type: null, charity_number: '',
    contact_email: '', contact_phone: '',
    entry_open_date: '', entry_close_date: '', show_date: '', show_time: '',
    vote_open_mode: 'after_entries_close',
    show_type: null, animal_type: 'dog',
    breed_scope: 'all', breed_filter: '', group_filter: '',
    has_sponsor: null, sponsors: [{ name: '', website: '', logo_url: '' }],
    is_judged: null, judge_count: 1, judge_setup: 'later',
    judges: [],
    has_digital_certs: null, has_physical_prizes: null, prize_source: null,
    prizes: [],
    is_fundraising: true,
    fundraising_goal: null,
    show_fundraising_publicly: null,
    currency: 'AUD', entry_fee: 0,
    classes: [],
    logo_url: '', banner_url: '', org_logo_url: '', logo_source: 'show',
    wizard_step: 1,
    timezone: '', entry_open_time: '', entry_close_time: '',
  };

  const CURRENCY_SYMBOLS  = { GBP: '£', USD: '$', EUR: '€', AUD: 'A$', CAD: 'C$', NZD: 'NZ$', ZAR: 'R', SGD: 'S$' };
  const getMin = (code) => minEntryFee(code, serviceFees);

  const TIMEZONES = [
    { group: 'Australia & New Zealand', zones: [
      { id: 'Pacific/Auckland',    label: 'New Zealand — Auckland, Wellington' },
      { id: 'Pacific/Chatham',     label: 'New Zealand — Chatham Islands' },
      { id: 'Australia/Sydney',    label: 'Australia — Sydney, Melbourne, Canberra (AEDT/AEST)' },
      { id: 'Australia/Brisbane',  label: 'Australia — Brisbane, QLD (no DST)' },
      { id: 'Australia/Adelaide',  label: 'Australia — Adelaide, SA (ACDT/ACST)' },
      { id: 'Australia/Darwin',    label: 'Australia — Darwin, NT (no DST)' },
      { id: 'Australia/Perth',     label: 'Australia — Perth, WA (AWST)' },
      { id: 'Australia/Hobart',    label: 'Australia — Hobart, TAS' },
    ]},
    { group: 'Pacific', zones: [
      { id: 'Pacific/Fiji',        label: 'Fiji' },
      { id: 'Pacific/Honolulu',    label: 'Hawaii (no DST)' },
      { id: 'Pacific/Guam',        label: 'Guam / Chamorro' },
    ]},
    { group: 'Asia', zones: [
      { id: 'Asia/Singapore',      label: 'Singapore / Malaysia / Western Indonesia' },
      { id: 'Asia/Hong_Kong',      label: 'Hong Kong' },
      { id: 'Asia/Tokyo',          label: 'Japan' },
      { id: 'Asia/Seoul',          label: 'South Korea' },
      { id: 'Asia/Kolkata',        label: 'India' },
      { id: 'Asia/Dubai',          label: 'UAE / Gulf (GST)' },
      { id: 'Asia/Bangkok',        label: 'Thailand / Vietnam / Indonesia (WIB)' },
      { id: 'Asia/Shanghai',       label: 'China' },
    ]},
    { group: 'Europe', zones: [
      { id: 'Europe/London',       label: 'UK / Ireland (GMT/BST)' },
      { id: 'Europe/Paris',        label: 'Central Europe — Paris, Berlin, Rome, Madrid' },
      { id: 'Europe/Helsinki',     label: 'Eastern Europe — Helsinki, Kyiv, Riga' },
      { id: 'Europe/Moscow',       label: 'Moscow Time' },
    ]},
    { group: 'Americas', zones: [
      { id: 'America/New_York',    label: 'Eastern US / Canada (ET)' },
      { id: 'America/Chicago',     label: 'Central US / Canada (CT)' },
      { id: 'America/Denver',      label: 'Mountain US / Canada (MT)' },
      { id: 'America/Los_Angeles', label: 'Pacific US / Canada (PT)' },
      { id: 'America/Anchorage',   label: 'Alaska' },
      { id: 'America/Sao_Paulo',   label: 'Brazil — São Paulo (BRT)' },
    ]},
    { group: 'Africa', zones: [
      { id: 'Africa/Johannesburg', label: 'South Africa (SAST)' },
      { id: 'Africa/Lagos',        label: 'West Africa Time (WAT)' },
      { id: 'Africa/Nairobi',      label: 'East Africa Time (EAT)' },
    ]},
  ];

  let currentStep = 1;
  let session, profile, base;
  let draftShow      = null;
  let serviceFees    = {};
  let savedJudges    = [];
  let maxUploadMb    = 5;
  const esc = s => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

  // ─── Auth ───────────────────────────────────────────────────────────────────
  const auth = await getAuth();
  session = auth.session;
  profile = auth.profile;
  base    = auth.base;

  if (!session) {
    window.location.replace(base + 'login');
  } else {
    // Sidebar
    const name = profile?.display_name || session.user.email?.split('@')[0] || 'Organiser';
    const avatarEl = document.getElementById('sidebar-avatar');
    const nameEl   = document.getElementById('sidebar-username');
    const badgeEl  = document.getElementById('sidebar-role-badge');
    if (avatarEl) {
      if (profile?.avatar_url) {
        avatarEl.innerHTML = `<img src="${profile.avatar_url}" alt="" style="width:100%;height:100%;object-fit:cover;">`;
      } else {
        avatarEl.textContent = name.charAt(0).toUpperCase();
      }
    }
    if (nameEl)   nameEl.textContent   = name;
    if (badgeEl)  badgeEl.textContent  = profile?.organiser_type === 'club' ? 'Club Organiser' : 'Organiser';
    document.getElementById('sidebar-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = base + 'login';
    });

    // Pre-fill
    show.contact_email = session.user.email || '';
    document.getElementById('s1-contact-email').value = show.contact_email;

    // Timezone: prefer profile.default_timezone (populated when account settings page ships),
    // otherwise auto-detect from browser. initTimezoneSelect() reads show.timezone.
    show.timezone = profile?.default_timezone
      || Intl.DateTimeFormat().resolvedOptions().timeZone
      || 'Australia/Sydney';

    // Currency: prefer profile.default_currency (populated when account settings page ships).
    if (profile?.default_currency) {
      show.currency = profile.default_currency;
      document.getElementById('s8-currency').value = profile.default_currency;
    }

    if (profile?.organisation_id) {
      const { data: org } = await supabase.from('organisations').select('name').eq('id', profile.organisation_id).single();
      if (org) { show.host_org = org.name; document.getElementById('s1-host-org').value = org.name; }
    }

    // Check for existing draft (skip banner if we're loading a specific show via ?id=)
    const urlIdEarly = new URLSearchParams(window.location.search).get('id');
    if (!urlIdEarly) {
      const { data: drafts } = await supabase
        .from('shows').select('id, title, wizard_step').eq('created_by', session.user.id)
        .eq('status', 'draft').order('created_at', { ascending: false }).limit(1);

      if (drafts && drafts.length > 0) {
        draftShow = drafts[0];
        document.getElementById('draft-title').textContent = draftShow.title || 'Untitled Show';
        document.getElementById('draft-banner').style.display = 'flex';
      }
    }

    const { data: feeSettings } = await supabase
      .from('platform_settings').select('key, value').or('key.like.service_fee_%,key.like.min_entry_fee_%,key.like.stripe_fee_%,key.eq.max_upload_mb');
    (feeSettings || []).forEach(r => {
      if (r.key === 'max_upload_mb') maxUploadMb = parseFloat(r.value) || 5;
      else serviceFees[r.key] = parseFloat(r.value) || 0;
    });
    document.querySelectorAll('.upload-size-hint').forEach(el => {
      el.textContent = el.textContent.replace(/\d+ MB/, `${maxUploadMb} MB`);
    });

    const { data: sjData } = await supabase
      .from('saved_judges').select('*').eq('organiser_id', session.user.id).order('first_name');
    if (sjData) savedJudges = sjData;

    setupEventListeners();
    initCardGroups();
    initBreedCombobox();
    initTimezoneSelect();

    const urlId = new URLSearchParams(window.location.search).get('id');
    if (urlId) {
      document.getElementById('draft-banner').style.display = 'none';
      await loadDraft(urlId);
    } else {
      goToStep(1);
    }
  }

  // ─── Navigation ─────────────────────────────────────────────────────────────
  function goToStep(n) {
    document.getElementById(`step-${currentStep}`).style.display = 'none';
    currentStep = n;
    document.getElementById(`step-${currentStep}`).style.display = 'block';
    document.getElementById('step-error').style.display = 'none';
    updateProgress();
    updateNav();
    if (n === 4) initStep4();
    if (n === 6) updateJudgePanels();
    if (n === 8) { applyCurrencySymbol(show.currency || 'AUD'); updatePublicToggleAvailability(); }
    if (n === 10) buildReview();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  // Exposed globally so inline onclick="goToStep(n)" in the review step works
  window.goToStep = goToStep;

  function updateProgress() {
    document.getElementById('prog-num').textContent = String(currentStep);
    document.getElementById('prog-name').textContent = STEP_NAMES[currentStep - 1];
    document.getElementById('prog-bar').style.width = `${(currentStep / 10) * 100}%`;
  }

  function updateNav() {
    const backBtn  = document.getElementById('btn-back');
    const nextBtn  = document.getElementById('btn-next');
    const draftBtn = document.getElementById('action-save-draft');
    backBtn.style.display  = currentStep > 1 ? 'inline-flex' : 'none';
    nextBtn.style.display  = currentStep < 10 ? 'inline-flex' : 'none';
    draftBtn.style.display = currentStep > 1 ? 'inline-flex' : 'none';
  }

  function showError(msg) {
    const el = document.getElementById('step-error');
    el.textContent = msg;
    el.style.display = 'block';
    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ─── Card selection helper ───────────────────────────────────────────────────
  function selectCard(container, value) {
    container.querySelectorAll('[data-value]').forEach(card => {
      if (card.disabled) return;
      const active = card.dataset.value === value;
      card.dataset.selected    = active ? 'true' : 'false';
      card.style.borderColor   = active ? '#1ba89a' : '#b8e4e0';
      card.style.background    = active ? '#f0fafa' : 'white';
      card.style.boxShadow     = active ? '0 0 0 3px rgba(27,168,154,0.18)' : 'none';
    });
  }

  function getSelectedCard(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return null;
    const active = el.querySelector('[data-selected="true"]');
    return active ? active.dataset.value : null;
  }

  // ─── Toggle switch helper ───────────────────────────────────────────────────
  function setupToggle(btnId, onChange) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.addEventListener('click', () => {
      const on = btn.dataset.on !== 'true';
      btn.dataset.on = String(on);
      btn.style.background = on ? '#1ba89a' : '#efebf5';
      btn.querySelector('span').style.transform = on ? 'translateX(20px)' : 'translateX(0)';
      onChange(on);
    });
  }

  function setToggle(btnId, on) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    btn.dataset.on = String(on);
    btn.style.background = on ? '#1ba89a' : '#efebf5';
    btn.querySelector('span').style.transform = on ? 'translateX(20px)' : 'translateX(0)';
  }

  // ─── YNA (Yes/No/Add Later) helper ──────────────────────────────────────────
  function setupYNA(containerId, onChange) {
    const el = document.getElementById(containerId);
    el.querySelectorAll('.yna').forEach(btn => {
      btn.addEventListener('click', () => {
        el.querySelectorAll('.yna').forEach(b => {
          b.dataset.selected = 'false';
          b.style.borderColor = '#b8e4e0'; b.style.background = 'white'; b.style.boxShadow = 'none';
        });
        btn.dataset.selected  = 'true';
        btn.style.borderColor = '#1ba89a';
        btn.style.background  = '#f0fafa';
        btn.style.boxShadow   = '0 0 0 3px rgba(27,168,154,0.18)';
        onChange(btn.dataset.value);
      });
    });
  }

  function setYNA(containerId, value) {
    const el = document.getElementById(containerId);
    if (!el || !value) return;
    el.querySelectorAll('.yna').forEach(btn => {
      const active = btn.dataset.value === value;
      btn.dataset.selected  = active ? 'true' : 'false';
      btn.style.borderColor = active ? '#1ba89a' : '#b8e4e0';
      btn.style.background  = active ? '#f0fafa' : 'white';
      btn.style.boxShadow   = active ? '0 0 0 3px rgba(27,168,154,0.18)' : 'none';
    });
  }

  // ─── Validation ─────────────────────────────────────────────────────────────
  function validateStep(n) {
    if (n === 1) {
      if (!document.getElementById('s1-title').value.trim()) return showError('Please enter a show name.'), false;
      if (!document.getElementById('s1-entry-close').value) return showError('Please set an entries close date.'), false;
      if (!document.getElementById('s1-show-date').value) return showError('Please set a show date.'), false;
      if (!getSelectedCard('org-type-cards')) return showError('Please select your type of organisation.'), false;
      const orgType = getSelectedCard('org-type-cards');
      if (orgType === 'non_profit' || orgType === 'registered_charity') {
        if (!document.getElementById('s1-charity-number').value.trim()) return showError('Please enter your Charity / Non-Profit Number to continue.'), false;
      }
      const email = document.getElementById('s1-contact-email').value.trim();
      if (!email || !email.includes('@')) return showError('Please enter a valid contact email.'), false;
      return true;
    }
    if (n === 2) {
      return true;
    }
    if (n === 3) {
      const scope = getSelectedCard('breed-scope-cards');
      if (!scope) return showError('Please select a breed scope.'), false;
      if (scope === 'breed_specific' && !document.getElementById('s3-breed').value.trim()) return showError('Please enter a breed name.'), false;
      if (scope === 'group_specific' && !document.getElementById('s3-group').value.trim()) return showError('Please enter a group name.'), false;
      return true;
    }
    if (n === 4) {
      if (show.classes.filter(c => c.enabled).length === 0) return showError('Please enable at least one class.'), false;
      return true;
    }
    if (n === 5) {
      const choice = getSelectedCard('sponsor-choice') || getYNAValue('sponsor-choice');
      if (!choice) return showError('Please make a selection.'), false;
      if (choice === 'yes' && !document.getElementById('s5-sponsor-name').value.trim()) return showError('Please enter a sponsor name.'), false;
      return true;
    }
    if (n === 6) {
      const choice = getYNAValue('judging-choice');
      if (!choice) return showError('Please make a selection.'), false;
      if (choice === 'yes') {
        const setup = getSelectedCard('judge-setup-cards');
        if (!setup) return showError('Please choose a judge setup option.'), false;
        if (setup === 'now') {
          {
            const fn = document.getElementById('judge-fn-0')?.value.trim();
            const ln = document.getElementById('judge-ln-0')?.value.trim();
            const em = document.getElementById('judge-em-0')?.value.trim();
            if (!fn || !ln || !em) return showError('Please fill in all required fields for the judge.'), false;
          }
        }
      }
      return true;
    }
    if (n === 7) {
      const choice = getYNAValue('awards-choice');
      if (!choice) return showError('Please make a selection.'), false;
      return true;
    }
    if (n === 8) {
      const fee = getFeeValue();
      const currency = document.getElementById('s8-currency')?.value || 'AUD';
      const minFee = getMin(currency);
      if (minFee == null) return showError('Fee settings could not be loaded — please refresh the page.'), false;
      if (fee < minFee) return showError(`Please set a valid entry fee (minimum ${CURRENCY_SYMBOLS[currency] || ''}${minFee}).`), false;
      return true;
    }
    return true;
  }

  function getYNAValue(containerId) {
    const el = document.getElementById(containerId);
    if (!el) return null;
    const active = el.querySelector('.yna[data-selected="true"]');
    return active ? active.dataset.value : null;
  }

  // ─── Read step values into show state ───────────────────────────────────────
  function readStep(n) {
    if (n === 1) {
      show.title          = document.getElementById('s1-title').value.trim();
      show.entry_open_date = document.getElementById('s1-entry-open').value || null;
      show.entry_close_date = document.getElementById('s1-entry-close').value || null;
      show.show_date      = document.getElementById('s1-show-date').value || null;
      show.show_time      = document.getElementById('s1-show-time').value || '';
      show.host_org       = document.getElementById('s1-host-org').value.trim();
      show.description    = document.getElementById('s1-description').value.trim() || null;
      show.about          = document.getElementById('s1-about').value.trim() || null;
      show.website_url    = document.getElementById('s1-website-url').value.trim() || null;
      show.org_type       = getSelectedCard('org-type-cards');
      show.charity_number = document.getElementById('s1-charity-number').value.trim();
      show.contact_email    = document.getElementById('s1-contact-email').value.trim();
      show.contact_phone    = document.getElementById('s1-contact-phone').value.trim();
      show.timezone         = document.getElementById('s1-timezone').value || show.timezone;
      show.entry_open_time  = document.getElementById('s1-entry-open-time').value || '';
      show.entry_close_time = document.getElementById('s1-entry-close-time').value || '';
    }
    if (n === 2) {
      show.show_type   = 'fun_stakes';
      show.animal_type = getSelectedCard('animal-type-cards') || 'dog';
    }
    if (n === 3) {
      show.breed_scope  = getSelectedCard('breed-scope-cards') || 'all';
      show.breed_filter = document.getElementById('s3-breed').value.trim();
      show.group_filter = document.getElementById('s3-group').value.trim();
    }
    if (n === 4) {
      // classes already updated in real-time via toggle handlers
    }
    if (n === 5) {
      const choice = getYNAValue('sponsor-choice');
      show.has_sponsor = choice === 'yes' ? true : choice === 'no' ? false : null;
      if (choice === 'yes') {
        show.sponsors = [{ name: document.getElementById('s5-sponsor-name').value.trim(), website: document.getElementById('s5-sponsor-website').value.trim(), logo_url: show.sponsors[0]?.logo_url || null }];
      }
    }
    if (n === 6) {
      const choice = getYNAValue('judging-choice');
      show.is_judged    = choice === 'yes' ? true : choice === 'no' ? false : null;
      show.judge_setup  = getSelectedCard('judge-setup-cards') || 'later';
      if (choice === 'no') {
        show.vote_open_mode = getSelectedCard('vote-timing-cards') || 'after_entries_close';
      }
      if (choice === 'yes' && show.judge_setup === 'now') {
        show.judges = [{
          first_name: document.getElementById('judge-fn-0')?.value.trim() || '',
          last_name:  document.getElementById('judge-ln-0')?.value.trim() || '',
          email:      document.getElementById('judge-em-0')?.value.trim() || '',
          phone:      document.getElementById('judge-ph-0')?.value.trim() || '',
          photo_url:  show.judges[0]?.photo_url || '',
        }];
      }
    }
    if (n === 7) {
      const choice = getYNAValue('awards-choice');
      show.has_digital_certs   = choice === 'yes' ? document.getElementById('s7-certs-toggle').dataset.on === 'true' : null;
      show.has_physical_prizes = choice === 'yes' ? document.getElementById('s7-physical-toggle').dataset.on === 'true' : null;
      show.prize_source        = choice === 'yes' ? getSelectedCard('prize-source-cards') : null;
      if (choice !== 'yes') { show.has_digital_certs = null; show.has_physical_prizes = null; }
    }
    if (n === 8) {
      show.is_fundraising            = true;
      show.fundraising_goal          = parseFloat(document.getElementById('s8-fund-goal').value) || null;
      show.show_fundraising_publicly = show.fundraising_goal > 0 && document.getElementById('s8-public-toggle').dataset.on === 'true';
      show.currency                  = document.getElementById('s8-currency').value || 'AUD';
      show.entry_fee                 = getFeeValue();
    }
    if (n === 9) {
      show.logo_source = getSelectedCard('s9-logo-source-cards') || 'show';
    }
  }

  // ─── Supabase save ───────────────────────────────────────────────────────────
  async function saveShow(completedStep) {
    const payload = {
      title: show.title, host_org: show.host_org || null, org_type: show.org_type, charity_number: show.charity_number || null,
      contact_email: show.contact_email, contact_phone: show.contact_phone || null,
      entry_open_date: show.entry_open_date || null, entry_close_date: show.entry_close_date || null,
      show_date: show.show_date || null,
      show_time: show.show_time || null,
      vote_open_mode: show.vote_open_mode || 'after_entries_close',
      show_type: show.show_type, animal_type: show.animal_type,
      breed_scope: show.breed_scope, breed_filter: show.breed_filter || null, group_filter: show.group_filter || null,
      has_sponsor: show.has_sponsor, is_judged: show.is_judged,
      judge_count: 1, judge_setup: show.judge_setup,
      has_digital_certs: show.has_digital_certs, has_physical_prizes: show.has_physical_prizes,
      prize_source: show.prize_source, is_fundraising: show.is_fundraising,
      donation_type: show.donation_type, fundraising_goal: show.fundraising_goal || null,
      show_fundraising_publicly: show.show_fundraising_publicly, donation_receipts: show.donation_receipts,
      description: show.description || null, about: show.about || null, website_url: show.website_url || null,
      logo_url: show.logo_url || null, banner_url: show.banner_url || null, org_logo_url: show.org_logo_url || null,
      logo_source: show.logo_source || 'show',
      currency: show.currency, entry_fee: show.entry_fee, status: 'draft',
      timezone: show.timezone || null,
      entry_open_time: show.entry_open_time || null,
      entry_close_time: show.entry_close_time || null,
      wizard_step: completedStep + 1,
    };

    if (!show.id) {
      payload.created_by = session.user.id;
      if (profile?.organisation_id) payload.organisation_id = profile.organisation_id;
      const { data, error } = await supabase.from('shows').insert(payload).select('id').single();
      if (!error && data) show.id = data.id;
    } else {
      await supabase.from('shows').update(payload).eq('id', show.id);
    }

    // Save categories for step 4
    if (completedStep === 4 && show.id) {
      await supabase.from('show_categories').delete().eq('show_id', show.id);
      const enabled = show.classes.filter(c => c.enabled);
      if (enabled.length > 0) {
        await supabase.from('show_categories').insert(enabled.map(c => ({ show_id: show.id, name: c.name, description: c.description || null })));
      }
    }

    // Save judges for step 6
    if (completedStep === 6 && show.id) {
      const judgePanels = Array.from(document.querySelectorAll('#s6-judge-panels > div'));
      let hasDuplicates = false;
      for (const panel of judgePanels) {
        if (panel.dataset.savedId) continue;
        const idx = panel.dataset.judgeIdx;
        const em  = document.getElementById(`judge-em-${idx}`)?.value.trim().toLowerCase();
        if (!em) continue;
        const match = savedJudges.find(sj => sj.email?.toLowerCase() === em);
        if (!match) continue;
        showWizardDuplicatePrompt(panel, match);
        hasDuplicates = true;
      }
      if (hasDuplicates) return false;

      // Judges can't also be exhibitors in the same show
      if (show.is_judged && show.judge_setup === 'now' && show.judges.length > 0) {
        const judgeEmails = show.judges.map(j => j.email?.trim().toLowerCase()).filter(Boolean);
        if (judgeEmails.length) {
          const { data: entryRows } = await supabase.from('show_entries')
            .select('exhibitor_email').eq('show_id', show.id).not('exhibitor_email', 'is', null);
          const entryEmails = new Set((entryRows || []).map(r => r.exhibitor_email.toLowerCase()));
          const clash = judgeEmails.find(em => entryEmails.has(em));
          if (clash) return showError(`An exhibitor with the email ${clash} has entered this show and can't be assigned as a judge.`), false;
        }
      }

      await supabase.from('show_judges').delete().eq('show_id', show.id);
      if (show.is_judged && show.judge_setup === 'now' && show.judges.length > 0) {
        await supabase.from('show_judges').insert(show.judges.map(j => ({ show_id: show.id, ...j })));
      }
      // Save ticked judges to saved_judges (skip duplicates by email)
      if (show.is_judged && show.judge_setup === 'now' && document.getElementById('judge-save-0')?.checked) {
        const fn = document.getElementById('judge-fn-0')?.value.trim();
        const ln = document.getElementById('judge-ln-0')?.value.trim();
        const em = document.getElementById('judge-em-0')?.value.trim() || null;
        const ph = document.getElementById('judge-ph-0')?.value.trim() || null;
        if (fn && ln && (!em || !savedJudges.some(sj => sj.email?.toLowerCase() === em.toLowerCase()))) {
          const pu = show.judges[0]?.photo_url || null;
          const { data: newSJ } = await supabase.from('saved_judges')
            .insert({ organiser_id: session.user.id, first_name: fn, last_name: ln, email: em, phone: ph, photo_url: pu })
            .select().single();
          if (newSJ) savedJudges.push(newSJ);
        }
      }
    }

    // Save sponsor for step 5
    if (completedStep === 5 && show.id) {
      await supabase.from('show_sponsors').delete().eq('show_id', show.id);
      if (show.has_sponsor && show.sponsors[0]?.name) {
        await supabase.from('show_sponsors').insert(show.sponsors.filter(s => s.name).map(s => ({ show_id: show.id, ...s })));
      }
    }

    // Save prizes for step 7
    if (completedStep === 7 && show.id) {
      await supabase.from('show_prizes').delete().eq('show_id', show.id);
      if (show.has_physical_prizes && show.prizes.length > 0) {
        await supabase.from('show_prizes').insert(show.prizes.filter(p => p).map(p => ({ show_id: show.id, description: p })));
      }
    }
  }

  // ─── Step 4 init ─────────────────────────────────────────────────────────────
  function initStep4() {
    if (show.classes.length === 0) {
      show.classes.push({ name: '', description: '', enabled: true, custom: true });
    }
    renderFunStakesCategories();
  }

  function renderFunStakesCategories() {
    const list = document.getElementById('s4-funstakes-list');
    list.innerHTML = '';
    show.classes.forEach((cls, i) => appendFunStakesRow(i, cls.name, cls.description));
    renderFunStakesSuggestions();
  }

  function appendFunStakesRow(idx, name, description) {
    const list = document.getElementById('s4-funstakes-list');
    const row = document.createElement('div');
    row.className = 'border border-[#efebf5] rounded-[13px] p-3.5 bg-[#fafafc]';
    row.innerHTML = `
      <div class="flex items-start gap-2 mb-2.5">
        <div class="flex-1">
          <label class="block text-[10.5px] font-bold text-[#9b94a8] uppercase tracking-wide mb-1">Category Name</label>
          <input type="text" value="${name}" placeholder="e.g. Best Rescue"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-3 py-2.5 text-[13px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <button type="button" class="fs-remove shrink-0 text-[#c4bed0] hover:text-red-400 transition-colors mt-[22px]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div>
        <label class="block text-[10.5px] font-bold text-[#9b94a8] uppercase tracking-wide mb-1">Description <span class="normal-case font-medium text-[#c4bed0]">(shown as a tooltip to entrants)</span></label>
        <input type="text" value="${description || ''}" placeholder="Briefly describe this category"
          class="w-full border border-[#efebf5] rounded-[11px] px-3 py-2 text-[12.5px] text-[#6f6880] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
      </div>
    `;
    row.querySelectorAll('input')[0].addEventListener('input', e => { show.classes[idx].name = e.target.value; });
    row.querySelectorAll('input')[1].addEventListener('input', e => { show.classes[idx].description = e.target.value; });
    row.querySelector('.fs-remove').addEventListener('click', () => {
      show.classes.splice(idx, 1);
      renderFunStakesCategories();
    });
    list.appendChild(row);
  }

  function renderFunStakesSuggestions() {
    const wrap = document.getElementById('s4-funstakes-suggestions');
    wrap.innerHTML = '';
    const existingNames = new Set(show.classes.map(c => c.name));
    FUN_STAKES.filter(cat => cat.suggested).forEach(cat => {
      const already = existingNames.has(cat.name);
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'rounded-full border-2 px-3.5 py-1.5 text-[12.5px] font-semibold transition-all';
      btn.style.borderColor = '#b8e4e0';
      btn.style.background  = 'white';
      btn.style.color       = already ? '#c4bed0' : '#4a4357';
      btn.style.cursor      = already ? 'default' : 'pointer';
      btn.disabled = already;
      btn.textContent = already ? `${cat.name} ✓` : `+ ${cat.name}`;
      attachTooltip(btn, cat.description);
      btn.addEventListener('click', () => {
        if (existingNames.has(cat.name)) return;
        _tip.style.display = 'none';
        const blankIdx = show.classes.findIndex(c => !c.name.trim());
        if (blankIdx !== -1) {
          show.classes[blankIdx].name = cat.name;
          show.classes[blankIdx].description = cat.description;
        } else {
          show.classes.push({ name: cat.name, description: cat.description, enabled: true, custom: true });
        }
        renderFunStakesCategories();
      });
      wrap.appendChild(btn);
    });
  }

  // ─── Judge panels ────────────────────────────────────────────────────────────
  function renderJudgeDisplay(judge) {
    const el = document.getElementById('judge-current');
    if (!el) return;
    if (judge?.first_name) {
      const photo = judge.photo_url
        ? `<img src="${esc(judge.photo_url)}" class="w-10 h-10 rounded-full object-cover shrink-0" />`
        : `<div class="w-10 h-10 rounded-full bg-brand-tint flex items-center justify-center text-brand font-extrabold text-[14px] shrink-0">${esc(judge.first_name[0].toUpperCase())}</div>`;
      el.className = 'flex items-center gap-3 p-3.5 rounded-[12px] border border-[#b8e4e0] bg-[#f0fafa] mb-5';
      el.innerHTML = `${photo}<div>
        <p class="text-[13.5px] font-bold text-[#1c1626]">${esc(judge.first_name)} ${esc(judge.last_name || '')}</p>
        ${judge.email ? `<p class="text-[12px] text-[#9b94a8]">${esc(judge.email)}</p>` : ''}
      </div>`;
    } else {
      el.className = 'flex items-center gap-3 p-3.5 rounded-[12px] border border-[#efebf5] mb-5';
      el.innerHTML = `
        <div class="w-10 h-10 rounded-full border-2 border-dashed border-[#c4bed0] flex items-center justify-center shrink-0">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
        </div>
        <div>
          <p class="text-[13px] font-semibold text-[#9b94a8]">No judge assigned yet</p>
          <p class="text-[12px] text-[#c4bed0]">Fill in the details below ↓</p>
        </div>`;
    }
  }

  function updateJudgePanels() {
    const container = document.getElementById('s6-judge-panels');
    container.innerHTML = '';
    renderJudgeDisplay(show.judges[0]);
    const i = 0;
    const j = show.judges[i] || { first_name: '', last_name: '', email: '', phone: '', photo_url: '' };
      const panel = document.createElement('div');
      panel.className = 'border border-[#efebf5] rounded-[14px] p-4 space-y-3';
      panel.dataset.judgeIdx = i;

      const pickerHtml = savedJudges.length > 0 ? `
        <div class="relative judge-picker-wrap">
          <button type="button" class="judge-picker-btn text-[12.5px] font-semibold text-brand flex items-center gap-1.5 hover:underline">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Saved judges
          </button>
          <div class="judge-picker-dropdown" style="display:none;position:absolute;left:0;top:100%;margin-top:4px;z-index:30;background:white;border:1px solid #e6dcfb;border-radius:12px;box-shadow:0 4px 20px rgba(0,0,0,0.10);min-width:230px;overflow:hidden;padding:4px 0;">
            ${savedJudges.map(sj => `<button type="button" class="judge-pick-item w-full text-left px-4 py-2.5 hover:bg-[#f0fafa] transition-colors" data-id="${sj.id}"><span style="display:block;font-size:13px;font-weight:600;color:#1c1626;">${esc(sj.first_name)} ${esc(sj.last_name)}</span>${sj.email ? `<span style="display:block;font-size:11.5px;color:#9b94a8;">${esc(sj.email)}</span>` : ''}</button>`).join('')}
          </div>
        </div>` : '';

      panel.innerHTML = `
        <div class="flex items-center justify-between">
          <p class="text-[13px] font-bold text-brand">Judge</p>
          ${pickerHtml}
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[12px] font-semibold text-[#4a4357] mb-1">First Name <span class="text-red-400">*</span></label>
            <input type="text" id="judge-fn-${i}" value="${esc(j.first_name)}"
              class="w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-[#4a4357] mb-1">Last Name <span class="text-red-400">*</span></label>
            <input type="text" id="judge-ln-${i}" value="${esc(j.last_name)}"
              class="w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[12px] font-semibold text-[#4a4357] mb-1">Email <span class="text-red-400">*</span></label>
            <input type="email" id="judge-em-${i}" value="${esc(j.email)}"
              class="w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-[#4a4357] mb-1">Phone <span class="text-[#9b94a8] font-normal">(optional)</span></label>
            <input type="tel" id="judge-ph-${i}" value="${esc(j.phone || '')}"
              class="w-full border border-[#b8e4e0] rounded-[10px] px-3 py-2.5 text-[14px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand transition-colors" />
          </div>
        </div>
        <label class="flex items-center gap-2 pt-1 cursor-pointer select-none">
          <input type="checkbox" id="judge-save-${i}" class="w-4 h-4 accent-brand" />
          <span class="text-[12.5px] text-[#6f6880]">Save to my judge book</span>
        </label>
        <div class="flex items-center gap-3 pt-2 border-t border-[#f5f3f8]">
          <div class="w-10 h-10 rounded-full border-2 border-dashed border-[#b8e4e0] bg-[#f0fafa] flex items-center justify-center overflow-hidden judge-photo-circle shrink-0">
            ${j.photo_url ? `<img src="${esc(j.photo_url)}" class="w-full h-full object-cover" />` : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`}
          </div>
          <div>
            <p class="text-[12px] font-semibold text-[#4a4357]">Profile Photo <span class="text-[11px] text-[#9b94a8] font-normal">(optional)</span></p>
            <button type="button" class="judge-photo-btn text-[12px] font-semibold text-brand hover:underline">${j.photo_url ? 'Replace photo' : 'Upload photo'}</button>
            <button type="button" class="judge-photo-remove text-[12px] font-semibold text-red-400 hover:underline ml-2" style="${j.photo_url ? '' : 'display:none'}">Remove</button>
            <input type="file" class="judge-photo-input hidden" accept="image/jpeg,image/png,image/webp" />
          </div>
        </div>
      `;

      const pickerBtn = panel.querySelector('.judge-picker-btn');
      const dropdown  = panel.querySelector('.judge-picker-dropdown');
      if (pickerBtn && dropdown) {
        pickerBtn.addEventListener('click', e => {
          e.stopPropagation();
          document.querySelectorAll('.judge-picker-dropdown').forEach(d => { if (d !== dropdown) d.style.display = 'none'; });
          dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
        });
        panel.querySelectorAll('.judge-pick-item').forEach(btn => {
          btn.addEventListener('click', () => {
            const sj = savedJudges.find(s => s.id === btn.dataset.id);
            if (!sj) return;
            document.getElementById(`judge-fn-${i}`).value = sj.first_name;
            document.getElementById(`judge-ln-${i}`).value = sj.last_name;
            document.getElementById(`judge-em-${i}`).value = sj.email || '';
            document.getElementById(`judge-ph-${i}`).value = sj.phone || '';
            panel.dataset.savedId = sj.id;
            dropdown.style.display = 'none';
          });
        });
      }
      // Judge photo upload
      const photoBtn    = panel.querySelector('.judge-photo-btn');
      const photoInput  = panel.querySelector('.judge-photo-input');
      const photoCircle = panel.querySelector('.judge-photo-circle');
      const photoRemove = panel.querySelector('.judge-photo-remove');

      async function processJudgePhoto(file) {
        if (!file || file.size > maxUploadMb * 1024 * 1024 || !show.id) return;
        photoBtn.textContent = 'Uploading…';
        showUploadOverlay('Uploading photo…');
        try {
          const url = await uploadImage(`judges/${show.id}/judge-${i}`, file);
          if (!show.judges[i]) show.judges[i] = {};
          show.judges[i].photo_url = url;
          photoCircle.innerHTML = `<img src="${url}" class="w-full h-full object-cover" />`;
          photoBtn.textContent = 'Replace photo';
          if (photoRemove) photoRemove.style.display = '';
        } catch { photoBtn.textContent = 'Failed — try again'; }
        finally { hideUploadOverlay(); }
      }

      photoRemove?.addEventListener('click', () => {
        if (show.judges[i]) show.judges[i].photo_url = null;
        photoCircle.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#c4bed0" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>`;
        photoBtn.textContent = 'Upload photo';
        photoInput.value = '';
        photoRemove.style.display = 'none';
      });

      photoBtn.addEventListener('click', () => photoInput.click());
      photoInput.addEventListener('change', () => processJudgePhoto(photoInput.files[0]));

      photoCircle.addEventListener('dragover', e => {
        e.preventDefault();
        photoCircle.style.borderColor = '#1ba89a';
        photoCircle.style.background  = 'rgba(27,168,154,0.10)';
      });
      photoCircle.addEventListener('dragleave', () => {
        photoCircle.style.borderColor = '';
        photoCircle.style.background  = '';
      });
      photoCircle.addEventListener('drop', e => {
        e.preventDefault();
        photoCircle.style.borderColor = '';
        photoCircle.style.background  = '';
        processJudgePhoto(e.dataTransfer.files[0]);
      });

      // Live-update the judge display as the organiser types
      const liveUpdate = () => renderJudgeDisplay({
        first_name: document.getElementById('judge-fn-0')?.value || '',
        last_name:  document.getElementById('judge-ln-0')?.value || '',
        email:      document.getElementById('judge-em-0')?.value || '',
        photo_url:  show.judges[0]?.photo_url || '',
      });
      panel.querySelector(`#judge-fn-${i}`)?.addEventListener('input', liveUpdate);
      panel.querySelector(`#judge-ln-${i}`)?.addEventListener('input', liveUpdate);

      container.appendChild(panel);
  }

  function showWizardDuplicatePrompt(panel, match) {
    if (panel.querySelector('.j-dup-prompt')) return;
    const idx         = panel.dataset.judgeIdx;
    const emailInput  = document.getElementById(`judge-em-${idx}`);
    const photoCircle = panel.querySelector('.judge-photo-circle');
    const photoBtn    = panel.querySelector('.judge-photo-btn');
    const prompt = document.createElement('div');
    prompt.className = 'j-dup-prompt rounded-[10px] p-3 flex items-start gap-3 flex-wrap';
    prompt.style.cssText = 'background:#fffbeb;border:1px solid #fde68a;margin-top:4px;';
    prompt.innerHTML = `
      <div class="flex-1 min-w-0">
        <p class="text-[12.5px] font-semibold" style="color:#92400e">${esc(match.first_name)} ${esc(match.last_name)} is already in your judge book.</p>
        <p class="text-[12px] mt-0.5" style="color:#b45309">Would you like to reuse their saved details?</p>
      </div>
      <div class="flex gap-2 shrink-0">
        <button type="button" class="j-dup-yes text-[12px] font-bold text-white bg-brand px-3 py-1.5 rounded-btn hover:bg-brand-dark transition-colors">Yes, reuse</button>
        <button type="button" class="j-dup-no text-[12px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-1.5 rounded-btn hover:bg-[#f0fafa] transition-colors">No</button>
      </div>`;
    prompt.querySelector('.j-dup-yes').addEventListener('click', () => {
      document.getElementById(`judge-fn-${idx}`).value = match.first_name;
      document.getElementById(`judge-ln-${idx}`).value = match.last_name;
      emailInput.value = match.email || '';
      document.getElementById(`judge-ph-${idx}`).value = match.phone || '';
      if (match.photo_url) {
        if (!show.judges[idx]) show.judges[idx] = {};
        show.judges[idx].photo_url = match.photo_url;
        if (photoCircle) photoCircle.innerHTML = `<img src="${match.photo_url}" class="w-full h-full object-cover" />`;
        if (photoBtn) photoBtn.textContent = 'Replace photo';
        const rm = panel.querySelector('.judge-photo-remove');
        if (rm) rm.style.display = '';
      }
      panel.dataset.savedId = match.id;
      prompt.remove();
    });
    prompt.querySelector('.j-dup-no').addEventListener('click', () => {
      emailInput.value = '';
      emailInput.focus();
      prompt.remove();
    });
    (emailInput.closest('.grid') || emailInput).after(prompt);
  }

  // ─── Prize rows ──────────────────────────────────────────────────────────────
