---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Create a Show" activePage="shows">

  <button slot="actions" id="action-save-draft" style="display:none"
    class="inline-flex items-center gap-2 text-[13.5px] font-bold text-[#6f6880] border border-[#b8e4e0] px-4 py-2.5 rounded-btn hover:bg-[#f0fafa] transition-colors">
    Save Draft
  </button>

  <!-- Draft resume banner -->
  <div id="draft-banner" style="display:none"
    class="flex items-center justify-between gap-4 bg-amber-tint border border-amber-brand/20 rounded-[14px] px-5 py-4 mb-6">
    <div class="flex items-center gap-3">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p class="text-[13.5px] font-semibold text-[#1c1626]">You have an unfinished show: <span id="draft-title" class="text-brand"></span></p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <button id="draft-continue" class="text-[13px] font-bold text-brand hover:underline">Continue →</button>
      <span class="text-[#c4bed0]">|</span>
      <button id="draft-fresh" class="text-[13px] text-[#9b94a8] hover:text-[#1c1626]">Start fresh</button>
    </div>
  </div>

  <div class="max-w-2xl mx-auto">

    <!-- Progress bar -->
    <div class="mb-7">
      <div class="flex items-center justify-between mb-2">
        <span class="text-[12px] font-bold text-brand uppercase tracking-wider">Step <span id="prog-num">1</span> of 10</span>
        <span id="prog-name" class="text-[13px] font-semibold text-[#6f6880]">Show Basics</span>
      </div>
      <div class="h-1.5 bg-[#efebf5] rounded-full overflow-hidden">
        <div id="prog-bar" class="h-full bg-brand rounded-full transition-all duration-500" style="width:10%"></div>
      </div>
    </div>

    <!-- Step error -->
    <p id="step-error" style="display:none"
      class="text-[13px] text-red-500 bg-red-50 border border-red-100 rounded-[11px] px-4 py-3 mb-5" role="alert"></p>

    <!-- ─── Step 1: Show Basics ─────────────────────────────────────────────── -->
    <div id="step-1" class="bg-white rounded-card shadow-winner-card p-8">
      <h2 class="text-[21px] font-extrabold text-[#1c1626] tracking-[-0.02em] mb-1">Show Basics</h2>
      <p class="text-[14px] text-[#6f6880] mb-7">The essentials — you can refine everything later.</p>

      <div class="mb-5">
        <label for="s1-title" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Show Name <span class="text-red-400">*</span></label>
        <input type="text" id="s1-title" placeholder="e.g. Spring Paws Charity Show 2025"
          class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
      </div>

      <div class="grid grid-cols-2 gap-4 mb-5">
        <div>
          <label for="s1-entry-open" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Entries Open</label>
          <input type="date" id="s1-entry-open"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <div>
          <label for="s1-entry-close" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Entries Close <span class="text-red-400">*</span></label>
          <input type="date" id="s1-entry-close"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
      </div>

      <div class="mb-5">
        <label for="s1-show-date" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Show Date <span class="text-red-400">*</span></label>
        <input type="date" id="s1-show-date"
          class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
      </div>

      <div class="mb-5">
        <label for="s1-host-org" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Host Organisation / Club</label>
        <input type="text" id="s1-host-org" placeholder="Your club or organisation name"
          class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
      </div>

      <div class="mb-5">
        <p class="text-[13px] font-semibold text-[#4a4357] mb-2.5">Type of Organisation <span class="text-red-400">*</span></p>
        <div class="grid grid-cols-3 gap-3" id="org-type-cards">
          <button type="button" data-value="non_profit" class="sel-card flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white px-2 py-4 text-center transition-all cursor-pointer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/></svg>
            <span class="text-[11.5px] font-bold text-[#1c1626] leading-tight">Non-Profit<br>Fundraiser</span>
          </button>
          <button type="button" data-value="registered_charity" class="sel-card flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white px-2 py-4 text-center transition-all cursor-pointer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <span class="text-[11.5px] font-bold text-[#1c1626] leading-tight">Registered<br>Charity</span>
          </button>
          <button type="button" data-value="commercial" disabled class="relative flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#efebf5] bg-[#fafafa] px-2 py-4 text-center opacity-50 cursor-not-allowed">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9b94a8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            <span class="text-[11.5px] font-bold text-[#9b94a8] leading-tight">Commercial<br>Organisation</span>
            <span class="text-[9px] font-bold text-[#9b94a8] uppercase tracking-wide">Coming soon</span>
          </button>
        </div>
      </div>

      <div id="s1-charity-field" style="display:none" class="mb-5">
        <label for="s1-charity-number" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Charity / Non-Profit Number <span class="text-red-400">*</span></label>
        <input type="text" id="s1-charity-number" placeholder="e.g. 1234567"
          class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        <p class="text-[11.5px] text-[#9b94a8] mt-1.5">Required to create and publish your show.</p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="s1-contact-email" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Contact Email <span class="text-red-400">*</span></label>
          <input type="email" id="s1-contact-email"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <div>
          <label for="s1-contact-phone" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Contact Phone <span class="text-[#9b94a8] font-normal">(optional)</span></label>
          <input type="tel" id="s1-contact-phone" placeholder="+44 7700 000000"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
      </div>
    </div>

    <!-- ─── Step 2: Show Type ──────────────────────────────────────────────── -->
    <div id="step-2" style="display:none" class="bg-white rounded-card shadow-winner-card p-8">
      <h2 class="text-[21px] font-extrabold text-[#1c1626] tracking-[-0.02em] mb-1">Show Type</h2>
      <p class="text-[14px] text-[#6f6880] mb-7">What kind of competition are you running?</p>

      <p class="text-[13px] font-semibold text-[#4a4357] mb-2.5">Type of Show <span class="text-red-400">*</span></p>
      <div class="grid grid-cols-2 gap-3 mb-7" id="show-type-cards">
        <button type="button" data-value="beauty_contest" class="sel-card flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white p-4 text-center transition-all cursor-pointer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <span class="text-[13px] font-bold text-[#1c1626]">Beauty Contest</span>
        </button>
        <button type="button" data-value="fun_stakes" class="sel-card flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white p-4 text-center transition-all cursor-pointer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          <span class="text-[13px] font-bold text-[#1c1626]">Fun Stakes</span>
        </button>
        <button type="button" data-value="memorial" class="sel-card flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white p-4 text-center transition-all cursor-pointer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21C12 21 3.5 15.5 3.5 9A4.5 4.5 0 0 1 12 6.1 4.5 4.5 0 0 1 20.5 9C20.5 15.5 12 21 12 21z"/></svg>
          <span class="text-[13px] font-bold text-[#1c1626]">Memorial Show<br><span class="text-[11px] text-[#9b94a8] font-normal">"Over the Rainbow Bridge"</span></span>
        </button>
        <button type="button" data-value="other" disabled class="sel-card flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#efebf5] bg-[#fafafa] p-4 text-center opacity-50 cursor-not-allowed relative">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#9b94a8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span class="text-[13px] font-bold text-[#9b94a8]">Other</span>
          <span class="absolute top-2 right-2 text-[10px] font-bold bg-[#efebf5] text-[#9b94a8] px-1.5 py-0.5 rounded-full">Soon</span>
        </button>
      </div>

      <p class="text-[13px] font-semibold text-[#4a4357] mb-2.5">Animal Type <span class="text-red-400">*</span></p>
      <div class="grid grid-cols-4 gap-2" id="animal-type-cards">
        <button type="button" data-value="dog" class="sel-card flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#b8e4e0] bg-white px-2 py-3 text-center transition-all cursor-pointer">
          <span class="text-[22px]">🐕</span>
          <span class="text-[12px] font-bold text-[#1c1626]">Dog</span>
        </button>
        {['Cat 🐱','Rabbit 🐰','Guinea Pig 🐹','Horse 🐴','Bird 🐦','Other'].map(a => (
          <button type="button" disabled class="flex flex-col items-center gap-1.5 rounded-[12px] border-2 border-[#efebf5] bg-[#fafafa] px-2 py-3 text-center opacity-40 cursor-not-allowed relative">
            <span class="text-[22px]">{a.split(' ')[1] || '🐾'}</span>
            <span class="text-[12px] font-bold text-[#9b94a8]">{a.split(' ')[0]}</span>
          </button>
        ))}
      </div>
      <p class="text-[11.5px] text-[#9b94a8] mt-2">More animal types coming soon.</p>
    </div>

    <!-- ─── Step 3: Breed & Eligibility ───────────────────────────────────── -->
    <div id="step-3" style="display:none" class="bg-white rounded-card shadow-winner-card p-8">
      <h2 class="text-[21px] font-extrabold text-[#1c1626] tracking-[-0.02em] mb-1">Breed & Eligibility</h2>
      <p class="text-[14px] text-[#6f6880] mb-7">Which dogs can enter this show?</p>

      <p class="text-[13px] font-semibold text-[#4a4357] mb-2.5">Breed Scope <span class="text-red-400">*</span></p>
      <div class="grid grid-cols-3 gap-3 mb-5" id="breed-scope-cards">
        <button type="button" data-value="all" class="sel-card flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white p-4 text-center transition-all cursor-pointer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <span class="text-[12px] font-bold text-[#1c1626]">All Breeds</span>
        </button>
        <button type="button" data-value="breed_specific" class="sel-card flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white p-4 text-center transition-all cursor-pointer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
          <span class="text-[12px] font-bold text-[#1c1626]">Breed Specific</span>
        </button>
        <button type="button" data-value="group_specific" class="sel-card flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white p-4 text-center transition-all cursor-pointer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span class="text-[12px] font-bold text-[#1c1626]">Group Specific</span>
        </button>
      </div>

      <div id="s3-breed-field" style="display:none" class="mb-4">
        <label for="s3-breed" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Breed Name <span class="text-red-400">*</span></label>
        <div class="relative">
          <input type="text" id="s3-breed" placeholder="Search breeds…" autocomplete="off"
            role="combobox" aria-expanded="false" aria-autocomplete="list" aria-controls="s3-breed-listbox"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
          <ul id="s3-breed-listbox" role="listbox" aria-label="Dog breeds"
            class="hidden absolute z-50 left-0 right-0 top-full mt-1 bg-white border border-[#b8e4e0] rounded-[11px] shadow-[0_4px_16px_rgba(0,0,0,0.10)] max-h-52 overflow-y-auto"></ul>
        </div>
      </div>
      <div id="s3-group-field" style="display:none">
        <label for="s3-group" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Group Name <span class="text-red-400">*</span></label>
        <input type="text" id="s3-group" placeholder="e.g. Gundog Group"
          class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        <p class="text-[11.5px] text-[#9b94a8] mt-1.5">Group selection dropdowns coming soon.</p>
      </div>
    </div>

    <!-- ─── Step 4: Competition Classes ───────────────────────────────────── -->
    <div id="step-4" style="display:none" class="bg-white rounded-card shadow-winner-card p-8">
      <h2 class="text-[21px] font-extrabold text-[#1c1626] tracking-[-0.02em] mb-1">Competition Classes</h2>
      <p id="s4-desc" class="text-[14px] text-[#6f6880] mb-7">Select and customise the classes for your show.</p>

      <!-- Beauty / Memorial: standard age classes -->
      <div id="s4-standard" style="display:none">
        <p class="text-[13px] font-semibold text-[#4a4357] mb-3">Standard Age Classes</p>
        <div id="s4-class-list" class="space-y-2 mb-4"></div>
        <button type="button" id="s4-add-class"
          class="flex items-center gap-1.5 text-[13px] font-semibold text-brand hover:text-brand-dark transition-colors mt-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Custom Class
        </button>
      </div>

      <!-- Fun Stakes: category checklist -->
      <div id="s4-funstakes" style="display:none">
        <p class="text-[13px] font-semibold text-[#4a4357] mb-3">Choose your categories</p>
        <div id="s4-funstakes-list" class="grid grid-cols-2 gap-2 mb-4"></div>
        <button type="button" id="s4-add-funstakes"
          class="flex items-center gap-1.5 text-[13px] font-semibold text-brand hover:text-brand-dark transition-colors mt-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Custom Category
        </button>
        <div id="s4-custom-funstakes" class="space-y-2 mt-3"></div>
      </div>
    </div>

    <!-- ─── Step 5: Sponsorship ────────────────────────────────────────────── -->
    <div id="step-5" style="display:none" class="bg-white rounded-card shadow-winner-card p-8">
      <h2 class="text-[21px] font-extrabold text-[#1c1626] tracking-[-0.02em] mb-1">Sponsorship</h2>
      <p class="text-[14px] text-[#6f6880] mb-7">Do you have a sponsor for this show?</p>

      <div class="grid grid-cols-3 gap-3 mb-6" id="sponsor-choice">
        <button type="button" data-value="yes" class="yna flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white p-4 transition-all cursor-pointer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span class="text-[13px] font-bold text-[#1c1626]">Yes</span>
        </button>
        <button type="button" data-value="no" class="yna flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white p-4 transition-all cursor-pointer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          <span class="text-[13px] font-bold text-[#1c1626]">No</span>
        </button>
        <button type="button" data-value="later" class="yna flex flex-col items-center gap-2 rounded-[14px] border-2 border-[#b8e4e0] bg-white p-4 transition-all cursor-pointer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span class="text-[13px] font-bold text-[#1c1626]">Add Later</span>
        </button>
      </div>

      <div id="s5-sponsor-form" style="display:none" class="border border-[#efebf5] rounded-[14px] p-5 space-y-4">
        <div>
          <label for="s5-sponsor-name" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Sponsor Name <span class="text-red-400">*</span></label>
          <input type="text" id="s5-sponsor-name" placeholder="e.g. Pawsome Pet Supplies"
            class="w-full border border-[#b8e4e0] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors" />
        </div>
        <div>
          <label for="s5-sponsor-website" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Sponsor Website <span class="text-[#9b94a8] font-normal">(optional)</span></label>
