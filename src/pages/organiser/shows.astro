---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="My Shows" activePage="shows">

  <button slot="actions" id="btn-new-show"
    class="inline-flex items-center gap-2 bg-brand text-white text-[13.5px] font-bold px-4 py-2.5 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    New Show
  </button>

  <!-- Loading -->
  <div id="state-loading" class="flex items-center justify-center h-64">
    <div class="w-8 h-8 border-[3px] border-brand/20 border-t-brand rounded-full animate-spin"></div>
  </div>

  <!-- Empty state -->
  <div id="state-empty" style="display:none" class="flex items-center justify-center min-h-[60vh]">
    <div class="text-center max-w-[380px]">
      <div class="w-20 h-20 rounded-full bg-brand-tint flex items-center justify-center mx-auto mb-6">
        <svg width="40" height="40" viewBox="0 0 48 48" fill="none" aria-hidden="true">
          <rect x="6" y="10" width="36" height="32" rx="4" fill="#e0f4f2"/>
          <rect x="6" y="10" width="36" height="32" rx="4" stroke="#1ba89a" stroke-width="2.5" fill="none"/>
          <line x1="16" y1="6" x2="16" y2="16" stroke="#1ba89a" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="32" y1="6" x2="32" y2="16" stroke="#1ba89a" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="6" y1="22" x2="42" y2="22" stroke="#1ba89a" stroke-width="2.5"/>
          <line x1="20" y1="32" x2="28" y2="32" stroke="#1ba89a" stroke-width="2" stroke-linecap="round"/>
          <line x1="24" y1="28" x2="24" y2="36" stroke="#1ba89a" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <h2 class="text-[23px] font-extrabold text-[#1c1626] tracking-[-0.02em] mb-3">No shows yet</h2>
      <p class="text-[14px] text-[#6f6880] leading-relaxed mb-7">Create your first show and it'll appear here with all its stats and settings.</p>
      <button id="btn-create-first"
        class="inline-flex items-center gap-2 bg-brand text-white text-[14px] font-bold px-6 py-3 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Create a Show
      </button>
    </div>
  </div>

  <!-- Shows list -->
  <div id="state-list" style="display:none">
    <div id="shows-list" class="space-y-3"></div>
  </div>

  <!-- Archive confirmation modal -->
  <div id="archive-modal" style="display:none" class="fixed inset-0 z-[200] bg-black/50 flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="archive-modal-title">
    <div class="bg-white rounded-[20px] w-full max-w-[440px] shadow-2xl">
      <div class="p-6">
        <div class="w-12 h-12 rounded-full bg-amber-50 flex items-center justify-center mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/>
            <line x1="10" y1="12" x2="14" y2="12"/>
          </svg>
        </div>
        <h2 id="archive-modal-title" style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 8px">Archive This Show?</h2>
        <p style="font-size:14px;color:#6b7c89;line-height:1.55;margin:0 0 16px">The show will be hidden from your dashboard and replaced with a lightweight results page showing winners and sponsors only.</p>
        <div id="archive-photo-summary" style="background:#fef3c7;border:1px solid #fde68a;border-radius:10px;padding:12px 16px;margin-bottom:20px"></div>
        <div style="display:flex;gap:12px">
          <button id="archive-cancel" style="flex:1;padding:11px;border-radius:10px;border:1.5px solid #e0dce8;background:white;font-size:14px;font-weight:600;color:#4a4357;cursor:pointer">Cancel</button>
          <button id="archive-confirm" style="flex:1;padding:11px;border-radius:10px;border:none;background:#f59e0b;color:white;font-size:14px;font-weight:700;cursor:pointer">Archive Show</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete confirmation modal -->
  <div id="delete-modal" style="display:none" class="fixed inset-0 z-[200] bg-black/50 flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="delete-modal-title">
    <div class="bg-white rounded-[20px] w-full max-w-[460px] shadow-2xl">
      <div class="p-6">
        <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center mb-4">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
            <path d="M10 11v6"/><path d="M14 11v6"/>
            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
          </svg>
        </div>
        <h2 id="delete-modal-title" style="font-size:18px;font-weight:800;color:#1c1626;margin:0 0 8px">Permanently Delete Show?</h2>
        <p style="font-size:14px;color:#6b7c89;line-height:1.55;margin:0 0 12px">This will <strong style="color:#1c1626">permanently remove</strong> everything associated with <strong id="delete-show-name" style="color:#1c1626"></strong> and <strong style="color:#ef4444">cannot be undone</strong>:</p>
        <ul style="margin:0 0 16px;padding:0 0 0 20px;font-size:13px;color:#4a4357;line-height:2">
          <li>All entries and participant data</li>
          <li>All uploaded photos and images</li>
          <li>All categories and class settings</li>
          <li>All judging scores and results</li>
          <li>All payout and financial records</li>
        </ul>
        <div id="delete-error" style="display:none;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:10px 12px;margin-bottom:12px;font-size:13px;color:#ef4444"></div>
        <div style="display:flex;gap:12px">
          <button id="delete-cancel" style="flex:1;padding:11px;border-radius:10px;border:1.5px solid #e0dce8;background:white;font-size:14px;font-weight:600;color:#4a4357;cursor:pointer">Cancel</button>
          <button id="delete-confirm" style="flex:1;padding:11px;border-radius:10px;border:none;background:#ef4444;color:white;font-size:14px;font-weight:700;cursor:pointer">Permanently Delete</button>
        </div>
      </div>
    </div>
  </div>

</DashboardLayout>

<script>
  import { getAuth } from '../../lib/auth.js';
  import { supabase } from '../../lib/supabase.js';

  const SHOW_TYPE_LABELS   = { beauty_contest: 'Beauty Contest', fun_stakes: 'Fun Stakes', memorial: 'Memorial Show', other: 'Other' };
  const BREED_SCOPE_LABELS = { all: 'All Breeds', breed_specific: 'Breed Specific', group_specific: 'Group Specific' };
  const CURRENCY_SYMBOLS   = { GBP: '£', USD: '$', EUR: '€', AUD: 'A$', CAD: 'C$', NZD: 'NZ$', ZAR: 'R', SGD: 'S$' };

  let pendingArchiveShow    = null;
  let pendingArchiveEntries = null;
  let pendingDeleteShow     = null;

  const { session, profile, base } = await getAuth();

  if (!session) {
    window.location.replace(base + 'login');
  } else {
    const name = profile?.display_name || session.user.email?.split('@')[0] || 'Organiser';
    const avatarEl = document.getElementById('sidebar-avatar');
    const nameEl   = document.getElementById('sidebar-username');
    const badgeEl  = document.getElementById('sidebar-role-badge');
    if (avatarEl) {
      if (profile?.avatar_url) {
        avatarEl.innerHTML = `<img src="${profile.avatar_url}" alt="" style="width:100%;height:100%;object-fit:cover;">`;
      } else {
        avatarEl.textContent = name.charAt(0).toUpperCase();
      }
    }
    if (nameEl)   nameEl.textContent   = name;
    if (badgeEl)  badgeEl.textContent  = profile?.organiser_type === 'club' ? 'Club Organiser' : 'Organiser';
    document.getElementById('sidebar-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = base + 'login';
    });

    document.getElementById('btn-new-show')?.addEventListener('click', () => { window.location.href = base + 'organiser/new-show'; });
    document.getElementById('btn-create-first')?.addEventListener('click', () => { window.location.href = base + 'organiser/new-show'; });

    const [activeRes, archivedRes] = await Promise.all([
      supabase.from('shows').select('*').eq('created_by', session.user.id).is('archived_at', null).order('created_at', { ascending: false }),
      supabase.from('shows').select('id').eq('created_by', session.user.id).not('archived_at', 'is', null),
    ]);

    const loadingEl = document.getElementById('state-loading');
    const emptyEl   = document.getElementById('state-empty');
    const listEl    = document.getElementById('state-list');
    if (loadingEl) loadingEl.style.display = 'none';

    const shows         = activeRes.data || [];
    const archivedCount = (archivedRes.data || []).length;

    if (archivedCount > 0) {
      const archLink = document.createElement('a');
      archLink.href = `${base}organiser/shows?archived=1`;
      archLink.className = 'text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors';
      archLink.style.textDecoration = 'none';
      archLink.textContent = `Archived (${archivedCount})`;
      const newBtn = document.getElementById('btn-new-show');
      if (newBtn) newBtn.parentElement.insertBefore(archLink, newBtn);
    }

    const viewingArchived = new URLSearchParams(window.location.search).get('archived') === '1';
    if (viewingArchived) {
      const { data: archived } = await supabase.from('shows').select('*').eq('created_by', session.user.id).not('archived_at', 'is', null).order('archived_at', { ascending: false });
      const list = archived || [];
      if (!list.length) {
        if (emptyEl) { emptyEl.style.display = 'flex'; emptyEl.querySelector('h2').textContent = 'No archived shows'; emptyEl.querySelector('p')?.remove(); }
      } else {
        const catCounts = {};
        const confirmedCounts = {};
        await Promise.all(list.map(async s => {
          const [catRes, entryRes] = await Promise.all([
            supabase.from('show_categories').select('*', { count: 'exact', head: true }).eq('show_id', s.id),
            supabase.from('show_entries').select('*', { count: 'exact', head: true }).eq('show_id', s.id).eq('status', 'confirmed'),
          ]);
          catCounts[s.id]       = catRes.count  || 0;
          confirmedCounts[s.id] = entryRes.count || 0;
        }));
        if (listEl) listEl.style.display = 'block';
        const container = document.getElementById('shows-list');
        const heading = document.createElement('p');
        heading.className = 'text-[12px] font-bold text-[#9b94a8] uppercase tracking-wider mb-3';
        heading.textContent = 'Archived Shows';
        container.appendChild(heading);
        list.forEach(s => container.appendChild(buildRow(s, catCounts[s.id] || 0, confirmedCounts[s.id] || 0)));
      }
    } else if (!shows.length) {
      if (emptyEl) emptyEl.style.display = 'flex';
    } else {
      const catCounts = {};
      const confirmedCounts = {};
      await Promise.all(shows.map(async s => {
        const [catRes, entryRes] = await Promise.all([
          supabase.from('show_categories').select('*', { count: 'exact', head: true }).eq('show_id', s.id),
          supabase.from('show_entries').select('*', { count: 'exact', head: true }).eq('show_id', s.id).eq('status', 'confirmed'),
        ]);
        catCounts[s.id]       = catRes.count  || 0;
        confirmedCounts[s.id] = entryRes.count || 0;
      }));
      if (listEl) listEl.style.display = 'block';
      const container = document.getElementById('shows-list');
      shows.forEach(show => container.appendChild(buildRow(show, catCounts[show.id] || 0, confirmedCounts[show.id] || 0)));
    }
  }

  // ── Helpers ───────────────────────────────────────────────────────────────────

  function showStatus(s) {
    if (s.archived_at)        return { label: 'Archived',          color: '#92400e', bg: '#fef3c7' };
    if (s.status === 'draft') return { label: 'Draft',             color: '#6f6880', bg: '#f5f3fa' };
    const now = Date.now();
    if (s.entry_open_date  && new Date(s.entry_open_date).getTime()  > now) return { label: 'Scheduled',        color: '#2563eb', bg: '#eff6ff' };
    if (s.entry_close_date && new Date(s.entry_close_date).getTime() >= now) return { label: 'Open for Entries', color: '#16a34a', bg: '#f0fdf4' };
    return { label: 'Closed', color: '#6b7280', bg: '#f9fafb' };
  }

  function archiveBlockedReason(show) {
    if (show.status !== 'published')                                   return 'Show must be published before archiving.';
    if (!show.results_published_at)                                    return 'Results must be published before archiving.';
    if (!show.show_date || new Date(show.show_date) > new Date())      return 'The show date must have passed before archiving.';
    return null;
  }

  function dot(state) {
    return state === 'ok' ? '#22c55e' : state === 'pending' ? '#fbbf24' : '#c4bed0';
  }

  function sectionTiles(show, catCount) {
    function tile(label, state, summary) {
      return `<div class="flex items-center gap-2 py-1.5 min-w-0">
        <span class="w-2 h-2 rounded-full shrink-0" style="background:${dot(state)}"></span>
        <span class="text-[12px] font-semibold text-[#4a4357] shrink-0">${label}</span>
        <span class="text-[12px] text-[#9b94a8] truncate">${summary || (state === 'pending' ? 'Not configured' : 'Not used')}</span>
      </div>`;
    }

    const breedSummary = show.breed_scope
      ? (BREED_SCOPE_LABELS[show.breed_scope] + (show.breed_filter ? ` — ${show.breed_filter}` : show.group_filter ? ` — ${show.group_filter}` : ''))
      : null;

    return [
      tile('Show Type',   show.show_type ? 'ok' : 'pending',    show.show_type ? SHOW_TYPE_LABELS[show.show_type] : null),
      tile('Breed',       show.breed_scope ? 'ok' : 'pending',  breedSummary),
      tile('Classes',     catCount > 0 ? 'ok' : 'pending',      catCount > 0 ? `${catCount} class${catCount !== 1 ? 'es' : ''}` : null),
      tile('Sponsor',     show.has_sponsor === true ? 'ok' : show.has_sponsor === false ? 'off' : 'pending',
                          show.has_sponsor === true ? 'Sponsor added' : show.has_sponsor === false ? 'No sponsor' : null),
      tile('Judging',     show.is_judged === true ? 'ok' : show.is_judged === false ? 'off' : 'pending',
                          show.is_judged === true ? 'Expert judges' : show.is_judged === false ? 'Public voting' : null),
      tile('Awards',      (show.has_digital_certs === true || show.has_physical_prizes === true) ? 'ok'
                          : (show.has_digital_certs === false && show.has_physical_prizes === false) ? 'off' : 'pending',
                          (show.has_digital_certs || show.has_physical_prizes) ? 'Configured' : (show.has_digital_certs === false) ? 'No awards' : null),
      tile('Fundraising', show.entry_fee > 0 ? 'ok' : 'pending',
                          show.entry_fee > 0 ? 'Active' : null),
      tile('Branding',    'pending', 'Upload coming soon'),
    ].join('');
  }

  function buildRow(show, catCount, confirmedEntryCount = 0) {
    const showUrl    = `${window.location.origin}${base}show?id=${show.id}`;
    const previewUrl = `${base}show?id=${show.id}&preview=1`;
    const status     = showStatus(show);
    const showDate   = show.show_date
      ? new Date(show.show_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
      : '—';
    const sym = CURRENCY_SYMBOLS[show.currency] || '£';

    const feeText = show.entry_fee > 0
      ? `${sym}${show.entry_fee} entry fee`
      : 'Fees: not set';

    const isArchived    = !!show.archived_at;
    const isDraft       = show.status === 'draft';
    const archiveReason = !isArchived ? archiveBlockedReason(show) : null;
    const hasPaidEntries = confirmedEntryCount > 0;
    const canDel        = (isDraft || isArchived) && !hasPaidEntries;

    const archiveBtnHtml = !isArchived
      ? archiveReason
        ? `<button class="btn-archive" disabled title="${esc(archiveReason)}" style="font-size:13px;font-weight:600;color:#d97706;border:1.5px solid #fde68a;background:#fefce8;padding:8px 14px;border-radius:8px;cursor:not-allowed;opacity:0.5">Archive</button>`
        : `<button class="btn-archive" style="font-size:13px;font-weight:600;color:#92400e;border:1.5px solid #fde68a;background:#fef3c7;padding:8px 14px;border-radius:8px;cursor:pointer">Archive</button>`
      : '';

    const deleteDisabledTitle = hasPaidEntries
      ? `Cannot delete: ${confirmedEntryCount} paid entr${confirmedEntryCount === 1 ? 'y has' : 'ies have'} been received. Financial records cannot be removed.`
      : 'Only draft or archived shows can be deleted.';

    const deleteBtnHtml = canDel
      ? `<button class="btn-delete" style="font-size:13px;font-weight:700;color:white;background:#ef4444;border:none;padding:8px 14px;border-radius:8px;cursor:pointer">Delete</button>`
      : `<button class="btn-delete" disabled title="${esc(deleteDisabledTitle)}" style="font-size:13px;font-weight:600;color:#c4bed0;background:transparent;border:1.5px solid #e0dce8;padding:8px 14px;border-radius:8px;cursor:not-allowed">Delete</button>`;

    const row = document.createElement('div');
    row.className = 'bg-white rounded-card border border-[#b8e4e0] overflow-hidden';
    row.innerHTML = `
      <button class="row-header w-full flex items-center gap-3 px-5 py-4 text-left hover:bg-[#f0fafa] transition-colors">
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold shrink-0"
          style="background:${status.bg};color:${status.color}">${esc(status.label)}</span>
        <span class="flex-1 text-[15px] font-bold text-[#1c1626] truncate">${esc(show.title || 'Untitled Show')}</span>
        <span class="text-[13px] text-[#9b94a8] shrink-0 hidden sm:block">${esc(showDate)}</span>
        <span class="text-[13px] text-[#9b94a8] shrink-0 hidden md:block">— entries</span>
        <svg class="chevron w-4 h-4 text-[#c4bed0] transition-transform duration-200 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>

      <div class="row-panel border-t border-[#efebf5]" style="display:none">
        <div class="flex flex-wrap gap-4 px-5 py-3.5 bg-[#f0fafa] border-b border-[#efebf5]">
          <span class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-[#4a4357]">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            ${catCount} class${catCount !== 1 ? 'es' : ''}
          </span>
          <span class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-[#4a4357]">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ${show.is_judged === true ? 'Expert judges' : show.is_judged === false ? 'Public voting' : 'Judging: not set'}
          </span>
          <span class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-[#4a4357]">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            ${esc(feeText)}
          </span>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 px-5 py-3 border-b border-[#efebf5]">
          ${sectionTiles(show, catCount)}
        </div>

        <div class="flex items-center gap-3 px-5 py-4 flex-wrap">
          ${!isArchived && show.status === 'published'
            ? `<button class="btn-dashboard inline-flex items-center gap-2 bg-brand text-white text-[13px] font-bold px-4 py-2 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">Dashboard</button>`
            : !isArchived
            ? `<button class="btn-wizard inline-flex items-center gap-2 bg-brand text-white text-[13px] font-bold px-4 py-2 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">Continue in Wizard</button>`
            : ''
          }
          <button class="btn-manage text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-4 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors">Settings</button>
          ${isArchived
            ? `<a href="${showUrl}" target="_blank" class="text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-4 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors" style="text-decoration:none">View Archive ↗</a>`
            : show.status === 'published'
            ? `<a href="${showUrl}" target="_blank" class="btn-view-show text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-4 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors" style="text-decoration:none">View Show ↗</a>
               <button class="btn-copy-url text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-4 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors">Copy URL</button>`
            : `<a href="${previewUrl}" target="_blank" class="btn-preview text-[13px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-4 py-2 rounded-btn hover:bg-[#f0fafa] transition-colors" style="text-decoration:none">Preview →</a>`
          }
          ${archiveBtnHtml}
          ${deleteBtnHtml}
          <div class="ml-auto flex items-center gap-1.5 text-[#9b94a8]">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span class="text-[11px]">Image templates:</span>
            <a href="${base}images/LogoTemplate.jpg" download="LogoTemplate.jpg" class="text-[11px] font-bold text-[#1ba89a] hover:underline">Logo</a>
            <span class="text-[11px]">·</span>
            <a href="${base}images/BannerTemplate.jpg" download="BannerTemplate.jpg" class="text-[11px] font-bold text-[#1ba89a] hover:underline">Banner</a>
          </div>
        </div>
      </div>
    `;

    row.querySelector('.row-header').addEventListener('click', () => {
      const panel   = row.querySelector('.row-panel');
      const chevron = row.querySelector('.chevron');
      const open    = panel.style.display !== 'none';
      panel.style.display    = open ? 'none' : 'block';
      chevron.style.transform = open ? '' : 'rotate(180deg)';
    });
    row.querySelector('.btn-dashboard')?.addEventListener('click', e => {
      e.stopPropagation();
      window.location.href = base + `organiser?show=${show.id}`;
    });
    row.querySelector('.btn-manage').addEventListener('click', e => {
      e.stopPropagation();
      window.location.href = base + `organiser/show/?id=${show.id}`;
    });
    row.querySelector('.btn-wizard')?.addEventListener('click', e => {
      e.stopPropagation();
      window.location.href = base + `organiser/new-show?id=${show.id}`;
    });
    row.querySelector('.btn-copy-url')?.addEventListener('click', e => {
      e.stopPropagation();
      navigator.clipboard.writeText(`${window.location.origin}${base}show?id=${show.id}`);
      const btn = e.currentTarget;
      btn.textContent = 'Copied! ✓';
      setTimeout(() => { btn.textContent = 'Copy URL'; }, 1800);
    });
    row.querySelector('.btn-archive')?.addEventListener('click', e => {
      e.stopPropagation();
      openArchiveModal(show);
    });
    row.querySelector('.btn-delete')?.addEventListener('click', e => {
      e.stopPropagation();
      openDeleteModal(show);
    });

    return row;
  }

  // ── Archive modal ─────────────────────────────────────────────────────────────

  async function openArchiveModal(show) {
    pendingArchiveShow    = show;
    pendingArchiveEntries = null;
    const summaryEl = document.getElementById('archive-photo-summary');
    if (summaryEl) summaryEl.innerHTML = '<p style="font-size:13px;color:#92400e;margin:0">Calculating photos…</p>';
    document.getElementById('archive-modal').style.display = 'flex';
    document.body.style.overflow = 'hidden';

    const { data: entries } = await supabase
      .from('show_entries')
      .select('id, photo_url, result_place')
      .eq('show_id', show.id)
      .eq('status', 'confirmed');

    pendingArchiveEntries = entries || [];
    const toDelete = pendingArchiveEntries.filter(e => !e.result_place && e.photo_url).length;
    const toKeep   = pendingArchiveEntries.filter(e =>  e.result_place && e.photo_url).length;

    if (summaryEl) {
      summaryEl.innerHTML = toDelete > 0
        ? `<p style="font-size:13px;color:#92400e;margin:0 0 4px"><strong>${toDelete}</strong> non-placing photo${toDelete !== 1 ? 's' : ''} will be permanently deleted.</p>
           <p style="font-size:13px;color:#92400e;margin:0"><strong>${toKeep}</strong> winner photo${toKeep !== 1 ? 's' : ''} will be kept.</p>`
        : `<p style="font-size:13px;color:#92400e;margin:0">No entry photos to delete.</p>`;
    }
  }

  function closeArchiveModal() {
    document.getElementById('archive-modal').style.display = 'none';
    document.body.style.overflow = '';
    pendingArchiveShow    = null;
    pendingArchiveEntries = null;
  }

  async function archiveShow(show, entries) {
    const confirmBtn = document.getElementById('archive-confirm');
    if (confirmBtn) { confirmBtn.textContent = 'Archiving…'; confirmBtn.disabled = true; }

    const toDelete    = entries.filter(e => !e.result_place && e.photo_url);
    const paths       = toDelete.map(e => e.photo_url.match(/\/show-assets\/(.+)/)?.[1]).filter(Boolean);
    if (paths.length) await supabase.storage.from('show-assets').remove(paths);

    const toDeleteIds = toDelete.map(e => e.id);
    if (toDeleteIds.length) {
      await supabase.from('show_entries').update({ photo_url: null }).in('id', toDeleteIds);
    }

    await supabase.from('shows').update({ archived_at: new Date().toISOString() }).eq('id', show.id);
    closeArchiveModal();
    window.location.reload();
  }

  // ── Delete modal ──────────────────────────────────────────────────────────────

  function openDeleteModal(show) {
    pendingDeleteShow = show;
    const nameEl = document.getElementById('delete-show-name');
    if (nameEl) nameEl.textContent = `"${show.title || 'Untitled Show'}"`;
    const errEl = document.getElementById('delete-error');
    if (errEl) errEl.style.display = 'none';
    const confirmBtn = document.getElementById('delete-confirm');
    if (confirmBtn) { confirmBtn.textContent = 'Permanently Delete'; confirmBtn.disabled = false; }
    document.getElementById('delete-modal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeDeleteModal() {
    document.getElementById('delete-modal').style.display = 'none';
    document.body.style.overflow = '';
    pendingDeleteShow = null;
  }

  async function deleteShow(show) {
    const confirmBtn = document.getElementById('delete-confirm');
    const errEl      = document.getElementById('delete-error');
    if (confirmBtn) { confirmBtn.textContent = 'Deleting…'; confirmBtn.disabled = true; }
    if (errEl) errEl.style.display = 'none';

    try {
      const { data: entries  } = await supabase.from('show_entries').select('id, photo_url').eq('show_id', show.id);
      const { data: sponsors } = await supabase.from('show_sponsors').select('logo_url').eq('show_id', show.id);

      const photoUrls = [
        ...(entries  || []).map(e => e.photo_url),
        ...(sponsors || []).map(s => s.logo_url),
        show.logo_url, show.banner_url, show.org_logo_url,
      ].filter(Boolean);

      const paths = photoUrls.map(u => u.match(/\/show-assets\/(.+)/)?.[1]).filter(Boolean);
      if (paths.length) await supabase.storage.from('show-assets').remove(paths);

      // Scores and rankings first (reference entries/categories)
      await Promise.all([
        supabase.from('judge_scores').delete().eq('show_id', show.id),
        supabase.from('judge_rankings').delete().eq('show_id', show.id),
      ]);

      // All remaining child records
      await Promise.all([
        supabase.from('show_entries').delete().eq('show_id', show.id),
        supabase.from('show_categories').delete().eq('show_id', show.id),
        supabase.from('show_sponsors').delete().eq('show_id', show.id),
        supabase.from('show_prizes').delete().eq('show_id', show.id),
        supabase.from('show_judges').delete().eq('show_id', show.id),
      ]);

      const { error } = await supabase.from('shows').delete().eq('id', show.id);
      if (error) throw error;

      closeDeleteModal();
      window.location.reload();
    } catch (err) {
      if (errEl) { errEl.textContent = `Delete failed: ${err.message}`; errEl.style.display = 'block'; }
      if (confirmBtn) { confirmBtn.textContent = 'Permanently Delete'; confirmBtn.disabled = false; }
    }
  }

  // ── Modal wiring ──────────────────────────────────────────────────────────────

  document.getElementById('archive-cancel')?.addEventListener('click', closeArchiveModal);
  document.getElementById('archive-modal')?.addEventListener('click', e => { if (e.target === e.currentTarget) closeArchiveModal(); });
  document.getElementById('archive-confirm')?.addEventListener('click', async () => {
    if (pendingArchiveShow && pendingArchiveEntries) await archiveShow(pendingArchiveShow, pendingArchiveEntries);
  });

  document.getElementById('delete-cancel')?.addEventListener('click', closeDeleteModal);
  document.getElementById('delete-modal')?.addEventListener('click', e => { if (e.target === e.currentTarget) closeDeleteModal(); });
  document.getElementById('delete-confirm')?.addEventListener('click', async () => {
    if (pendingDeleteShow) await deleteShow(pendingDeleteShow);
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') { closeArchiveModal(); closeDeleteModal(); }
  });

  function esc(s) {
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
</script>
