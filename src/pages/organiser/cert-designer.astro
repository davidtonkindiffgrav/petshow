---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Certificate Designer" activePage="judging">

  <!-- Loading -->
  <div id="state-loading" class="flex items-center justify-center h-64">
    <div class="w-8 h-8 border-[3px] border-brand/20 border-t-brand rounded-full animate-spin"></div>
  </div>

  <!-- Error -->
  <div id="state-error" style="display:none" class="flex items-center justify-center h-64">
    <div class="text-center max-w-sm">
      <p id="error-msg" class="text-[14px] text-[#6f6880] mb-4"></p>
      <a id="back-link" href="#" class="text-[13px] font-semibold text-brand hover:text-brand-dark transition-colors">← Back</a>
    </div>
  </div>

  <!-- Content -->
  <div id="state-content" style="display:none">

    <!-- Page header -->
    <div class="flex items-start justify-between gap-4 mb-5 flex-wrap">
      <div>
        <a id="nav-back" href="#" class="text-[13px] font-semibold text-[#9b94a8] hover:text-brand transition-colors">← Manage Results</a>
        <h1 class="text-[22px] font-extrabold text-[#1c1626] tracking-[-0.01em] mt-1">Certificate Designer</h1>
        <p id="show-subtitle" class="text-[13px] text-[#6f6880] mt-0.5"></p>
      </div>
      <div class="flex items-center gap-3">
        <div id="lock-status" style="display:none"
          class="inline-flex items-center gap-1.5 text-[12px] font-bold px-3 py-1.5 rounded-full"
          style="background:#dcf6e3;color:#166534">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Design Locked
        </div>
        <button id="btn-unlock" style="display:none"
          class="text-[12px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-1.5 rounded-btn hover:bg-[#f0fafa] transition-colors">
          Unlock to Edit
        </button>
        <button id="btn-dl-jpg"
          class="text-[12px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-1.5 rounded-btn hover:bg-[#f0fafa] transition-colors">
          ↓ JPG
        </button>
        <button id="btn-dl-pdf"
          class="text-[12px] font-semibold text-[#6f6880] border border-[#b8e4e0] px-3 py-1.5 rounded-btn hover:bg-[#f0fafa] transition-colors">
          ↓ PDF
        </button>
        <button id="btn-save"
          class="text-[13px] font-semibold text-brand border border-brand/30 px-4 py-2 rounded-btn hover:bg-brand/5 transition-colors">
          Save Design
        </button>
        <button id="btn-lock"
          class="text-[13px] font-bold bg-brand text-white px-4 py-2 rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
          Lock &amp; Activate
        </button>
      </div>
    </div>

    <!-- Status message -->
    <p id="status-msg" style="display:none"
      class="text-[13px] text-[#6f6880] bg-[#f0fafa] border border-brand/20 rounded-[11px] px-4 py-2.5 mb-4"></p>

    <!-- Two-column layout -->
    <div class="flex gap-5" style="align-items:flex-start">

      <!-- Left: independent scrollable options panel -->
      <div class="w-[280px] shrink-0 relative">

        <!-- Top scroll indicator -->
        <div id="scroll-top-fade"
          class="absolute inset-x-0 top-0 h-14 z-10 pointer-events-none flex items-start justify-center pt-2"
          style="background:linear-gradient(to bottom,#f0fafa 40%,transparent);opacity:0;transition:opacity 0.2s">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>
        </div>

        <!-- Scrollable content -->
        <div id="left-panel" class="space-y-4" style="overflow-y:auto;scrollbar-width:none;-ms-overflow-style:none">

          <!-- Page Size -->
          <div class="bg-white rounded-card border border-[#b8e4e0] p-4">
            <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider mb-3">Page Size</p>
            <div class="flex gap-2" id="page-size-opts">
              <button data-size="a4" class="page-size-opt flex-1 text-[12px] font-semibold py-2 rounded-[8px] border transition-colors">
                A4
              </button>
              <button data-size="letter" class="page-size-opt flex-1 text-[12px] font-semibold py-2 rounded-[8px] border transition-colors">
                Letter
              </button>
            </div>
            <p class="text-[10px] text-[#9b94a8] mt-2">Both are landscape orientation</p>
          </div>

          <!-- Border style -->
          <div class="bg-white rounded-card border border-[#b8e4e0] p-4">
            <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider mb-3">Border Style</p>
            <div class="grid grid-cols-2 gap-2" id="border-opts">
              <button data-val="none"     class="border-opt text-[12px] font-semibold py-2 rounded-[8px] border transition-colors">None</button>
              <button data-val="classic"  class="border-opt text-[12px] font-semibold py-2 rounded-[8px] border transition-colors">Classic</button>
              <button data-val="elegant"  class="border-opt text-[12px] font-semibold py-2 rounded-[8px] border transition-colors">Elegant</button>
              <button data-val="playful"  class="border-opt text-[12px] font-semibold py-2 rounded-[8px] border transition-colors">Playful</button>
              <button data-val="gallery"  class="border-opt text-[12px] font-semibold py-2 rounded-[8px] border transition-colors">Gallery</button>
              <button data-val="rainbow"  class="border-opt text-[12px] font-semibold py-2 rounded-[8px] border transition-colors">Rainbow</button>
            </div>
          </div>

          <!-- Text Font -->
          <div class="bg-white rounded-card border border-[#b8e4e0] p-4">
            <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider mb-3">Text Font</p>
            <div class="grid grid-cols-2 gap-2" id="font-opts">
              <button data-val="Playfair Display"   class="font-opt text-[13px] font-semibold py-2 rounded-[8px] border transition-colors" style="font-family:'Playfair Display',Georgia,serif">Playfair</button>
              <button data-val="Cormorant Garamond" class="font-opt text-[13px] font-semibold py-2 rounded-[8px] border transition-colors" style="font-family:'Cormorant Garamond',Georgia,serif">Cormorant</button>
              <button data-val="Merriweather"       class="font-opt text-[13px] font-semibold py-2 rounded-[8px] border transition-colors" style="font-family:'Merriweather',Georgia,serif">Merriweather</button>
              <button data-val="Plus Jakarta Sans"  class="font-opt text-[13px] font-semibold py-2 rounded-[8px] border transition-colors" style="font-family:'Plus Jakarta Sans',sans-serif">Jakarta Sans</button>
            </div>
            <p class="text-[10px] text-[#9b94a8] mt-2">Applies to the certificate text. Judge signature font is unchanged.</p>
          </div>

          <!-- Background -->
          <div class="bg-white rounded-card border border-[#b8e4e0] p-4">
            <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider mb-3">Background</p>
            <div class="flex gap-2" id="bg-opts">
              <button data-val="#ffffff" class="bg-opt w-8 h-8 rounded-full border-2 transition-all" style="background:#ffffff" title="White"></button>
              <button data-val="#fffef5" class="bg-opt w-8 h-8 rounded-full border-2 transition-all" style="background:#fffef5" title="Cream"></button>
              <button data-val="#f0fafa" class="bg-opt w-8 h-8 rounded-full border-2 transition-all" style="background:#f0fafa" title="Light Teal"></button>
              <button data-val="#f5f3fa" class="bg-opt w-8 h-8 rounded-full border-2 transition-all" style="background:#f5f3fa" title="Lavender"></button>
              <button data-val="#fef5f7" class="bg-opt w-8 h-8 rounded-full border-2 transition-all" style="background:#fef5f7" title="Blush"></button>
              <button data-val="#f3f8f4" class="bg-opt w-8 h-8 rounded-full border-2 transition-all" style="background:#f3f8f4" title="Sage"></button>
            </div>
          </div>

          <!-- Image -->
          <div class="bg-white rounded-card border border-[#b8e4e0] p-4 space-y-3">
            <div class="flex items-center justify-between">
              <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider">Image</p>
              <div class="relative group">
                <button type="button" class="w-4 h-4 rounded-full bg-[#e8e4f0] text-[#9b94a8] text-[10px] font-bold flex items-center justify-center leading-none hover:bg-[#d4cfe3] transition-colors" aria-label="Image mode info">?</button>
                <div class="absolute right-0 bottom-full mb-2 w-56 bg-[#1c1626] text-white text-[11px] leading-relaxed rounded-[8px] px-3 py-2 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity" style="z-index:9999">
                  The preview uses a sample image. On the real certificate the image sits in a fixed left column, sized to fit — portrait, square, and landscape photos all use the same layout. The ratio buttons just preview how each shape fills that column.
                  <span class="absolute right-2 top-full border-4 border-transparent border-t-[#1c1626]"></span>
                </div>
              </div>
            </div>

            <!-- Mode selector -->
            <div class="grid grid-cols-3 gap-1.5" id="image-mode-opts">
              <button data-mode="none"   class="img-mode-opt text-[11px] font-semibold py-2 rounded-[8px] border transition-colors">None</button>
              <button data-mode="photo"  class="img-mode-opt text-[11px] font-semibold py-2 rounded-[8px] border transition-colors">Photo</button>
              <button data-mode="ribbon" class="img-mode-opt text-[11px] font-semibold py-2 rounded-[8px] border transition-colors">Ribbon</button>
            </div>

            <!-- Sub-controls greyed when None -->
            <div id="photo-sub-controls" class="space-y-3 transition-opacity">

              <!-- Size slider (Photo + Ribbon) -->
              <div class="space-y-1.5">
                <div class="flex items-center justify-between">
                  <span class="text-[12px] text-[#6f6880]">Image Size</span>
                  <span id="photo-size-val" class="text-[12px] font-bold text-brand">33%</span>
                </div>
                <input type="range" id="photo-size-slider" min="25" max="50" step="1" value="33"
                  class="w-full accent-brand h-1.5 cursor-pointer" />
                <div class="flex justify-between text-[10px] text-[#c4bed0]">
                  <span>Smaller</span><span>Larger</span>
                </div>
              </div>

              <!-- Ratio + real/temp toggle: Photo mode only -->
              <div id="photo-only-controls" class="pt-1 border-t border-[#f5f3fa]">
                <p class="text-[11px] text-[#9b94a8] mb-2">Preview photo ratio</p>
                <div class="grid grid-cols-3 gap-1.5 mb-2" id="ratio-opts">
                  <button data-ratio="landscape" class="ratio-opt text-center text-[11px] font-semibold py-2 rounded-[8px] border leading-tight transition-colors">
                    Landscape<br><span class="text-[10px] font-normal opacity-60">3:2</span>
                  </button>
                  <button data-ratio="square" class="ratio-opt text-center text-[11px] font-semibold py-2 rounded-[8px] border leading-tight transition-colors">
                    Square<br><span class="text-[10px] font-normal opacity-60">1:1</span>
                  </button>
                  <button data-ratio="portrait" class="ratio-opt text-center text-[11px] font-semibold py-2 rounded-[8px] border leading-tight transition-colors">
                    Portrait<br><span class="text-[10px] font-normal opacity-60">2:3</span>
                  </button>
                </div>
                <button id="btn-toggle-photo" class="w-full text-[11px] font-semibold border py-1.5 rounded-[8px] transition-colors">
                  Use real winner photo
                </button>
              </div>

            </div>
          </div>

          <!-- Logo & Sponsors -->
          <div class="bg-white rounded-card border border-[#b8e4e0] p-4 space-y-3">
            <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider">Logo & Extras</p>

            <label id="lbl-logo" class="flex items-center justify-between cursor-pointer">
              <span class="text-[13px] font-semibold text-[#1c1626]">Show Logo</span>
              <input type="checkbox" id="tog-logo" class="cert-toggle w-4 h-4 accent-brand" data-key="show_logo" />
            </label>

            <label id="lbl-sponsors" class="flex items-center justify-between cursor-pointer">
              <span class="text-[13px] font-semibold text-[#1c1626]">Sponsor Logos</span>
              <input type="checkbox" id="tog-sponsors" class="cert-toggle w-4 h-4 accent-brand" data-key="show_sponsors" />
            </label>

            <label id="lbl-signature" class="flex items-center justify-between cursor-pointer">
              <div>
                <span class="text-[13px] font-semibold text-[#1c1626]">Judge Signature</span>
                <p class="text-[11px] text-[#9b94a8] mt-0.5">Bottom-right corner</p>
              </div>
              <input type="checkbox" id="tog-signature" class="cert-toggle w-4 h-4 accent-brand" data-key="show_signature" />
            </label>
          </div>

          <!-- Fields -->
          <div class="bg-white rounded-card border border-[#b8e4e0] p-4">
            <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider mb-3">Fields to Show</p>
            <div class="space-y-2.5">
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" class="field-tog w-4 h-4 accent-brand" data-field="animal_name" />
                <span class="text-[13px] text-[#1c1626]">Animal Name</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" class="field-tog w-4 h-4 accent-brand" data-field="breed" />
                <span class="text-[13px] text-[#1c1626]">Breed</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" class="field-tog w-4 h-4 accent-brand" data-field="exhibitor_name" />
                <span class="text-[13px] text-[#1c1626]">Owner Name</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" class="field-tog w-4 h-4 accent-brand" data-field="category" />
                <span class="text-[13px] text-[#1c1626]">Category</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" class="field-tog w-4 h-4 accent-brand" data-field="place" />
                <span class="text-[13px] text-[#1c1626]">Place</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="checkbox" class="field-tog w-4 h-4 accent-brand" data-field="show_date" />
                <span class="text-[13px] text-[#1c1626]">Show Date</span>
              </label>
            </div>
          </div>

        </div>

        <!-- Bottom scroll indicator -->
        <div id="scroll-bottom-fade"
          class="absolute inset-x-0 bottom-0 h-14 z-10 pointer-events-none flex items-end justify-center pb-2"
          style="background:linear-gradient(to top,#f0fafa 40%,transparent);transition:opacity 0.2s">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </div>

      </div>

      <!-- Right: preview panel -->
      <div class="flex-1 min-w-0 sticky top-6">
        <div class="bg-white rounded-card border border-[#b8e4e0] p-4">
          <div class="flex items-center justify-between mb-3">
            <p class="text-[11px] font-bold text-[#9b94a8] uppercase tracking-wider">Live Preview</p>
            <p id="preview-photo-label" class="text-[11px] text-[#9b94a8]">Landscape sample photo</p>
          </div>
          <div id="cert-canvas-wrapper" class="overflow-hidden rounded-[10px] border border-[#efebf5] bg-[#f9fffe] max-w-[820px]"
               style="aspect-ratio:842/595">
            <canvas id="cert-canvas" style="width:100%;height:100%;display:block"></canvas>
          </div>
          <p id="preview-note" class="text-[11px] text-[#9b94a8] mt-2 text-center">
            No winner data yet — showing placeholder layout
          </p>
        </div>
      </div>

    </div>

  </div>

</DashboardLayout>

<style is:global>
  #left-panel::-webkit-scrollbar { display: none; }
</style>

<script>
  import { getAuth }        from '../../lib/auth.js';
  import { supabase }       from '../../lib/supabase.js';
  import { renderCertificate, CERT_DEFAULTS } from '../../lib/cert-renderer.js';

  let show, sampleEntry, sampleCategory, sponsors;
  let design = { ...CERT_DEFAULTS };
  let renderPending = false;
  let renderQueued  = false;

  // Preview photo state
  let placeholders   = {};  // { landscape, square, portrait } → URL strings
  let realPhotoUrl   = null;
  let currentRatio   = 'landscape'; // which placeholder is active; null = real photo
  let previewPhotoUrl = null;

  function syncRatioUI() {
    // Ratio buttons
    document.querySelectorAll('.ratio-opt').forEach(btn => {
      const active = btn.dataset.ratio === currentRatio;
      btn.className = `ratio-opt text-center text-[11px] font-semibold py-2 rounded-[8px] border leading-tight transition-colors ${
        active ? 'border-brand bg-brand/10 text-brand' : 'border-[#efebf5] text-[#6f6880] hover:border-brand/40'
      }`;
    });

    // Toggle button — always visible, three states
    const toggleBtn = document.getElementById('btn-toggle-photo');
    if (toggleBtn) {
      if (!realPhotoUrl) {
        // No real photo available yet
        toggleBtn.textContent = 'No winner photo yet';
        toggleBtn.disabled = true;
        toggleBtn.className = 'w-full text-[11px] font-semibold border border-[#efebf5] py-1.5 rounded-[8px] text-[#c4bed0] cursor-not-allowed select-none';
      } else if (currentRatio === null) {
        // Currently showing real photo → offer switch to temp
        toggleBtn.textContent = 'Use temp image instead';
        toggleBtn.disabled = false;
        toggleBtn.className = 'w-full text-[11px] font-semibold border border-[#b8e4e0] py-1.5 rounded-[8px] text-[#6f6880] hover:bg-[#f0fafa] transition-colors';
      } else {
        // Currently showing temp → offer switch to real
        toggleBtn.textContent = 'Use real winner photo';
        toggleBtn.disabled = false;
        toggleBtn.className = 'w-full text-[11px] font-semibold border border-brand/30 py-1.5 rounded-[8px] text-brand hover:bg-brand/5 transition-colors';
      }
    }

    // Preview label
    const labelEl = document.getElementById('preview-photo-label');
    if (labelEl) {
      const mode = design.image_mode ?? 'photo';
      if (mode === 'ribbon') {
        const p = sampleEntry?.result_place ?? 1;
        labelEl.textContent = `${p === 1 ? '1st' : p === 2 ? '2nd' : '3rd'} place ribbon`;
      } else if (mode === 'none') {
        labelEl.textContent = 'No image';
      } else {
        const labelMap = { landscape: 'Landscape sample (3:2)', square: 'Square sample (1:1)', portrait: 'Portrait sample (2:3)' };
        labelEl.textContent = currentRatio ? labelMap[currentRatio] : 'Real winner photo';
      }
    }
  }

  function syncPhotoControls() {
    const mode      = design.image_mode ?? 'photo';
    const sub       = document.getElementById('photo-sub-controls');
    const slider    = document.getElementById('photo-size-slider');
    const val       = document.getElementById('photo-size-val');
    const photoOnly = document.getElementById('photo-only-controls');
    if (!slider) return;

    // Grey whole sub-section when None
    const hasImage = mode !== 'none';
    sub.style.opacity       = hasImage ? '1' : '0.4';
    sub.style.pointerEvents = hasImage ? '' : 'none';

    // Ratio + real/temp toggle only applies to Photo mode
    if (photoOnly) photoOnly.style.display = mode === 'photo' ? '' : 'none';

    const pct = Math.round((design.photo_size ?? 0.45) * 100);
    slider.value    = pct;
    val.textContent = pct + '%';

    // Image mode buttons
    document.querySelectorAll('.img-mode-opt').forEach(btn => {
      const isActive = btn.dataset.mode === mode;
      btn.className = `img-mode-opt text-[11px] font-semibold py-2 rounded-[8px] border transition-colors ${
        isActive ? 'border-brand bg-brand/10 text-brand' : 'border-[#efebf5] text-[#6f6880] hover:border-brand/40'
      }`;
    });
  }

  function showToast(msg, isError = false) {
    const el = document.getElementById('status-msg');
    el.textContent = msg;
    el.style.display = 'block';
    el.style.color = isError ? '#b91c1c' : '#1c1626';
    el.style.background = isError ? '#fef2f2' : '#f0fafa';
    el.style.borderColor = isError ? '#fca5a5' : 'rgba(27,168,154,0.2)';
    clearTimeout(el._t);
    el._t = setTimeout(() => { el.style.display = 'none'; }, 4000);
  }

  async function redraw() {
    if (renderPending) { renderQueued = true; return; }
    renderPending = true;
    const canvas = document.getElementById('cert-canvas');

    // Build the preview entry: only inject photo_url in photo mode.
    const photoUrl = design.image_mode === 'photo'
      ? (previewPhotoUrl ?? sampleEntry?.photo_url ?? null)
      : null;
    const previewEntry = sampleEntry
      ? { ...sampleEntry, photo_url: photoUrl }
      : { photo_url: photoUrl, animal_name: 'Sample Animal', breed: 'Sample Breed',
          exhibitor_name: 'J. Smith', result_place: 1, category_id: null };

    await renderCertificate(canvas, {
      show:     show,
      entry:    previewEntry,
      category: sampleCategory,
      sponsors: sponsors,
      design:   design,
    });
    // Renderer sets fixed pixel sizes; reset so the canvas scales to the wrapper.
    canvas.style.width  = '100%';
    canvas.style.height = '100%';
    renderPending = false;
    if (renderQueued) { renderQueued = false; redraw(); }
  }

  function syncUI() {
    // Border buttons
    document.querySelectorAll('.border-opt').forEach(btn => {
      const active = btn.dataset.val === design.border_style;
      btn.className = `border-opt text-[12px] font-semibold py-2 rounded-[8px] border transition-colors ${
        active ? 'border-brand bg-brand/10 text-brand' : 'border-[#efebf5] text-[#6f6880] hover:border-brand/40'
      }`;
    });
    // Font buttons (className reset keeps the inline font-family preview style)
    document.querySelectorAll('.font-opt').forEach(btn => {
      const active = btn.dataset.val === design.text_font;
      btn.className = `font-opt text-[13px] font-semibold py-2 rounded-[8px] border transition-colors ${
        active ? 'border-brand bg-brand/10 text-brand' : 'border-[#efebf5] text-[#6f6880] hover:border-brand/40'
      }`;
    });
    // BG buttons
    document.querySelectorAll('.bg-opt').forEach(btn => {
      btn.style.borderColor = btn.dataset.val === design.bg_color ? '#1ba89a' : '#efebf5';
    });
    // Toggles
    document.querySelectorAll('.cert-toggle').forEach(inp => {
      inp.checked = !!design[inp.dataset.key];
    });
    // Field checkboxes
    document.querySelectorAll('.field-tog').forEach(inp => {
      inp.checked = design.fields.includes(inp.dataset.field);
    });
    // Logo / sponsor toggles
    const hasLogo     = !!(show?.logo_url || show?.org_logo_url);
    const hasSponsors = sponsors?.length > 0;
    document.getElementById('lbl-logo').style.opacity     = hasLogo     ? '1' : '0.4';
    document.getElementById('tog-logo').disabled          = !hasLogo;
    document.getElementById('lbl-sponsors').style.opacity = hasSponsors ? '1' : '0.4';
    document.getElementById('tog-sponsors').disabled      = !hasSponsors;

    // Page size buttons
    const ps = design.page_size || 'a4';
    document.querySelectorAll('.page-size-opt').forEach(btn => {
      const active = btn.dataset.size === ps;
      btn.className = `page-size-opt flex-1 text-[12px] font-semibold py-2 rounded-[8px] border transition-colors ${
        active ? 'border-brand bg-brand/10 text-brand' : 'border-[#efebf5] text-[#6f6880] hover:border-brand/40'
      }`;
    });

    // Update canvas wrapper aspect ratio to match page size
    const ratios = { a4: '842/595', letter: '792/612' };
    const wrapper = document.getElementById('cert-canvas-wrapper');
    if (wrapper) wrapper.style.aspectRatio = ratios[ps] || '842/595';

    syncPhotoControls();
  }

  function updateLockUI(isLocked) {
    document.getElementById('lock-status').style.display = isLocked ? 'inline-flex' : 'none';
    document.getElementById('btn-unlock').style.display  = isLocked ? 'inline-flex' : 'none';
    document.getElementById('btn-lock').style.display    = isLocked ? 'none' : 'inline-flex';
    document.getElementById('btn-save').style.display    = isLocked ? 'none' : 'inline-flex';
    // Freeze / thaw all design controls
    const panel = document.getElementById('left-panel');
    if (panel) panel.style.opacity = isLocked ? '0.45' : '1';
    document.querySelectorAll('.cert-toggle, .field-tog').forEach(el => el.disabled = isLocked);
    document.querySelectorAll('.border-opt, .font-opt, .bg-opt, .img-mode-opt, .ratio-opt, .page-size-opt').forEach(el => el.disabled = isLocked);
    const slider = document.getElementById('photo-size-slider');
    if (slider) slider.disabled = isLocked;
    const togPhoto = document.getElementById('btn-toggle-photo');
    if (togPhoto) togPhoto.disabled = isLocked;
  }

  function downloadJpg() {
    const canvas = document.getElementById('cert-canvas');
    const link = document.createElement('a');
    link.href = canvas.toDataURL('image/jpeg', 0.92);
    link.download = 'certificate-sample.jpg';
    link.click();
  }

  async function downloadPdf() {
    const canvas = document.getElementById('cert-canvas');
    const PAGE_PT = { a4: [842, 595], letter: [792, 612] };
    const [W, H] = PAGE_PT[design.page_size || 'a4'];
    const pdfBytes = await buildPdf(canvas, W, H);
    const blob = new Blob([pdfBytes], { type: 'application/pdf' });
    const url  = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url; link.download = 'certificate-sample.pdf'; link.click();
    setTimeout(() => URL.revokeObjectURL(url), 5000);
  }

  async function buildPdf(canvas, W, H) {
    const jpegBlob  = await new Promise(res => canvas.toBlob(res, 'image/jpeg', 0.92));
    const jpegBytes = new Uint8Array(await jpegBlob.arrayBuffer());
    const iw = canvas.width, ih = canvas.height;
    const enc = s => typeof s === 'string' ? new TextEncoder().encode(s) : s;
    const parts = []; let pos = 0; const off = {};
    const push = s => { const b = enc(s); parts.push(b); pos += b.length; };

    push('%PDF-1.4\n');
    off[1] = pos; push('1 0 obj\n<< /Type /Catalog /Pages 2 0 R >>\nendobj\n');
    off[2] = pos; push('2 0 obj\n<< /Type /Pages /Kids [3 0 R] /Count 1 >>\nendobj\n');
    off[3] = pos; push(`3 0 obj\n<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ${W} ${H}] /Resources << /XObject << /img 4 0 R >> >> /Contents 5 0 R >>\nendobj\n`);
    off[4] = pos; push(`4 0 obj\n<< /Type /XObject /Subtype /Image /Width ${iw} /Height ${ih} /ColorSpace /DeviceRGB /BitsPerComponent 8 /Filter /DCTDecode /Length ${jpegBytes.length} >>\nstream\n`);
    push(jpegBytes); push('\nendstream\nendobj\n');
    const cs = `q ${W} 0 0 ${H} 0 0 cm /img Do Q`;
    off[5] = pos; push(`5 0 obj\n<< /Length ${cs.length} >>\nstream\n${cs}\nendstream\nendobj\n`);
    const xref = pos;
    push('xref\n0 6\n0000000000 65535 f \n');
    for (let i = 1; i <= 5; i++) push(off[i].toString().padStart(10, '0') + ' 00000 n \n');
    push(`trailer\n<< /Size 6 /Root 1 0 R >>\nstartxref\n${xref}\n%%EOF\n`);

    const total = parts.reduce((n, b) => n + b.length, 0);
    const out = new Uint8Array(total); let p = 0;
    for (const b of parts) { out.set(b, p); p += b.length; }
    return out;
  }

  async function saveDesign(lock = false) {
    const payload = { cert_design_json: JSON.stringify(design) };
    if (lock) payload.cert_design_locked_at = new Date().toISOString();
    const { error } = await supabase.from('shows').update(payload).eq('id', show.id);
    if (error) { showToast('Failed to save — please try again', true); return false; }
    if (lock) { show.cert_design_locked_at = payload.cert_design_locked_at; updateLockUI(true); }
    showToast(lock ? 'Design locked and activated!' : 'Design saved.');
    return true;
  }

  async function unlock() {
    const { error } = await supabase.from('shows')
      .update({ cert_design_locked_at: null })
      .eq('id', show.id);
    if (error) { showToast('Failed to unlock — please try again', true); return; }
    show.cert_design_locked_at = null;
    updateLockUI(false);
    showToast('Design unlocked. Send Certificate is now disabled until you re-lock.');
  }

  (async () => {
    const auth = await getAuth();
    const base = auth.base;

    document.getElementById('back-link').href = base + 'organiser/judging';

    if (!auth.session) { window.location.replace(base + 'login'); return; }

    const name = auth.profile?.display_name || auth.session.user.email?.split('@')[0] || 'Organiser';
    const avatarEl = document.getElementById('sidebar-avatar');
    const nameEl   = document.getElementById('sidebar-username');
    const badgeEl  = document.getElementById('sidebar-role-badge');
    if (avatarEl) {
      if (auth.profile?.avatar_url) {
        avatarEl.innerHTML = `<img src="${auth.profile.avatar_url}" alt="" style="width:100%;height:100%;object-fit:cover;">`;
      } else {
        avatarEl.textContent = name.charAt(0).toUpperCase();
      }
    }
    if (nameEl)   nameEl.textContent   = name;
    if (badgeEl)  badgeEl.textContent  = auth.profile?.organiser_type === 'club' ? 'Club Organiser' : 'Organiser';
    document.getElementById('sidebar-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = base + 'login';
    });

    const uid = auth.session.user.id;

    const params  = new URLSearchParams(window.location.search);
    const showId  = params.get('id');

    function showError(msg) {
      document.getElementById('state-loading').style.display = 'none';
      document.getElementById('state-error').style.display   = 'flex';
      document.getElementById('error-msg').textContent = msg;
    }

    if (!showId) { showError('No show specified.'); return; }

    const [showRes, catsRes, winnersRes, sponsorsRes, judgeRes] = await Promise.all([
      supabase.from('shows').select('*').eq('id', showId).eq('created_by', uid).single(),
      supabase.from('show_categories').select('id, name').eq('show_id', showId),
      supabase.from('show_entries')
        .select('id, animal_name, breed, exhibitor_name, photo_url, result_place, category_id')
        .eq('show_id', showId).eq('result_place', 1).limit(1),
      supabase.from('show_sponsors').select('name, logo_url').eq('show_id', showId),
      supabase.from('show_judges').select('first_name, last_name').eq('show_id', showId).limit(1).maybeSingle(),
    ]);

    if (showRes.error || !showRes.data) { showError('Show not found or access denied.'); return; }

    show      = showRes.data;
    sponsors  = sponsorsRes.data || [];

    const j = judgeRes?.data;
    if (j) show.judge_name = `${j.first_name || ''} ${j.last_name || ''}`.trim() || null;

    const cats = catsRes.data || [];
    sampleEntry = winnersRes.data?.[0] || null;
    sampleCategory = cats.find(c => c.id === sampleEntry?.category_id) || cats[0] || null;

    // Back link goes to results page if results are published
    if (show.results_published_at) {
      document.getElementById('nav-back').href = base + 'organiser/results?id=' + showId;
    } else {
      document.getElementById('nav-back').href = base + 'organiser/judging';
    }

    document.getElementById('show-subtitle').textContent = show.title || 'Untitled Show';
    // preview-note is now always hidden since we always have a placeholder
    document.getElementById('preview-note').style.display = 'none';

    // Point to the real sample images in public/images/
    const origin = window.location.origin;
    placeholders = {
      landscape: origin + '/images/landscapeSample.jpg',
      square:    origin + '/images/squareSample.jpg',
      portrait:  origin + '/images/portraitSample.jpg',
    };
    realPhotoUrl    = sampleEntry?.photo_url || null;
    currentRatio    = 'landscape';
    previewPhotoUrl = placeholders.landscape;
    syncRatioUI();

    // Load saved design
    if (show.cert_design_json) {
      try {
        const saved = JSON.parse(show.cert_design_json);
        Object.assign(design, saved);
        // Backward compat: old show_photo boolean → image_mode
        if (!design.image_mode && 'show_photo' in saved) {
          design.image_mode = saved.show_photo ? 'photo' : 'none';
        }
      } catch {}
    }
    if (design.image_mode !== 'photo') previewPhotoUrl = null;

    // Public-voting shows have no judge, so no signature option
    if (show.is_judged === false) {
      design.show_signature = false;
      document.getElementById('lbl-signature').style.display = 'none';
    }

    updateLockUI(!!show.cert_design_locked_at);
    syncUI();

    document.getElementById('state-loading').style.display = 'none';
    document.getElementById('state-content').style.display = 'block';

    await redraw();

    // ── Scroll panel: dynamic height + scroll indicators ──────────────────
    function updatePanelHeight() {
      const panel = document.getElementById('left-panel');
      if (!panel) return;
      const rect = panel.getBoundingClientRect();
      panel.style.maxHeight = Math.max(200, window.innerHeight - rect.top - 24) + 'px';
    }
    function updateScrollIndicators() {
      const panel   = document.getElementById('left-panel');
      const topFade = document.getElementById('scroll-top-fade');
      const botFade = document.getElementById('scroll-bottom-fade');
      if (!panel || !topFade || !botFade) return;
      const { scrollTop, scrollHeight, clientHeight } = panel;
      topFade.style.opacity = scrollTop > 8 ? '1' : '0';
      botFade.style.opacity = scrollTop < scrollHeight - clientHeight - 8 ? '1' : '0';
    }
    updatePanelHeight();
    updateScrollIndicators();
    document.getElementById('left-panel')?.addEventListener('scroll', updateScrollIndicators);
    window.addEventListener('resize', () => { updatePanelHeight(); updateScrollIndicators(); });

    // ── Event listeners ───────────────────────────────────────────────────

    // Image mode selector
    document.getElementById('image-mode-opts').addEventListener('click', e => {
      const btn = e.target.closest('.img-mode-opt');
      if (!btn) return;
      design.image_mode = btn.dataset.mode;
      previewPhotoUrl = design.image_mode === 'photo'
        ? (currentRatio ? placeholders[currentRatio] : (realPhotoUrl ?? placeholders.landscape))
        : null;
      syncPhotoControls();
      syncRatioUI();
      redraw();
    });

    // Ratio picker
    document.getElementById('ratio-opts').addEventListener('click', e => {
      const btn = e.target.closest('.ratio-opt');
      if (!btn) return;
      currentRatio    = btn.dataset.ratio;
      previewPhotoUrl = placeholders[currentRatio];
      syncRatioUI();
      redraw();
    });

    // Photo size slider
    document.getElementById('photo-size-slider')?.addEventListener('input', e => {
      design.photo_size = parseInt(e.target.value) / 100;
      document.getElementById('photo-size-val').textContent = e.target.value + '%';
      redraw();
    });

    // Photo toggle button (always visible, text changes)
    document.getElementById('btn-toggle-photo')?.addEventListener('click', () => {
      if (!realPhotoUrl) return;
      if (currentRatio === null) {
        // Switch back to the last used temp ratio (default landscape)
        currentRatio    = 'landscape';
        previewPhotoUrl = placeholders.landscape;
        // Sync ratio buttons so landscape is highlighted
        syncRatioUI();
      } else {
        currentRatio    = null;
        previewPhotoUrl = realPhotoUrl;
      }
      syncRatioUI();
      redraw();
    });

    // Border buttons
    document.getElementById('border-opts').addEventListener('click', e => {
      const btn = e.target.closest('.border-opt');
      if (!btn) return;
      design.border_style = btn.dataset.val;
      syncUI(); redraw();
    });

    // Font buttons
    document.getElementById('font-opts').addEventListener('click', e => {
      const btn = e.target.closest('.font-opt');
      if (!btn) return;
      design.text_font = btn.dataset.val;
      syncUI(); redraw();
    });

    // BG buttons
    document.getElementById('bg-opts').addEventListener('click', e => {
      const btn = e.target.closest('.bg-opt');
      if (!btn) return;
      design.bg_color = btn.dataset.val;
      syncUI(); redraw();
    });

    // Toggle checkboxes
    document.querySelectorAll('.cert-toggle').forEach(inp => {
      inp.addEventListener('change', () => {
        design[inp.dataset.key] = inp.checked;
        syncPhotoControls();
        redraw();
      });
    });

    // Field checkboxes
    document.querySelectorAll('.field-tog').forEach(inp => {
      inp.addEventListener('change', () => {
        if (inp.checked) {
          if (!design.fields.includes(inp.dataset.field)) design.fields.push(inp.dataset.field);
        } else {
          design.fields = design.fields.filter(f => f !== inp.dataset.field);
        }
        redraw();
      });
    });

    // Page size
    document.getElementById('page-size-opts').addEventListener('click', e => {
      const btn = e.target.closest('.page-size-opt');
      if (!btn) return;
      design.page_size = btn.dataset.size;
      syncUI();
      redraw();
    });

    document.getElementById('btn-dl-jpg').addEventListener('click', downloadJpg);
    document.getElementById('btn-dl-pdf').addEventListener('click', downloadPdf);
    document.getElementById('btn-save').addEventListener('click', () => saveDesign(false));
    document.getElementById('btn-lock').addEventListener('click', () => saveDesign(true));
    document.getElementById('btn-unlock').addEventListener('click', unlock);
  })();
</script>
