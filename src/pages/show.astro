---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Show" description="Public pet show page">

  <div style="background:#F0F7F5;min-height:100vh;padding-bottom:100px">

    <!-- Loading -->
    <div id="state-loading" style="display:flex;align-items:center;justify-content:center;min-height:60vh">
      <div style="width:40px;height:40px;border:3px solid rgba(30,142,126,0.2);border-top-color:#1E8E7E;border-radius:50%;animation:spin 0.8s linear infinite"></div>
    </div>

    <!-- Not found -->
    <div id="state-not-found" style="display:none;align-items:center;justify-content:center;min-height:60vh">
      <div style="text-align:center;max-width:360px;padding:0 24px">
        <div style="font-size:48px;margin-bottom:16px">🐾</div>
        <h2 style="font-size:22px;font-weight:800;color:#143A37;margin-bottom:8px">Show not found</h2>
        <p style="color:#6B7C79;margin-bottom:24px">This show may have been removed or the link may be incorrect.</p>
        <a id="link-home" href="#" style="display:inline-flex;align-items:center;gap:8px;background:#1E8E7E;color:white;font-weight:700;font-size:14px;padding:12px 24px;border-radius:10px;text-decoration:none">Browse Shows</a>
      </div>
    </div>

    <!-- Show content -->
    <div id="state-show" style="display:none">
      <!-- Preview banner (shown only in ?preview=1 mode) -->
      <div id="preview-banner" style="display:none;background:#FEF3C7;border-bottom:2px solid #F59E0B;padding:12px 24px;align-items:center;justify-content:space-between;gap:12px">
        <div style="display:flex;align-items:center;gap:10px">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#92400E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span style="font-size:13px;font-weight:600;color:#92400E">Preview — This show has not been published yet. Only you can see this page.</span>
        </div>
        <a id="preview-settings-link" href="#" style="font-size:13px;font-weight:700;color:#B45309;white-space:nowrap;text-decoration:none">Settings →</a>
      </div>
      <div style="max-width:1200px;margin:0 auto;padding:24px 24px 0">
        <div id="show-hero" style="margin-bottom:20px"></div>
        <div id="show-body"></div>
      </div>
    </div>

  </div>

  <!-- Sticky bottom CTA -->
  <div id="sticky-cta" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:50;background:#1E8E7E;box-shadow:0 -2px 16px rgba(0,0,0,0.15)">
    <div style="max-width:1200px;margin:0 auto;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px">
      <div style="display:flex;align-items:center;gap:10px;min-width:0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="white" stroke="white" stroke-width="0"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span id="sticky-text" style="color:white;font-weight:700;font-size:15px;white-space:nowrap"></span>
        <span id="sticky-fee" style="color:rgba(255,255,255,0.7);font-size:13px;white-space:nowrap"></span>
      </div>
      <button id="sticky-btn" style="background:#0E2A2A;color:white;font-weight:700;font-size:13px;padding:10px 22px;border-radius:10px;border:none;cursor:pointer;white-space:nowrap;flex-shrink:0"></button>
    </div>
  </div>

  <!-- All entries modal -->
  <div id="entries-modal" style="display:none;position:fixed;inset:0;z-index:100;background:rgba(14,42,42,0.55);backdrop-filter:blur(3px)" role="dialog" aria-modal="true" aria-labelledby="entries-modal-title">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:white;border-radius:20px;width:min(780px,94vw);max-height:85vh;display:flex;flex-direction:column;box-shadow:0 24px 64px rgba(14,42,42,0.22)">
      <div style="padding:20px 24px 16px;border-bottom:1px solid #E6EEEC;display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
        <h2 id="entries-modal-title" style="font-size:17px;font-weight:800;color:#143A37;margin:0">All Entries</h2>
        <button id="close-entries-modal" style="background:none;border:none;cursor:pointer;color:#9BB4AF;padding:4px;display:flex;align-items:center;justify-content:center" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div id="entries-modal-body" style="overflow-y:auto;padding:20px 24px 24px"></div>
    </div>
  </div>

  <!-- Classes modal -->
  <div id="classes-modal" style="display:none;position:fixed;inset:0;z-index:100;background:rgba(14,42,42,0.55);backdrop-filter:blur(3px)" role="dialog" aria-modal="true" aria-labelledby="classes-modal-title">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:white;border-radius:20px;width:min(480px,92vw);max-height:80vh;display:flex;flex-direction:column;box-shadow:0 24px 64px rgba(14,42,42,0.22)">
      <div style="padding:20px 24px 16px;border-bottom:1px solid #E6EEEC;display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
        <h2 id="classes-modal-title" style="font-size:17px;font-weight:800;color:#143A37;margin:0">Entry Classes</h2>
        <button id="close-classes-modal" style="background:none;border:none;cursor:pointer;color:#9BB4AF;padding:4px;display:flex;align-items:center;justify-content:center" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div id="classes-modal-body" style="overflow-y:auto;padding:8px 24px 24px"></div>
    </div>
  </div>

  <!-- Sponsors modal -->
  <div id="sponsors-modal" style="display:none;position:fixed;inset:0;z-index:100;background:rgba(14,42,42,0.55);backdrop-filter:blur(3px)" role="dialog" aria-modal="true" aria-labelledby="sponsors-modal-title">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:white;border-radius:20px;width:min(560px,92vw);max-height:85vh;display:flex;flex-direction:column;box-shadow:0 24px 64px rgba(14,42,42,0.22)">
      <div style="padding:20px 24px 16px;border-bottom:1px solid #E6EEEC;display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
        <h2 id="sponsors-modal-title" style="font-size:17px;font-weight:800;color:#143A37;margin:0">Our Sponsors</h2>
        <button id="close-sponsors-modal" style="background:none;border:none;cursor:pointer;color:#9BB4AF;padding:4px;display:flex;align-items:center;justify-content:center" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div id="sponsors-modal-body" style="overflow-y:auto;padding:8px 24px 24px"></div>
    </div>
  </div>

  <!-- Results modal -->
  <div id="results-modal" style="display:none;position:fixed;inset:0;z-index:100;background:rgba(14,42,42,0.55);backdrop-filter:blur(3px)" role="dialog" aria-modal="true" aria-labelledby="results-modal-title">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:white;border-radius:20px;width:min(560px,92vw);max-height:85vh;display:flex;flex-direction:column;box-shadow:0 24px 64px rgba(14,42,42,0.22)">
      <div style="padding:20px 24px 16px;border-bottom:1px solid #E6EEEC;display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
        <h2 id="results-modal-title" style="font-size:17px;font-weight:800;color:#143A37;margin:0">Full Results</h2>
        <button id="close-results-modal" style="background:none;border:none;cursor:pointer;color:#9BB4AF;padding:4px;display:flex;align-items:center;justify-content:center" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div id="results-modal-body" style="overflow-y:auto;padding:8px 24px 24px"></div>
    </div>
  </div>

  <!-- Entry image viewer (voting grid lightbox) -->
  <div id="image-modal" style="display:none;position:fixed;inset:0;z-index:120;background:rgba(14,42,42,0.82);backdrop-filter:blur(4px)" role="dialog" aria-modal="true" aria-label="Entry photo">
    <button id="close-image-modal" aria-label="Close" style="position:absolute;top:16px;right:16px;z-index:2;width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,0.12);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:white">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div id="image-modal-backdrop" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;padding:24px">
      <div style="max-width:min(640px,92vw)">
        <div id="image-modal-photo" style="border-radius:16px;overflow:hidden;display:flex;align-items:center;justify-content:center"></div>
        <div style="display:flex;align-items:center;justify-content:space-between;gap:14px;margin-top:14px">
          <div style="min-width:0">
            <p id="image-modal-name" style="color:white;font-weight:800;font-size:18px;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></p>
            <p id="image-modal-sub" style="color:rgba(255,255,255,0.7);font-size:13px;margin:3px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></p>
          </div>
          <button id="image-modal-vote" style="flex-shrink:0;background:#1E8E7E;color:white;font-weight:700;font-size:13.5px;padding:11px 22px;border-radius:10px;border:none;cursor:pointer;font-family:inherit"></button>
        </div>
      </div>
    </div>
  </div>

  <!-- Vote basket sticky footer (shown during public voting) -->
  <div id="vote-basket" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:50;background:#1E8E7E;box-shadow:0 -2px 16px rgba(0,0,0,0.15)">
    <div style="max-width:1200px;margin:0 auto;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px">
      <div style="display:flex;align-items:center;gap:10px;min-width:0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        <span id="basket-text" style="color:white;font-weight:700;font-size:15px;white-space:nowrap"></span>
      </div>
      <button id="basket-submit-btn" disabled
        style="background:#0E2A2A;color:white;font-weight:700;font-size:13px;padding:10px 22px;border-radius:10px;border:none;cursor:pointer;white-space:nowrap;flex-shrink:0;opacity:0.5;transition:opacity .15s">
        Submit My Votes →
      </button>
    </div>
  </div>

  <!-- Vote email confirmation modal -->
  <div id="vote-email-modal" style="display:none;position:fixed;inset:0;z-index:100;background:rgba(14,42,42,0.55);backdrop-filter:blur(3px)" role="dialog" aria-modal="true" aria-labelledby="vote-modal-title">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:white;border-radius:20px;width:min(440px,92vw);box-shadow:0 24px 64px rgba(14,42,42,0.22);overflow:hidden">
      <div style="padding:22px 24px 16px;border-bottom:1px solid #E6EEEC;display:flex;align-items:center;justify-content:space-between">
        <h2 id="vote-modal-title" style="font-size:17px;font-weight:800;color:#143A37;margin:0">Confirm your votes</h2>
        <button id="close-vote-modal" style="background:none;border:none;cursor:pointer;color:#9BB4AF;padding:4px;display:flex;align-items:center;justify-content:center" aria-label="Close">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div style="padding:20px 24px 24px">
        <div id="vote-modal-form">
          <p style="font-size:14px;color:#6B7C79;margin:0 0 16px;line-height:1.5">We'll email you a link to confirm your votes. One click and you're done.</p>
          <label style="display:block;font-size:13px;font-weight:600;color:#4A4357;margin-bottom:6px" for="vote-email-input">Email address</label>
          <input id="vote-email-input" type="email" placeholder="you@example.com" autocomplete="email"
            style="width:100%;border:1.5px solid #b8e4e0;border-radius:11px;padding:12px 14px;font-size:14px;color:#1c1626;box-sizing:border-box;outline:none"
            onfocus="this.style.borderColor='#1E8E7E'" onblur="this.style.borderColor='#b8e4e0'" />
          <p style="font-size:11.5px;color:#9BB4AF;margin:8px 0 20px;line-height:1.5">
            We will never send you marketing emails. Your email is used only to verify that each person votes fairly.
          </p>
          <p id="vote-modal-error" style="display:none;font-size:13px;color:#DC2626;background:#FEF2F2;border:1px solid #FECACA;border-radius:8px;padding:10px 12px;margin:0 0 14px"></p>
          <div style="display:flex;gap:10px">
            <button id="vote-modal-cancel" style="flex:1;font-size:13.5px;font-weight:600;color:#6B7C79;border:1.5px solid #b8e4e0;border-radius:11px;padding:12px;background:white;cursor:pointer">
              Cancel
            </button>
            <button id="vote-modal-submit" style="flex:2;font-size:13.5px;font-weight:700;color:white;background:#1E8E7E;border:none;border-radius:11px;padding:12px;cursor:pointer">
              Send confirmation →
            </button>
          </div>
        </div>
        <div id="vote-modal-success" style="display:none;text-align:center;padding:8px 0 4px">
          <div style="width:56px;height:56px;border-radius:50%;background:#E3F5F2;display:flex;align-items:center;justify-content:center;margin:0 auto 14px">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1E8E7E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 style="font-size:17px;font-weight:800;color:#143A37;margin:0 0 8px">Check your inbox!</h3>
          <p style="font-size:13.5px;color:#6B7C79;margin:0;line-height:1.5">We've sent you a confirmation link. Click it within 30 minutes to confirm your votes.</p>
        </div>
      </div>
    </div>
  </div>

  <style>@keyframes spin{to{transform:rotate(360deg)}}</style>

</BaseLayout>

<script>
  import { getAuth } from '../lib/auth.js';
  import { supabase } from '../lib/supabase.js';
  import { zonedDateTime } from '../lib/voteWindow.js';
  import { organiserNet } from '../lib/fees.js';

  const CURRENCY_SYMBOLS = { GBP: '£', USD: '$', EUR: '€', AUD: 'A$', CAD: 'C$', NZD: 'NZ$', ZAR: 'R', SGD: 'S$' };
  const SHOW_TYPE_LABELS = { beauty_contest: 'Beauty Contest', fun_stakes: 'Fun Stakes', memorial: 'Memorial Show', other: 'Other' };

  let show, categories, entries, sponsors, showState, base, showId, sym, totalRaised, displayFee, isPreview;
  let earlyVoting = false;   // vote show accepting votes while entries are still open
  let votingActive = false;  // any state where the ballot UI is live
  let enterBtnVisible = false;
  let voteSelections = {}; // { [category_id]: entry_id }
  let focusCategoryId = null;
  let focusEntryId = null;

  // ── Init ──────────────────────────────────────────────────────────────────────

  async function init() {
    const raw = import.meta.env.BASE_URL;
    base = raw.endsWith('/') ? raw : raw + '/';
    document.getElementById('link-home').href = base;

    const params = new URLSearchParams(window.location.search);
    showId = params.get('id');
    if (!showId) { showNotFound(); return; }

    focusCategoryId = params.get('category') || null;
    focusEntryId    = params.get('entry')    || null;
    isPreview = params.get('preview') === '1';
    let showQ = supabase.from('shows').select('*').eq('id', showId);
    if (!isPreview) showQ = showQ.eq('status', 'published');

    const [showRes, catsRes, entriesRes, sponsorsRes, feesRes] = await Promise.all([
      showQ.single(),
      supabase.from('show_categories').select('id, name').eq('show_id', showId),
      supabase.from('show_entries')
        .select('id, animal_name, breed, photo_url, category_id, entry_number, exhibitor_name, result_place')
        .eq('show_id', showId).eq('status', 'confirmed').order('entry_number'),
      supabase.from('show_sponsors').select('name, website, logo_url').eq('show_id', showId),
      supabase.from('platform_settings').select('key, value').or('key.like.service_fee_%,key.like.stripe_fee_%'),
    ]);

    if (showRes.error || !showRes.data) { showNotFound(); return; }

    show = showRes.data;

    // A published show never needs preview mode — a stale ?preview=1 link
    // should show the real page, warning-free
    if (isPreview && show.status === 'published') isPreview = false;

    if (isPreview) {
      const auth = await getAuth();
      if (!auth.session) { window.location.replace(base + 'login'); return; }
      if (show.created_by !== auth.session.user.id) { showNotFound(); return; }
      const banner = document.getElementById('preview-banner');
      banner.style.display = 'flex';
      document.getElementById('preview-settings-link').href = `${base}organiser/show/?id=${showId}`;
    }

    // A suspended show is unavailable to the public regardless of status —
    // independent of the draft/published/cancelled lifecycle. The organiser's
    // own preview link still works so they can see why.
    if (show.suspended_at && !isPreview) { showNotFound(); return; }

    categories  = catsRes.data    || [];
    entries     = entriesRes.data  || [];
    sponsors    = sponsorsRes.data || [];
    sym         = CURRENCY_SYMBOLS[show.currency] || '£';
    showState   = getShowState(show);
    earlyVoting  = showState === 'entries_open' && show.is_judged === false && show.vote_open_mode === 'on_entries_open';
    votingActive = showState === 'voting' || earlyVoting;
    // "Total raised" is what the organiser actually receives — the all-in fee
    // the exhibitor paid, minus the platform + Stripe fees. Never show gross.
    const serviceFees = {};
    for (const r of (feesRes.data || [])) serviceFees[r.key] = parseFloat(r.value) || 0;
    const netPerEntry = organiserNet(show.entry_fee || 0, show.currency || 'AUD', serviceFees) ?? 0;
    totalRaised = entries.length * netPerEntry;

    // All-in pricing: entry_fee is the total the entrant pays.
    displayFee = show.entry_fee > 0 ? Number(show.entry_fee) : null;

    document.title = show.title || 'Pet Show';
    document.getElementById('state-loading').style.display = 'none';
    document.getElementById('state-show').style.display    = 'block';

    renderHero();
    renderBody();
    wireButtons();
    renderStickyCTA();
    if (votingActive) postRenderVoting();
    if (isPreview) document.getElementById('sticky-cta').style.display = 'none';
  }

  function getShowState(s) {
    const now       = new Date();
    if (s.archived_at)          return 'archived';
    if (s.results_published_at) return 'results';
    const open      = zonedDateTime(s.entry_open_date,  s.entry_open_time,  s.timezone);
    const close     = zonedDateTime(s.entry_close_date, s.entry_close_time, s.timezone);
    const showStart = zonedDateTime(s.show_date,        s.show_time,        s.timezone);
    // Public vote shows: voting cuts off the moment the show starts (missing
    // start time = midnight, i.e. the start of show day).
    if (s.is_judged === false && showStart && now >= showStart) return 'vote_closed';
    if (!open || open > now) return 'upcoming';
    if (!close || close >= now) return 'entries_open';
    if (s.is_judged === false) return 'voting';
    const showDay = s.show_date ? new Date(s.show_date) : null;
    if (showDay && showDay.toDateString() === now.toDateString()) return 'show_day';
    return 'judging';
  }

  // ── Hero ──────────────────────────────────────────────────────────────────────

  function renderHero() {
    const el = document.getElementById('show-hero');

    const statusPills = {
      upcoming:     { label: 'ENTRIES OPENING SOON!', bg: '#1E8E7E' },
      entries_open: { label: 'ENTRIES OPEN',           bg: '#1E9E5A' },
      judging:      { label: 'JUDGING UNDERWAY',       bg: '#D97706' },
      voting:       { label: 'VOTING OPEN',            bg: '#5B43C4' },
      vote_closed:  { label: '🗳️ VOTING CLOSED',       bg: '#D97706' },
      show_day:     { label: '🎉 SHOW DAY!',            bg: '#7c3aed' },
      results:      { label: '🏆 RESULTS PUBLISHED',   bg: '#5B43C4' },
      archived:     { label: '📦 ARCHIVED',             bg: '#92400e' },
    }[showState];
    if (earlyVoting) statusPills.label = 'ENTRIES & VOTING OPEN';

    const voteCloseLabel = show.show_date
      ? `🗳️ Voting closes ${fmt(show.show_date)}${show.show_time ? ' at ' + show.show_time : ''}`
      : '';

    const datePill = showState === 'results'
      ? `<span style="color:rgba(255,255,255,0.6);font-size:13px;margin-left:4px">Thank you to everyone who entered!</span>`
      : showState === 'upcoming' && show.entry_open_date
        ? pill(`📅 Expected Open: ${fmt(show.entry_open_date)}`)
        : showState === 'voting' && voteCloseLabel
          ? pill(voteCloseLabel)
          : showState === 'vote_closed'
            ? pill('Results coming soon')
            : show.entry_close_date
              ? pill(`📅 Closes ${fmt(show.entry_close_date)}`)
              : '';

    const activeLogoUrl = show.logo_source === 'club' ? show.org_logo_url : show.logo_url;
    const logoEl = activeLogoUrl
      ? `<div style="width:110px;height:110px;border-radius:16px;overflow:hidden;border:3px solid rgba(255,255,255,0.3);flex-shrink:0">
           <img src="${esc(activeLogoUrl)}" alt="Show logo" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block">
         </div>`
      : `<div style="width:110px;height:110px;border-radius:16px;background:#1E8E7E;border:3px solid rgba(255,255,255,0.3);display:flex;align-items:center;justify-content:center;color:white;font-size:36px;font-weight:800;flex-shrink:0">${esc((show.title||'S').charAt(0).toUpperCase())}</div>`;

    const typePill = show.show_type && SHOW_TYPE_LABELS[show.show_type]
      ? `<span style="background:rgba(255,255,255,0.15);color:white;font-size:11px;font-weight:700;padding:4px 12px;border-radius:999px;letter-spacing:0.03em">${esc(SHOW_TYPE_LABELS[show.show_type])}</span>`
      : '';

    // Banner photo fills the right side in every state. Fundraising totals render
    // as a card in the body (fundraisingCard) rather than overlaying the banner.
    const showFundraising = showState === 'results' && show.show_fundraising_publicly;
    // Anchor right: the left edge of the banner sits under the gradient fade
    // and text panel, so any cover-cropping must happen on the left
    const bannerLayer = show.banner_url
      ? `<img src="${esc(show.banner_url)}" alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:right center;display:block">`
      : `<div style="position:absolute;inset:0;background:linear-gradient(135deg,#1E8E7E,#0E2A2A)"></div>`;


    el.innerHTML = `
      <div style="position:relative;height:300px;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(14,42,42,0.18)">
        <!-- Dark base -->
        <div style="position:absolute;inset:0;background:#0E2A2A"></div>

        <!-- Right: banner photo -->
        <div style="position:absolute;top:0;right:0;bottom:0;width:58%;overflow:hidden">
          ${bannerLayer}
          <!-- Gradient fade from dark into photo -->
          <div style="position:absolute;inset:0;background:linear-gradient(to right,#0E2A2A 0%,rgba(14,42,42,0.4) 35%,transparent 65%);pointer-events:none"></div>
        </div>

        <!-- Left: text panel -->
        <div style="position:absolute;left:0;top:0;bottom:0;width:50%;padding:28px 32px;display:flex;flex-direction:column;justify-content:space-between;z-index:1">
          <div>
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
              ${logoEl}
              ${typePill}
            </div>
            <h1 style="font-size:28px;font-weight:800;color:white;line-height:1.22;letter-spacing:-0.02em;margin:0 0 8px">${esc(show.title || 'Untitled Show')}</h1>
            ${show.organisation_name
              ? `<p style="font-size:13px;color:rgba(255,255,255,0.55);margin:0 0 6px">Hosted by <strong style="color:rgba(255,255,255,0.85);font-weight:600">${esc(show.organisation_name)}</strong> ✓</p>`
              : ''}
            ${show.description && !showFundraising
              ? `<p style="font-size:13px;color:rgba(255,255,255,0.7);margin:0;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${esc(show.description)}</p>`
              : ''}
          </div>
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            <span style="background:${statusPills.bg};color:white;font-size:11px;font-weight:800;padding:6px 14px;border-radius:999px;letter-spacing:0.04em">${statusPills.label}</span>
            ${datePill}
          </div>
        </div>
      </div>`;
  }

  // ── Body dispatcher ───────────────────────────────────────────────────────────

  function renderBody() {
    const el = document.getElementById('show-body');
    if (showState === 'archived') {
      el.innerHTML = archivedBody();
    } else if (showState === 'results') {
      el.innerHTML = resultsBody();
    } else if (showState === 'judging' || showState === 'show_day' || showState === 'vote_closed') {
      el.innerHTML = interimBody();
    } else if (showState === 'voting') {
      el.innerHTML = votingBody();
    } else if (earlyVoting) {
      el.innerHTML = state1Body() + `<div style="margin-top:28px">${votingBody()}</div>`;
    } else {
      el.innerHTML = state1Body();
    }
  }

  function state1Body() {
    return `
      <div style="display:grid;grid-template-columns:1fr 1.6fr 1fr;gap:20px;align-items:start">
        <div style="display:flex;flex-direction:column;gap:16px">
          ${enterCard()}
          ${entryClassesCard(false)}
        </div>
        <div style="display:flex;flex-direction:column;gap:16px">
          ${fundraisingCard()}
          ${meetEntrantsCard()}
        </div>
        <div style="display:flex;flex-direction:column;gap:16px">
          ${sponsorsCard()}
          ${keyDatesCard()}
        </div>
      </div>`;
  }

  function interimBody() {
    const isVoteClosed = showState === 'vote_closed';
    const title = isVoteClosed ? 'Voting Closed' : 'Judging Underway';
    const statusMsg = isVoteClosed
      ? 'Voting has closed. Results are being finalised and will be published soon.'
      : 'Entries are closed and judging is underway. Results coming soon.';
    return `
      <div style="display:grid;grid-template-columns:1fr 1.6fr 1fr;gap:20px;align-items:start">
        <div style="display:flex;flex-direction:column;gap:16px">
          ${card(`
            <h3 style="font-size:15px;font-weight:700;color:#143A37;margin:0 0 8px">${title}</h3>
            <p style="font-size:13px;color:#6B7C79;margin:0">${statusMsg}</p>
          `)}
          ${entryClassesCard(false)}
        </div>
        <div style="display:flex;flex-direction:column;gap:16px">
          ${fundraisingCard()}
          ${meetEntrantsCard()}
        </div>
        <div style="display:flex;flex-direction:column;gap:16px">
          ${sponsorsCard()}
          ${keyDatesCard()}
        </div>
      </div>`;
  }

  function archivedBody() {
    const archivedOn = show.archived_at
      ? new Date(show.archived_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
      : '';
    const notice = `
      <div style="background:#FEF3C7;border:1px solid #FDE68A;border-radius:14px;padding:14px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#92400E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>
        <p style="font-size:13px;color:#92400E;font-weight:600;margin:0">This show has concluded and been archived${archivedOn ? ' on ' + archivedOn : ''}. Winners are displayed below.</p>
      </div>`;
    return `
      ${notice}
      <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;align-items:start">
        <div>${winnersCard()}</div>
        <div>${sponsorsCard()}</div>
      </div>`;
  }

  function resultsBody() {
    return `
      ${datesStrip()}
      <div style="display:grid;grid-template-columns:1fr 2fr 1fr;gap:20px;align-items:start;margin-top:20px">
        <div>${entryClassesCard(true)}</div>
        <div>${winnersCard()}</div>
        <div style="display:flex;flex-direction:column;gap:16px">
          ${fundraisingCard()}
          ${sponsorsCard()}
          ${digitalCertCard()}
        </div>
      </div>
      <div style="margin-top:20px">${fullEntrantsStrip()}</div>`;
  }

  // ── Enter Your Pet card ───────────────────────────────────────────────────────

  function buildEnterBullets() {
    const bullets = [];

    const animal = show.animal_type || 'dog';
    const plural  = animal + 's';

    if (show.breed_scope === 'breed_specific' && show.breed_filter) {
      bullets.push(`Open to ${show.breed_filter} ${plural}`);
    } else if (show.breed_scope === 'group_specific' && show.group_filter) {
      bullets.push(`Open to the ${show.group_filter} group`);
    } else {
      bullets.push(`Open to all ${plural}`);
    }

    bullets.push('Fun, friendly & open to everyone');

    if (show.has_digital_certs && show.has_physical_prizes) {
      bullets.push('Digital certificates & physical prizes for winners');
    } else if (show.has_digital_certs) {
      bullets.push('Digital certificates for all winners');
    } else if (show.has_physical_prizes) {
      bullets.push('Physical prizes for winners');
    }

    return bullets;
  }

  function enterCard() {
    const fee       = displayFee;
    const closeDate = zonedDateTime(show.entry_close_date, show.entry_close_time, show.timezone);
    const countdown = closeDate ? getCountdown(closeDate) : null;
    const isUpcoming = showState === 'upcoming';

    const bulletList = buildEnterBullets().map(b =>
      `<li style="display:flex;align-items:flex-start;gap:8px;margin-bottom:9px;list-style:none;padding:0">
        <span style="font-size:15px;flex-shrink:0;line-height:1.3">🐾</span>
        <span style="color:rgba(255,255,255,0.9);font-size:13px;line-height:1.4">${b}</span>
      </li>`
    ).join('');

    return `
      <div style="background:linear-gradient(135deg,#1FA08D,#14796B);border-radius:16px;padding:20px;box-shadow:0 8px 24px rgba(20,58,55,0.14)">
        <h3 style="color:white;font-size:16px;font-weight:800;margin:0 0 16px;letter-spacing:-0.01em">Enter Your Pet Today!</h3>
        <div style="display:flex;gap:12px;margin-bottom:16px">
          <ul style="flex:1;margin:0;padding:0">${bulletList}</ul>
          <div style="background:rgba(255,255,255,0.18);border-radius:12px;padding:14px 12px;text-align:center;flex-shrink:0;min-width:88px">
            <p style="color:rgba(255,255,255,0.7);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 2px">Entry fee</p>
            <p style="color:white;font-size:38px;font-weight:900;margin:0;line-height:1">${fee != null ? sym + fee.toFixed(2) : '—'}</p>
            <p style="color:rgba(255,255,255,0.65);font-size:10px;margin:0 0 10px">per entry · incl. all fees</p>
            <div style="border-top:1px solid rgba(255,255,255,0.22);padding-top:10px">
              ${closeDate
                ? `<p style="color:rgba(255,255,255,0.6);font-size:9px;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 2px">Entries close in</p>
                   ${countdown ? `<p style="color:white;font-size:14px;font-weight:800;margin:0 0 1px">${countdown}</p>` : ''}
                   <p style="color:rgba(255,255,255,0.6);font-size:10px;margin:0">${fmt(show.entry_close_date)}</p>`
                : `<p style="color:rgba(255,255,255,0.7);font-size:11px;margin:0">Open now</p>`}
            </div>
          </div>
        </div>
        ${isUpcoming
          ? `<div style="width:100%;background:rgba(255,255,255,0.18);color:rgba(255,255,255,0.6);font-weight:700;font-size:14px;padding:13px;border-radius:10px;text-align:center;letter-spacing:0.01em">Entries Opening Soon</div>`
          : `<button id="btn-enter-now" style="width:100%;background:white;color:#14796B;font-weight:800;font-size:14px;padding:13px;border-radius:10px;border:none;cursor:pointer;letter-spacing:0.01em">Enter Now →</button>`
        }
      </div>`;
  }

  // ── Fundraising card ──────────────────────────────────────────────────────────

  function fundraisingCard() {
    if (!show.show_fundraising_publicly) return '';
    const goal = show.fundraising_goal || 0;
    const pct  = goal > 0 ? Math.round(totalRaised / goal * 100) : 0;
    return card(`
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px">
        <h3 style="font-size:15px;font-weight:700;color:#143A37;margin:0">Help Us Reach Our Goal</h3>
        ${goal > 0 ? `<span style="font-size:12px;color:#6B7C79">Goal: ${sym}${goal.toLocaleString()}</span>` : ''}
      </div>
      <p style="font-size:26px;font-weight:800;color:#1E8E7E;margin:0 0 12px">Raised ${sym}${totalRaised.toLocaleString()}</p>
      <div style="height:12px;border-radius:999px;background:#E6EEEC;overflow:hidden;margin-bottom:4px">
        <div style="height:100%;border-radius:999px;width:${Math.min(pct, 100)}%;background:linear-gradient(to right,#A6D84A,#5FB23E)"></div>
      </div>
      <p style="font-size:12px;font-weight:700;color:#5FB23E;margin:0 0 10px;text-align:right">${pct}%</p>
      ${show.description ? `<p style="font-size:12px;color:#6B7C79;margin:0 0 8px">${esc(show.description)}</p>` : ''}
      ${show.website_url ? `<a href="${esc(absUrl(show.website_url))}" target="_blank" rel="noopener noreferrer" style="font-size:13px;color:#1E8E7E;font-weight:600;text-decoration:none">Learn more about our cause →</a>` : ''}
    `);
  }

  // ── Key Dates card ────────────────────────────────────────────────────────────

  function keyDatesCard() {
    const now = Date.now();
    const tzAbbr = (() => {
      if (!show.timezone) return '';
      try {
        const parts = Intl.DateTimeFormat('en', { timeZone: show.timezone, timeZoneName: 'short' }).formatToParts(new Date());
        return parts.find(p => p.type === 'timeZoneName')?.value || '';
      } catch { return ''; }
    })();
    const rows = [
      { label: 'Entries Open',  date: show.entry_open_date,  time: show.entry_open_time },
      { label: 'Entries Close', date: show.entry_close_date, time: show.entry_close_time },
      { label: 'Show Day',      date: show.show_date,        time: show.show_time },
    ].filter(d => d.date).map((d, i) => {
      const past   = new Date(d.date).getTime() < now;
      const border = i > 0 ? 'border-top:1px solid #F0F4F3;' : '';
      const timeEl = d.time
        ? `<span style="display:block;font-size:11.5px;color:#9BB4AF;margin-top:2px">${d.time}${tzAbbr ? ' ' + tzAbbr : ''}</span>`
        : '';
      return `<div style="display:flex;justify-content:space-between;align-items:${d.time ? 'flex-start' : 'center'};padding:10px 0;${border}">
        <span style="font-size:13px;color:${past ? '#9BB4AF' : '#143A37'};font-weight:500;display:flex;align-items:center;gap:7px;padding-top:${d.time ? '1px' : '0'}">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="${past ? '#1E8E7E' : '#9BB4AF'}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          ${d.label}
        </span>
        <div style="text-align:right">
          <span style="display:block;font-size:13px;${past ? 'color:#9BB4AF;text-decoration:line-through' : 'color:#6B7C79;font-weight:600'}">${fmt(d.date)}</span>
          ${timeEl}
        </div>
      </div>`;
    }).join('');

    const judgeRow = show.is_judged !== null && show.is_judged !== undefined
      ? `<div style="display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-top:1px solid #F0F4F3">
          <span style="font-size:13px;color:#143A37;font-weight:500;display:flex;align-items:center;gap:7px">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1E8E7E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
            Judging
          </span>
          <span style="font-size:13px;color:#6B7C79">${show.is_judged ? 'By Expert Judges' : 'Public Vote'}</span>
        </div>` : '';

    return card(`<h3 style="font-size:15px;font-weight:700;color:#143A37;margin:0 0 4px">Key Dates</h3>${rows}${judgeRow}`);
  }

  // ── Entry Classes card ────────────────────────────────────────────────────────

  function entryClassesCard(resultsMode) {
    const fee = displayFee;
    if (!categories.length) return card(`
      <h3 style="font-size:15px;font-weight:700;color:#143A37;margin:0 0 10px">Entry Classes</h3>
      <p style="font-size:13px;color:#6B7C79">No classes configured yet.</p>`);

    const visible = categories.slice(0, 3);
    const hasMore = categories.length > 3;

    const rows = visible.map((cat, i) => {
      const count  = entries.filter(e => e.category_id === cat.id).length;
      const border = i > 0 ? 'border-top:1px solid #F0F4F3;' : '';
      return `<div style="display:flex;align-items:center;gap:8px;padding:8px 0;${border}">
        <span style="color:#1E8E7E;font-size:14px;flex-shrink:0">🐾</span>
        <span style="flex:1;font-size:13px;font-weight:600;color:#143A37;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(cat.name)}</span>
        ${!resultsMode ? `<span style="font-size:12px;color:#6B7C79;flex-shrink:0">${fee != null ? sym + fee.toFixed(2) : '—'}</span>` : ''}
        <span style="font-size:12px;color:#6B7C79;flex-shrink:0;min-width:20px;text-align:right">${count}</span>
      </div>`;
    }).join('');

    const footer = `
      <div style="margin-top:10px;padding-top:10px;border-top:1px solid #E6EEEC;display:flex;align-items:center;justify-content:space-between">
        ${hasMore ? `<span style="font-size:11px;color:#9BB4AF">+ ${categories.length - 3} more</span>` : '<span></span>'}
        <button id="btn-view-classes" style="background:none;border:none;padding:0;font-size:13px;color:#1E8E7E;font-weight:600;cursor:pointer">View All Classes →</button>
      </div>`;

    return card(`
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <h3 style="font-size:15px;font-weight:700;color:#143A37;margin:0">Entry Classes</h3>
        <span style="font-size:11px;color:#9BB4AF">${resultsMode ? 'Entries' : 'Fee | Entries'}</span>
      </div>
      ${rows}
      ${footer}`);
  }

  // ── Meet Our Entrants card ────────────────────────────────────────────────────

  function meetEntrantsCard() {
    const shown = entries.slice(0, 10);
    const header = `
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
        <h3 style="font-size:15px;font-weight:700;color:#143A37;margin:0">Meet Our Entrants</h3>
        <a href="#" id="btn-view-all-entries" style="font-size:12px;color:#1E8E7E;font-weight:600;text-decoration:none">View all entries →</a>
      </div>`;

    if (!shown.length) {
      return card(`
        ${header}
        <div style="text-align:center;padding:28px 12px">
          <div style="font-size:32px;opacity:0.25;margin-bottom:14px;letter-spacing:4px">🐾 🐾 🐾</div>
          <p style="font-size:15px;font-weight:700;color:#143A37;margin:0 0 6px">The show floor is empty!</p>
          <p style="font-size:13px;color:#6B7C79;margin:0">The very first entry could be yours… be ready!</p>
        </div>`);
    }

    const grid = shown.map(e => {
      const catName = categories.find(c => c.id === e.category_id)?.name || '';
      return `<div style="border-radius:10px;overflow:hidden;border:1px solid #E6EEEC;background:white">
        <div style="aspect-ratio:4/3;overflow:hidden">
          ${e.photo_url
            ? `<img src="${esc(e.photo_url)}" alt="${esc(e.animal_name||'')} — ${esc(e.breed||'')}" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block">`
            : `<div style="width:100%;height:100%;background:#F0F7F5;display:flex;align-items:center;justify-content:center;font-size:26px">🐾</div>`}
        </div>
        <div style="padding:7px 8px">
          <p style="font-size:12px;font-weight:700;color:#143A37;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(e.animal_name||'Unnamed')}</p>
          <p style="font-size:11px;color:#6B7C79;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(e.breed||'')}</p>
          <p style="font-size:11px;color:#1E8E7E;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(catName)}</p>
        </div>
      </div>`;
    }).join('');

    return card(`${header}<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px">${grid}</div>`);
  }

  // ── Sponsors card ─────────────────────────────────────────────────────────────

  function sponsorsCard() {
    if (!sponsors.length) {
      return card(`
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#9BB4AF;margin:0 0 10px">Sponsors</p>
        <p style="font-size:12px;color:#6B7C79;margin:0">This event is not sponsored.</p>
      `);
    }

    const logos = sponsors.map((s, i) => {
      const border = i < sponsors.length - 1 ? 'border-bottom:1px solid #F0F4F3;' : '';
      return `<div style="padding:10px 0;${border}">
        ${s.logo_url
          ? `<a href="${esc(absUrl(s.website))}" target="_blank" rel="noopener">
               <div style="height:44px;display:flex;align-items:center">
                 <img src="${esc(s.logo_url)}" alt="${esc(s.name)}" style="max-height:38px;max-width:100%;object-fit:contain;object-position:left center;display:block">
               </div>
             </a>`
          : `<a href="${esc(absUrl(s.website))}" target="_blank" rel="noopener" style="font-size:14px;font-weight:700;color:#143A37;text-decoration:none">${esc(s.name)}</a>`}
      </div>`;
    }).join('');

    return card(`
      <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#9BB4AF;margin:0 0 4px">Proudly Sponsored By</p>
      ${logos}
      <button id="open-sponsors-modal" style="display:block;background:none;border:none;padding:0;cursor:pointer;font-size:12px;color:#1E8E7E;font-weight:600;margin-top:10px;font-family:inherit">View All Sponsors →</button>`);
  }

  function openSponsorsModal() {
    const rows = sponsors.map(s => {
      const logo = s.logo_url
        ? `<img src="${esc(s.logo_url)}" alt="${esc(s.name)}" style="max-width:85%;max-height:150px;object-fit:contain;display:block">`
        : `<span style="font-size:56px;font-weight:800;color:#1E8E7E">${esc((s.name || 'S').charAt(0).toUpperCase())}</span>`;
      const site = absUrl(s.website);
      return `
        <div style="border:1px solid #E6EEEC;border-radius:16px;overflow:hidden;margin-top:14px">
          <div style="height:180px;background:#F7FAF9;display:flex;align-items:center;justify-content:center;padding:16px">
            ${logo}
          </div>
          <div style="padding:14px 18px;text-align:center">
            <p style="font-size:16px;font-weight:800;color:#143A37;margin:0">${esc(s.name)}</p>
            ${site
              ? `<a href="${esc(site)}" target="_blank" rel="noopener" style="display:inline-block;font-size:13px;color:#1E8E7E;font-weight:600;text-decoration:none;margin-top:4px;word-break:break-all">${esc(site.replace(/^https?:\/\//, '').replace(/\/$/, ''))} ↗</a>`
              : ''}
          </div>
        </div>`;
    }).join('');
    document.getElementById('sponsors-modal-body').innerHTML =
      rows || '<p style="color:#6B7C79;font-size:13px;padding:16px 0">This event is not sponsored.</p>';
    document.getElementById('sponsors-modal').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeSponsorsModal() {
    document.getElementById('sponsors-modal').style.display = 'none';
    document.body.style.overflow = '';
  }

  // ── Results: dates strip ──────────────────────────────────────────────────────

  function datesStrip() {
    const items = [
      { label: 'Entry Open',   value: show.entry_open_date  ? fmt(show.entry_open_date)  : null },
      { label: 'Entries Close',value: show.entry_close_date ? fmt(show.entry_close_date) : null },
      { label: 'Show Day',     value: show.show_date        ? fmt(show.show_date)        : null },
      { label: 'Judging',      value: show.is_judged != null ? (show.is_judged ? 'By Expert Judges' : 'Public Vote') : null },
    ].filter(d => d.value);

    const cells = items.map((item, i) => `
      <div style="display:flex;align-items:center;gap:8px;${i > 0 ? 'padding-left:16px;border-left:1px solid #E6EEEC' : ''}">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1E8E7E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <div>
          <p style="font-size:10px;text-transform:uppercase;letter-spacing:0.06em;color:#9BB4AF;margin:0;font-weight:600">${item.label}</p>
          <p style="font-size:13px;font-weight:700;color:#143A37;margin:0">${item.value}</p>
        </div>
      </div>`).join('');

    return `<div style="background:white;border-radius:14px;border:1px solid #E6EEEC;box-shadow:0 4px 12px rgba(20,58,55,0.04);padding:16px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap">
      <div style="display:flex;align-items:center;gap:0;flex-wrap:wrap">${cells}</div>
      <div style="text-align:right">
        <p style="font-size:15px;font-weight:800;color:#143A37;margin:0 0 2px">🏆 What a Show!</p>
        <p style="font-size:12px;color:#6B7C79;margin:0">Amazing pets, incredible stories, and a wonderful community.</p>
      </div>
    </div>`;
  }

  // ── Results: Winners card ─────────────────────────────────────────────────────

  function winnersCard() {
    const cols = categories.map(cat => {
      const first = entries.find(e => e.category_id === cat.id && e.result_place === 1);
      if (!first) return null;
      return { cat, first };
    }).filter(Boolean);

    if (!cols.length) return card(`
      <h3 style="font-size:15px;font-weight:700;color:#143A37;margin:0 0 10px">Winners</h3>
      <p style="font-size:13px;color:#6B7C79">No results published yet.</p>`);

    const winnerCols = cols.map(({ cat, first }) => `
      <div>
        <div style="background:#1E8E7E;color:white;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;padding:5px 8px;border-radius:8px 8px 0 0;text-align:center;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(cat.name)}</div>
        <div style="border:1.5px solid #E6EEEC;border-top:none;border-radius:0 0 12px 12px;overflow:hidden">
          <div style="position:relative;aspect-ratio:4/3;overflow:hidden">
            ${first.photo_url
              ? `<img src="${esc(first.photo_url)}" alt="${esc(first.animal_name||'')} — ${esc(first.breed||'')}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center">`
              : `<div style="position:absolute;inset:0;background:#F0F7F5;display:flex;align-items:center;justify-content:center;font-size:36px">🐾</div>`}
            <div style="position:absolute;bottom:6px;right:6px;background:#F0A92B;color:white;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;border:2px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.2)">1</div>
          </div>
          <div style="padding:8px">
            <p style="font-size:12px;font-weight:800;color:#143A37;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(first.animal_name||'Unnamed')}</p>
            <p style="font-size:11px;color:#6B7C79;margin:1px 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(first.breed||'')}</p>
            ${first.exhibitor_name ? `<p style="font-size:10px;color:#9BB4AF;margin:1px 0">Owner: ${esc(first.exhibitor_name)}</p>` : ''}
          </div>
        </div>
      </div>`).join('');

    return card(`
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
        <h3 style="font-size:15px;font-weight:700;color:#143A37;margin:0">Winners</h3>
        <button id="open-results-modal" style="background:none;border:none;cursor:pointer;font-size:12px;color:#1E8E7E;font-weight:600;padding:0;font-family:inherit">View All Results →</button>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px">${winnerCols}</div>`);
  }

  function buildResultsModal() {
    const PLACE = { 1: '🥇 1st', 2: '🥈 2nd', 3: '🥉 3rd' };
    const sections = categories.map(cat => {
      const placed = entries
        .filter(e => e.category_id === cat.id && e.result_place >= 1 && e.result_place <= 3)
        .sort((a, b) => a.result_place - b.result_place);
      if (!placed.length) return '';
      const rows = placed.map(e => `
        <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid #F0F4F3">
          <span style="font-size:13px;font-weight:700;color:#143A37;min-width:52px">${PLACE[e.result_place] || `#${e.result_place}`}</span>
          ${e.photo_url
            ? `<img src="${esc(e.photo_url)}" style="width:40px;height:40px;border-radius:8px;object-fit:cover;flex-shrink:0">`
            : `<div style="width:40px;height:40px;border-radius:8px;background:#F0F7F5;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0">🐾</div>`}
          <div style="min-width:0">
            <p style="font-size:13px;font-weight:700;color:#143A37;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(e.animal_name||'Unnamed')}</p>
            <p style="font-size:11px;color:#6B7C79;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(e.breed||'')}${e.exhibitor_name ? ' · ' + esc(e.exhibitor_name) : ''}</p>
          </div>
        </div>`).join('');
      return `
        <div style="padding:16px 0 4px">
          <p style="font-size:10px;font-weight:700;color:#9BB4AF;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 4px">${esc(cat.name)}</p>
          ${rows}
        </div>`;
    }).join('');

    document.getElementById('results-modal-body').innerHTML = sections || '<p style="color:#6B7C79;font-size:13px;padding:16px 0">No results available.</p>';
  }

  // ── Results: digital cert card ────────────────────────────────────────────────

  function digitalCertCard() {
    if (!show.has_digital_certs) return '';
    return card(`
      <h3 style="font-size:14px;font-weight:700;color:#143A37;margin:0 0 6px">Your Digital Certificate</h3>
      <p style="font-size:12px;color:#6B7C79;margin:0 0 12px">All participants receive a beautiful digital certificate.</p>
      <div style="border:2px dashed #E6EEEC;border-radius:10px;padding:14px;text-align:center;background:#FAFFFE;margin-bottom:12px">
        <p style="font-size:11px;font-weight:700;color:#143A37;margin:0">${esc(show.title||'Pet Show')}</p>
        <p style="font-size:10px;color:#6B7C79;margin:2px 0 6px">Certificate of Participation</p>
        <div style="font-size:20px">🥇</div>
        <p style="font-size:11px;color:#1E8E7E;font-weight:700;margin:4px 0 0">Awarded to Luna</p>
      </div>
      <a href="${base}login" style="display:block;text-align:center;font-size:13px;color:#1E8E7E;font-weight:700;text-decoration:none">View Your Certificate →</a>`);
  }

  // ── Results: full entrants strip ──────────────────────────────────────────────

  function fullEntrantsStrip() {
    if (!entries.length) return '';
    const shown = entries.slice(0, 10);
    const thumbs = shown.map(e => `
      <div style="border-radius:10px;overflow:hidden;border:1px solid #E6EEEC">
        <div style="aspect-ratio:1/1;overflow:hidden">
          ${e.photo_url
            ? `<img src="${esc(e.photo_url)}" alt="${esc(e.animal_name||'')} — ${esc(e.breed||'')}" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block">`
            : `<div style="width:100%;height:100%;background:#F0F7F5;display:flex;align-items:center;justify-content:center;font-size:22px">🐾</div>`}
        </div>
        <div style="padding:5px 7px">
          <p style="font-size:11px;font-weight:700;color:#143A37;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(e.animal_name||'Unnamed')}</p>
        </div>
      </div>`).join('');

    return card(`
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
        <h3 style="font-size:15px;font-weight:700;color:#143A37;margin:0">Meet Our Entrants</h3>
        <a href="#" id="btn-view-all-entries" style="font-size:12px;color:#1E8E7E;font-weight:600;text-decoration:none">View All Entries →</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(10,1fr);gap:8px">${thumbs}</div>`);
  }

  // ── Sticky CTA ────────────────────────────────────────────────────────────────

  function renderStickyCTA() {
    if (showState !== 'entries_open') return;
    const fee     = displayFee;
    const textEl  = document.getElementById('sticky-text');
    const feeEl   = document.getElementById('sticky-fee');
    const btnEl   = document.getElementById('sticky-btn');

    textEl.textContent = 'Enter Your Pet Today!';
    feeEl.textContent  = fee != null ? `${sym}${fee.toFixed(2)} per class` : '';
    btnEl.textContent  = 'Enter Now →';

    btnEl.addEventListener('click', handleEnterNow);
    syncStickyFooters();

    const enterBtn = document.getElementById('btn-enter-now');
    if (enterBtn) {
      new IntersectionObserver(evts => {
        enterBtnVisible = evts[0].isIntersecting;
        syncStickyFooters();
      }, { threshold: 0.5 }).observe(enterBtn);
    }
  }

  // One fixed footer at a time: the vote basket wins over the Enter CTA. In
  // early-voting mode the basket only appears once a favourite is picked.
  function syncStickyFooters() {
    const ctaEl  = document.getElementById('sticky-cta');
    const basket = document.getElementById('vote-basket');
    const count  = Object.keys(voteSelections).length;
    const basketShowing = votingActive && (!earlyVoting || count > 0);
    basket.style.display = basketShowing ? 'block' : 'none';
    const ctaAllowed = showState === 'entries_open' && !isPreview;
    ctaEl.style.display = ctaAllowed && !enterBtnVisible && !basketShowing ? 'block' : 'none';
  }

  // ── Classes modal ─────────────────────────────────────────────────────────────

  function openClassesModal() {
    const resultsMode = showState === 'results';
    const body = document.getElementById('classes-modal-body');

    const header = `
      <div style="display:flex;justify-content:space-between;padding:12px 0 6px;border-bottom:1px solid #E6EEEC;margin-bottom:4px">
        <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#9BB4AF">Class</span>
        <div style="display:flex;gap:24px">
          ${!resultsMode ? `<span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#9BB4AF">Fee</span>` : ''}
          <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#9BB4AF">Entries</span>
        </div>
      </div>`;

    const rows = categories.map((cat, i) => {
      const count  = entries.filter(e => e.category_id === cat.id).length;
      const border = i > 0 ? 'border-top:1px solid #F0F4F3;' : '';
      return `<div style="display:flex;align-items:center;gap:10px;padding:10px 0;${border}">
        <span style="color:#1E8E7E;font-size:14px;flex-shrink:0">🐾</span>
        <span style="flex:1;font-size:14px;font-weight:600;color:#143A37">${esc(cat.name)}</span>
        <div style="display:flex;gap:24px;align-items:center;flex-shrink:0">
          ${!resultsMode ? `<span style="font-size:13px;color:#6B7C79;min-width:40px;text-align:right">${displayFee != null ? sym + displayFee.toFixed(2) : '—'}</span>` : ''}
          <span style="font-size:13px;color:#6B7C79;min-width:40px;text-align:right">${count}</span>
        </div>
      </div>`;
    }).join('');

    body.innerHTML = header + rows;
    document.getElementById('classes-modal').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeClassesModal() {
    document.getElementById('classes-modal').style.display = 'none';
    document.body.style.overflow = '';
  }

  // ── All entries modal ─────────────────────────────────────────────────────────

  function openEntriesModal() {
    const body = document.getElementById('entries-modal-body');

    // Group entries by category, uncategorised last
    const grouped = [];
    categories.forEach(cat => {
      const catEntries = entries.filter(e => e.category_id === cat.id);
      if (catEntries.length) grouped.push({ name: cat.name, entries: catEntries });
    });
    const uncategorised = entries.filter(e => !categories.find(c => c.id === e.category_id));
    if (uncategorised.length) grouped.push({ name: 'Uncategorised', entries: uncategorised });

    if (!grouped.length) {
      body.innerHTML = `<p style="font-size:14px;color:#6B7C79;text-align:center;padding:32px 0">No entries yet.</p>`;
    } else {
      body.innerHTML = grouped.map((group, gi) => {
        const cards = group.entries.map(e => `
          <div style="border-radius:10px;overflow:hidden;border:1px solid #E6EEEC;background:white">
            <div style="aspect-ratio:4/3;overflow:hidden">
              ${e.photo_url
                ? `<img src="${esc(e.photo_url)}" alt="${esc(e.animal_name||'')} — ${esc(e.breed||'')}" style="width:100%;height:100%;object-fit:cover;object-position:center;display:block">`
                : `<div style="width:100%;height:100%;background:#F0F7F5;display:flex;align-items:center;justify-content:center;font-size:26px">🐾</div>`}
            </div>
            <div style="padding:7px 8px">
              <p style="font-size:12px;font-weight:700;color:#143A37;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(e.animal_name||'Unnamed')}</p>
              ${e.breed ? `<p style="font-size:11px;color:#6B7C79;margin:2px 0 0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(e.breed)}</p>` : ''}
              ${e.entry_number ? `<p style="font-size:10px;color:#9BB4AF;margin:2px 0 0">#${esc(String(e.entry_number))}</p>` : ''}
            </div>
          </div>`).join('');

        const mt = gi > 0 ? 'margin-top:24px;' : '';
        return `
          <div style="${mt}">
            <p style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#1E8E7E;margin:0 0 12px">${esc(group.name)} <span style="color:#9BB4AF;font-weight:600">(${group.entries.length})</span></p>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:10px">${cards}</div>
          </div>`;
      }).join('');
    }

    // Update title with total count
    document.getElementById('entries-modal-title').textContent = `All Entries (${entries.length})`;
    document.getElementById('entries-modal').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeEntriesModal() {
    document.getElementById('entries-modal').style.display = 'none';
    document.body.style.overflow = '';
  }

  // ── Button wiring ─────────────────────────────────────────────────────────────

  async function handleEnterNow() {
    const { session: s } = await getAuth();
    if (!s) {
      window.location.href = base + 'login?redirect=' + encodeURIComponent('participant/enter?show=' + showId);
    } else {
      window.location.href = base + 'participant/enter?show=' + showId;
    }
  }

  function openResultsModal() {
    buildResultsModal();
    document.getElementById('results-modal').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeResultsModal() {
    document.getElementById('results-modal').style.display = 'none';
    document.body.style.overflow = '';
  }

  function wireButtons() {
    document.getElementById('btn-enter-now')?.addEventListener('click', handleEnterNow);
    document.getElementById('btn-view-classes')?.addEventListener('click', openClassesModal);
    document.getElementById('close-classes-modal').addEventListener('click', closeClassesModal);
    document.getElementById('classes-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeClassesModal();
    });
    document.getElementById('btn-view-all-entries')?.addEventListener('click', e => { e.preventDefault(); openEntriesModal(); });
    document.getElementById('close-entries-modal').addEventListener('click', closeEntriesModal);
    document.getElementById('entries-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeEntriesModal();
    });
    document.getElementById('open-sponsors-modal')?.addEventListener('click', openSponsorsModal);
    document.getElementById('close-sponsors-modal').addEventListener('click', closeSponsorsModal);
    document.getElementById('sponsors-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeSponsorsModal();
    });
    document.getElementById('open-results-modal')?.addEventListener('click', openResultsModal);
    document.getElementById('close-results-modal').addEventListener('click', closeResultsModal);
    document.getElementById('results-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeResultsModal();
    });
    document.getElementById('close-vote-modal').addEventListener('click', closeVoteModal);
    document.getElementById('vote-email-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeVoteModal();
    });
    document.getElementById('vote-modal-cancel').addEventListener('click', closeVoteModal);
    document.getElementById('basket-submit-btn').addEventListener('click', openVoteModal);
    document.getElementById('vote-modal-submit').addEventListener('click', submitVotes);
    document.getElementById('close-image-modal').addEventListener('click', closeImageModal);
    document.getElementById('image-modal-backdrop').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeImageModal();
    });
    document.getElementById('image-modal-vote').addEventListener('click', e => {
      const entryId = (e.currentTarget as HTMLElement).dataset.entryId;
      const card = document.querySelector(`.vote-card[data-entry-id="${CSS.escape(entryId)}"]`);
      if (card) selectEntry(card);
      closeImageModal();
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        closeClassesModal();
        closeEntriesModal();
        closeResultsModal();
        closeVoteModal();
        closeImageModal();
      }
    });
  }

  // ── Public Voting ─────────────────────────────────────────────────────────────

  function votingBody() {
    const alreadyVoted = (() => { try { return !!localStorage.getItem('ps_voted_' + show.id); } catch { return false; } })();

    const banner = alreadyVoted
      ? `<div style="background:#FEF3C7;border:1px solid #FDE68A;border-radius:12px;padding:12px 16px;margin-bottom:20px;display:flex;align-items:center;gap:10px">
           <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#92400E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
           <p style="font-size:13px;color:#92400E;margin:0;font-weight:600;line-height:1.4">It looks like you've already voted from this device. You're welcome to try again with a different email address.</p>
         </div>`
      : '';

    const catSections = categories.map(cat => {
      // Shuffled per page load so late entrants get seen too, not buried
      // under the pets that entered first
      const catEntries = shuffle(entries.filter(e => e.category_id === cat.id));
      if (catEntries.length === 0) return '';
      const cards = catEntries.map(e => `
        <div class="vote-card" data-entry-id="${esc(e.id)}" data-cat-id="${esc(e.category_id)}"
          style="border-radius:14px;border:2.5px solid #E6EEEC;background:#fff;overflow:hidden;transition:border-color .15s,box-shadow .15s;position:relative;-webkit-tap-highlight-color:transparent">
          <div style="aspect-ratio:1;overflow:hidden;background:#E6EEEC;position:relative;cursor:zoom-in" title="Tap to view larger photo">
            ${e.photo_url
              ? `<img src="${esc(e.photo_url)}" style="width:100%;height:100%;object-fit:cover;display:block" alt="${esc(e.animal_name)}" loading="lazy">`
              : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:36px;color:#9BB4AF;font-weight:800">${esc((e.animal_name||'?')[0].toUpperCase())}</div>`}
            <div class="vote-check-overlay" style="display:none;position:absolute;inset:0;background:rgba(30,142,126,0.15);pointer-events:none">
              <div style="position:absolute;top:8px;right:8px;width:28px;height:28px;border-radius:50%;background:#1E8E7E;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,0.2)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
            </div>
          </div>
          <div style="padding:8px 10px 10px">
            <p style="font-size:13px;font-weight:700;color:#143A37;margin:0 0 2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${esc(e.animal_name)}</p>
            ${e.breed ? `<p style="font-size:11px;color:#6B7C79;margin:0 0 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${esc(e.breed)}</p>` : '<p style="margin:0 0 4px"></p>'}
            <div style="display:flex;align-items:center;justify-content:space-between">
              ${e.entry_number ? `<span style="font-size:10px;color:#9BB4AF">Entry #${esc(String(e.entry_number))}</span>` : '<span></span>'}
              <button class="share-entry-btn" data-entry-id="${esc(e.id)}"
                style="background:none;border:none;cursor:pointer;padding:3px;display:flex;align-items:center;color:#9BB4AF;border-radius:4px"
                title="Copy shareable link" aria-label="Copy link to this entry">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
              </button>
            </div>
            <button class="vote-entry-btn" aria-label="Vote for ${esc(e.animal_name || 'this entry')}"
              style="width:100%;margin-top:7px;padding:7px 0;border-radius:8px;border:1.5px solid #1E8E7E;background:white;color:#1E8E7E;font-weight:700;font-size:12px;cursor:pointer;font-family:inherit;transition:background .15s,color .15s">
              Vote
            </button>
          </div>
        </div>`).join('');

      return `
        <div class="vote-category" id="vcat-${esc(cat.id)}" style="margin-bottom:28px">
          <h3 style="font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:0.07em;color:#143A37;margin:0 0 10px">${esc(cat.name)}</h3>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:8px">
            ${cards}
          </div>
        </div>`;
    }).join('');

    return `
      ${banner}
      <div style="margin-bottom:20px">
        <h2 style="font-size:18px;font-weight:800;color:#143A37;margin:0 0 4px">Vote for Your Favourites</h2>
        <p style="font-size:13px;color:#6B7C79;margin:0">Pick your favourite pet in each category, then submit your votes to receive a confirmation email.${show.show_date ? ` Voting closes ${fmt(show.show_date)}${show.show_time ? ' at ' + show.show_time : ''}.` : ''}</p>
      </div>
      ${catSections || `<p style="font-size:14px;color:#6B7C79">No entries yet.</p>`}
      <div style="height:72px"></div>`;
  }

  function postRenderVoting() {
    updateVoteBasket();

    // Wire card interactions: Vote button selects, photo/card opens the viewer
    document.getElementById('show-body').addEventListener('click', e => {
      const shareBtn = e.target.closest('.share-entry-btn');
      if (shareBtn) { e.stopPropagation(); copyEntryLink(shareBtn.dataset.entryId); return; }
      const voteBtn = e.target.closest('.vote-entry-btn');
      if (voteBtn) { selectEntry(voteBtn.closest('.vote-card')); return; }
      const card = e.target.closest('.vote-card');
      if (card) openImageModal(card.dataset.entryId);
    });

    // Scroll to focused category
    if (focusCategoryId) {
      const el = document.getElementById('vcat-' + focusCategoryId);
      if (el) setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'start' }), 150);
    }

    // Highlight focused entry (pre-select it)
    if (focusEntryId) {
      const card = document.querySelector(`.vote-card[data-entry-id="${CSS.escape(focusEntryId)}"]`);
      if (card) { setTimeout(() => selectEntry(card), 200); }
    }
  }

  function applyCardState(cardEl, selected) {
    cardEl.style.borderColor = selected ? '#1E8E7E' : '#E6EEEC';
    cardEl.style.boxShadow   = selected ? '0 0 0 2px rgba(30,142,126,0.18)' : '';
    const overlay = cardEl.querySelector('.vote-check-overlay');
    if (overlay) overlay.style.display = selected ? 'block' : 'none';
    const btn = cardEl.querySelector('.vote-entry-btn');
    if (btn) {
      btn.textContent      = selected ? 'Voted ✓' : 'Vote';
      btn.style.background = selected ? '#1E8E7E' : 'white';
      btn.style.color      = selected ? 'white' : '#1E8E7E';
    }
  }

  function selectEntry(card) {
    const entryId = card.dataset.entryId;
    const catId   = card.dataset.catId;
    const already = voteSelections[catId] === entryId;

    // Deselect current selection in this category
    const prevId = voteSelections[catId];
    if (prevId) {
      const prev = document.querySelector(`.vote-card[data-entry-id="${CSS.escape(prevId)}"]`);
      if (prev) applyCardState(prev, false);
    }

    if (already) {
      delete voteSelections[catId];
    } else {
      voteSelections[catId] = entryId;
      applyCardState(card, true);
    }

    updateVoteBasket();
  }

  // ── Entry image viewer ────────────────────────────────────────────────────────

  function openImageModal(entryId) {
    const entry = entries.find(x => x.id === entryId);
    if (!entry) return;

    const photoEl = document.getElementById('image-modal-photo');
    photoEl.innerHTML = entry.photo_url
      ? `<img src="${esc(entry.photo_url)}" alt="${esc(entry.animal_name || '')}" style="max-width:100%;max-height:70vh;object-fit:contain;display:block;border-radius:16px">`
      : `<div style="width:min(480px,80vw);aspect-ratio:1;background:#143A37;display:flex;align-items:center;justify-content:center;font-size:72px;color:#9BB4AF;font-weight:800;border-radius:16px">${esc((entry.animal_name || '?')[0].toUpperCase())}</div>`;

    const catName = categories.find(c => c.id === entry.category_id)?.name || '';
    document.getElementById('image-modal-name').textContent = entry.animal_name || 'Unnamed';
    document.getElementById('image-modal-sub').textContent = [
      entry.breed,
      entry.entry_number ? `Entry #${entry.entry_number}` : '',
      catName,
    ].filter(Boolean).join(' · ');

    const voteBtn = document.getElementById('image-modal-vote') as HTMLButtonElement;
    const selected = voteSelections[entry.category_id] === entry.id;
    voteBtn.textContent = selected ? 'Voted ✓' : `Vote for ${entry.animal_name || 'this entry'}`;
    voteBtn.dataset.entryId = entry.id;

    document.getElementById('image-modal').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  function closeImageModal() {
    document.getElementById('image-modal').style.display = 'none';
    document.body.style.overflow = '';
  }

  function updateVoteBasket() {
    const count   = Object.keys(voteSelections).length;
    const total   = categories.filter(c => entries.some(e => e.category_id === c.id)).length;
    const textEl  = document.getElementById('basket-text');
    const btn     = document.getElementById('basket-submit-btn');
    if (!textEl || !btn) return;
    textEl.textContent = count === 0
      ? 'Select your favourites above'
      : `${count} of ${total} ${total === 1 ? 'category' : 'categories'} voted`;
    btn.disabled = count === 0;
    btn.style.opacity = count === 0 ? '0.5' : '1';
    btn.style.cursor  = count === 0 ? 'not-allowed' : 'pointer';
    syncStickyFooters();
  }

  function copyEntryLink(entryId) {
    const url = window.location.origin + (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/') + 'entry?id=' + encodeURIComponent(entryId);
    navigator.clipboard.writeText(url).catch(() => {});
    // Brief toast
    let toast = document.getElementById('entry-link-toast');
    if (!toast) {
      toast = document.createElement('div');
      toast.id = 'entry-link-toast';
      Object.assign(toast.style, {
        position: 'fixed', bottom: '84px', left: '50%', transform: 'translateX(-50%)',
        background: '#1c1626', color: 'white', padding: '8px 16px', borderRadius: '10px',
        fontSize: '13px', fontWeight: '600', zIndex: '200', transition: 'opacity 0.25s',
        whiteSpace: 'nowrap', opacity: '0', pointerEvents: 'none',
      });
      document.body.appendChild(toast);
    }
    toast.textContent = 'Entry link copied!';
    toast.style.opacity = '1';
    clearTimeout((toast as any)._t);
    (toast as any)._t = setTimeout(() => { toast.style.opacity = '0'; }, 2500);
  }

  function openVoteModal() {
    // Reset form
    const formEl    = document.getElementById('vote-modal-form');
    const successEl = document.getElementById('vote-modal-success');
    const errorEl   = document.getElementById('vote-modal-error');
    const emailInput = document.getElementById('vote-email-input') as HTMLInputElement;
    if (formEl)    formEl.style.display    = 'block';
    if (successEl) successEl.style.display = 'none';
    if (errorEl)   errorEl.style.display   = 'none';
    if (emailInput) emailInput.value = '';
    document.getElementById('vote-email-modal').style.display = 'block';
    document.body.style.overflow = 'hidden';
    if (emailInput) setTimeout(() => emailInput.focus(), 50);
  }

  function closeVoteModal() {
    document.getElementById('vote-email-modal').style.display = 'none';
    document.body.style.overflow = '';
  }

  async function submitVotes() {
    const emailInput  = document.getElementById('vote-email-input') as HTMLInputElement;
    const submitBtn   = document.getElementById('vote-modal-submit') as HTMLButtonElement;
    const errorEl     = document.getElementById('vote-modal-error');
    const email = emailInput?.value?.trim() || '';

    if (!email || !email.includes('@')) {
      errorEl.textContent = 'Please enter a valid email address.';
      errorEl.style.display = 'block';
      return;
    }
    errorEl.style.display = 'none';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    const picks = Object.entries(voteSelections).map(([category_id, entry_id]) => ({ category_id, entry_id }));
    const fnUrl = import.meta.env.PUBLIC_SUPABASE_URL + '/functions/v1/send-vote-magic-link';

    let fingerprint = '';
    try { fingerprint = localStorage.getItem('ps_fp_' + show.id) || ''; } catch {}
    if (!fingerprint) {
      fingerprint = crypto.randomUUID();
      try { localStorage.setItem('ps_fp_' + show.id, fingerprint); } catch {}
    }

    try {
      const res = await fetch(fnUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', apikey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY },
        body: JSON.stringify({
          show_id:              show.id,
          voter_email:          email,
          picks,
          ip_address:           null,
          user_agent:           navigator.userAgent,
          browser_fingerprint:  fingerprint,
        }),
      });
      const result = await res.json();

      if (result.error === 'already_voted') {
        errorEl.textContent = 'You have already voted in this show.';
        errorEl.style.display = 'block';
      } else if (result.error === 'already_submitted') {
        errorEl.textContent = "We've already sent you a confirmation link — please check your email.";
        errorEl.style.display = 'block';
      } else if (result.success) {
        try { localStorage.setItem('ps_voted_' + show.id, '1'); } catch {}
        document.getElementById('vote-modal-form').style.display = 'none';
        document.getElementById('vote-modal-success').style.display = 'block';
        return;
      } else {
        errorEl.textContent = result.error || 'Something went wrong. Please try again.';
        errorEl.style.display = 'block';
      }
    } catch {
      errorEl.textContent = 'Could not send confirmation email. Please try again.';
      errorEl.style.display = 'block';
    }

    submitBtn.disabled = false;
    submitBtn.textContent = 'Send confirmation →';
  }

  // ── Utilities ─────────────────────────────────────────────────────────────────

  function card(html) {
    return `<div style="background:white;border-radius:16px;border:1px solid #E6EEEC;box-shadow:0 8px 24px rgba(20,58,55,0.06);padding:20px">${html}</div>`;
  }

  function pill(text) {
    return `<span style="background:rgba(255,255,255,0.12);color:rgba(255,255,255,0.9);font-size:12px;font-weight:600;padding:6px 14px;border-radius:999px">${text}</span>`;
  }

  function fmt(d) {
    return d ? new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '—';
  }

  function esc(s) {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function absUrl(url) {
    if (!url) return '#';
    return /^https?:\/\//i.test(url) ? url : 'https://' + url;
  }

  function shuffle(arr) {
    const a = arr.slice();
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function getCountdown(target) {
    const diff = target.getTime() - Date.now();
    if (diff <= 0) return null;
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000)  / 60000);
    return `${d}d ${h}h ${m}m`;
  }

  function showNotFound() {
    document.getElementById('state-loading').style.display = 'none';
    document.getElementById('state-not-found').style.display = 'flex';
  }

  init();
</script>
