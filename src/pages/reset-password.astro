---
import BaseLayout from '../layouts/BaseLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<BaseLayout title="Set New Password — Fur to Feathers" description="Choose a new password for your Fur to Feathers account.">

  <div class="min-h-[80vh] flex items-center justify-center bg-brand-tint/50 px-4 py-12">

    <!-- Loading -->
    <div id="rp-loading" class="flex flex-col items-center gap-3">
      <div class="w-10 h-10 rounded-full border-4 border-brand/20 border-t-brand animate-spin"></div>
      <p class="text-[14px] text-[#9b94a8]">Verifying your reset link…</p>
    </div>

    <!-- New password card -->
    <div id="rp-card" style="display:none" class="w-full max-w-md bg-white rounded-card-lg shadow-card-float p-10">

      <!-- Logo -->
      <div class="flex justify-center mb-6">
        <a href={base} class="inline-flex items-center no-underline">
          <img src={`${base}images/ftf_logo_1024x847.png`} alt="Fur to Feathers" style="height:64px;width:auto" class="block" />
        </a>
      </div>

      <h1 class="text-[26px] font-extrabold text-[#1c1626] text-center mb-1">Set a new password</h1>
      <p class="text-[15px] text-[#6f6880] text-center mb-8">Choose a new password for <strong id="rp-email" class="text-[#1c1626]"></strong>.</p>

      <form id="rp-form" novalidate>
        <div class="mb-3">
          <label for="rp-pw" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">
            New password <span class="text-[#9b94a8] font-normal">(at least 6 characters)</span>
          </label>
          <div class="relative">
            <input
              type="password"
              id="rp-pw"
              autocomplete="new-password"
              placeholder="••••••••"
              class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 pr-11 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
            />
            <button type="button" id="rp-toggle"
              class="absolute right-3 top-1/2 -translate-y-1/2 text-[#c4bed0] hover:text-brand transition-colors p-1"
              aria-label="Show password">
              <svg id="rp-icon-eye" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
              <svg id="rp-icon-eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
            </button>
          </div>
        </div>
        <div class="mb-4">
          <label for="rp-pw2" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Confirm new password</label>
          <input
            type="password"
            id="rp-pw2"
            autocomplete="new-password"
            placeholder="••••••••"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>

        <p id="rp-error" style="display:none"
          class="text-[13px] text-red-500 text-center mb-4 bg-red-50 border border-red-100 rounded-lg px-3 py-2" role="alert"></p>

        <button
          type="submit"
          id="rp-btn"
          class="w-full bg-brand text-white text-[16px] font-bold py-[14px] rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors"
        >
          Update Password
        </button>
      </form>
    </div>

    <!-- Error card -->
    <div id="rp-invalid" style="display:none" class="w-full max-w-md bg-white rounded-card-lg shadow-card-float p-10 text-center">
      <p class="text-[15px] text-[#6f6880] mb-6">This password reset link has expired or is invalid. Please request a new one.</p>
      <a href={`${base}forgot-password`}
        class="inline-flex items-center justify-center bg-brand text-white text-[15px] font-bold px-8 py-[13px] rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors">
        Request New Link
      </a>
    </div>

  </div>

</BaseLayout>

<script>
  import { supabase } from '../lib/supabase.js';

  const raw  = import.meta.env.BASE_URL;
  const base = raw.endsWith('/') ? raw : raw + '/';

  (async () => {
    // Supabase v2 auto-processes the recovery token from the URL on init.
    let session = (await supabase.auth.getSession()).data.session;

    // If getSession returned null, wait briefly for the async token exchange
    if (!session) {
      session = await new Promise(resolve => {
        const timer = setTimeout(() => { sub.unsubscribe(); resolve(null); }, 5000);
        const { data: { subscription: sub } } = supabase.auth.onAuthStateChange((event, s) => {
          if (event === 'SIGNED_IN' || event === 'PASSWORD_RECOVERY') {
            clearTimeout(timer);
            sub.unsubscribe();
            resolve(s);
          }
        });
      });
    }

    document.getElementById('rp-loading').style.display = 'none';
    if (!session) {
      document.getElementById('rp-invalid').style.display = 'block';
      return;
    }

    document.getElementById('rp-email').textContent = session.user.email || 'your account';
    document.getElementById('rp-card').style.display = 'block';

    // Show/hide password toggle
    const pwInput   = document.getElementById('rp-pw') as HTMLInputElement;
    const toggleBtn = document.getElementById('rp-toggle');
    const iconEye   = document.getElementById('rp-icon-eye');
    const iconOff   = document.getElementById('rp-icon-eye-off');
    toggleBtn?.addEventListener('click', () => {
      const show = pwInput.type === 'password';
      pwInput.type = show ? 'text' : 'password';
      iconEye.classList.toggle('hidden', show);
      iconOff.classList.toggle('hidden', !show);
      toggleBtn.setAttribute('aria-label', show ? 'Hide password' : 'Show password');
    });

    document.getElementById('rp-form')?.addEventListener('submit', async e => {
      e.preventDefault();
      const pw    = (document.getElementById('rp-pw') as HTMLInputElement).value;
      const pw2   = (document.getElementById('rp-pw2') as HTMLInputElement).value;
      const errEl = document.getElementById('rp-error');
      const btn   = document.getElementById('rp-btn') as HTMLButtonElement;

      errEl.style.display = 'none';

      if (!pw || pw.length < 6) {
        errEl.textContent   = 'Password must be at least 6 characters.';
        errEl.style.display = 'block';
        return;
      }
      if (pw !== pw2) {
        errEl.textContent   = 'Passwords do not match.';
        errEl.style.display = 'block';
        return;
      }

      btn.disabled    = true;
      btn.textContent = 'Updating…';

      const { error } = await supabase.auth.updateUser({ password: pw });
      if (error) {
        errEl.textContent   = error.message;
        errEl.style.display = 'block';
        btn.disabled        = false;
        btn.textContent     = 'Update Password';
        return;
      }

      // User is signed in via the recovery session — send them to their hub
      const { data: profile } = await supabase
        .from('profiles')
        .select('roles')
        .eq('id', session.user.id)
        .single();
      const roles = profile?.roles || ['participant'];
      window.location.href = roles.length === 1 ? base + roles[0] : base + 'choose';
    });
  })();
</script>
