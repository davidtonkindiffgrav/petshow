---
import BaseLayout from '../layouts/BaseLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<BaseLayout title="Reset Password — Fur to Feathers" description="Reset your Fur to Feathers account password.">

  <div class="min-h-[80vh] flex items-center justify-center bg-brand-tint/50 px-4 py-12">
    <div class="w-full max-w-md bg-white rounded-card-lg shadow-card-float p-10">

      <!-- Logo -->
      <div class="flex justify-center mb-6">
        <a href={base} class="inline-flex items-center no-underline">
          <img src={`${base}images/ftf_logo_1024x847.png`} alt="Fur to Feathers — Online Pet Shows" style="height:72px;width:auto" class="block" />
        </a>
      </div>

      <!-- Request form -->
      <div id="fp-request">
        <h1 class="text-[26px] font-extrabold text-[#1c1626] text-center mb-1">Forgot your password?</h1>
        <p class="text-[15px] text-[#6f6880] text-center mb-8">Enter your email and we'll send you a link to reset it.</p>

        <form id="fp-form" novalidate>
          <div class="mb-6">
            <label for="fp-email" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Email address</label>
            <input
              type="email"
              id="fp-email"
              autocomplete="email"
              placeholder="you@example.com"
              class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
            />
          </div>

          <p id="fp-error" class="hidden text-[13px] text-red-500 text-center mb-4 bg-red-50 border border-red-100 rounded-lg px-3 py-2" role="alert"></p>

          <button
            type="submit"
            class="w-full bg-brand text-white text-[16px] font-bold py-[14px] rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors"
          >
            Send Reset Link
          </button>
        </form>
      </div>

      <!-- Success state -->
      <div id="fp-success" style="display:none" class="text-center">
        <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-5" style="background:#e8f7f6">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1ba89a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <h1 class="text-[24px] font-extrabold text-[#1c1626] mb-2">Check your inbox</h1>
        <p class="text-[14px] text-[#6f6880] leading-relaxed mb-2">
          If an account exists for <strong id="fp-sent-email" class="text-[#1c1626]"></strong>, we've sent a password reset link.
        </p>
        <p class="text-[13px] text-[#9b94a8]">The link expires after a short time — if you don't see the email, check your spam folder.</p>
      </div>

      <p class="text-center text-[13px] text-[#9b94a8] mt-6">
        Remembered it?
        <a href={`${base}login`} class="text-brand font-semibold hover:underline">Back to Log In</a>
      </p>
    </div>
  </div>

</BaseLayout>

<script>
  import { supabase } from '../lib/supabase.js';

  const raw = import.meta.env.BASE_URL;
  const base = raw.endsWith('/') ? raw : raw + '/';

  document.getElementById('fp-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const email = (document.getElementById('fp-email') as HTMLInputElement).value.trim().toLowerCase();
    const errEl = document.getElementById('fp-error');
    const btn   = (e.target as HTMLFormElement).querySelector('button[type="submit"]') as HTMLButtonElement;

    errEl.classList.add('hidden');

    if (!email || !email.includes('@')) {
      errEl.textContent = 'Please enter a valid email address.';
      errEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending…';

    const { error } = await supabase.auth.resetPasswordForEmail(email, {
      redirectTo: window.location.origin + base + 'reset-password',
    });

    if (error) {
      errEl.textContent = error.message;
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Send Reset Link';
      return;
    }

    document.getElementById('fp-sent-email').textContent = email;
    document.getElementById('fp-request').style.display = 'none';
    document.getElementById('fp-success').style.display = 'block';
  });
</script>
