---
import BaseLayout from '../layouts/BaseLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<BaseLayout title="Log In — Fur to Feathers" description="Log in to your Fur to Feathers account.">

  <div class="min-h-[80vh] flex items-center justify-center bg-brand-tint/50 px-4 py-12">
    <div class="w-full max-w-md bg-white rounded-card-lg shadow-card-float p-10">

      <!-- Logo -->
      <div class="flex justify-center mb-6">
        <a href={base} class="inline-flex items-center gap-2.5 no-underline">
          <svg width="42" height="42" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <ellipse cx="24" cy="31" rx="11" ry="9" fill="#7c3aed"/>
            <ellipse cx="11" cy="23" rx="5.5" ry="6" fill="#7c3aed"/>
            <ellipse cx="37" cy="23" rx="5.5" ry="6" fill="#7c3aed"/>
            <ellipse cx="17" cy="14" rx="5" ry="5.5" fill="#a855f7"/>
            <ellipse cx="31" cy="14" rx="5" ry="5.5" fill="#a855f7"/>
          </svg>
          <div class="flex flex-col leading-none">
            <span class="text-[20px] font-extrabold tracking-[-0.02em] text-[#1c1626]">Fur to Feathers</span>
            <span class="text-[9px] font-bold text-[#9b94a8] tracking-[0.32em] uppercase">PET SHOWS</span>
          </div>
        </a>
      </div>

      <h1 class="text-[26px] font-extrabold text-[#1c1626] text-center mb-1">Welcome back</h1>
      <p class="text-[15px] text-[#6f6880] text-center mb-8">Enter your email and password to continue.</p>

      <!-- Login form -->
      <form id="login-form" novalidate>
        <div class="mb-4">
          <label for="username" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Email address</label>
          <input
            type="email"
            id="username"
            autocomplete="email"
            placeholder="you@example.com"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>

        <div class="mb-6">
          <label for="password" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Password</label>
          <input
            type="password"
            id="password"
            autocomplete="current-password"
            placeholder="••••••••"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>

        <!-- Error message -->
        <p id="login-error" class="hidden text-[13px] text-red-500 text-center mb-4 bg-red-50 border border-red-100 rounded-lg px-3 py-2" role="alert"></p>

        <button
          type="submit"
          class="w-full bg-brand text-white text-[16px] font-bold py-[14px] rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors"
        >
          Log In
        </button>
      </form>

      <p class="text-center text-[13px] text-[#9b94a8] mt-6">
        Don't have an account?
        <a href={`${base}signup`} class="text-brand font-semibold hover:underline">Sign up free</a>
      </p>
    </div>
  </div>

</BaseLayout>

<script>
  import { supabase } from '../lib/supabase.js';

  const raw = import.meta.env.BASE_URL;
  const base = raw.endsWith('/') ? raw : raw + '/';

  document.getElementById('login-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const email    = document.getElementById('username').value.trim().toLowerCase();
    const password = document.getElementById('password').value;
    const errEl    = document.getElementById('login-error');
    const btn      = e.target.querySelector('button[type="submit"]');

    btn.disabled = true;
    btn.textContent = 'Logging in…';

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      errEl.textContent = error.message;
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Log In';
      return;
    }

    const { data: profile } = await supabase
      .from('profiles')
      .select('roles')
      .eq('id', data.user.id)
      .single();

    const roles = profile?.roles || ['participant'];
    window.location.href = roles.length === 1 ? base + roles[0] : base + 'choose';
  });
</script>
