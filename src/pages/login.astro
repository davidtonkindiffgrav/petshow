---
import BaseLayout from '../layouts/BaseLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<BaseLayout title="Log In — Fur to Feathers" description="Log in to your Fur to Feathers account.">

  <div class="min-h-[80vh] flex items-center justify-center bg-brand-tint/50 px-4 py-12">
    <div class="w-full max-w-md bg-white rounded-card-lg shadow-card-float p-10">

      <!-- Logo -->
      <div class="flex justify-center mb-6">
        <a href={base} class="inline-flex items-center no-underline">
          <img src={`${base}images/ftf_logo_2048x648.png`} alt="Fur to Feathers — Online Pet Shows" style="height:40px;width:auto" class="block" />
        </a>
      </div>

      <h1 class="text-[26px] font-extrabold text-[#1c1626] text-center mb-1">Welcome back</h1>
      <p class="text-[15px] text-[#6f6880] text-center mb-8">Enter your email and password to continue.</p>

      <!-- Login form -->
      <form id="login-form" novalidate>
        <div class="mb-4">
          <label for="username" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Email address</label>
          <input
            type="email"
            id="username"
            autocomplete="email"
            placeholder="you@example.com"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>

        <div class="mb-6">
          <label for="password" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Password</label>
          <div class="relative">
            <input
              type="password"
              id="password"
              autocomplete="current-password"
              placeholder="••••••••"
              class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 pr-11 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
            />
            <button type="button" id="toggle-password"
              class="absolute right-3 top-1/2 -translate-y-1/2 text-[#c4bed0] hover:text-brand transition-colors p-1"
              aria-label="Show password">
              <!-- Eye icon (shown when password hidden) -->
              <svg id="icon-eye" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
              </svg>
              <!-- Eye-off icon (shown when password visible) -->
              <svg id="icon-eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Error message -->
        <p id="login-error" class="hidden text-[13px] text-red-500 text-center mb-4 bg-red-50 border border-red-100 rounded-lg px-3 py-2" role="alert"></p>

        <button
          type="submit"
          class="w-full bg-brand text-white text-[16px] font-bold py-[14px] rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors"
        >
          Log In
        </button>
      </form>

      <p class="text-center text-[13px] text-[#9b94a8] mt-6">
        Don't have an account?
        <a href={`${base}signup`} class="text-brand font-semibold hover:underline">Sign up free</a>
      </p>
    </div>
  </div>

</BaseLayout>

<script>
  import { supabase } from '../lib/supabase.js';

  const raw = import.meta.env.BASE_URL;
  const base = raw.endsWith('/') ? raw : raw + '/';

  const pwInput   = document.getElementById('password');
  const toggleBtn = document.getElementById('toggle-password');
  const iconEye   = document.getElementById('icon-eye');
  const iconOff   = document.getElementById('icon-eye-off');
  toggleBtn?.addEventListener('click', () => {
    const show = pwInput.type === 'password';
    pwInput.type = show ? 'text' : 'password';
    iconEye.classList.toggle('hidden', show);
    iconOff.classList.toggle('hidden', !show);
    toggleBtn.setAttribute('aria-label', show ? 'Hide password' : 'Show password');
  });

  document.getElementById('login-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const email    = document.getElementById('username').value.trim().toLowerCase();
    const password = document.getElementById('password').value;
    const errEl    = document.getElementById('login-error');
    const btn      = e.target.querySelector('button[type="submit"]');

    btn.disabled = true;
    btn.textContent = 'Logging in…';

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      errEl.textContent = error.message;
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Log In';
      return;
    }

    const { data: profile } = await supabase
      .from('profiles')
      .select('roles')
      .eq('id', data.user.id)
      .single();

    const roles = profile?.roles || ['participant'];
    window.location.href = roles.length === 1 ? base + roles[0] : base + 'choose';
  });
</script>
