---
import BaseLayout from '../layouts/BaseLayout.astro';
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';
---

<BaseLayout title="Log In — PetShow Online" description="Log in to your PetShow Online account.">

  <div class="min-h-[80vh] flex items-center justify-center bg-brand-tint/50 px-4 py-12">
    <div class="w-full max-w-md bg-white rounded-card-lg shadow-card-float p-10">

      <!-- Logo -->
      <div class="flex justify-center mb-6">
        <a href={base} class="inline-flex items-center gap-2.5 no-underline">
          <svg width="42" height="42" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <ellipse cx="24" cy="31" rx="11" ry="9" fill="#7c3aed"/>
            <ellipse cx="11" cy="23" rx="5.5" ry="6" fill="#7c3aed"/>
            <ellipse cx="37" cy="23" rx="5.5" ry="6" fill="#7c3aed"/>
            <ellipse cx="17" cy="14" rx="5" ry="5.5" fill="#a855f7"/>
            <ellipse cx="31" cy="14" rx="5" ry="5.5" fill="#a855f7"/>
          </svg>
          <div class="flex flex-col leading-none">
            <span class="text-[22px] font-extrabold tracking-[-0.02em] text-[#1c1626]">PetShow</span>
            <span class="text-[9px] font-bold text-[#9b94a8] tracking-[0.32em] uppercase">ONLINE</span>
          </div>
        </a>
      </div>

      <h1 class="text-[26px] font-extrabold text-[#1c1626] text-center mb-1">Welcome back</h1>
      <p class="text-[15px] text-[#6f6880] text-center mb-8">Select your role and log in below.</p>

      <!-- Role selector -->
      <div class="grid grid-cols-3 gap-3 mb-7" role="group" aria-label="Select your role">
        {[
          { id: 'organiser',   label: 'Organiser',   emoji: '🎪' },
          { id: 'judge',       label: 'Judge',       emoji: '⭐' },
          { id: 'participant', label: 'Participant',  emoji: '🐾' },
        ].map(({ id, label, emoji }) => (
          <button
            type="button"
            data-role={id}
            class={`role-card border-2 rounded-card-sm p-3 text-center cursor-pointer transition-all select-none ${id === 'participant' ? 'border-brand bg-brand-tint text-brand ring-2 ring-brand' : 'border-[#e6dcfb] text-[#4a4357] bg-white hover:bg-brand-tint hover:border-brand'}`}
            aria-pressed={id === 'participant' ? 'true' : 'false'}
          >
            <div class="text-2xl mb-1">{emoji}</div>
            <div class="text-[13px] font-bold">{label}</div>
          </button>
        ))}
      </div>

      <!-- Hint text -->
      <p id="login-hint" class="text-[12px] text-[#9b94a8] text-center mb-5 leading-relaxed">
        Participant: <code class="bg-gray-100 px-1 rounded">participant@petshow.com</code> / <code class="bg-gray-100 px-1 rounded">participant123</code>
      </p>

      <!-- Login form -->
      <form id="login-form" novalidate>
        <div class="mb-4">
          <label for="username" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Email address</label>
          <input
            type="email"
            id="username"
            autocomplete="email"
            placeholder="you@example.com"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>

        <div class="mb-6">
          <label for="password" class="block text-[13px] font-semibold text-[#4a4357] mb-1.5">Password</label>
          <input
            type="password"
            id="password"
            autocomplete="current-password"
            placeholder="••••••••"
            class="w-full border border-[#e6dcfb] rounded-[11px] px-4 py-3 text-[15px] text-[#1c1626] placeholder-[#c4bed0] focus:outline-none focus:ring-2 focus:ring-brand focus:border-brand transition-colors"
          />
        </div>

        <!-- Error message -->
        <p id="login-error" class="hidden text-[13px] text-red-500 text-center mb-4 bg-red-50 border border-red-100 rounded-lg px-3 py-2" role="alert"></p>

        <button
          type="submit"
          class="w-full bg-brand text-white text-[16px] font-bold py-[14px] rounded-btn shadow-btn-primary hover:bg-brand-dark transition-colors"
        >
          Log In
        </button>
      </form>

      <p class="text-center text-[13px] text-[#9b94a8] mt-6">
        Don't have an account?
        <a href="#" class="text-brand font-semibold hover:underline">Sign up free</a>
      </p>
    </div>
  </div>

</BaseLayout>

<script define:vars={{ base }}>
  // Temporary mock credentials — replace with real auth before launch
  const CREDENTIALS = {
    organiser:   { email: 'organiser@petshow.com',   password: 'organiser123'   },
    judge:       { email: 'judge@petshow.com',       password: 'judge123'       },
    participant: { email: 'participant@petshow.com', password: 'participant123' },
  };

  const REDIRECTS = {
    organiser:   base + 'organiser',
    judge:       base + 'judge',
    participant: base + 'participant',
  };

  const HINTS = {
    organiser:   'organiser@petshow.com / organiser123',
    judge:       'judge@petshow.com / judge123',
    participant: 'participant@petshow.com / participant123',
  };

  let selectedRole = 'participant';

  // Role card selection
  document.querySelectorAll('.role-card').forEach(card => {
    card.addEventListener('click', () => {
      selectedRole = card.dataset.role;
      document.querySelectorAll('.role-card').forEach(c => {
        const active = c.dataset.role === selectedRole;
        c.classList.toggle('border-brand', active);
        c.classList.toggle('bg-brand-tint', active);
        c.classList.toggle('text-brand', active);
        c.classList.toggle('ring-2', active);
        c.classList.toggle('ring-brand', active);
        c.classList.toggle('border-[#e6dcfb]', !active);
        c.classList.toggle('text-[#4a4357]', !active);
        c.classList.toggle('bg-white', !active);
        c.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      // Update hint
      const hint = document.getElementById('login-hint');
      const cred = CREDENTIALS[selectedRole];
      if (hint && cred) {
        hint.innerHTML = `<code class="bg-gray-100 px-1 rounded">${cred.email}</code> / <code class="bg-gray-100 px-1 rounded">${cred.password}</code>`;
      }

      // Clear error
      const err = document.getElementById('login-error');
      err?.classList.add('hidden');
    });
  });

  // Form submission
  document.getElementById('login-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const email    = document.getElementById('username').value.trim().toLowerCase();
    const password = document.getElementById('password').value;
    const cred     = CREDENTIALS[selectedRole];
    const errEl    = document.getElementById('login-error');

    if (cred && email === cred.email && password === cred.password) {
      window.location.href = REDIRECTS[selectedRole];
    } else {
      errEl.textContent = 'Invalid email or password. Check the hint above and try again.';
      errEl.classList.remove('hidden');
    }
  });
</script>
