---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Financial Centre" activePage="financial">

  <div id="state-loading" class="flex items-center justify-center h-64">
    <div class="w-8 h-8 border-[3px] border-coral/20 border-t-coral rounded-full animate-spin"></div>
  </div>

  <div id="state-content" style="display:none">

    <!-- Balance / revenue tiles -->
    <div id="summary-grid" class="grid gap-3 items-start" style="grid-template-columns:repeat(auto-fill,minmax(190px,1fr));"></div>

    <!-- Filters -->
    <div class="bg-white rounded-card border border-[#b8e4e0] p-4 mt-6 flex flex-wrap gap-3 items-end">
      <div>
        <label class="block text-[11px] font-semibold text-[#9b94a8] mb-1">Show</label>
        <select id="f-show" class="text-[13px] border border-[#b8e4e0] rounded-btn-sm px-2.5 py-2 bg-white min-w-[160px]">
          <option value="">All shows</option>
        </select>
      </div>
      <div>
        <label class="block text-[11px] font-semibold text-[#9b94a8] mb-1">Organisation</label>
        <select id="f-org" class="text-[13px] border border-[#b8e4e0] rounded-btn-sm px-2.5 py-2 bg-white min-w-[160px]">
          <option value="">All organisations</option>
        </select>
      </div>
      <div>
        <label class="block text-[11px] font-semibold text-[#9b94a8] mb-1">Status</label>
        <select id="f-status" class="text-[13px] border border-[#b8e4e0] rounded-btn-sm px-2.5 py-2 bg-white">
          <option value="">Any status</option>
          <option value="confirmed">Confirmed</option>
          <option value="pending">Pending</option>
          <option value="cancelled">Cancelled</option>
        </select>
      </div>
      <div>
        <label class="block text-[11px] font-semibold text-[#9b94a8] mb-1">From</label>
        <input id="f-from" type="date" class="text-[13px] border border-[#b8e4e0] rounded-btn-sm px-2.5 py-2 bg-white" />
      </div>
      <div>
        <label class="block text-[11px] font-semibold text-[#9b94a8] mb-1">To</label>
        <input id="f-to" type="date" class="text-[13px] border border-[#b8e4e0] rounded-btn-sm px-2.5 py-2 bg-white" />
      </div>
      <button id="btn-apply-filters" class="text-[13px] font-bold text-white bg-brand px-4 py-2 rounded-btn hover:bg-brand-dark transition-colors">Apply</button>
    </div>

    <!-- Payment history -->
    <div class="bg-white rounded-card border border-[#b8e4e0] p-5 mt-6">
      <div class="flex items-center justify-between mb-3">
        <p style="font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#9b94a8;">Payment History</p>
        <button id="btn-export-payments" class="text-[12.5px] font-bold text-brand hover:underline">Export CSV</button>
      </div>
      <div class="overflow-x-auto"><table class="w-full text-[13px]"><thead>
        <tr class="text-left text-[11px] text-[#9b94a8] uppercase tracking-wide border-b border-[#f5f3fa]">
          <th class="pb-2 pr-3">Date</th><th class="pb-2 pr-3">Show</th><th class="pb-2 pr-3">Entrant</th>
          <th class="pb-2 pr-3">Amount</th><th class="pb-2 pr-3">Status</th><th class="pb-2 pr-3">Stripe</th>
        </tr>
      </thead><tbody id="payments-tbody"></tbody></table></div>
      <div id="payments-pagination" class="flex items-center justify-between mt-4 text-[12.5px] text-[#6f6880]"></div>
    </div>

    <!-- Payout history -->
    <div class="bg-white rounded-card border border-[#b8e4e0] p-5 mt-6">
      <p style="font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#9b94a8;margin-bottom:6px;">Stripe Payouts</p>
      <p class="text-[12px] text-[#9b94a8] mb-4">Payouts from the platform's Stripe balance to its own bank account — not the same as organiser settlements. See Settlements for what's owed to organisers.</p>
      <div class="overflow-x-auto"><table class="w-full text-[13px]"><thead>
        <tr class="text-left text-[11px] text-[#9b94a8] uppercase tracking-wide border-b border-[#f5f3fa]">
          <th class="pb-2 pr-3">Created</th><th class="pb-2 pr-3">Amount</th><th class="pb-2 pr-3">Status</th><th class="pb-2 pr-3">Arrival</th>
        </tr>
      </thead><tbody id="payouts-tbody"></tbody></table></div>
    </div>

    <!-- Failed / disputed / refunds -->
    <div class="bg-white rounded-card border border-[#b8e4e0] p-5 mt-6">
      <p style="font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#9b94a8;margin-bottom:14px;">Failed Payments, Disputes &amp; Refunds</p>
      <div id="events-content"></div>
    </div>

  </div>

</AdminLayout>

<script>
  import { getAdminAuth, callAdminApi } from '../../lib/adminAuth.js';
  import { supabase } from '../../lib/supabase.js';
  import { esc, currencyTable, statusPill } from '../../lib/format.js';
  import { downloadCsv } from '../../lib/csv.js';

  function kpiCard(label, valueHtml, sub) {
    return `<div class="bg-white rounded-card border border-[#b8e4e0] px-4 py-3.5">
      <p class="text-[11px] font-semibold text-[#9b94a8] uppercase tracking-wide mb-1">${esc(label)}</p>
      ${valueHtml}
      ${sub ? `<p class="text-[11px] text-[#9b94a8] mt-0.5">${esc(sub)}</p>` : ''}
    </div>`;
  }

  const MONEY_TABLE = { bigClass: 'text-[18px]', rowClass: 'text-[12px]', rowHeightPx: 26, maxVisibleRows: 4 };
  const BALANCE_ROW = { bigClass: 'text-[16px]', rowClass: 'text-[11px]', rowHeightPx: 22, maxVisibleRows: 3, showCount: false };

  // Available + Pending is a real total — pending funds are already
  // collected, just still inside Stripe's clearing period — not a
  // projection, so summing them is accurate.
  function mergeBalances(available, pending) {
    const map = {};
    for (const b of available || []) map[b.currency] = (map[b.currency] || 0) + b.amount;
    for (const b of pending || []) map[b.currency] = (map[b.currency] || 0) + b.amount;
    return Object.entries(map).map(([currency, amount]) => ({ currency, amount }));
  }

  function balanceCard(balance) {
    const available = balance?.available || [];
    const pending = balance?.pending || [];
    const total = mergeBalances(available, pending);
    const section = (label, entries, emphasis) => `
      <div class="${emphasis ? 'pt-2 border-t border-[#f5f3fa]' : ''}">
        <p class="text-[11px] ${emphasis ? 'font-bold text-[#1c1626]' : 'text-[#6f6880]'} mb-1">${esc(label)}</p>
        ${currencyTable(entries, BALANCE_ROW)}
      </div>`;
    return `<div class="bg-white rounded-card border border-[#b8e4e0] px-4 py-3.5">
      <p class="text-[11px] font-semibold text-[#9b94a8] uppercase tracking-wide mb-2">Stripe Balance</p>
      <div class="space-y-2">
        ${section('Available', available)}
        ${section('Pending', pending)}
        ${section('Total', total, true)}
      </div>
    </div>`;
  }

  let page = 1;
  const PAGE_SIZE = 25;

  async function loadSummary() {
    const filters = currentFilters();
    const summary = await callAdminApi('financial-summary', filters);
    const el = document.getElementById('summary-grid');
    el.innerHTML = [
      balanceCard(summary.stripe_balance),
      kpiCard('Gross Revenue', currencyTable(summary.gross_revenue, MONEY_TABLE)),
      kpiCard('Platform Revenue', currencyTable(summary.platform_revenue, MONEY_TABLE), 'Estimated'),
      kpiCard('Processing Fees', currencyTable(summary.stripe_processing_fees, MONEY_TABLE), 'Estimated'),
      kpiCard('Net Paid to Organisers', currencyTable(summary.net_paid_to_organisers, MONEY_TABLE), 'Estimated'),
    ].join('');
  }

  function currentFilters() {
    const f = {};
    const show_id = document.getElementById('f-show').value;
    const organisation_id = document.getElementById('f-org').value;
    const status = document.getElementById('f-status').value;
    const date_from = document.getElementById('f-from').value;
    const date_to = document.getElementById('f-to').value;
    if (show_id) f.show_id = show_id;
    if (organisation_id) f.organisation_id = organisation_id;
    if (status) f.status = status;
    if (date_from) f.date_from = date_from;
    if (date_to) f.date_to = date_to;
    return f;
  }

  async function loadPayments() {
    const filters = { ...currentFilters(), page, page_size: PAGE_SIZE };
    const result = await callAdminApi('payments-list', filters);
    const tbody = document.getElementById('payments-tbody');
    if (!result.rows.length) {
      tbody.innerHTML = `<tr><td colspan="6" class="py-4 text-center text-[#9b94a8]">No payments match these filters.</td></tr>`;
    } else {
      tbody.innerHTML = result.rows.map(r => `
        <tr class="border-b border-[#f5f3fa]">
          <td class="py-2 pr-3">${new Date(r.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</td>
          <td class="py-2 pr-3">${esc(r.shows?.title || '—')}</td>
          <td class="py-2 pr-3">${esc(r.exhibitor_name || r.animal_name || '—')}</td>
          <td class="py-2 pr-3 font-semibold">${esc(r.shows?.currency || '')} ${Number(r.entry_fee_paid || 0).toFixed(2)}</td>
          <td class="py-2 pr-3">${statusPill(r.status)}</td>
          <td class="py-2 pr-3 text-[#9b94a8]">${esc(r.stripe_status || '—')}</td>
        </tr>
      `).join('');
    }
    const totalPages = Math.max(1, Math.ceil(result.total / PAGE_SIZE));
    document.getElementById('payments-pagination').innerHTML = `
      <span>Page ${page} of ${totalPages} · ${result.total} payment${result.total === 1 ? '' : 's'}</span>
      <div class="flex gap-2">
        <button id="btn-prev-page" ${page <= 1 ? 'disabled' : ''} class="px-3 py-1.5 border border-[#b8e4e0] rounded-btn-sm text-[12px] font-semibold ${page <= 1 ? 'opacity-40' : 'hover:bg-[#f0fafa]'}">Prev</button>
        <button id="btn-next-page" ${page >= totalPages ? 'disabled' : ''} class="px-3 py-1.5 border border-[#b8e4e0] rounded-btn-sm text-[12px] font-semibold ${page >= totalPages ? 'opacity-40' : 'hover:bg-[#f0fafa]'}">Next</button>
      </div>`;
    document.getElementById('btn-prev-page')?.addEventListener('click', () => { if (page > 1) { page--; loadPayments(); } });
    document.getElementById('btn-next-page')?.addEventListener('click', () => { if (page < totalPages) { page++; loadPayments(); } });
  }

  async function loadPayouts() {
    const result = await callAdminApi('payouts-list', {});
    const tbody = document.getElementById('payouts-tbody');
    if (!result.rows.length) {
      tbody.innerHTML = `<tr><td colspan="4" class="py-4 text-center text-[#9b94a8]">No payouts yet.</td></tr>`;
      return;
    }
    tbody.innerHTML = result.rows.map(p => `
      <tr class="border-b border-[#f5f3fa]">
        <td class="py-2 pr-3">${new Date(p.created).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</td>
        <td class="py-2 pr-3 font-semibold">${esc(p.currency)} ${p.amount.toFixed(2)}</td>
        <td class="py-2 pr-3">${statusPill(p.status)}</td>
        <td class="py-2 pr-3">${p.arrival_date ? new Date(p.arrival_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) : '—'}</td>
      </tr>
    `).join('');
  }

  async function loadEvents() {
    const events = await callAdminApi('stripe-events', {});
    const el = document.getElementById('events-content');
    const section = (title, rows, renderRow) => `
      <p class="text-[12.5px] font-bold text-[#1c1626] mt-4 mb-2">${title} (${rows.length})</p>
      ${rows.length
        ? `<div class="overflow-x-auto"><table class="w-full text-[13px]"><tbody>${rows.map(renderRow).join('')}</tbody></table></div>`
        : `<p class="text-[12.5px] text-[#9b94a8]">None.</p>`}
    `;
    el.innerHTML =
      section('Failed Payments', events.failed_payments, r => `
        <tr class="border-b border-[#f5f3fa]"><td class="py-2 pr-3">${new Date(r.created).toLocaleDateString('en-GB', { day:'numeric', month:'short' })}</td>
        <td class="py-2 pr-3">${esc(r.currency)} ${r.amount.toFixed(2)}</td><td class="py-2 pr-3 text-red-500">${esc(r.last_error || '—')}</td></tr>
      `) +
      section('Disputes', events.disputes, r => `
        <tr class="border-b border-[#f5f3fa]"><td class="py-2 pr-3">${new Date(r.created).toLocaleDateString('en-GB', { day:'numeric', month:'short' })}</td>
        <td class="py-2 pr-3">${esc(r.currency)} ${r.amount.toFixed(2)}</td><td class="py-2 pr-3">${statusPill(r.status)}</td><td class="py-2 pr-3 text-[#9b94a8]">${esc(r.reason || '—')}</td></tr>
      `) +
      section('Refunds', events.refunds, r => `
        <tr class="border-b border-[#f5f3fa]"><td class="py-2 pr-3">${new Date(r.created).toLocaleDateString('en-GB', { day:'numeric', month:'short' })}</td>
        <td class="py-2 pr-3">${esc(r.currency)} ${r.amount.toFixed(2)}</td><td class="py-2 pr-3">${statusPill(r.status)}</td></tr>
      `);
  }

  async function populateFilterOptions() {
    // shows/organisations have no admin RLS bypass — must go through
    // admin-api (service-role), never a direct client-side supabase query.
    const { shows, organisations } = await callAdminApi('filter-options');
    const showSel = document.getElementById('f-show');
    for (const s of shows || []) showSel.insertAdjacentHTML('beforeend', `<option value="${s.id}">${esc(s.title)}</option>`);
    const orgSel = document.getElementById('f-org');
    for (const o of organisations || []) orgSel.insertAdjacentHTML('beforeend', `<option value="${o.id}">${esc(o.name)}</option>`);
  }

  async function loadAll() {
    await Promise.all([loadSummary(), loadPayments(), loadPayouts(), loadEvents()]);
  }

  const auth = await getAdminAuth();
  if (auth.session && auth.profile?.roles?.includes('admin')) {
    const { session, profile } = auth;
    const name = profile?.display_name || session.user.email?.split('@')[0] || 'Admin';

    const avatarEl = document.getElementById('sidebar-avatar');
    const nameEl = document.getElementById('sidebar-username');
    if (avatarEl) {
      if (profile?.avatar_url) {
        avatarEl.innerHTML = `<img src="${profile.avatar_url}" alt="" style="width:100%;height:100%;object-fit:cover;">`;
      } else {
        avatarEl.textContent = name.charAt(0).toUpperCase();
      }
    }
    if (nameEl) nameEl.textContent = name;

    document.getElementById('sidebar-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = auth.base + 'login';
    });

    document.getElementById('btn-apply-filters')?.addEventListener('click', () => { page = 1; loadPayments(); loadSummary(); });

    document.getElementById('btn-export-payments')?.addEventListener('click', async (e) => {
      e.target.disabled = true; e.target.textContent = 'Preparing…';
      try {
        const result = await callAdminApi('payments-list', { ...currentFilters(), page: 1, page_size: 5000 });
        downloadCsv('payments', result.rows, [
          { label: 'Date', value: r => r.created_at },
          { label: 'Show', value: r => r.shows?.title || '' },
          { label: 'Entrant', value: r => r.exhibitor_name || r.animal_name || '' },
          { label: 'Currency', value: r => r.shows?.currency || '' },
          { label: 'Amount', value: r => r.entry_fee_paid },
          { label: 'Status', value: r => r.status },
          { label: 'Stripe Status', value: r => r.stripe_status || '' },
        ]);
      } catch (err) {
        alert('Failed to export: ' + err.message);
      } finally {
        e.target.disabled = false; e.target.textContent = 'Export CSV';
      }
    });

    try {
      await populateFilterOptions();
      // Support landing here pre-filtered to a show, e.g. from a Global Search result.
      const preselectShow = new URLSearchParams(window.location.search).get('show_id');
      if (preselectShow) document.getElementById('f-show').value = preselectShow;
      await loadAll();
      document.getElementById('state-loading').style.display = 'none';
      document.getElementById('state-content').style.display = 'block';
    } catch (err) {
      document.getElementById('state-loading').innerHTML = `<p class="text-[#6f6880] text-center">Failed to load: ${esc(err.message)}</p>`;
    }
  }
</script>
