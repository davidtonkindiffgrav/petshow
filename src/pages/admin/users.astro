---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Users" activePage="users">

  <div id="state-loading" class="flex items-center justify-center h-64">
    <div class="w-8 h-8 border-[3px] border-coral/20 border-t-coral rounded-full animate-spin"></div>
  </div>

  <div id="state-content" style="display:none">

    <div class="bg-white rounded-card border border-[#b8e4e0] p-4 flex flex-wrap gap-3 items-end">
      <div class="flex-1 min-w-[180px]">
        <label class="block text-[11px] font-semibold text-[#9b94a8] mb-1">Search</label>
        <input id="f-search" type="text" placeholder="Name…" class="text-[13px] border border-[#b8e4e0] rounded-btn-sm px-2.5 py-2 bg-white w-full" />
      </div>
      <div>
        <label class="block text-[11px] font-semibold text-[#9b94a8] mb-1">Role</label>
        <select id="f-role" class="text-[13px] border border-[#b8e4e0] rounded-btn-sm px-2.5 py-2 bg-white">
          <option value="">Any role</option>
          <option value="organiser">Organiser</option>
          <option value="participant">Participant</option>
          <option value="judge">Judge</option>
          <option value="admin">Admin</option>
        </select>
      </div>
      <div>
        <label class="block text-[11px] font-semibold text-[#9b94a8] mb-1">Status</label>
        <select id="f-suspended" class="text-[13px] border border-[#b8e4e0] rounded-btn-sm px-2.5 py-2 bg-white">
          <option value="">Any status</option>
          <option value="active">Active</option>
          <option value="suspended">Suspended</option>
        </select>
      </div>
      <button id="btn-apply-filters" class="text-[13px] font-bold text-white bg-brand px-4 py-2 rounded-btn hover:bg-brand-dark transition-colors">Apply</button>
    </div>

    <div class="bg-white rounded-card border border-[#b8e4e0] p-5 mt-4">
      <div class="overflow-x-auto"><table class="w-full text-[13px]"><thead>
        <tr class="text-left text-[11px] text-[#9b94a8] uppercase tracking-wide border-b border-[#f5f3fa]">
          <th class="pb-2 pr-3">Name</th><th class="pb-2 pr-3">Email</th><th class="pb-2 pr-3">Roles</th>
          <th class="pb-2 pr-3">Joined</th><th class="pb-2 pr-3">Status</th>
        </tr>
      </thead><tbody id="users-tbody"></tbody></table></div>
      <div id="users-pagination" class="flex items-center justify-between mt-4 text-[12.5px] text-[#6f6880]"></div>
    </div>

  </div>

</AdminLayout>

<script>
  import { getAdminAuth, callAdminApi } from '../../lib/adminAuth.js';
  import { supabase } from '../../lib/supabase.js';
  import { esc, statusPill } from '../../lib/format.js';

  const raw = import.meta.env.BASE_URL;
  const base = raw.endsWith('/') ? raw : raw + '/';

  let page = 1;
  const PAGE_SIZE = 25;

  function currentFilters() {
    const f = {};
    const search = document.getElementById('f-search').value.trim();
    const role = document.getElementById('f-role').value;
    const suspended = document.getElementById('f-suspended').value;
    if (search) f.search = search;
    if (role) f.role = role;
    if (suspended) f.suspended = suspended;
    return f;
  }

  async function loadUsers() {
    const filters = { ...currentFilters(), page, page_size: PAGE_SIZE };
    const result = await callAdminApi('users-list', filters);
    const tbody = document.getElementById('users-tbody');
    if (!result.rows.length) {
      tbody.innerHTML = `<tr><td colspan="5" class="py-4 text-center text-[#9b94a8]">No users match these filters.</td></tr>`;
    } else {
      tbody.innerHTML = result.rows.map(u => {
        const name = u.display_name || [u.first_name, u.last_name].filter(Boolean).join(' ') || '—';
        const roles = (u.roles || []).join(', ') || '—';
        return `
          <tr class="border-b border-[#f5f3fa] cursor-pointer hover:bg-[#f0fafa]" data-id="${u.id}">
            <td class="py-2 pr-3 font-semibold">${esc(name)}</td>
            <td class="py-2 pr-3 text-[#6f6880]">${esc(u.email || '—')}</td>
            <td class="py-2 pr-3">${esc(roles)}</td>
            <td class="py-2 pr-3">${new Date(u.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</td>
            <td class="py-2 pr-3">${statusPill(u.suspended_at ? 'suspended' : 'active')}</td>
          </tr>`;
      }).join('');
      tbody.querySelectorAll('tr[data-id]').forEach(tr => {
        tr.addEventListener('click', () => { window.location.href = `${base}admin/user?id=${tr.dataset.id}`; });
      });
    }
    const totalPages = Math.max(1, Math.ceil(result.total / PAGE_SIZE));
    document.getElementById('users-pagination').innerHTML = `
      <span>Page ${page} of ${totalPages} · ${result.total} user${result.total === 1 ? '' : 's'}</span>
      <div class="flex gap-2">
        <button id="btn-prev-page" ${page <= 1 ? 'disabled' : ''} class="px-3 py-1.5 border border-[#b8e4e0] rounded-btn-sm text-[12px] font-semibold ${page <= 1 ? 'opacity-40' : 'hover:bg-[#f0fafa]'}">Prev</button>
        <button id="btn-next-page" ${page >= totalPages ? 'disabled' : ''} class="px-3 py-1.5 border border-[#b8e4e0] rounded-btn-sm text-[12px] font-semibold ${page >= totalPages ? 'opacity-40' : 'hover:bg-[#f0fafa]'}">Next</button>
      </div>`;
    document.getElementById('btn-prev-page')?.addEventListener('click', () => { if (page > 1) { page--; loadUsers(); } });
    document.getElementById('btn-next-page')?.addEventListener('click', () => { if (page < totalPages) { page++; loadUsers(); } });
  }

  const auth = await getAdminAuth();
  if (auth.session && auth.profile?.roles?.includes('admin')) {
    const { session, profile } = auth;
    const name = profile?.display_name || session.user.email?.split('@')[0] || 'Admin';

    const avatarEl = document.getElementById('sidebar-avatar');
    const nameEl = document.getElementById('sidebar-username');
    if (avatarEl) {
      if (profile?.avatar_url) {
        avatarEl.innerHTML = `<img src="${profile.avatar_url}" alt="" style="width:100%;height:100%;object-fit:cover;">`;
      } else {
        avatarEl.textContent = name.charAt(0).toUpperCase();
      }
    }
    if (nameEl) nameEl.textContent = name;

    document.getElementById('sidebar-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = auth.base + 'login';
    });

    document.getElementById('btn-apply-filters')?.addEventListener('click', () => { page = 1; loadUsers(); });

    try {
      await loadUsers();
      document.getElementById('state-loading').style.display = 'none';
      document.getElementById('state-content').style.display = 'block';
    } catch (err) {
      document.getElementById('state-loading').innerHTML = `<p class="text-[#6f6880] text-center">Failed to load: ${esc(err.message)}</p>`;
    }
  }
</script>
